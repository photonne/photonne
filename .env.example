# Copia este archivo como .env y rellena los valores obligatorios (marcados con*)
# docker compose up -d lee automáticamente el archivo .env de la misma carpeta

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=photonne
POSTGRES_USER=photonne_user
POSTGRES_PASSWORD=cambia_esto_por_password_seguro        # * obligatorio

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres, aleatorio. Puedes generar uno con:
#   openssl rand -base64 48
JWT_KEY=cambia_esto_por_clave_jwt_muy_larga_y_aleatoria  # * obligatorio

# ─── Rutas del HOST ───────────────────────────────────────────────────────────
# Dónde están tus fotos en el host (se monta en /data/assets dentro del contenedor)
# Linux:  /data/photos
# Windows:         C:/Users/TuUsuario/Pictures
ASSETS_HOST_PATH=./data/photos

# Dónde se guardan las miniaturas en el host (se monta en /data/thumbnails dentro del contenedor)
# Por defecto crea ./data/thumbnails junto al compose
THUMBNAILS_HOST_PATH=./data/thumbnails

# ─── Puerto externo de la app ─────────────────────────────────────────────────
API_PORT=1107

# ─── Usuario administrador (se crea al arrancar si no existe) ─────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@photonne.local
ADMIN_PASSWORD=cambia_esto_por_password_seguro           # * obligatorio
ADMIN_FIRSTNAME=Administrador
ADMIN_LASTNAME=Sistema

# ─── Opcionales ───────────────────────────────────────────────────────────────
# Redirigir HTTP a HTTPS (solo si tienes TLS en el propio contenedor, no en proxy)
HTTPS_REDIRECT=false

# ─── Reconocimiento facial (microservicio Python) ─────────────────────────────
# Activa/desactiva el procesamiento de jobs FaceDetection.
FACE_RECOGNITION_ENABLED=true
# URL interna del microservicio (en docker-compose se resuelve por DNS de servicio).
FACE_SERVICE_URL=http://photonne-faces:8000
# Modelo InsightFace (buffalo_l = RetinaFace + ArcFace 512d, ~280 MB).
FACE_MODEL_NAME=buffalo_l
# Tamaño de entrada del detector (640 es el sweet spot calidad/velocidad).
FACE_DET_SIZE=640
# Tamaño mínimo de cara en píxeles para considerarla válida.
FACE_MIN_SIZE=40
# Score mínimo del detector (0..1).
FACE_MIN_DET_SCORE=0.5
# Providers de ONNX Runtime (CPU por defecto). Para GPU NVIDIA:
# CUDAExecutionProvider,CPUExecutionProvider
FACE_ONNX_PROVIDERS=CPUExecutionProvider
