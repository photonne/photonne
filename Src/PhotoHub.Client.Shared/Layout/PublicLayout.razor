@inherits LayoutComponentBase
@inject LayoutService LayoutService
@inject ThemeService ThemeService

<MudThemeProvider IsDarkMode="LayoutService.IsDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="public-layout">
    <header class="public-header">
        <MudText Typo="Typo.h6" Class="public-brand">PhotoHub</MudText>
        <MudButton Href="/login" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
            Iniciar sesión
        </MudButton>
    </header>
    <main class="public-content">
        @Body
    </main>
</div>

<style>
    .public-layout {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: #111;
    }
    .public-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: #1a1a1a;
    }
    .public-brand {
        font-weight: 700;
        letter-spacing: 0.05em;
    }
    .public-content {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
</style>
