@page "/my-shares"
@using PhotoHub.Client.Shared.Models
@using PhotoHub.Client.Shared.Services
@inject IShareService ShareService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Mis enlaces - PhotoHub</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Mis enlaces</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Gestiona todos los enlaces públicos que has creado.
</MudText>

@if (_loading)
{
    <div class="d-flex justify-center py-10">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else if (!_links.Any())
{
    <div class="my-shares-empty">
        <MudIcon Icon="@Icons.Material.Outlined.LinkOff" Style="font-size:56px;" />
        <MudText Typo="Typo.body1" Class="mt-3">No tienes enlaces activos</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
            Puedes crear enlaces desde el detalle de cualquier foto o álbum.
        </MudText>
    </div>
}
else
{
    <div class="my-shares-list">
        @foreach (var link in _links)
        {
            <div class="my-shares-row">
                <div class="my-shares-thumb">
                    @if (link.ThumbnailUrl != null && !link.HasPassword)
                    {
                        <img src="@link.ThumbnailUrl" alt="@link.DisplayName" loading="lazy" />
                    }
                    else
                    {
                        <MudIcon Icon="@(link.HasPassword ? Icons.Material.Outlined.Lock : (link.AlbumId.HasValue ? Icons.Material.Outlined.Collections : Icons.Material.Outlined.Photo))"
                                 Style="font-size:28px; opacity:0.4;" />
                    }
                    <div class="my-shares-badge-type" title="@(link.AlbumId.HasValue ? "Álbum" : "Foto")">
                        <MudIcon Icon="@(link.AlbumId.HasValue ? Icons.Material.Outlined.Collections : Icons.Material.Outlined.Photo)"
                                 Style="font-size:11px;" />
                    </div>
                </div>

                <div class="my-shares-info">
                    <div class="my-shares-name-row">
                        <MudText Typo="Typo.subtitle2" Class="my-shares-name">@link.DisplayName</MudText>
                        <div class="my-shares-chips">
                            @if (link.HasPassword)
                            {
                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Lock"
                                         Color="Color.Warning" Variant="Variant.Text" Class="my-shares-chip">
                                    Con contraseña
                                </MudChip>
                            }
                            @if (!link.AllowDownload)
                            {
                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.DownloadForOffline"
                                         Color="Color.Default" Variant="Variant.Text" Class="my-shares-chip">
                                    Sin descarga
                                </MudChip>
                            }
                        </div>
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary my-shares-url">
                        @BuildShareUrl(link.Token)
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                        Creado @link.CreatedAt.ToString("dd/MM/yyyy")
                        @if (link.ExpiresAt.HasValue)
                        {
                            <span> · Expira @link.ExpiresAt.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <span> · Sin expiración</span>
                        }
                        @if (link.MaxViews.HasValue)
                        {
                            <span> · @link.ViewCount / @link.MaxViews vistas</span>
                        }
                        else if (link.ViewCount > 0)
                        {
                            <span> · @link.ViewCount @(link.ViewCount == 1 ? "vista" : "vistas")</span>
                        }
                    </MudText>
                </div>

                <div class="my-shares-actions">
                    <MudTooltip Text="Copiar enlace">
                        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                                       Size="Size.Small"
                                       OnClick="() => CopyLink(link.Token)" />
                    </MudTooltip>
                    @if (link.AssetId.HasValue)
                    {
                        <MudTooltip Text="Ver foto">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small"
                                           OnClick="() => GoToAsset(link.AssetId!.Value)" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Revocar enlace">
                        <MudIconButton Icon="@Icons.Material.Outlined.LinkOff"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="() => RevokeLink(link)" />
                    </MudTooltip>
                </div>
            </div>
        }
    </div>
}

<style>
    .my-shares-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 64px 24px;
        opacity: 0.5;
        text-align: center;
    }

    .my-shares-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .my-shares-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 10px 12px;
        border-radius: 8px;
        transition: background 0.15s;
    }
    .my-shares-row:hover { background: rgba(255,255,255,0.05); }

    .my-shares-thumb {
        position: relative;
        width: 56px;
        height: 56px;
        border-radius: 6px;
        overflow: hidden;
        background: rgba(255,255,255,0.07);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .my-shares-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .my-shares-badge-type {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(2px);
    }

    .my-shares-info {
        flex: 1;
        min-width: 0;
    }

    .my-shares-name-row {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .my-shares-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
    }

    .my-shares-url {
        font-family: monospace;
        font-size: 0.72rem;
        opacity: 0.6;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        display: block;
        margin-top: 2px;
    }

    .my-shares-chip {
        height: 20px;
        font-size: 0.7rem;
    }

    .my-shares-actions {
        display: flex;
        gap: 2px;
        flex-shrink: 0;
    }
</style>

@code {
    private List<SentShareLinkDto> _links = new();
    private bool _loading = true;

    private void GoToAsset(Guid assetId) => Navigation.NavigateTo("/asset/" + assetId);

    protected override async Task OnInitializedAsync()
    {
        try { _links = await ShareService.GetSentShareLinksAsync(); }
        catch { Snackbar.Add("Error al cargar los enlaces", Severity.Error); }
        finally { _loading = false; }
    }

    private string BuildShareUrl(string token)
    {
        var baseUri = new Uri(Navigation.BaseUri);
        return $"{baseUri.Scheme}://{baseUri.Authority}/share/{token}";
    }

    private async Task CopyLink(string token)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", BuildShareUrl(token));
        Snackbar.Add("Enlace copiado al portapapeles", Severity.Success);
    }

    private async Task RevokeLink(SentShareLinkDto link)
    {
        try
        {
            await ShareService.RevokeShareAsync(link.Token);
            _links.Remove(link);
            Snackbar.Add("Enlace revocado", Severity.Info);
        }
        catch
        {
            Snackbar.Add("Error al revocar el enlace", Severity.Error);
        }
    }
}
