@page "/settings"
@inject ISettingsService SettingsService
@inject IUserService UserService
@inject ISnackbar Snackbar
@inject LayoutService LayoutService

<PageTitle>Configuración de cuenta - PhotoHub</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Configuración de cuenta</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" TabPanelsClass="pt-6">

        <MudTabPanel Text="Perfil" Icon="@Icons.Material.Filled.Person">
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudCard>
                        <MudCardContent>
                            <div class="d-flex flex-column align-center py-4">
                                <MudAvatar Color="Color.Primary" Style="width: 80px; height: 80px; font-size: 2rem;" Class="mb-3">
                                    @_userInitial
                                </MudAvatar>
                                <MudText Typo="Typo.h6">@_userFullName</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="mt-1">
                                    @_currentUser?.Role
                                </MudChip>
                            </div>

                            <MudDivider Class="my-2" />

                            <MudList T="string" ReadOnly="true">
                                <MudListItem Icon="@Icons.Material.Filled.CalendarToday" IconColor="Color.Inherit">
                                    <div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Cuenta creada</MudText>
                                        <MudText Typo="Typo.body2">@_currentUser?.CreatedAt.ToString("dd MMM yyyy")</MudText>
                                    </div>
                                </MudListItem>
                                @if (_currentUser?.LastLoginAt != null)
                                {
                                    <MudListItem Icon="@Icons.Material.Filled.Login" IconColor="Color.Inherit">
                                        <div>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Último acceso</MudText>
                                            <MudText Typo="Typo.body2">@_currentUser.LastLoginAt.Value.ToString("dd MMM yyyy HH:mm")</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="9">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Datos personales</MudText>
                                <MudText Typo="Typo.body2">Actualiza tu nombre, email y nombre de usuario.</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_profile.FirstName"
                                                  Label="Nombre"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudTextField @bind-Value="_profile.LastName"
                                                  Label="Apellidos"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_profile.Email"
                                                  Label="Email"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true"
                                                  InputType="InputType.Email" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="_profile.Username"
                                                  Label="Nombre de usuario"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true" />
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="SaveProfile"
                                       Disabled="_savingProfile"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @if (_savingProfile)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Guardar cambios
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Seguridad" Icon="@Icons.Material.Filled.Lock">
            <MudGrid>
                <MudItem xs="12">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Cambiar contraseña</MudText>
                                <MudText Typo="Typo.body2">La contraseña debe tener al menos 8 caracteres.</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_password.Current"
                                          Label="Contraseña actual"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          InputType="InputType.Password"
                                          Class="mb-4" />
                            <MudTextField @bind-Value="_password.New"
                                          Label="Nueva contraseña"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          InputType="InputType.Password"
                                          Class="mb-4" />
                            <MudTextField @bind-Value="_password.Confirm"
                                          Label="Confirmar nueva contraseña"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          InputType="InputType.Password"
                                          Error="@(_passwordMismatch)"
                                          ErrorText="Las contraseñas no coinciden" />
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="ChangePassword"
                                       Disabled="_savingPassword"
                                       StartIcon="@Icons.Material.Filled.Lock">
                                @if (_savingPassword)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Cambiar contraseña
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Apariencia" Icon="@Icons.Material.Filled.Palette">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Tema</MudText>
                                <MudText Typo="Typo.body2">Elige entre el modo claro y oscuro.</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.LightMode" Class="mr-3" />
                                <MudSwitch T="bool"
                                           Value="LayoutService.IsDarkMode"
                                           ValueChanged="@(async v => await LayoutService.ToggleDarkModeAsync())"
                                           Color="Color.Primary" />
                                <MudIcon Icon="@Icons.Material.Filled.DarkMode" Class="ml-1" />
                                <MudText Typo="Typo.body1" Class="ml-4">
                                    @(LayoutService.IsDarkMode ? "Modo oscuro" : "Modo claro")
                                </MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Dispositivo" Icon="@Icons.Material.Filled.FolderOpen">
            <MudGrid>
                <MudItem xs="12">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Almacenamiento del dispositivo</MudText>
                                <MudText Typo="Typo.body2">Ruta donde se encuentran tus fotos y vídeos en este dispositivo.</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_assetsPath"
                                          Label="Ruta de assets"
                                          HelperText="Esta ruta se usará para sincronizar con el servidor."
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          Class="mb-4" />
                            <MudAlert Severity="Severity.Info">
                                Ruta actual en el servidor: <strong>@_currentServerPath</strong>
                            </MudAlert>
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="SaveAssetsPath"
                                       Disabled="_savingPath"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @if (_savingPath)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Guardar ruta
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>
}

@code {
    private bool _loading = true;
    private UserDto? _currentUser;

    private string _userInitial = "?";
    private string _userFullName = "";

    // Tab: Perfil
    private ProfileForm _profile = new();
    private bool _savingProfile;

    // Tab: Seguridad
    private PasswordForm _password = new();
    private bool _savingPassword;
    private bool _passwordMismatch;

    // Tab: Dispositivo
    private string _assetsPath = "";
    private string _currentServerPath = "";
    private bool _savingPath;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _currentUser = await UserService.GetCurrentUserAsync();
            _profile = new ProfileForm
            {
                FirstName = _currentUser.FirstName ?? "",
                LastName  = _currentUser.LastName  ?? "",
                Email     = _currentUser.Email,
                Username  = _currentUser.Username,
            };
            RefreshDisplayName();

            _currentServerPath = await SettingsService.GetAssetsPathAsync();
            _assetsPath = _currentServerPath;
        }
        finally
        {
            _loading = false;
        }
    }

    private void RefreshDisplayName()
    {
        if (_currentUser == null) return;

        var parts = new[] { _currentUser.FirstName, _currentUser.LastName }
            .Where(s => !string.IsNullOrWhiteSpace(s)).ToArray();
        _userFullName = parts.Length > 0
            ? string.Join(" ", parts)
            : _currentUser.Username;

        _userInitial = !string.IsNullOrWhiteSpace(_currentUser.FirstName)
            ? _currentUser.FirstName.Trim()[0].ToString().ToUpperInvariant()
            : _currentUser.Username.Trim()[0].ToString().ToUpperInvariant();
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_profile.Username) || string.IsNullOrWhiteSpace(_profile.Email))
        {
            Snackbar.Add("El email y el nombre de usuario son obligatorios", Severity.Warning);
            return;
        }

        try
        {
            _savingProfile = true;
            _currentUser = await UserService.UpdateProfileAsync(new UpdateProfileRequest
            {
                FirstName = _profile.FirstName,
                LastName  = _profile.LastName,
                Email     = _profile.Email,
                Username  = _profile.Username,
            });
            RefreshDisplayName();
            Snackbar.Add("Perfil actualizado correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingProfile = false;
        }
    }

    private async Task ChangePassword()
    {
        _passwordMismatch = false;

        if (string.IsNullOrWhiteSpace(_password.Current) ||
            string.IsNullOrWhiteSpace(_password.New)     ||
            string.IsNullOrWhiteSpace(_password.Confirm))
        {
            Snackbar.Add("Rellena todos los campos de contraseña", Severity.Warning);
            return;
        }

        if (_password.New != _password.Confirm)
        {
            _passwordMismatch = true;
            return;
        }

        try
        {
            _savingPassword = true;
            await UserService.ChangePasswordAsync(new ChangePasswordRequest
            {
                CurrentPassword = _password.Current,
                NewPassword     = _password.New,
            });
            Snackbar.Add("Contraseña cambiada correctamente", Severity.Success);
            _password = new PasswordForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingPassword = false;
        }
    }

    private async Task SaveAssetsPath()
    {
        if (string.IsNullOrWhiteSpace(_assetsPath))
        {
            Snackbar.Add("La ruta no puede estar vacía", Severity.Warning);
            return;
        }

        try
        {
            _savingPath = true;
            var success = await SettingsService.SaveSettingAsync("AssetsPath", _assetsPath);
            if (success)
            {
                Snackbar.Add("Ruta guardada correctamente", Severity.Success);
                _currentServerPath = await SettingsService.GetAssetsPathAsync();
            }
            else
            {
                Snackbar.Add("Error al guardar la ruta", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingPath = false;
        }
    }

    private class ProfileForm
    {
        public string FirstName { get; set; } = "";
        public string LastName  { get; set; } = "";
        public string Email     { get; set; } = "";
        public string Username  { get; set; } = "";
    }

    private class PasswordForm
    {
        public string Current { get; set; } = "";
        public string New     { get; set; } = "";
        public string Confirm { get; set; } = "";
    }
}
