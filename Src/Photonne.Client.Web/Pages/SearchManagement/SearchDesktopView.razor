<div class="page-pad">

    <div class="search-filters mb-4" style="gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <div style="flex:1; min-width:180px; max-width:240px;">
            <MudDatePicker Label="Desde" Date="FromDate" DateChanged="OnFromDateChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           MaxDate="ToDate" Clearable="true" />
        </div>
        <div style="flex:1; min-width:180px; max-width:240px;">
            <MudDatePicker Label="Hasta" Date="ToDate" DateChanged="OnToDateChanged"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           MinDate="FromDate" Clearable="true" />
        </div>
        <div style="flex:2; min-width:200px;">
            <MudTextField @bind-Value="_localFolderFilter"
                          @bind-Value:after="OnFolderFilterInput"
                          Label="Ruta de carpeta"
                          Placeholder="Ej. vacaciones, 2024/agosto..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Outlined.FolderOpen"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          DebounceInterval="400"
                          Clearable="true" />
        </div>
    </div>

    @if (Loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
    }
    else if (!HasAnyFilter)
    {
        <EmptyState Icon="@Icons.Material.Filled.Search"
                    Title="Escribe algo para buscar"
                    Description="Busca por nombre de archivo, etiqueta (#paisaje) o ruta de carpeta. También puedes filtrar por fecha." />
    }
    else if (!Results.Any())
    {
        <EmptyState Icon="@Icons.Material.Filled.SearchOff"
                    Title="Sin resultados"
                    Description="Prueba con otro término o ajusta los filtros." />
    }
    else
    {
        <div class="d-flex align-center mb-3 gap-2">
            <MudText Typo="Typo.subtitle2">@ResultCountLabel</MudText>
            @if (HasMore)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                    Hay más — refina la búsqueda
                </MudChip>
            }
        </div>
        <div class="media-thumb-grid mt-1">
            @foreach (var asset in Results)
            {
                <div class="media-thumb-cell"
                     @key="asset.Id"
                     @onclick="@(() => OnOpenAsset.InvokeAsync(asset))">
                    @if (asset.HasThumbnails && !asset.IsFileMissing)
                    {
                        <img src="@asset.ThumbnailUrl"
                             alt="@asset.FileName"
                             loading="lazy"
                             decoding="async" />
                    }
                    @if (asset.IsFileMissing)
                    {
                        <div class="media-thumb-broken">
                            <MudIcon Icon="@Icons.Material.Filled.BrokenImage" Size="Size.Medium" />
                        </div>
                    }
                    @if (asset.Type == "Video")
                    {
                        <div class="media-thumb-video-icon">
                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public bool Loading { get; set; }
    [Parameter] public List<TimelineItem> Results { get; set; } = new();
    [Parameter] public bool HasMore { get; set; }
    [Parameter] public DateTime? FromDate { get; set; }
    [Parameter] public EventCallback<DateTime?> OnFromDateChanged { get; set; }
    [Parameter] public DateTime? ToDate { get; set; }
    [Parameter] public EventCallback<DateTime?> OnToDateChanged { get; set; }
    [Parameter] public string FolderFilter { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnFolderFilterChanged { get; set; }
    [Parameter] public string ResultCountLabel { get; set; } = "";
    [Parameter] public bool HasAnyFilter { get; set; }
    [Parameter] public EventCallback<TimelineItem> OnOpenAsset { get; set; }

    private string _localFolderFilter = string.Empty;

    protected override void OnParametersSet()
    {
        _localFolderFilter = FolderFilter;
    }

    private async Task OnFolderFilterInput()
    {
        await OnFolderFilterChanged.InvokeAsync(_localFolderFilter);
    }
}
