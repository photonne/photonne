<div class="asset-detail-container" @ref="ContainerRef" @onkeydown="OnKeyDown" @onmousemove="OnSlideshowMouseMove" tabindex="0">
    <div class="asset-detail-content @(Zoomed ? "zoomed-container" : "") @(InfoOpen ? "info-open" : "")" @onclick="OnToggleToolbar" @ontouchstart="OnTouchStart" @ontouchmove="OnTouchMove" @ontouchend="OnTouchEnd" @oncontextmenu:preventDefault="true" @oncontextmenu:stopPropagation="true">
        <span @onclick:stopPropagation="true" @onclick:preventDefault="true">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                           Class="@NavButtonPrevClass"
                           Size="Size.Large"
                           OnClick="OnNavigatePrev"
                           Disabled="@(PrevAsset == null)" />
        </span>

        @if (Asset!.Type == "Video")
        {
            <video controls autoplay class="asset-detail-image">
                <source src="@DisplayContentUrl" type="video/mp4">
                Tu navegador no soporta la reproducci&oacute;n de videos.
            </video>
        }
        else if (Asset.IsFileMissing || ImageLoadError)
        {
            <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; color: rgba(255,255,255,0.5);">
                <MudIcon Icon="@Icons.Material.Filled.BrokenImage" Style="width: 96px; height: 96px;" />
                <MudText Typo="Typo.body2">@(Asset.IsFileMissing ? "Archivo no encontrado en disco" : "No se pudo cargar la imagen")</MudText>
            </div>
        }
        else if (Asset.HasThumbnails || Asset.Type == "Image")
        {
            <img src="@(Asset.Type == "Image" ? DisplayContentUrl : DisplayThumbnailUrl)"
                 alt="@Asset.FileName"
                 class="asset-detail-image @(Zoomed ? "zoomed" : "")"
                 @onerror="OnImageError" />
        }
        else
        {
            <MudIcon Icon="@AssetIcon" Size="Size.Large" Color="Color.Inherit" Style="width: 128px; height: 128px;" />
        }

        <span @onclick:stopPropagation="true" @onclick:preventDefault="true">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                           Class="@NavButtonNextClass"
                           Size="Size.Large"
                           OnClick="OnNavigateNext"
                           Disabled="@(NextAsset == null)" />
        </span>
    </div>

    @if (SlideshowActive)
    {
        <div class="slideshow-controls-bar @(SlideshowControlsVisible ? "" : "controls-hidden")">
            <ResponsiveTooltip Text="Anterior">
                <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious" Color="Color.Inherit" Size="Size.Medium"
                               OnClick="OnNavigatePrev" Disabled="@(PrevAsset == null)" />
            </ResponsiveTooltip>
            <MudIconButton Icon="@(SlideshowPaused ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Pause)"
                           Color="Color.Inherit" Size="Size.Large"
                           OnClick="OnToggleSlideshowPause" />
            <ResponsiveTooltip Text="Siguiente">
                <MudIconButton Icon="@Icons.Material.Filled.SkipNext" Color="Color.Inherit" Size="Size.Medium"
                               OnClick="OnNavigateNext" Disabled="@(NextAsset == null)" />
            </ResponsiveTooltip>
            <div class="slideshow-divider"></div>
            @foreach (var secs in new[] { 3, 5, 10 })
            {
                <button class="slideshow-speed-btn @(SlideshowInterval == secs ? "active" : "")"
                        @onclick="@(() => OnSetSlideshowInterval.InvokeAsync(secs))">@secs s</button>
            }
            <div class="slideshow-divider"></div>
            <ResponsiveTooltip Text="Salir (Esc)">
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Medium"
                               OnClick="OnStopSlideshow" />
            </ResponsiveTooltip>
        </div>
        <div class="slideshow-progress">
            <div @key="SlideshowProgressKey"
                 class="slideshow-progress-fill @(SlideshowPaused ? "paused" : "")"
                 style="animation-duration: @(SlideshowInterval)s;"></div>
        </div>
    }

    @* Desktop: no backdrop for info drawer *@

    <div class="add-to-album-drawer-backdrop @(AddToAlbumDialogVisible ? "" : "hidden")"
         @onclick="OnCloseAddToAlbumDrawer"></div>
    <div class="add-to-album-drawer @(AddToAlbumDialogVisible ? "" : "closed")">
        <div class="pa-4">
            <div class="d-flex align-center mb-3">
                <MudText Typo="Typo.h6">A&ntilde;adir a &Aacute;lbum</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Inherit"
                               OnClick="OnCloseAddToAlbumDrawer" />
            </div>
            @if (!ShowCreateAlbum)
            {
                @if (LoadingAlbums)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
                }
                else if (AvailableAlbums.Any())
                {
                    <MudRadioGroup T="Guid?" Value="SelectedAlbumId" ValueChanged="OnSelectedAlbumIdChanged">
                        @foreach (var album in AvailableAlbums)
                        {
                            <MudRadio T="Guid?" Value="@album.Id">
                                <div class="d-flex align-center gap-2">
                                    @if (!string.IsNullOrEmpty(album.CoverThumbnailUrl))
                                    {
                                        <img src="@album.CoverThumbnailUrl"
                                             style="width: 48px; height: 48px; object-fit: cover; border-radius: 4px;"
                                             alt="@album.Name" />
                                    }
                                    else
                                    {
                                        <div style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: #333; border-radius: 4px;">
                                            <MudIcon Icon="@Icons.Material.Filled.Collections" Size="Size.Small" />
                                        </div>
                                    }
                                    <div>
                                        <MudText Typo="Typo.body1">@album.Name</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            @album.AssetCount @(album.AssetCount == 1 ? "foto" : "fotos")
                                        </MudText>
                                    </div>
                                </div>
                            </MudRadio>
                        }
                    </MudRadioGroup>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Class="mb-3">
                        No tienes ning&uacute;n &aacute;lbum. Crea uno nuevo para a&ntilde;adir esta foto.
                    </MudAlert>
                }

                <MudDivider Class="my-3" Style="background-color: #444;" />
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OnShowCreateAlbum"
                           FullWidth="true">
                    Crear nuevo &aacute;lbum
                </MudButton>
            }
            else
            {
                <MudTextField Value="NewAlbumName" ValueChanged="OnNewAlbumNameChanged"
                              Label="Nombre del &aacute;lbum"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Class="mb-3" />
                <MudTextField Value="NewAlbumDescription" ValueChanged="OnNewAlbumDescriptionChanged"
                              Label="Descripci&oacute;n (opcional)"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Lines="3" />
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="OnHideCreateAlbum"
                           Class="mt-2">
                    Volver a seleccionar &aacute;lbum
                </MudButton>
            }

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton OnClick="OnCloseAddToAlbumDrawer">Cancelar</MudButton>
                @if (ShowCreateAlbum)
                {
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnCreateAlbumAndAdd">
                        Crear y A&ntilde;adir
                    </MudButton>
                }
                else
                {
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               OnClick="OnAddToAlbum"
                               Disabled="@(!SelectedAlbumId.HasValue)">
                        A&ntilde;adir
                    </MudButton>
                }
            </div>
        </div>
    </div>

    <div class="asset-info-drawer @(InfoOpen ? "" : "closed")">
        <div class="pa-4">
            <div class="d-flex align-center mb-4">
                <MudText Typo="Typo.h6">Informaci&oacute;n</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Inherit" OnClick="OnToggleInfo" />
            </div>

            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">Detalles del archivo</MudText>
            <MudList T="string" ReadOnly="true">
                <MudListItem Icon="@Icons.Material.Filled.InsertDriveFile" IconColor="Color.Info">
                    <MudText Typo="Typo.body2">@Asset.FileName</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.CalendarToday" IconColor="Color.Info">
                    <MudText Typo="Typo.body2">@Asset.DisplayDate</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.SdStorage" IconColor="Color.Info">
                    <MudText Typo="Typo.body2">@Asset.FileSizeFormatted</MudText>
                </MudListItem>
                @if (!string.IsNullOrEmpty(Asset.FolderPath))
                {
                    <MudListItem Icon="@Icons.Material.Filled.Folder" IconColor="Color.Info">
                        <MudText Typo="Typo.body2">@Asset.FolderPath</MudText>
                    </MudListItem>
                }
            </MudList>

            @if (Asset.Exif != null)
            {
                <MudDivider Class="my-4" Style="background-color: #333;" />
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">Informaci&oacute;n t&eacute;cnica</MudText>
                <MudList T="string" ReadOnly="true">
                    @if (Asset.Exif.CameraMake != null)
                    {
                        <MudListItem Icon="@Icons.Material.Filled.Camera" IconColor="Color.Info">
                            <MudText Typo="Typo.body2">@Asset.Exif.CameraMake @Asset.Exif.CameraModel</MudText>
                        </MudListItem>
                    }
                    @if (Asset.Exif.Width.HasValue)
                    {
                        <MudListItem Icon="@Icons.Material.Filled.AspectRatio" IconColor="Color.Info">
                            <MudText Typo="Typo.body2">@Asset.Exif.Width x @Asset.Exif.Height</MudText>
                        </MudListItem>
                    }
                    @if (Asset.Exif.Iso.HasValue || Asset.Exif.Aperture.HasValue || Asset.Exif.ShutterSpeed.HasValue)
                    {
                        <MudListItem Icon="@Icons.Material.Filled.Settings" IconColor="Color.Info">
                            <MudText Typo="Typo.body2">
                                @( Asset.Exif.Iso.HasValue ? $"ISO {Asset.Exif.Iso} " : "" )
                                @( Asset.Exif.Aperture.HasValue ? $"f/{Asset.Exif.Aperture:0.#} " : "" )
                                @if (Asset.Exif.ShutterSpeed.HasValue)
                                {
                                    var ss = Asset.Exif.ShutterSpeed.Value;
                                    var ssText = ss < 1 ? $"1/{(int)Math.Round(1 / ss)}s" : $"{ss:0.#}s";
                                    <span>@ssText </span>
                                }
                                @( Asset.Exif.FocalLength.HasValue ? $"{Asset.Exif.FocalLength:0.#}mm" : "" )
                            </MudText>
                        </MudListItem>
                    }
                </MudList>

                @if (Asset.Exif.Latitude.HasValue && Asset.Exif.Longitude.HasValue)
                {
                    <MudDivider Class="my-4" Style="background-color: #333;" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Ubicaci&oacute;n</MudText>

                    <div id="asset-mini-map" style="width: 100%; height: 180px; border-radius: 12px; overflow: hidden;"></div>

                    <div class="d-flex align-center justify-space-between mt-2">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @Asset.Exif.Latitude.Value.ToString("F6"), @Asset.Exif.Longitude.Value.ToString("F6")
                            </MudText>
                            @if (Asset.Exif.Altitude.HasValue)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Altitud: @Asset.Exif.Altitude.Value.ToString("F0") m
                                </MudText>
                            }
                        </div>
                        <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Title="Ver en OpenStreetMap"
                                       Href="@($"https://www.openstreetmap.org/?mlat={Asset.Exif.Latitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)}&mlon={Asset.Exif.Longitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)}#map=15/{Asset.Exif.Latitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)}/{Asset.Exif.Longitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)}")"
                                       Target="_blank" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(Asset.Exif.Description))
                {
                    <MudDivider Class="my-4" Style="background-color: #333;" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">Descripci&oacute;n EXIF</MudText>
                    <MudText Typo="Typo.body2" Class="px-4 py-2" Style="font-style: italic;">@Asset.Exif.Description</MudText>
                }
            }

            <MudDivider Class="my-4" Style="background-color: #333;" />
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Descripci&oacute;n</MudText>
            <MudTextField Value="DescriptionEdit" ValueChanged="OnDescriptionEditChanged"
                          Placeholder="A&ntilde;ade una descripci&oacute;n..."
                          Variant="Variant.Outlined"
                          Lines="3"
                          MaxLength="2000"
                          FullWidth="true"
                          Class="mb-2"
                          Style="font-size: 0.85rem;" />
            <div class="d-flex justify-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="@SavingDescription"
                           OnClick="OnSaveDescription">
                    @if (SavingDescription)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    }
                    Guardar
                </MudButton>
            </div>

            <MudDivider Class="my-4" Style="background-color: #333;" />
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Etiquetas</MudText>
            <div class="d-flex flex-wrap gap-2">
                @if (Asset.Tags.Any())
                {
                    @foreach (var tag in Asset.Tags)
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Text"
                                 Color="Color.Primary"
                                 Closable="@CanEditTags"
                                 OnClose="() => OnRemoveTag.InvokeAsync(tag)">
                            @tag
                        </MudChip>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Sin etiquetas</MudText>
                }
            </div>
            @if (CanEditTags)
            {
                <div class="d-flex align-center gap-2 mt-3">
                    <MudTextField Value="NewTag" ValueChanged="OnNewTagChanged"
                                  Placeholder="A&ntilde;adir etiqueta"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Disabled="@TagBusy"
                                  Class="flex-grow-1" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@TagBusy"
                               OnClick="OnAddTag">
                        A&ntilde;adir
                    </MudButton>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Photonne.Client.Web.Models.AssetDetail Asset { get; set; } = default!;
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool InfoOpen { get; set; }
    [Parameter] public bool Zoomed { get; set; }
    [Parameter] public bool ToolbarVisible { get; set; }
    [Parameter] public TimelineItem? PrevAsset { get; set; }
    [Parameter] public TimelineItem? NextAsset { get; set; }
    [Parameter] public string DisplayContentUrl { get; set; } = string.Empty;
    [Parameter] public string DisplayThumbnailUrl { get; set; } = string.Empty;
    [Parameter] public bool ImageLoadError { get; set; }
    [Parameter] public string AssetIcon { get; set; } = string.Empty;
    [Parameter] public string NavButtonPrevClass { get; set; } = string.Empty;
    [Parameter] public string NavButtonNextClass { get; set; } = string.Empty;

    // Slideshow
    [Parameter] public bool SlideshowActive { get; set; }
    [Parameter] public bool SlideshowPaused { get; set; }
    [Parameter] public bool SlideshowControlsVisible { get; set; }
    [Parameter] public int SlideshowInterval { get; set; }
    [Parameter] public int SlideshowProgressKey { get; set; }

    // Add to album
    [Parameter] public bool AddToAlbumDialogVisible { get; set; }
    [Parameter] public List<AlbumItem> AvailableAlbums { get; set; } = new();
    [Parameter] public bool LoadingAlbums { get; set; }
    [Parameter] public Guid? SelectedAlbumId { get; set; }
    [Parameter] public bool ShowCreateAlbum { get; set; }
    [Parameter] public string NewAlbumName { get; set; } = string.Empty;
    [Parameter] public string? NewAlbumDescription { get; set; }

    // Description & tags
    [Parameter] public string DescriptionEdit { get; set; } = string.Empty;
    [Parameter] public bool SavingDescription { get; set; }
    [Parameter] public string NewTag { get; set; } = string.Empty;
    [Parameter] public bool TagBusy { get; set; }
    [Parameter] public bool CanEditTags { get; set; }

    // Element ref
    [Parameter] public ElementReference ContainerRef { get; set; }
    [Parameter] public EventCallback<ElementReference> ContainerRefChanged { get; set; }

    // EventCallbacks
    [Parameter] public EventCallback OnToggleToolbar { get; set; }
    [Parameter] public EventCallback OnToggleInfo { get; set; }
    [Parameter] public EventCallback OnNavigatePrev { get; set; }
    [Parameter] public EventCallback OnNavigateNext { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchStart { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchMove { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchEnd { get; set; }
    [Parameter] public EventCallback OnImageError { get; set; }
    [Parameter] public EventCallback OnSlideshowMouseMove { get; set; }

    // Slideshow callbacks
    [Parameter] public EventCallback OnToggleSlideshowPause { get; set; }
    [Parameter] public EventCallback<int> OnSetSlideshowInterval { get; set; }
    [Parameter] public EventCallback OnStopSlideshow { get; set; }

    // Add to album callbacks
    [Parameter] public EventCallback OnCloseAddToAlbumDrawer { get; set; }
    [Parameter] public EventCallback OnAddToAlbum { get; set; }
    [Parameter] public EventCallback OnCreateAlbumAndAdd { get; set; }
    [Parameter] public EventCallback OnShowCreateAlbum { get; set; }
    [Parameter] public EventCallback OnHideCreateAlbum { get; set; }
    [Parameter] public EventCallback<Guid?> OnSelectedAlbumIdChanged { get; set; }
    [Parameter] public EventCallback<string> OnNewAlbumNameChanged { get; set; }
    [Parameter] public EventCallback<string?> OnNewAlbumDescriptionChanged { get; set; }

    // Description & tag callbacks
    [Parameter] public EventCallback<string> OnDescriptionEditChanged { get; set; }
    [Parameter] public EventCallback OnSaveDescription { get; set; }
    [Parameter] public EventCallback<string> OnNewTagChanged { get; set; }
    [Parameter] public EventCallback OnAddTag { get; set; }
    [Parameter] public EventCallback<string> OnRemoveTag { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ContainerRefChanged.InvokeAsync(ContainerRef);
        }
    }
}
