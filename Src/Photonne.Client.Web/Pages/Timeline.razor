@page "/"
@inject IAssetService AssetService
@inject IAlbumService AlbumService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject LayoutService LayoutService
@inject IAssetListNavigationState AssetListNavigationState
@inject IDialogService DialogService
@inject TimelineCache TimelineCache
@inject TimelinePersistenceService TimelinePersistence
@implements IDisposable

<PageTitle>Timeline - Photonne</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}

<div class="timeline-wrapper">
    <div class="timeline-main-container">
        <div class="timeline-content-wrapper">

            <div class="filter-chips-bar">
                <!-- Móvil: botón que abre el bottom sheet de filtros -->
                <button class="filter-mobile-btn filter-chips-mobile" @onclick="OpenFilterSheet">
                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
                    <span>@GetFilterLabel()</span>
                    <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" Class="filter-mobile-btn-chevron" />
                </button>
                <div class="filter-density-controls">
                    <!-- Desktop: 3 botones individuales -->
                    <MudTooltip Text="Compacto" Class="density-btn-desktop">
                        <MudIconButton Icon="@Icons.Material.Outlined.GridOn"
                                       Size="Size.Small"
                                       Color="@(_density == "S" ? Color.Primary : Color.Inherit)"
                                       OnClick="@(async () => await SetDensity("S"))" />
                    </MudTooltip>
                    <MudTooltip Text="Mediano" Class="density-btn-desktop">
                        <MudIconButton Icon="@Icons.Material.Outlined.GridView"
                                       Size="Size.Small"
                                       Color="@(_density == "M" ? Color.Primary : Color.Inherit)"
                                       OnClick="@(async () => await SetDensity("M"))" />
                    </MudTooltip>
                    <MudTooltip Text="Grande" Class="density-btn-desktop">
                        <MudIconButton Icon="@Icons.Material.Outlined.PhotoSizeSelectLarge"
                                       Size="Size.Small"
                                       Color="@(_density == "L" ? Color.Primary : Color.Inherit)"
                                       OnClick="@(async () => await SetDensity("L"))" />
                    </MudTooltip>
                </div>
            </div>

            <div class="timeline-container" id="timeline-scroll-container">
                <div class="timeline-content @(_density == "S" ? "density-s" : _density == "L" ? "density-l" : "")"  >
                    <MemoriesWidget OnThumbClick="OpenMemoryAsset" Test="false" />

                    @if (_visibleGroupedGridItems.Any())
                    {
                        @if (_topSpacerHeight > 0)
                        {
                            <div class="timeline-spacer" style="height: @(_topSpacerHeight)px;"></div>
                        }
                        <div class="timeline-flat-grid">
                        @foreach (var group in _visibleGroupedGridItems)
                        {
                            var dayDate = DateTime.ParseExact(group.Key, "yyyy-MM-dd", null);
                            <div class="day-header-row" id="@GetGroupId(group.Key)">
                                <MudText Typo="Typo.body2" Class="day-header">@FormatDayHeader(dayDate)</MudText>
                            </div>
                            @foreach (var item in group.Value)
                            {
                                <div class="masonry-item"
                                     data-day="@group.Key"
                                     data-aspect-ratio="@item.AspectRatio.ToString("F4", System.Globalization.CultureInfo.InvariantCulture)"
                                     data-width="@item.Width"
                                     data-height="@item.Height">
                                    <div class="asset-select-container @(_selectionMode ? "selection-mode" : "") @(IsAssetSelected(item.Id) ? "selected" : "")"
                                         data-asset-id="@item.Id"
                                         @ontouchstart="@(e => OnGridItemTouchStart(e, item))"
                                         @ontouchmove="OnCardTouchMove"
                                         @ontouchend="OnCardTouchEnd">
                                        <div class="asset-card-container" @onclick="@(() => OnGridItemClick(item))">
                                            <div class="asset-placeholder"
                                                 style="@(!string.IsNullOrEmpty(item.DominantColor) ? $"background-color:{item.DominantColor};" : "")">
                                            </div>
                                            <img data-src="@item.ThumbnailUrl" alt="" class="asset-card-image lazy-img" />
                                            @if (item.Type == "Video")
                                            {
                                                <div class="asset-type-icon">
                                                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                                                </div>
                                            }
                                        </div>
                                        <div class="asset-select-checkbox" @onclick:stopPropagation="true">
                                            <MudCheckBox T="bool"
                                                         Value="@IsAssetSelected(item.Id)"
                                                         ValueChanged="@(EventCallback.Factory.Create<bool>(this, value => ToggleAssetSelection(item.Id, value)))" />
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        </div>
                        @if (_bottomSpacerHeight > 0)
                        {
                            <div class="timeline-spacer" style="height: @(_bottomSpacerHeight)px;"></div>
                        }
                    }
                    else if (!_loading)
                    {
                        @if (_activeFilter != "All")
                        {
                            <EmptyState Icon="@Icons.Material.Filled.FilterAlt"
                                        Title="Sin resultados"
                                        Description="No hay elementos que coincidan con el filtro seleccionado." />
                        }
                        else
                        {
                            <EmptyState Icon="@Icons.Material.Filled.PhotoLibrary"
                                        Title="No hay fotografías disponibles"
                                        Description="Indexa un directorio para comenzar." />
                        }
                    }
                </div>
            </div>
        </div>
        
        @if (_groupedGridItems.Any())
        {
            <div class="scrubber-overlay">
                <div class="scrubber-track" id="scrubber-track">
                    <div class="scrubber-thumb" id="scrubber-thumb">
                        <span class="scrubber-thumb-label" id="scrubber-thumb-label"></span>
                        <svg class="scrubber-arrow" viewBox="0 0 24 24" fill="currentColor"><path d="M7 14l5-5 5 5z"/></svg>
                        <div class="scrubber-thumb-bar"></div>
                        <svg class="scrubber-arrow" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg>
                    </div>
                    @if (_timelineIndex.Any())
                    {
                        var indexTotal = _timelineIndex.Sum(i => i.Count);
                        var indexCumulative = 0;
                        foreach (var yearGroup in _timelineIndex.GroupBy(i => i.Date.Year).OrderByDescending(g => g.Key))
                        {
                            var scrubYear = yearGroup.Key.ToString();
                            var yearPos = indexTotal > 0 ? (double)indexCumulative / indexTotal * 100 : 0;
                            var yearPosStr = yearPos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                            var loadedGroupId = _groupedGridItems.Keys.FirstOrDefault(k => k.StartsWith(scrubYear + "-")) ?? "";
                            <div class="scrubber-year-marker @(IsActiveYear(scrubYear) ? "active" : "")"
                                 data-group-id="@(string.IsNullOrEmpty(loadedGroupId) ? "" : GetGroupId(loadedGroupId))"
                                 style="top: @($"{yearPosStr}%")">
                                <span class="scrubber-year-label">@scrubYear</span>
                                <div class="scrubber-year-dot"></div>
                            </div>
                            indexCumulative += yearGroup.Sum(i => i.Count);
                        }
                    }
                    else
                    {
                        var renderedScrubYears = new HashSet<string>();
                        @foreach (var group in _groupedGridItems)
                        {
                            var scrubYear = GetYearFromGroup(group.Key);
                            @if (!renderedScrubYears.Contains(scrubYear))
                            {
                                renderedScrubYears.Add(scrubYear);
                                var scrubPos = GetGroupPosition(group.Key);
                                var scrubPosStr = scrubPos.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                <div class="scrubber-year-marker @(IsActiveYear(scrubYear) ? "active" : "")"
                                     data-group-id="@GetGroupId(group.Key)"
                                     style="top: @($"{scrubPosStr}%")">
                                    <span class="scrubber-year-label">@scrubYear</span>
                                    <div class="scrubber-year-dot"></div>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        }
    </div>

@if (_filterSheetOpen)
{
    <div class="filter-sheet-backdrop" @onclick="CloseFilterSheet"></div>
    <div class="filter-sheet">
        <div class="filter-sheet-handle"></div>
        <MudText Typo="Typo.subtitle2" Class="filter-sheet-title">Filtrar por</MudText>
        <div class="filter-sheet-options">
            <button class="filter-sheet-option @(_activeFilter == "All" ? "active" : "")"
                    @onclick="@(async () => { await SetFilter("All"); CloseFilterSheet(); })">
                <MudIcon Icon="@Icons.Material.Outlined.PhotoLibrary" />
                <span>Todas</span>
                @if (_activeFilter == "All") { <MudIcon Icon="@Icons.Material.Filled.Check" Class="filter-sheet-check" /> }
            </button>
            <button class="filter-sheet-option @(_activeFilter == "Photos" ? "active" : "")"
                    @onclick="@(async () => { await SetFilter("Photos"); CloseFilterSheet(); })">
                <MudIcon Icon="@Icons.Material.Outlined.Image" />
                <span>Fotos</span>
                @if (_activeFilter == "Photos") { <MudIcon Icon="@Icons.Material.Filled.Check" Class="filter-sheet-check" /> }
            </button>
            <button class="filter-sheet-option @(_activeFilter == "Videos" ? "active" : "")"
                    @onclick="@(async () => { await SetFilter("Videos"); CloseFilterSheet(); })">
                <MudIcon Icon="@Icons.Material.Outlined.Videocam" />
                <span>Vídeos</span>
                @if (_activeFilter == "Videos") { <MudIcon Icon="@Icons.Material.Filled.Check" Class="filter-sheet-check" /> }
            </button>
            <button class="filter-sheet-option @(_activeFilter == "Favorites" ? "active" : "")"
                    @onclick="@(async () => { await SetFilter("Favorites"); CloseFilterSheet(); })">
                <MudIcon Icon="@Icons.Material.Outlined.FavoriteBorder" />
                <span>Favoritos</span>
                @if (_activeFilter == "Favorites") { <MudIcon Icon="@Icons.Material.Filled.Check" Class="filter-sheet-check" /> }
            </button>
        </div>
    </div>
}
</div>

<style>
    /* Desactivar scroll en body/html y contenedores de MudBlazor */
    :global(body.timeline-page) {
        overflow: hidden !important;
        height: 100vh !important;
    }

    :global(body.timeline-page html) {
        overflow: hidden !important;
        height: 100vh !important;
    }

    :global(body.timeline-page .mud-layout) {
        overflow: hidden !important;
        height: 100vh !important;
    }

    :global(body.timeline-page .mud-main-content) {
        overflow: hidden !important;
        height: 100vh !important;
        position: relative !important;
    }

    /* Contenedor principal del timeline */
    .timeline-wrapper {
        position: relative;
        width: 100%;
        height: calc(100vh - var(--mud-appbar-height, 64px));
    }

    @@media (max-width: 959.98px) {
        .timeline-wrapper {
            height: calc(100vh - var(--mud-appbar-height, 64px) - 56px - env(safe-area-inset-bottom));
        }
    }

    /* Contenedor principal con flex para layout horizontal */
    .timeline-main-container {
        display: flex;
        width: 100%;
        height: 100%;
        position: relative;
    }

    /* Contenedor del contenido principal */
    .timeline-content-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* Barra de filtros */
    .filter-chips-bar {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 0 48px 4px 0;
        flex-shrink: 0;
        margin-bottom: 4px;
    }

    .filter-chips-scroll {
        display: flex;
        align-items: center;
        gap: 4px;
        flex: 1;
        min-width: 0;
        flex-wrap: wrap;
    }

    .filter-density-controls {
        display: flex;
        align-items: center;
        gap: 2px;
        flex-shrink: 0;
    }

    /* Botón de filtro móvil (oculto en desktop) */
    .filter-chips-mobile {
        display: none;
    }

    /* Bottom sheet de filtros */
    .filter-sheet-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        z-index: 1200;
        animation: fadeIn 0.2s ease;
    }

    .filter-sheet {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--mud-palette-surface);
        border-radius: 16px 16px 0 0;
        padding: 8px 0 32px;
        z-index: 1201;
        animation: slideUp 0.25s cubic-bezier(0.32, 0.72, 0, 1);
    }

    .filter-sheet-handle {
        width: 36px;
        height: 4px;
        background: var(--mud-palette-divider);
        border-radius: 2px;
        margin: 0 auto 12px;
    }

    .filter-sheet-title {
        padding: 0 20px 8px;
        color: var(--mud-palette-text-secondary);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .filter-sheet-options {
        display: flex;
        flex-direction: column;
    }

    .filter-sheet-option {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 20px;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--mud-palette-text-primary);
        font-size: 1rem;
        text-align: left;
        transition: background 0.15s;
    }

    .filter-sheet-option:active {
        background: var(--mud-palette-action-default-hover);
    }

    .filter-sheet-option.active {
        color: var(--mud-palette-primary);
    }

    .filter-sheet-option span {
        flex: 1;
    }

    .filter-sheet-check {
        color: var(--mud-palette-primary);
    }

    /* Botón de filtro móvil */
    .filter-mobile-btn {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px 4px 8px;
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        background: none;
        cursor: pointer;
        color: var(--mud-palette-text-primary);
        font-size: 0.875rem;
        white-space: nowrap;
    }

    .filter-mobile-btn-chevron {
        opacity: 0.6;
    }

    @@keyframes slideUp {
        from { transform: translateY(100%); }
        to   { transform: translateY(0); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    /* Contenedor del timeline es el único con scroll */
    .timeline-container {
        display: flex;
        position: relative;
        width: 100%;
        height: 100%;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-gutter: stable;
        overflow-anchor: auto;
    }

    /* Hide native scrollbar — custom scrubber replaces it */
    .timeline-container::-webkit-scrollbar {
        display: none;
    }

    .timeline-container {
        scrollbar-width: none;
    }

    .timeline-content {
        flex: 1;
        padding-right: 40px;
        padding-bottom: 80px;
    }


    .timeline-spacer {
        flex: 0 0 100%;
        width: 100%;
    }

    /* Grid continuo — todas las fotos en un único contenedor flex */
    .timeline-flat-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 2px;
        align-items: flex-start;
        align-content: flex-start;
    }

    /* Cabecera de día: ocupa todo el ancho y fuerza nueva fila */
    .day-header-row {
        flex: 0 0 100%;
        width: 100%;
        padding-top: 20px;
    }

    .day-header-row:first-child {
        padding-top: 4px;
    }

    .day-header {
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        text-transform: capitalize;
        padding: 0 4px 6px 4px;
        display: block;
    }

    .masonry-item {
        height: 180px;
        flex-shrink: 0;
        break-inside: avoid;
        page-break-inside: avoid;
        content-visibility: auto;
        contain-intrinsic-block-size: 180px;
    }

    @@media (min-width: 600px) {
        .masonry-item {
            height: 200px;
            contain-intrinsic-block-size: 200px;
        }
    }

    @@media (min-width: 960px) {
        .masonry-item {
            height: 220px;
            contain-intrinsic-block-size: 220px;
        }
    }

    @@media (min-width: 1280px) {
        .masonry-item {
            height: 240px;
            contain-intrinsic-block-size: 240px;
        }
    }

    @@media (min-width: 1920px) {
        .masonry-item {
            height: 260px;
            contain-intrinsic-block-size: 260px;
        }
    }

    /* ── Density: Small ── */
    .density-s .masonry-item { height: 100px !important; contain-intrinsic-block-size: 100px !important; }
    @@media (min-width: 600px)  { .density-s .masonry-item { height: 110px !important; contain-intrinsic-block-size: 110px !important; } }
    @@media (min-width: 960px)  { .density-s .masonry-item { height: 120px !important; contain-intrinsic-block-size: 120px !important; } }
    @@media (min-width: 1280px) { .density-s .masonry-item { height: 130px !important; contain-intrinsic-block-size: 130px !important; } }
    @@media (min-width: 1920px) { .density-s .masonry-item { height: 140px !important; contain-intrinsic-block-size: 140px !important; } }

    /* ── Density: Large ── */
    .density-l .masonry-item { height: 260px !important; contain-intrinsic-block-size: 260px !important; }
    @@media (min-width: 600px)  { .density-l .masonry-item { height: 300px !important; contain-intrinsic-block-size: 300px !important; } }
    @@media (min-width: 960px)  { .density-l .masonry-item { height: 340px !important; contain-intrinsic-block-size: 340px !important; } }
    @@media (min-width: 1280px) { .density-l .masonry-item { height: 380px !important; contain-intrinsic-block-size: 380px !important; } }
    @@media (min-width: 1920px) { .density-l .masonry-item { height: 420px !important; contain-intrinsic-block-size: 420px !important; } }

    /* ── Inline asset card (no AssetCard component) ── */
    .asset-card-container {
        position: relative;
        cursor: pointer;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background-color: #333;
    }

    .asset-placeholder {
        position: absolute;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        background: linear-gradient(90deg, #252525 25%, #303030 50%, #252525 75%);
        background-size: 200% 100%;
        animation: asset-shimmer 1.6s infinite ease-in-out;
        pointer-events: none;
        transition: opacity 0.25s ease;
    }

    .asset-placeholder[style*="background-color"] {
        background-image: none;
        animation: none;
        background-size: auto;
    }

    @@keyframes asset-shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .asset-card-container.img-loaded .asset-placeholder {
        opacity: 0;
        pointer-events: none;
    }

    .lazy-img {
        opacity: 0;
        transition: opacity 0.35s ease;
    }

    .asset-card-container.img-loaded .lazy-img {
        opacity: 1;
    }

    .asset-card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .asset-type-icon {
        position: absolute;
        bottom: 6px;
        right: 6px;
        z-index: 2;
        color: white;
        filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5));
    }

    .masonry-item .asset-card-container {
        width: 100%;
        height: 100%;
        border-radius: 0 !important;
    }

    .masonry-item .asset-placeholder {
        border-radius: 0 !important;
    }

    .masonry-item img,
    .masonry-item video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .asset-select-container {
        position: relative;
        height: 100%;
        transition: transform 0.15s ease, background-color 0.15s ease;
        background-color: transparent;
    }

    .asset-select-container.selected {
        transform: scale(0.90);
        background-color: var(--mud-palette-background-gray);
    }

    .asset-select-container.selection-mode:active {
        transform: scale(0.90);
        transition-duration: 0.06s;
    }

    .asset-select-checkbox {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 5;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s;
        background: rgba(0,0,0,0.4);
        border-radius: 999px;
        padding: 2px;
        color: white;
    }

    .asset-select-checkbox .mud-icon-root {
        color: white !important;
    }

    .asset-select-container:hover .asset-select-checkbox {
        opacity: 1;
        pointer-events: auto;
    }

    .asset-select-container.selected .asset-select-checkbox {
        opacity: 1;
        pointer-events: auto;
    }

    /* En dispositivos móviles (max 959px) */
    @@media (max-width: 959.98px) {
        .asset-select-container:not(.selection-mode):not(.selected):hover .asset-select-checkbox {
            opacity: 0;
            pointer-events: none;
        }

        /* Móvil: contenido a full width, scrubber flota encima */
        .filter-chips-bar {
            padding-right: 4px;
        }

        .filter-chips-desktop {
            display: none;
        }

        .filter-chips-mobile {
            display: flex;
        }

        .filter-density-controls {
            display: none;
        }

        /* Forzar compact en móvil independientemente de la densidad seleccionada */
        .timeline-content .masonry-item {
            height: 120px !important;
        }

        .timeline-content {
            padding: 12px 0;
        }

        /* Quitar la reserva de gutter en móvil para que el scrubber quede pegado al borde */
        .timeline-container {
            scrollbar-gutter: auto;
        }

        /* En móvil el scrubber es columna flex, no flotante */
        .scrubber-overlay {
            position: relative;
            top: auto;
            bottom: auto;
            right: auto;
            width: 40px;
            flex-shrink: 0;
            pointer-events: auto;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .scrubber-overlay.scrubber-visible {
            opacity: 1;
        }

        .scrubber-track {
            position: relative;
            top: 0;
            right: 0; /* reset del right: 4px de desktop */
            bottom: 0;
            height: 100%;
            width: 100%; /* ocupa los 40px del overlay para que el thumb quede flush al borde */
        }

        /* Ocultar línea del track y markers de año */
        .scrubber-track::before {
            display: none !important;
        }

        .scrubber-year-marker,
        .scrubber-year-dot,
        .scrubber-year-label {
            display: none !important;
        }

        /* Ocultar barra de filtros en móvil */
        .filter-chips-bar {
            display: none;
        }

        .day-header-row {
            padding-top: 12px;
        }

        .day-header-row:first-child {
            padding-top: 2px;
        }

        .day-header {
            font-size: 0.78rem !important;
        }

        /* Handle: pill draggable con flechas arriba/abajo — estilo Google Photos */
        .scrubber-thumb {
            width: 26px;
            height: 52px;
            left: auto;
            right: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 4px 0;
            background: rgba(28, 28, 28, 0.85);
            border-radius: 10px 0 0 10px;
            cursor: grab;
            touch-action: none;
            box-shadow: -1px 0 6px rgba(0,0,0,0.2);
        }

        .mud-dark .scrubber-thumb {
            background: rgba(255, 255, 255, 0.22);
        }

        .scrubber-thumb.dragging {
            cursor: grabbing;
        }

        /* Ocultar la barra horizontal del thumb desktop */
        .scrubber-thumb-bar {
            display: none;
        }

        /* Flechas arriba/abajo */
        .scrubber-arrow {
            display: block;
            height: 20px;
            color: rgba(255, 255, 255, 1);
            pointer-events: none;
            flex-shrink: 0;
        }

        .mud-dark .scrubber-arrow {
            color: rgba(255, 255, 255, 0.75);
        }

        /* Etiqueta de fecha: siempre visible a la izquierda del handle */
        .scrubber-thumb-label {
            opacity: 1 !important;
            position: absolute;
            right: calc(100% + 10px);
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.78rem;
            font-weight: 600;
            padding: 4px 10px;
            white-space: nowrap;
            background: rgba(30, 30, 30, 0.75);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            border-radius: 8px;
            color: white;
            pointer-events: none;
        }
    }

    /* ===== Custom Scrubber ===== */
    .scrubber-overlay {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 25px;
        z-index: 100;
        pointer-events: none;
    }

    /* Arrows — only visible on touch devices */
    @@media (hover: hover) {
        .scrubber-arrow {
            display: none;
        }
    }

    /* Large invisible hit area + visual bar via ::before */
    .scrubber-track {
        position: absolute;
        right: 0px;
        top: 0px;
        bottom: 8px;
        width: 25px;
        pointer-events: auto;
        cursor: pointer;
    }

    .scrubber-track::before {
        content: '';
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: rgba(128, 128, 128, 0.2);
        border-radius: 2px;
        pointer-events: none;
        transition: background 0.2s;
    }

    .scrubber-track:hover::before {
        background: rgba(128, 128, 128, 0.35);
    }

    /* Thumb: horizontal bar spanning the full track width */
    .scrubber-thumb {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        height: 40px;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        justify-content: center;
        cursor: grab;
        user-select: none;
        will-change: transform;
        pointer-events: auto;
    }

    .scrubber-thumb.dragging {
        cursor: grabbing;
    }

    .scrubber-thumb-bar {
        width: 100%;
        height: 4px;
        background: var(--mud-palette-primary);
        border-radius: 2px;
        flex-shrink: 0;
        transition: height 0.15s ease;
    }

    .scrubber-track:hover .scrubber-thumb-bar,
    .scrubber-thumb.dragging .scrubber-thumb-bar {
        height: 6px;
    }

    .scrubber-thumb-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: white;
        background: rgba(0, 0, 0, 0.7);
        padding: 3px 8px;
        border-radius: 4px;
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.15s ease;
        pointer-events: none;
        position: absolute;
        right: calc(100% + 8px);
        top: 50%;
        transform: translateY(-50%);
    }

    .scrubber-track:hover .scrubber-thumb-label,
    .scrubber-thumb.dragging .scrubber-thumb-label {
        opacity: 1;
    }

    /* Year markers */
    .scrubber-year-marker {
        position: absolute;
        right: 0;
        display: flex;
        align-items: center;
        gap: 6px;
        pointer-events: auto;
        cursor: pointer;
        transform: translateY(-50%);
    }

    .scrubber-year-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: rgba(128, 128, 128, 0.5);
        flex-shrink: 0;
        margin-right: -2px;
        transition: background 0.2s, transform 0.2s;
    }

    .scrubber-year-marker:hover .scrubber-year-dot,
    .scrubber-year-marker.active .scrubber-year-dot {
        background: var(--mud-palette-primary);
        transform: scale(1.4);
    }

    .scrubber-year-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.15s ease;
        order: -1;
    }

    .scrubber-track:hover .scrubber-year-label,
    .scrubber-year-marker.active .scrubber-year-label {
        opacity: 1;
    }
</style>

<MudDialog @bind-Visible="_addToAlbumDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Añadir a álbum</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">@($"{_selectedAssetIds.Count} elementos seleccionados")</MudText>
        @if (!_showCreateAlbum)
        {
            @if (_loadingAlbums)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_availableAlbums.Any())
            {
                <MudRadioGroup T="Guid?" @bind-Value="_selectedAlbumId">
                    @foreach (var album in _availableAlbums)
                    {
                        <MudRadio T="Guid?" Value="@album.Id">
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.subtitle2">@album.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@album.AssetCount fotos</MudText>
                            </div>
                        </MudRadio>
                    }
                </MudRadioGroup>
            }
            else
            {
                <MudAlert Severity="Severity.Info">No hay álbumes disponibles.</MudAlert>
            }
            
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Add"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = true)">
                Crear nuevo álbum
            </MudButton>
        }
        else
        {
            <MudTextField @bind-Value="_newAlbumName"
                          Label="Nombre del álbum"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="_newAlbumDescription"
                          Label="Descripción (opcional)"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Lines="3" />
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = false)">
                Volver a selección
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseAddToAlbumDialog">Cancelar</MudButton>
        @if (_showCreateAlbum)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAlbumAndAddAsync">
                Crear y añadir
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddSelectionToAlbumAsync"
                       Disabled="@(!_selectedAlbumId.HasValue)">
                Añadir
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteAssetsDialogVisible" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar archivos</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>¿Quieres mover @_selectedAssetIds.Count archivos a la papelera?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteAssetsDialog">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteSelectedAsync">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<TimelineGridSection> _gridSections = new();
    private Dictionary<string, List<TimelineGridItem>> _groupedGridItems = new();
    private Dictionary<string, List<TimelineGridItem>> _visibleGroupedGridItems = new();
    private bool _loading = true;
    private bool _loadingMore = false;
    // Window-based rendering: only render groups within [_windowStart, _windowEnd) item range
    private int _windowStart = 0;
    private int _windowEnd = WINDOW_SIZE;
    private const int WINDOW_SIZE = 600;       // max items rendered at once
    private const int LOAD_MORE_BATCH = 300;   // items added when scrolling near edges
    private double _lastScrollTop = 0;
    private string _activeGroup = "";
    private DotNetObjectReference<Timeline>? _objRef;
    private bool _selectionMode = false;
    private HashSet<Guid> _selectedAssetIds = new();
    private bool _addToAlbumDialogVisible = false;
    private bool _deleteAssetsDialogVisible = false;
    private bool _downloadingZip = false;
    private List<AlbumItem> _availableAlbums = new();
    private bool _loadingAlbums = false;
    private Guid? _selectedAlbumId = null;
    private bool _showCreateAlbum = false;
    private string _newAlbumName = "";
    private string? _newAlbumDescription = "";
    private bool _deleteDialogVisible = false;
    private string _activeFilter = "All"; // All, Photos, Videos, Favorites
    private string _density = "M"; // S, M, L
    private bool _filterSheetOpen = false;

    private IEnumerable<TimelineGridItem> AllGridItems =>
        _gridSections.SelectMany(s => s.Items);

    private IEnumerable<TimelineGridItem> FilteredGridItems => _activeFilter switch
    {
        "Photos" => AllGridItems.Where(a => a.Type.Equals("Image", StringComparison.OrdinalIgnoreCase)),
        "Videos" => AllGridItems.Where(a => a.Type.Equals("Video", StringComparison.OrdinalIgnoreCase)),
        // Favorites filter not available in grid-only mode (no IsFavorite field)
        _ => AllGridItems
    };

    private string GetFilterLabel() => _activeFilter switch
    {
        "Photos"    => "Fotos",
        "Videos"    => "Vídeos",
        "Favorites" => "Favoritos",
        _           => "Todas"
    };

    private void OpenFilterSheet() => _filterSheetOpen = true;
    private void CloseFilterSheet() => _filterSheetOpen = false;

    private async Task SetDensity(string density)
    {
        if (_density == density) return;
        _density = density;
        _masonryInitialized = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("localStorage.setItem", "timelineDensity", density);
    }

    private async Task SetFilter(string filter)
    {
        if (_activeFilter == filter) return;
        _activeFilter = filter;
        _masonryInitialized = false;
        RebuildGroupedGridItems();
        StateHasChanged();
        await Task.Delay(50);
        if (_groupedGridItems.Any() && _scrollSetupDone)
            await JS.InvokeVoidAsync("scrollHelpers.scrollToElement", GetGroupId(_groupedGridItems.Keys.First()));
    }

    protected override async Task OnInitializedAsync()
    {
        var savedDensity = await JS.InvokeAsync<string?>("localStorage.getItem", "timelineDensity");
        if (savedDensity is "S" or "M" or "L") _density = savedDensity;
        await InitializeTimelineAsync();
    }

    private async Task InitializeTimelineAsync()
    {
        try
        {
            // Try memory cache first (instant)
            if (TimelineCache.HasValidIndex && TimelineCache.Index != null && TimelineCache.HasGrid && TimelineCache.Grid != null)
            {
                _timelineIndex = TimelineCache.Index;
                _gridSections = TimelineCache.Grid;
                RebuildGroupedGridItems();
                _loading = false;
                StateHasChanged();
                _ = RefreshInBackgroundAsync();
                return;
            }

            // Try IndexedDB next
            var persistedIndex = await TimelinePersistence.LoadIndexAsync();
            var persistedGrid = await TimelinePersistence.LoadGridAsync();

            if (persistedIndex != null && persistedGrid != null)
            {
                TimelineCache.SetIndex(persistedIndex);
                TimelineCache.SetGrid(persistedGrid);
                _timelineIndex = persistedIndex;
                _gridSections = persistedGrid;
                RebuildGroupedGridItems();
                _loading = false;
                StateHasChanged();
                _ = RefreshInBackgroundAsync();
                return;
            }

            // Cold start: fetch index + stream grid sections progressively
            _loading = true;
            StateHasChanged();

            _timelineIndex = await AssetService.GetTimelineIndexAsync();
            TimelineCache.SetIndex(_timelineIndex);
            _ = TimelinePersistence.SaveIndexAsync(_timelineIndex);

            _gridSections = new List<TimelineGridSection>();
            var sectionsReceived = 0;
            await foreach (var section in AssetService.GetTimelineGridStreamAsync())
            {
                _gridSections.Add(section);
                sectionsReceived++;
                // Render progressively: first batch immediately, then every 3 sections
                if (sectionsReceived == 1 || sectionsReceived % 3 == 0)
                {
                    RebuildGroupedGridItems();
                    StateHasChanged();
                }
            }

            TimelineCache.SetGrid(_gridSections);
            _ = TimelinePersistence.SaveGridAsync(_gridSections);

            RebuildGroupedGridItems();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar timeline: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshInBackgroundAsync()
    {
        try
        {
            var freshIndex = await AssetService.GetTimelineIndexAsync();
            if (_isDisposed) return;

            if (!TimelineCache.IndexChangedFrom(freshIndex))
            {
                TimelineCache.SetIndex(freshIndex);
                return;
            }

            // Index changed — stream fresh grid
            var freshGrid = new List<TimelineGridSection>();
            await foreach (var section in AssetService.GetTimelineGridStreamAsync())
            {
                if (_isDisposed) return;
                freshGrid.Add(section);
            }

            TimelineCache.SetIndex(freshIndex);
            TimelineCache.SetGrid(freshGrid);
            _ = TimelinePersistence.SaveIndexAsync(freshIndex);
            _ = TimelinePersistence.SaveGridAsync(freshGrid);

            _timelineIndex = freshIndex;
            _gridSections = freshGrid;
            _masonryInitialized = false;
            RebuildGroupedGridItems();

            if (!_isDisposed)
                StateHasChanged();
        }
        catch
        {
            // Fallo silencioso — los datos en caché siguen siendo válidos
        }
    }

    private string? GetDateFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (string.IsNullOrEmpty(uri.Query))
            return null;
            
        var query = uri.Query.TrimStart('?');
        var pairs = query.Split('&');
        
        foreach (var pair in pairs)
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 && parts[0] == "date")
            {
                return Uri.UnescapeDataString(parts[1]);
            }
        }
        
        return null;
    }

    private bool _scrollSetupDone = false;
    private bool _groupMapNeedsUpdate = false;
    private bool _isDisposed = false;
    private bool _masonryInitialized = false;
    private List<TimelineIndexItem> _timelineIndex = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed) return;

        if (firstRender)
        {
            await JS.InvokeVoidAsync("scrollHelpers.enableTimelineScroll");
            if (_objRef == null) _objRef = DotNetObjectReference.Create(this);
        }

        if (!_groupedGridItems.Any()) return;

        if (!_scrollSetupDone)
        {
            _scrollSetupDone = true;
            _groupMapNeedsUpdate = false;
            await SetupScrollListener();
            await InitScrubber();

            // Initialise the scroll-aware image loader and register all images
            await JS.InvokeVoidAsync("imageLoadManager.init");
            await JS.InvokeVoidAsync("timelineVirtualScroll.init", _objRef);

            if (_isDisposed) return;
            var dateParam = GetDateFromQuery();
            if (!string.IsNullOrEmpty(dateParam))
                await ScrollToDate(dateParam);
        }
        else if (_groupMapNeedsUpdate)
        {
            _groupMapNeedsUpdate = false;
            await JS.InvokeVoidAsync("scrubberHelpers.updateGroupMap", BuildGroupData());
            var groupIds = _groupedGridItems.Keys.Select(GetGroupId).ToList();
            await JS.InvokeVoidAsync("scrollHelpers.updateGroupIds", groupIds);
        }

        if (_isDisposed) return;

        // Single masonry pass: run once after grid renders, re-run on density/filter change
        if (!_masonryInitialized && _groupedGridItems.Any())
        {
            _masonryInitialized = true;
            await JS.InvokeVoidAsync("masonryHelpers.initializeMasonry");
            if (!_isDisposed)
                await JS.InvokeVoidAsync("imageLoadManager.observeAll");
        }
    }

    private async Task InitScrubber()
    {
        await JS.InvokeVoidAsync("scrubberHelpers.init", BuildGroupData());
    }

    private List<object> BuildGroupData()
    {
        if (_timelineIndex.Any())
        {
            var total = _timelineIndex.Sum(i => i.Count);
            var cumulative = 0;
            var result = new List<object>();
            foreach (var item in _timelineIndex.OrderByDescending(i => i.Date))
            {
                var groupKey = item.Date.ToString("yyyy-MM-dd");
                result.Add(new
                {
                    id = GetGroupId(groupKey),
                    label = GetGroupLabel(groupKey),
                    position = total > 0 ? (double)cumulative / total : 0.0
                });
                cumulative += item.Count;
            }
            return result;
        }

        // Fallback: use loaded grid groups
        var totalAssets = _groupedGridItems.Values.Sum(g => g.Count);
        var fallbackCumulative = 0;
        var fallbackResult = new List<object>();
        foreach (var kvp in _groupedGridItems)
        {
            fallbackResult.Add(new
            {
                id = GetGroupId(kvp.Key),
                label = GetGroupLabel(kvp.Key),
                position = totalAssets > 0 ? (double)fallbackCumulative / totalAssets : 0.0
            });
            fallbackCumulative += kvp.Value.Count;
        }
        return fallbackResult;
    }

    private string GetGroupLabel(string groupKey)
    {
        var date = GetDayDateFromGroup(groupKey);
        if (date == DateTime.MinValue) return "";
        return date.ToString("MMM yyyy", new System.Globalization.CultureInfo("es-ES"));
    }

    private string GetThumbLabel()
    {
        return GetGroupLabel(_activeGroup);
    }
    
    private async Task ScrollToDate(string dateString)
    {
        if (DateTime.TryParse(dateString, out var targetDate))
        {
            if (!_groupedGridItems.Any()) return;

            var targetGroup = _groupedGridItems.Keys.FirstOrDefault(g =>
            {
                var groupDate = GetDayDateFromGroup(g);
                return groupDate.Date == targetDate.Date;
            });

            if (!string.IsNullOrEmpty(targetGroup))
            {
                await Task.Delay(300); // allow masonry to settle
                await ScrollToGroup(targetGroup);
            }
        }
    }

    private async Task SetupScrollListener()
    {
        if (_objRef == null)
        {
            _objRef = DotNetObjectReference.Create(this);
        }
        var groupIds = _groupedGridItems.Keys.Select(GetGroupId).ToList();
        await JS.InvokeVoidAsync("scrollHelpers.onWindowScroll", _objRef, groupIds);
    }

    [JSInvokable]
    public async Task ScrollToGroupFromJS(string groupKey)
    {
        if (_groupedGridItems.ContainsKey(groupKey))
        {
            await ScrollToGroup(groupKey);
        }
    }

    [JSInvokable]
    public Task OnVirtualScrollIdle(double scrollTop)
    {
        _lastScrollTop = scrollTop;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public void OnScrollUpdated(string activeGroupId)
    {
        var groupName = _groupedGridItems.Keys.FirstOrDefault(k => GetGroupId(k) == activeGroupId);
        if (!string.IsNullOrEmpty(groupName))
            _activeGroup = groupName;
    }

    private double GetGroupPosition(string groupName)
    {
        if (!_groupedGridItems.Any()) return 0;
        var totalAssets = _groupedGridItems.Values.Sum(g => g.Count);
        if (totalAssets == 0) return 0;

        var cumulative = 0;
        foreach (var kvp in _groupedGridItems)
        {
            if (kvp.Key == groupName)
                return (double)cumulative / totalAssets * 100;
            cumulative += kvp.Value.Count;
        }
        return 0;
    }

    private string GetGroupStyle(string groupName)
    {
        return $"top: {GetGroupPosition(groupName).ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}%;";
    }

    private async Task LoadTimeline()
    {
        // Full reload (called after mutations like delete/archive)
        TimelineCache.InvalidateAll();
        _ = TimelinePersistence.ClearAllAsync();
        _groupedGridItems = new();
        _gridSections = new();
        _activeGroup = "";
        _scrollSetupDone = false;
        _masonryInitialized = false;
        _loading = true;
        StateHasChanged();
        await InitializeTimelineAsync();
    }

    private void RebuildGroupedGridItems()
    {
        _groupedGridItems = FilteredGridItems
            .GroupBy(a => a.Date)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
        if (_groupedGridItems.Any())
            _activeGroup = _groupedGridItems.Keys.First();
        _windowStart = 0;
        _windowEnd = WINDOW_SIZE;
        RebuildVisibleItems();
        _groupMapNeedsUpdate = true;
    }

    private int _topSpacerHeight = 0;
    private int _bottomSpacerHeight = 0;

    private void RebuildVisibleItems()
    {
        var visible = new Dictionary<string, List<TimelineGridItem>>();
        var index = 0;
        var beforeCount = 0;
        var afterCount = 0;
        var inWindow = false;

        foreach (var kvp in _groupedGridItems)
        {
            var groupEnd = index + kvp.Value.Count;

            if (groupEnd <= _windowStart)
            {
                // Entire group is before the window
                beforeCount += kvp.Value.Count;
            }
            else if (index >= _windowEnd)
            {
                // Entire group is after the window
                afterCount += kvp.Value.Count;
            }
            else
            {
                // Group overlaps the window — include it fully
                visible[kvp.Key] = kvp.Value;
                inWindow = true;
            }
            index = groupEnd;
        }
        _visibleGroupedGridItems = visible;

        // Estimate spacer heights: ~200px row height, ~5 items per row
        _topSpacerHeight = (int)((double)beforeCount / 5 * 200);
        _bottomSpacerHeight = (int)((double)afterCount / 5 * 200);
    }

    /// <summary>
    /// Called from JS when the user scrolls near the bottom of the rendered content.
    /// Extends the window downward.
    /// </summary>
    [JSInvokable]
    public async Task LoadMoreItems()
    {
        if (_loadingMore) return;
        var totalItems = _groupedGridItems.Values.Sum(g => g.Count);
        if (_windowEnd >= totalItems) return;

        _loadingMore = true;
        _windowEnd = Math.Min(_windowEnd + LOAD_MORE_BATCH, totalItems);
        // Reclaim from the top if window exceeds max size
        if (_windowEnd - _windowStart > WINDOW_SIZE)
            _windowStart = _windowEnd - WINDOW_SIZE;
        RebuildVisibleItems();
        _masonryInitialized = false;
        StateHasChanged();
        await Task.Yield();
        _loadingMore = false;
    }

    /// <summary>
    /// Called from JS when the user scrolls near the top of the rendered content.
    /// Extends the window upward.
    /// </summary>
    [JSInvokable]
    public async Task LoadPreviousItems()
    {
        if (_loadingMore || _windowStart <= 0) return;

        _loadingMore = true;
        _windowStart = Math.Max(_windowStart - LOAD_MORE_BATCH, 0);
        // Reclaim from the bottom if window exceeds max size
        if (_windowEnd - _windowStart > WINDOW_SIZE)
            _windowEnd = _windowStart + WINDOW_SIZE;
        RebuildVisibleItems();
        _masonryInitialized = false;
        StateHasChanged();
        await Task.Yield();
        _loadingMore = false;
    }
    
    private string FormatDayHeader(DateTime date)
    {
        var today = DateTime.Today;
        var yesterday = today.AddDays(-1);
        
        if (date.Date == today)
            return "Hoy";
        else if (date.Date == yesterday)
            return "Ayer";
        else if (date.Year == today.Year)
            return date.ToString("dddd, d 'de' MMMM", new System.Globalization.CultureInfo("es-ES"));
        else
            return date.ToString("dddd, d 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"));
    }

    private void OpenAsset(Guid assetId)
    {
        Navigation.NavigateTo($"/asset/{assetId}");
    }

    private void OpenMemoryAsset(MemoryClickArgs args)
    {
        AssetListNavigationState.SetList(args.GroupAssets, albumId: null);
        if (args.Asset.SyncStatus == AssetSyncStatus.Synced)
        {
            Navigation.NavigateTo($"/asset/{args.Asset.Id}");
        }
        else
        {
            var encodedPath = System.Net.WebUtility.UrlEncode(args.Asset.FullPath);
            Navigation.NavigateTo($"/asset/{Guid.Empty}?path={encodedPath}");
        }
    }

    // ── Touch / long-press / drag-select ───────────────────────────────────
    private System.Threading.Timer? _longPressTimer;
    private bool _longPressHandled;
    private double _touchStartX;
    private double _touchStartY;

    private async Task OnGridItemTouchStart(TouchEventArgs e, TimelineGridItem item)
    {
        if (e.Touches.Length == 0) return;
        _touchStartX = e.Touches[0].ClientX;
        _touchStartY = e.Touches[0].ClientY;
        _longPressHandled = false;

        if (_selectionMode)
        {
            var selectMode = !IsAssetSelected(item.Id);
            _longPressHandled = true;
            ToggleAssetSelection(item.Id, selectMode);
            await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
            if (_objRef != null)
                await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, selectMode);
            return;
        }

        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _longPressHandled = true;
                ToggleAssetSelection(item.Id, true);
                await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
                if (_objRef != null)
                    await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, true);
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private void OnCardTouchMove(TouchEventArgs e)
    {
        // Solo necesario para cancelar el long press si el dedo se mueve antes de 500ms
        if (e.Touches.Length == 0 || _longPressTimer == null) return;
        var dx = e.Touches[0].ClientX - _touchStartX;
        var dy = e.Touches[0].ClientY - _touchStartY;
        if (Math.Sqrt(dx * dx + dy * dy) > 10)
        {
            _longPressTimer.Dispose();
            _longPressTimer = null;
        }
    }

    private void OnCardTouchEnd(TouchEventArgs e)
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
        // El arrastre JS se limpia solo (escucha touchend en el documento)
    }

    [JSInvokable]
    public void OnDragSelectAsset(string assetIdStr, bool select)
    {
        if (!Guid.TryParse(assetIdStr, out var assetId)) return;
        if (select == IsAssetSelected(assetId)) return; // ya está en el estado deseado
        ToggleAssetSelection(assetId, select);
        StateHasChanged();
    }
