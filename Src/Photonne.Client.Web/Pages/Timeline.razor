@page "/"
@inject IAssetService AssetService
@inject IAlbumService AlbumService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject LayoutService LayoutService
@inject IAssetListNavigationState AssetListNavigationState
@inject IDialogService DialogService
@inject TimelineCache TimelineCache
@inject TimelinePersistenceService TimelinePersistence
@inject DeviceLayoutService DeviceLayout
@implements IDisposable

<PageTitle>Timeline - Photonne</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}

@if (DeviceLayout.IsMobile)
{
    <TimelineMobileView Loading="_loading"
                        Density="@_density"
                        ActiveFilter="@_activeFilter"
                        SelectionMode="_selectionMode"
                        FilterSheetOpen="_filterSheetOpen"
                        TopSpacerHeight="_topSpacerHeight"
                        BottomSpacerHeight="_bottomSpacerHeight"
                        GroupedGridItems="_groupedGridItems"
                        VisibleGroupedGridItems="_visibleGroupedGridItems"
                        TimelineIndex="_timelineIndex"
                        SelectedAssetIds="_selectedAssetIds"
                        ActiveGroup="@_activeGroup"
                        OnSetFilter="SetFilter"
                        OnOpenFilterSheet="OpenFilterSheet"
                        OnCloseFilterSheet="CloseFilterSheet"
                        OnGridItemClick="OnGridItemClick"
                        OnGridItemTouchStart="OnGridItemTouchStartFromView"
                        OnCardTouchMove="OnCardTouchMove"
                        OnCardTouchEnd="OnCardTouchEnd"
                        OnToggleAssetSelection="ToggleAssetSelectionFromView"
                        OnMemoryThumbClick="OpenMemoryAsset" />
}
else
{
    <TimelineDesktopView Loading="_loading"
                         Density="@_density"
                         ActiveFilter="@_activeFilter"
                         SelectionMode="_selectionMode"
                         TopSpacerHeight="_topSpacerHeight"
                         BottomSpacerHeight="_bottomSpacerHeight"
                         GroupedGridItems="_groupedGridItems"
                         VisibleGroupedGridItems="_visibleGroupedGridItems"
                         TimelineIndex="_timelineIndex"
                         SelectedAssetIds="_selectedAssetIds"
                         ActiveGroup="@_activeGroup"
                         OnSetDensity="SetDensity"
                         OnSetFilter="SetFilter"
                         OnGridItemClick="OnGridItemClick"
                         OnGridItemTouchStart="OnGridItemTouchStartFromView"
                         OnCardTouchMove="OnCardTouchMove"
                         OnCardTouchEnd="OnCardTouchEnd"
                         OnToggleAssetSelection="ToggleAssetSelectionFromView"
                         OnMemoryThumbClick="OpenMemoryAsset" />
}

<MudDialog @bind-Visible="_addToAlbumDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Añadir a álbum</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">@($"{_selectedAssetIds.Count} elementos seleccionados")</MudText>
        @if (!_showCreateAlbum)
        {
            @if (_loadingAlbums)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_availableAlbums.Any())
            {
                <MudRadioGroup T="Guid?" @bind-Value="_selectedAlbumId">
                    @foreach (var album in _availableAlbums)
                    {
                        <MudRadio T="Guid?" Value="@album.Id">
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.subtitle2">@album.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@album.AssetCount fotos</MudText>
                            </div>
                        </MudRadio>
                    }
                </MudRadioGroup>
            }
            else
            {
                <MudAlert Severity="Severity.Info">No hay álbumes disponibles.</MudAlert>
            }
            
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Add"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = true)">
                Crear nuevo álbum
            </MudButton>
        }
        else
        {
            <MudTextField @bind-Value="_newAlbumName"
                          Label="Nombre del álbum"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="_newAlbumDescription"
                          Label="Descripción (opcional)"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Lines="3" />
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = false)">
                Volver a selección
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseAddToAlbumDialog">Cancelar</MudButton>
        @if (_showCreateAlbum)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAlbumAndAddAsync">
                Crear y añadir
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddSelectionToAlbumAsync"
                       Disabled="@(!_selectedAlbumId.HasValue)">
                Añadir
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteAssetsDialogVisible" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar archivos</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>¿Quieres mover @_selectedAssetIds.Count archivos a la papelera?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteAssetsDialog">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteSelectedAsync">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<TimelineGridSection> _gridSections = new();
    private Dictionary<string, List<TimelineGridItem>> _groupedGridItems = new();
    private Dictionary<string, List<TimelineGridItem>> _visibleGroupedGridItems = new();
    private bool _loading = true;
    private bool _loadingMore = false;
    // Window-based rendering: only render groups within [_windowStart, _windowEnd) item range
    private int _windowStart = 0;
    private int _windowEnd = WINDOW_SIZE;
    private const int WINDOW_SIZE = 600;       // max items rendered at once
    private const int LOAD_MORE_BATCH = 300;   // items added when scrolling near edges
    private double _lastScrollTop = 0;
    private string _activeGroup = "";
    private DotNetObjectReference<Timeline>? _objRef;
    private bool _selectionMode = false;
    private HashSet<Guid> _selectedAssetIds = new();
    private bool _addToAlbumDialogVisible = false;
    private bool _deleteAssetsDialogVisible = false;
    private bool _downloadingZip = false;
    private List<AlbumItem> _availableAlbums = new();
    private bool _loadingAlbums = false;
    private Guid? _selectedAlbumId = null;
    private bool _showCreateAlbum = false;
    private string _newAlbumName = "";
    private string? _newAlbumDescription = "";
    private bool _deleteDialogVisible = false;
    private string _activeFilter = "All"; // All, Photos, Videos, Favorites
    private string _density = "M"; // S, M, L
    private bool _filterSheetOpen = false;

    private IEnumerable<TimelineGridItem> AllGridItems =>
        _gridSections.SelectMany(s => s.Items);

    private IEnumerable<TimelineGridItem> FilteredGridItems => _activeFilter switch
    {
        "Photos" => AllGridItems.Where(a => a.Type.Equals("Image", StringComparison.OrdinalIgnoreCase)),
        "Videos" => AllGridItems.Where(a => a.Type.Equals("Video", StringComparison.OrdinalIgnoreCase)),
        // Favorites filter not available in grid-only mode (no IsFavorite field)
        _ => AllGridItems
    };

    private string GetFilterLabel() => _activeFilter switch
    {
        "Photos"    => "Fotos",
        "Videos"    => "Vídeos",
        "Favorites" => "Favoritos",
        _           => "Todas"
    };

    private void OpenFilterSheet() => _filterSheetOpen = true;
    private void CloseFilterSheet() => _filterSheetOpen = false;

    private async Task SetDensity(string density)
    {
        if (_density == density) return;
        _density = density;
        _masonryInitialized = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("localStorage.setItem", "timelineDensity", density);
    }

    private async Task SetFilter(string filter)
    {
        if (_activeFilter == filter) return;
        _activeFilter = filter;
        _masonryInitialized = false;
        RebuildGroupedGridItems();
        StateHasChanged();
        await Task.Delay(50);
        if (_groupedGridItems.Any() && _scrollSetupDone)
            await JS.InvokeVoidAsync("scrollHelpers.scrollToElement", GetGroupId(_groupedGridItems.Keys.First()));
    }

    protected override async Task OnInitializedAsync()
    {
        var savedDensity = await JS.InvokeAsync<string?>("localStorage.getItem", "timelineDensity");
        if (savedDensity is "S" or "M" or "L") _density = savedDensity;
        await InitializeTimelineAsync();
    }

    private async Task InitializeTimelineAsync()
    {
        try
        {
            // Try memory cache first (instant)
            if (TimelineCache.HasValidIndex && TimelineCache.Index != null && TimelineCache.HasGrid && TimelineCache.Grid != null)
            {
                _timelineIndex = TimelineCache.Index;
                _gridSections = TimelineCache.Grid;
                RebuildGroupedGridItems();
                _loading = false;
                StateHasChanged();
                _ = RefreshInBackgroundAsync();
                return;
            }

            // Try IndexedDB next
            var persistedIndex = await TimelinePersistence.LoadIndexAsync();
            var persistedGrid = await TimelinePersistence.LoadGridAsync();

            if (persistedIndex != null && persistedGrid != null)
            {
                TimelineCache.SetIndex(persistedIndex);
                TimelineCache.SetGrid(persistedGrid);
                _timelineIndex = persistedIndex;
                _gridSections = persistedGrid;
                RebuildGroupedGridItems();
                _loading = false;
                StateHasChanged();
                _ = RefreshInBackgroundAsync();
                return;
            }

            // Cold start: fetch index + stream grid sections progressively
            _loading = true;
            StateHasChanged();

            _timelineIndex = await AssetService.GetTimelineIndexAsync();
            TimelineCache.SetIndex(_timelineIndex);
            _ = TimelinePersistence.SaveIndexAsync(_timelineIndex);

            _gridSections = new List<TimelineGridSection>();
            var sectionsReceived = 0;
            await foreach (var section in AssetService.GetTimelineGridStreamAsync())
            {
                _gridSections.Add(section);
                sectionsReceived++;
                // Render progressively: first batch immediately, then every 3 sections
                if (sectionsReceived == 1 || sectionsReceived % 3 == 0)
                {
                    RebuildGroupedGridItems();
                    StateHasChanged();
                }
            }

            TimelineCache.SetGrid(_gridSections);
            _ = TimelinePersistence.SaveGridAsync(_gridSections);

            RebuildGroupedGridItems();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar timeline: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshInBackgroundAsync()
    {
        try
        {
            var freshIndex = await AssetService.GetTimelineIndexAsync();
            if (_isDisposed) return;

            if (!TimelineCache.IndexChangedFrom(freshIndex))
            {
                TimelineCache.SetIndex(freshIndex);
                return;
            }

            // Index changed — stream fresh grid
            var freshGrid = new List<TimelineGridSection>();
            await foreach (var section in AssetService.GetTimelineGridStreamAsync())
            {
                if (_isDisposed) return;
                freshGrid.Add(section);
            }

            TimelineCache.SetIndex(freshIndex);
            TimelineCache.SetGrid(freshGrid);
            _ = TimelinePersistence.SaveIndexAsync(freshIndex);
            _ = TimelinePersistence.SaveGridAsync(freshGrid);

            _timelineIndex = freshIndex;
            _gridSections = freshGrid;
            _masonryInitialized = false;
            RebuildGroupedGridItems();

            if (!_isDisposed)
                StateHasChanged();
        }
        catch
        {
            // Fallo silencioso — los datos en caché siguen siendo válidos
        }
    }

    private string? GetDateFromQuery()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (string.IsNullOrEmpty(uri.Query))
            return null;
            
        var query = uri.Query.TrimStart('?');
        var pairs = query.Split('&');
        
        foreach (var pair in pairs)
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 && parts[0] == "date")
            {
                return Uri.UnescapeDataString(parts[1]);
            }
        }
        
        return null;
    }

    private bool _scrollSetupDone = false;
    private bool _groupMapNeedsUpdate = false;
    private bool _isDisposed = false;
    private bool _masonryInitialized = false;
    private List<TimelineIndexItem> _timelineIndex = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed) return;

        if (firstRender)
        {
            await DeviceLayout.InitializeAsync();
            DeviceLayout.OnChanged += OnDeviceLayoutChanged;
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollHelpers.enableTimelineScroll");
            if (_objRef == null) _objRef = DotNetObjectReference.Create(this);
        }

        if (!_groupedGridItems.Any()) return;

        if (!_scrollSetupDone)
        {
            _scrollSetupDone = true;
            _groupMapNeedsUpdate = false;
            await SetupScrollListener();
            await InitScrubber();

            // Initialise the scroll-aware image loader and register all images
            await JS.InvokeVoidAsync("imageLoadManager.init");
            await JS.InvokeVoidAsync("timelineVirtualScroll.init", _objRef);

            if (_isDisposed) return;
            var dateParam = GetDateFromQuery();
            if (!string.IsNullOrEmpty(dateParam))
                await ScrollToDate(dateParam);
        }
        else if (_groupMapNeedsUpdate)
        {
            _groupMapNeedsUpdate = false;
            await JS.InvokeVoidAsync("scrubberHelpers.updateGroupMap", BuildGroupData());
            var groupIds = _groupedGridItems.Keys.Select(GetGroupId).ToList();
            await JS.InvokeVoidAsync("scrollHelpers.updateGroupIds", groupIds);
        }

        if (_isDisposed) return;

        // Single masonry pass: run once after grid renders, re-run on density/filter change
        if (!_masonryInitialized && _groupedGridItems.Any())
        {
            _masonryInitialized = true;
            await JS.InvokeVoidAsync("masonryHelpers.initializeMasonry");
            if (!_isDisposed)
                await JS.InvokeVoidAsync("imageLoadManager.observeAll");
        }
    }

    private async Task InitScrubber()
    {
        await JS.InvokeVoidAsync("scrubberHelpers.init", BuildGroupData());
    }

    private List<object> BuildGroupData()
    {
        if (_timelineIndex.Any())
        {
            var total = _timelineIndex.Sum(i => i.Count);
            var cumulative = 0;
            var result = new List<object>();
            foreach (var item in _timelineIndex.OrderByDescending(i => i.Date))
            {
                var groupKey = item.Date.ToString("yyyy-MM-dd");
                result.Add(new
                {
                    id = GetGroupId(groupKey),
                    label = GetGroupLabel(groupKey),
                    position = total > 0 ? (double)cumulative / total : 0.0
                });
                cumulative += item.Count;
            }
            return result;
        }

        // Fallback: use loaded grid groups
        var totalAssets = _groupedGridItems.Values.Sum(g => g.Count);
        var fallbackCumulative = 0;
        var fallbackResult = new List<object>();
        foreach (var kvp in _groupedGridItems)
        {
            fallbackResult.Add(new
            {
                id = GetGroupId(kvp.Key),
                label = GetGroupLabel(kvp.Key),
                position = totalAssets > 0 ? (double)fallbackCumulative / totalAssets : 0.0
            });
            fallbackCumulative += kvp.Value.Count;
        }
        return fallbackResult;
    }

    private string GetGroupLabel(string groupKey)
    {
        var date = GetDayDateFromGroup(groupKey);
        if (date == DateTime.MinValue) return "";
        return date.ToString("MMM yyyy", new System.Globalization.CultureInfo("es-ES"));
    }

    private string GetThumbLabel()
    {
        return GetGroupLabel(_activeGroup);
    }
    
    private async Task ScrollToDate(string dateString)
    {
        if (DateTime.TryParse(dateString, out var targetDate))
        {
            if (!_groupedGridItems.Any()) return;

            var targetGroup = _groupedGridItems.Keys.FirstOrDefault(g =>
            {
                var groupDate = GetDayDateFromGroup(g);
                return groupDate.Date == targetDate.Date;
            });

            if (!string.IsNullOrEmpty(targetGroup))
            {
                await Task.Delay(300); // allow masonry to settle
                await ScrollToGroup(targetGroup);
            }
        }
    }

    private async Task SetupScrollListener()
    {
        if (_objRef == null)
        {
            _objRef = DotNetObjectReference.Create(this);
        }
        var groupIds = _groupedGridItems.Keys.Select(GetGroupId).ToList();
        await JS.InvokeVoidAsync("scrollHelpers.onWindowScroll", _objRef, groupIds);
    }

    [JSInvokable]
    public async Task ScrollToGroupFromJS(string groupKey)
    {
        if (_groupedGridItems.ContainsKey(groupKey))
        {
            await ScrollToGroup(groupKey);
        }
    }

    [JSInvokable]
    public Task OnVirtualScrollIdle(double scrollTop)
    {
        _lastScrollTop = scrollTop;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public void OnScrollUpdated(string activeGroupId)
    {
        var groupName = _groupedGridItems.Keys.FirstOrDefault(k => GetGroupId(k) == activeGroupId);
        if (!string.IsNullOrEmpty(groupName))
            _activeGroup = groupName;
    }

    private double GetGroupPosition(string groupName)
    {
        if (!_groupedGridItems.Any()) return 0;
        var totalAssets = _groupedGridItems.Values.Sum(g => g.Count);
        if (totalAssets == 0) return 0;

        var cumulative = 0;
        foreach (var kvp in _groupedGridItems)
        {
            if (kvp.Key == groupName)
                return (double)cumulative / totalAssets * 100;
            cumulative += kvp.Value.Count;
        }
        return 0;
    }

    private string GetGroupStyle(string groupName)
    {
        return $"top: {GetGroupPosition(groupName).ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}%;";
    }

    private async Task LoadTimeline()
    {
        // Full reload (called after mutations like delete/archive)
        TimelineCache.InvalidateAll();
        _ = TimelinePersistence.ClearAllAsync();
        _groupedGridItems = new();
        _gridSections = new();
        _activeGroup = "";
        _scrollSetupDone = false;
        _masonryInitialized = false;
        _loading = true;
        StateHasChanged();
        await InitializeTimelineAsync();
    }

    private void RebuildGroupedGridItems()
    {
        _groupedGridItems = FilteredGridItems
            .GroupBy(a => a.Date)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
        if (_groupedGridItems.Any())
            _activeGroup = _groupedGridItems.Keys.First();
        _windowStart = 0;
        _windowEnd = WINDOW_SIZE;
        RebuildVisibleItems();
        _groupMapNeedsUpdate = true;
    }

    private int _topSpacerHeight = 0;
    private int _bottomSpacerHeight = 0;

    private void RebuildVisibleItems()
    {
        var visible = new Dictionary<string, List<TimelineGridItem>>();
        var index = 0;
        var beforeCount = 0;
        var afterCount = 0;
        var inWindow = false;

        foreach (var kvp in _groupedGridItems)
        {
            var groupEnd = index + kvp.Value.Count;

            if (groupEnd <= _windowStart)
            {
                // Entire group is before the window
                beforeCount += kvp.Value.Count;
            }
            else if (index >= _windowEnd)
            {
                // Entire group is after the window
                afterCount += kvp.Value.Count;
            }
            else
            {
                // Group overlaps the window — include it fully
                visible[kvp.Key] = kvp.Value;
                inWindow = true;
            }
            index = groupEnd;
        }
        _visibleGroupedGridItems = visible;

        // Estimate spacer heights: ~200px row height, ~5 items per row
        _topSpacerHeight = (int)((double)beforeCount / 5 * 200);
        _bottomSpacerHeight = (int)((double)afterCount / 5 * 200);
    }

    /// <summary>
    /// Called from JS when the user scrolls near the bottom of the rendered content.
    /// Extends the window downward.
    /// </summary>
    [JSInvokable]
    public async Task LoadMoreItems()
    {
        if (_loadingMore) return;
        var totalItems = _groupedGridItems.Values.Sum(g => g.Count);
        if (_windowEnd >= totalItems) return;

        _loadingMore = true;
        _windowEnd = Math.Min(_windowEnd + LOAD_MORE_BATCH, totalItems);
        // Reclaim from the top if window exceeds max size
        if (_windowEnd - _windowStart > WINDOW_SIZE)
            _windowStart = _windowEnd - WINDOW_SIZE;
        RebuildVisibleItems();
        _masonryInitialized = false;
        StateHasChanged();
        await Task.Yield();
        _loadingMore = false;
    }

    /// <summary>
    /// Called from JS when the user scrolls near the top of the rendered content.
    /// Extends the window upward.
    /// </summary>
    [JSInvokable]
    public async Task LoadPreviousItems()
    {
        if (_loadingMore || _windowStart <= 0) return;

        _loadingMore = true;
        _windowStart = Math.Max(_windowStart - LOAD_MORE_BATCH, 0);
        // Reclaim from the bottom if window exceeds max size
        if (_windowEnd - _windowStart > WINDOW_SIZE)
            _windowEnd = _windowStart + WINDOW_SIZE;
        RebuildVisibleItems();
        _masonryInitialized = false;
        StateHasChanged();
        await Task.Yield();
        _loadingMore = false;
    }
    
    private string FormatDayHeader(DateTime date)
    {
        var today = DateTime.Today;
        var yesterday = today.AddDays(-1);
        
        if (date.Date == today)
            return "Hoy";
        else if (date.Date == yesterday)
            return "Ayer";
        else if (date.Year == today.Year)
            return date.ToString("dddd, d 'de' MMMM", new System.Globalization.CultureInfo("es-ES"));
        else
            return date.ToString("dddd, d 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"));
    }

    private void OpenAsset(Guid assetId)
    {
        Navigation.NavigateTo($"/asset/{assetId}");
    }

    private void OpenMemoryAsset(MemoryClickArgs args)
    {
        AssetListNavigationState.SetList(args.GroupAssets, albumId: null);
        if (args.Asset.SyncStatus == AssetSyncStatus.Synced)
        {
            Navigation.NavigateTo($"/asset/{args.Asset.Id}");
        }
        else
        {
            var encodedPath = System.Net.WebUtility.UrlEncode(args.Asset.FullPath);
            Navigation.NavigateTo($"/asset/{Guid.Empty}?path={encodedPath}");
        }
    }

    // ── Touch / long-press / drag-select ───────────────────────────────────
    private System.Threading.Timer? _longPressTimer;
    private bool _longPressHandled;
    private double _touchStartX;
    private double _touchStartY;

    private async Task OnGridItemTouchStart(TouchEventArgs e, TimelineGridItem item)
    {
        if (e.Touches.Length == 0) return;
        _touchStartX = e.Touches[0].ClientX;
        _touchStartY = e.Touches[0].ClientY;
        _longPressHandled = false;

        if (_selectionMode)
        {
            var selectMode = !IsAssetSelected(item.Id);
            _longPressHandled = true;
            ToggleAssetSelection(item.Id, selectMode);
            await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
            if (_objRef != null)
                await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, selectMode);
            return;
        }

        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _longPressHandled = true;
                ToggleAssetSelection(item.Id, true);
                await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
                if (_objRef != null)
                    await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, true);
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private void OnCardTouchMove(TouchEventArgs e)
    {
        // Solo necesario para cancelar el long press si el dedo se mueve antes de 500ms
        if (e.Touches.Length == 0 || _longPressTimer == null) return;
        var dx = e.Touches[0].ClientX - _touchStartX;
        var dy = e.Touches[0].ClientY - _touchStartY;
        if (Math.Sqrt(dx * dx + dy * dy) > 10)
        {
            _longPressTimer.Dispose();
            _longPressTimer = null;
        }
    }

    private void OnCardTouchEnd(TouchEventArgs e)
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
        // El arrastre JS se limpia solo (escucha touchend en el documento)
    }

    private async Task OnGridItemTouchStartFromView((TouchEventArgs e, TimelineGridItem item) args) =>
        await OnGridItemTouchStart(args.e, args.item);

    private void ToggleAssetSelectionFromView((Guid id, bool value) args) =>
        ToggleAssetSelection(args.id, args.value);

    private void OnDeviceLayoutChanged() => InvokeAsync(StateHasChanged);

    [JSInvokable]
    public void OnDragSelectAsset(string assetIdStr, bool select)
    {
        if (!Guid.TryParse(assetIdStr, out var assetId)) return;
        if (select == IsAssetSelected(assetId)) return; // ya está en el estado deseado
        ToggleAssetSelection(assetId, select);
        StateHasChanged();
    }
    // ───────────────────────────────────────────────────────────────────────

    private void OnGridItemClick(TimelineGridItem item)
    {
        if (_longPressHandled)
        {
            _longPressHandled = false;
            return;
        }

        if (_selectionMode)
        {
            ToggleAssetSelection(item.Id, !IsAssetSelected(item.Id));
            return;
        }

        OpenAsset(item.Id);
    }

    private void ToggleAssetSelection(Guid assetId, bool selected)
    {
        if (!_selectionMode)
        {
            _selectionMode = true;
        }

        if (selected)
        {
            _selectedAssetIds.Add(assetId);
        }
        else
        {
            _selectedAssetIds.Remove(assetId);
            if (_selectedAssetIds.Count == 0)
            {
                ExitSelectionMode();
                return;
            }
        }

        UpdateSelectionNavbar();
    }

    private bool IsAssetSelected(Guid assetId) => _selectedAssetIds.Contains(assetId);

    private void ExitSelectionMode()
    {
        _selectionMode = false;
        _selectedAssetIds.Clear();
        UpdateSelectionNavbar();
    }

    private void ToggleSelectAll()
    {
        var visibleItems = FilteredGridItems.ToList();
        if (_selectedAssetIds.Count == visibleItems.Count && visibleItems.Any())
        {
            _selectedAssetIds.Clear();
            UpdateSelectionNavbar();
            return;
        }

        _selectedAssetIds = visibleItems.Select(asset => asset.Id).ToHashSet();
        if (_selectedAssetIds.Any())
        {
            _selectionMode = true;
        }
        UpdateSelectionNavbar();
    }

    private async Task OpenShareSelectionDialog()
    {
        if (!_selectedAssetIds.Any()) return;

        var parameters = new DialogParameters<ShareSelectionDialog>
        {
            { x => x.AssetIds, new HashSet<Guid>(_selectedAssetIds) }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        var dialogRef = await DialogService.ShowAsync<ShareSelectionDialog>("Compartir selección", parameters, options);
        var result = await dialogRef.Result;

        if (result is { Canceled: false, Data: AlbumItem album })
        {
            ExitSelectionMode();
            var shareParams = new DialogParameters<ShareDialog>
            {
                { x => x.AlbumId, album.Id },
                { x => x.AlbumName, album.Name }
            };
            var shareOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<ShareDialog>($"Compartir álbum", shareParams, shareOptions);
        }
    }

    private void OpenAddToAlbumDialog()
    {
        if (!_selectedAssetIds.Any())
        {
            return;
        }

        _addToAlbumDialogVisible = true;
        _loadingAlbums = true;
        _ = LoadAlbumsForSelectionAsync();
    }

    private async Task LoadAlbumsForSelectionAsync()
    {
        try
        {
            _availableAlbums = await AlbumService.GetAlbumsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar álbumes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingAlbums = false;
            StateHasChanged();
        }
    }

    private void CloseAddToAlbumDialog()
    {
        _addToAlbumDialogVisible = false;
        _showCreateAlbum = false;
        _selectedAlbumId = null;
    }

    private async Task AddSelectionToAlbumAsync()
    {
        if (!_selectedAlbumId.HasValue || !_selectedAssetIds.Any())
        {
            return;
        }

        var failed = 0;
        var alreadyInAlbum = 0;
        var permissionDenied = false;
        foreach (var assetId in _selectedAssetIds.ToList())
        {
            try
            {
                var success = await AlbumService.AddAssetToAlbumAsync(_selectedAlbumId.Value, assetId);
                if (!success)
                {
                    failed++;
                }
            }
            catch (InvalidOperationException)
            {
                alreadyInAlbum++;
                failed++;
            }
            catch (UnauthorizedAccessException)
            {
                permissionDenied = true;
                failed++;
                break;
            }
            catch
            {
                failed++;
            }
        }

        CloseAddToAlbumDialog();
        ExitSelectionMode();

        if (permissionDenied)
        {
            Snackbar.Add("No tienes permisos suficientes para añadir elementos a este álbum.", Severity.Error);
            return;
        }

        if (failed == 0)
        {
            Snackbar.Add("Elementos añadidos al álbum", Severity.Success);
        }
        else
        {
            if (alreadyInAlbum > 0)
            {
                var message = alreadyInAlbum == 1
                    ? "El elemento ya está en el álbum."
                    : $"{alreadyInAlbum} elementos ya estaban en el álbum.";
                Snackbar.Add(message, Severity.Warning);
            }

            if (failed > alreadyInAlbum)
            {
                Snackbar.Add("Algunos elementos no se pudieron añadir", Severity.Warning);
            }
        }
    }

    private async Task CreateAlbumAndAddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newAlbumName))
        {
            Snackbar.Add("El nombre del álbum es obligatorio", Severity.Warning);
            return;
        }

        var album = await AlbumService.CreateAlbumAsync(_newAlbumName, _newAlbumDescription);
        if (album == null)
        {
            Snackbar.Add("Error al crear el álbum", Severity.Error);
            return;
        }

        _selectedAlbumId = album.Id;
        await AddSelectionToAlbumAsync();
    }

    private void ExitSelectionFromNavbar()
    {
        ExitSelectionMode();
    }

    private void OpenDeleteAssetsDialog()
    {
        _deleteAssetsDialogVisible = true;
    }

    private void CloseDeleteAssetsDialog()
    {
        _deleteAssetsDialogVisible = false;
    }

    private async Task DownloadSelectedAsync()
    {
        if (!_selectedAssetIds.Any()) return;

        _downloadingZip = true;
        UpdateSelectionNavbar();
        try
        {
            var bytes = await AssetService.DownloadZipAsync(_selectedAssetIds.ToList());
            if (bytes != null)
                await JS.InvokeVoidAsync("downloadFileFromBytes", "photonne_selection.zip", "application/zip", bytes);
            else
                Snackbar.Add("Error al generar el ZIP", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al descargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloadingZip = false;
            UpdateSelectionNavbar();
        }
    }

    private async Task ArchiveSelectedAsync()
    {
        if (!_selectedAssetIds.Any()) return;
        try
        {
            await AssetService.ArchiveAssetsAsync(new ArchiveAssetsRequest
            {
                AssetIds = _selectedAssetIds.ToList()
            });
            ExitSelectionMode();
            await LoadTimeline();
            Snackbar.Add("Assets archivados correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al archivar: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSelectedAsync()
    {
        if (!_selectedAssetIds.Any())
        {
            return;
        }

        try
        {
            var request = new DeleteAssetsRequest
            {
                AssetIds = _selectedAssetIds.ToList()
            };

            await AssetService.DeleteAssetsAsync(request);
            _deleteAssetsDialogVisible = false;
            Snackbar.Add($"{_selectedAssetIds.Count} elementos movidos a la papelera", Severity.Success);
            await LoadTimeline();
            ExitSelectionMode();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al eliminar archivos: {ex.Message}", Severity.Error);
        }
    }

    private void UpdateSelectionNavbar()
    {
        if (!_selectionMode)
        {
            LayoutService.ResetNavbar();
            return;
        }

        var selectedCount = _selectedAssetIds.Count;
        var visibleItems = FilteredGridItems.ToList();
        var allSelected = visibleItems.Any() && selectedCount == visibleItems.Count;
        var hasReadOnly = _selectedAssetIds.Any(id => visibleItems.Any(i => i.Id == id && i.IsReadOnly));

        LayoutService.SetCustomNavbar(
            @<text>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Edge="Edge.Start" OnClick="ExitSelectionFromNavbar" />
                <MudText Typo="Typo.h6" Class="ml-2">@($"{selectedCount} seleccionadas")</MudText>
                <MudSpacer />
                <MudTooltip Text="@(allSelected ? "Deseleccionar todo" : "Seleccionar todo")">
                    <MudIconButton Icon="@Icons.Material.Filled.SelectAll" Color="Color.Inherit" Disabled="@(!visibleItems.Any())" OnClick="ToggleSelectAll" />
                </MudTooltip>

                @* Botones individuales — solo desktop *@
                <span class="d-none d-md-flex">
                    <MudTooltip Text="Compartir selección">
                        <MudIconButton Icon="@Icons.Material.Outlined.Share" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenShareSelectionDialog" />
                    </MudTooltip>
                    <MudTooltip Text="Añadir a álbum">
                        <MudIconButton Icon="@Icons.Material.Outlined.AddToPhotos" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenAddToAlbumDialog" />
                    </MudTooltip>
                    <MudTooltip Text="Descargar">
                        <MudIconButton Icon="@Icons.Material.Outlined.Download" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any() || _downloadingZip)" OnClick="DownloadSelectedAsync" />
                    </MudTooltip>
                    @if (!hasReadOnly)
                    {
                        <MudTooltip Text="Archivar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Archive" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="ArchiveSelectedAsync" />
                        </MudTooltip>
                        <MudTooltip Text="Eliminar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenDeleteAssetsDialog" />
                        </MudTooltip>
                    }
                </span>

                @* Menú de desbordamiento — solo móvil *@
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Class="d-flex d-md-none">
                    <MudMenuItem Icon="@Icons.Material.Outlined.Share" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenShareSelectionDialog">
                        Compartir
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.AddToPhotos" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenAddToAlbumDialog">
                        Añadir a álbum
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Download" Disabled="@(!_selectedAssetIds.Any() || _downloadingZip)" OnClick="DownloadSelectedAsync">
                        Descargar
                    </MudMenuItem>
                    @if (!hasReadOnly)
                    {
                        <MudMenuItem Icon="@Icons.Material.Outlined.Archive" Disabled="@(!_selectedAssetIds.Any())" OnClick="ArchiveSelectedAsync">
                            Archivar
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Delete" IconColor="Color.Error" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenDeleteAssetsDialog">
                            <MudText Color="Color.Error">Eliminar</MudText>
                        </MudMenuItem>
                    }
                </MudMenu>
            </text>
        , keepDrawerVisible: true);
    }

    private string GetGroupId(string groupName)
    {
        return "group-" + groupName.Replace(" ", "-").ToLower();
    }
    
    private DateTime GetDayDateFromGroup(string groupKey)
    {
        if (DateTime.TryParseExact(groupKey, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var date))
        {
            return date;
        }
        return DateTime.MinValue;
    }

    private async Task ScrollToGroup(string groupName)
    {
        // Ensure items up to this group are rendered before scrolling
        await EnsureGroupRendered(groupName);
        _activeGroup = groupName;
        await JS.InvokeVoidAsync("scrollHelpers.scrollToElement", GetGroupId(groupName));
    }

    private async Task EnsureGroupRendered(string groupName)
    {
        if (_visibleGroupedGridItems.ContainsKey(groupName)) return;

        // Find the item index where this group starts
        var groupStart = 0;
        foreach (var kvp in _groupedGridItems)
        {
            if (kvp.Key == groupName) break;
            groupStart += kvp.Value.Count;
        }

        // Center the window on this group
        var half = WINDOW_SIZE / 2;
        _windowStart = Math.Max(0, groupStart - half);
        _windowEnd = _windowStart + WINDOW_SIZE;
        RebuildVisibleItems();
        _masonryInitialized = false;
        StateHasChanged();
        // Allow Blazor to render the new DOM before scrolling
        await Task.Delay(50);
    }

    private bool IsActiveYear(string year) 
    {
        if (string.IsNullOrEmpty(_activeGroup)) return false;
        return GetYearFromGroup(_activeGroup) == year;
    }

    private bool IsActive(string groupName) => _activeGroup == groupName;

    private string GetYearFromGroup(string groupKey)
    {
        // "2024-01-15" -> "2024"
        var date = GetDayDateFromGroup(groupKey);
        return date != DateTime.MinValue ? date.Year.ToString() : "";
    }

    public void Dispose()
    {
        _isDisposed = true;
        DeviceLayout.OnChanged -= OnDeviceLayoutChanged;
        _objRef?.Dispose();
        _longPressTimer?.Dispose();
        JS.InvokeVoidAsync("scrollHelpers.disableTimelineScroll");
        JS.InvokeVoidAsync("scrubberHelpers.cleanup");
        JS.InvokeVoidAsync("timelineVirtualScroll.cleanup");
        JS.InvokeVoidAsync("imageLoadManager.cleanup");
        LayoutService.ResetNavbar();
    }
}
