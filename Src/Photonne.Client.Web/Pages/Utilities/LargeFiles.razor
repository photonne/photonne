@page "/utilities/large-files"
@inject IAssetService AssetService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Archivos grandes - Photonne</PageTitle>

<div class="page-pad">

    <div class="d-flex align-center gap-3 mb-2 flex-wrap">
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Navigation.NavigateTo("/utilities"))">
            Utilidades
        </MudButton>
        <MudText Typo="Typo.h5">Archivos grandes</MudText>
    </div>

    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
        Los @_count elementos que más espacio ocupan en tu biblioteca.
    </MudText>

    <div class="d-flex align-center gap-3 mb-4 flex-wrap">
        <MudSelect T="int" Value="_count" ValueChanged="OnCountChanged" Label="Mostrar"
                   Variant="Variant.Outlined" Style="width:120px;" Dense="true">
            <MudSelectItem Value="25">25</MudSelectItem>
            <MudSelectItem Value="50">50</MudSelectItem>
            <MudSelectItem Value="100">100</MudSelectItem>
            <MudSelectItem Value="200">200</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadAsync" Disabled="_loading">
            Actualizar
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else if (_items.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No se encontraron archivos.</MudAlert>
    }
    else
    {
        <div class="lf-list">
            @for (int i = 0; i < _items.Count; i++)
            {
                var item   = _items[i];
                var rank   = i + 1;
                var href   = $"/asset/{item.Id}?returnTo=utilities/large-files";
                var isVideo = item.Type == "Video";

                <a class="lf-item" href="@href">
                    <div class="lf-thumb">
                        <img src="@item.ThumbnailUrl" alt="@item.FileName"
                             onerror="this.style.display='none'" />
                        <span class="lf-rank">#@rank</span>
                    </div>

                    <div class="lf-body">
                        <MudText Typo="Typo.body2" Class="lf-name">@item.FileName</MudText>
                        <div class="lf-meta">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                     Color="@(isVideo ? Color.Secondary : Color.Default)"
                                     Class="lf-type-chip">
                                @item.Type
                            </MudChip>
                            <MudText Typo="Typo.caption" Class="lf-size">@item.FileSizeFormatted</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary lf-date">@item.DisplayDate</MudText>
                        </div>
                    </div>

                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="lf-chevron mud-text-secondary" />
                </a>
            }
        </div>

        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-3 d-block">
            Total mostrado: @FormatBytes(_items.Sum(x => x.FileSize))
        </MudText>
    }

</div>

@code {
    private List<TimelineItem> _items = new();
    private bool _loading;
    private int _count = 50;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnCountChanged(int value)
    {
        _count = value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _items = await AssetService.GetLargeFilesAsync(_count);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1) { order++; len /= 1024; }
        return $"{len:0.##} {sizes[order]}";
    }
}
