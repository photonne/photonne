@page "/search"
@inject IAssetService AssetService
@inject IAlbumService AlbumService
@inject IPeopleService PeopleService
@inject LayoutService LayoutService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IAssetListNavigationState AssetListNavigationState
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject DeviceLayoutService DeviceLayout
@implements IDisposable

<PageTitle>Buscar - Photonne</PageTitle>

@if (_personFilters.Count > 0)
{
    <div class="ph-search-people-bar">
        <MudIcon Icon="@Icons.Material.Outlined.People" Size="Size.Small" Class="me-1" />
        <MudText Typo="Typo.caption" Class="me-2">Personas:</MudText>
        @foreach (var p in _personFilters)
        {
            <MudChip T="Guid"
                     Value="@p.Id"
                     Size="Size.Small"
                     Color="Color.Primary"
                     OnClose="@(() => RemovePersonFilter(p.Id))">
                @(string.IsNullOrWhiteSpace(p.Name) ? "Sin nombre" : p.Name)
            </MudChip>
        }
    </div>
}

@if (DeviceLayout.IsMobile)
{
    <SearchMobileView Loading="_loading"
                      Results="_results"
                      HasMore="_hasMore"
                      SearchTerm="@_searchTerm"
                      OnSearchTermChanged="HandleSearchTermChanged"
                      FromDate="_fromDate"
                      OnFromDateChanged="OnFromDateChanged"
                      ToDate="_toDate"
                      OnToDateChanged="OnToDateChanged"
                      FolderFilter="@_folderFilter"
                      OnFolderFilterChanged="HandleFolderFilterChanged"
                      FiltersExpanded="_filtersExpanded"
                      OnToggleFilters="ToggleFiltersExpanded"
                      ActiveFilterCount="ActiveFilterCount"
                      ResultCountLabel="@ResultCountLabel"
                      HasAnyFilter="HasAnyFilter"
                      SelectionMode="_selectionMode"
                      SelectedAssetIds="_selectedAssetIds"
                      OnToggleSelection="ToggleAssetSelection"
                      OnAssetTouchStart="OnCardTouchStart"
                      OnOpenAsset="OpenAsset" />
}
else
{
    <SearchDesktopView Loading="_loading"
                       Results="_results"
                       HasMore="_hasMore"
                       FromDate="_fromDate"
                       OnFromDateChanged="OnFromDateChanged"
                       ToDate="_toDate"
                       OnToDateChanged="OnToDateChanged"
                       FolderFilter="@_folderFilter"
                       OnFolderFilterChanged="HandleFolderFilterChanged"
                       ResultCountLabel="@ResultCountLabel"
                       HasAnyFilter="HasAnyFilter"
                       SelectionMode="_selectionMode"
                       SelectedAssetIds="_selectedAssetIds"
                       OnToggleSelection="ToggleAssetSelection"
                       OnAssetTouchStart="OnCardTouchStart"
                       OnOpenAsset="OpenAsset" />
}

<MudDialog @bind-Visible="_addToAlbumDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Añadir a álbum</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">@($"{_selectedAssetIds.Count} elementos seleccionados")</MudText>
        @if (!_showCreateAlbum)
        {
            @if (_loadingAlbums)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_availableAlbums.Any())
            {
                <MudRadioGroup T="Guid?" @bind-Value="_selectedAlbumId">
                    @foreach (var album in _availableAlbums)
                    {
                        <MudRadio T="Guid?" Value="@album.Id">
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.subtitle2">@album.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@album.AssetCount fotos</MudText>
                            </div>
                        </MudRadio>
                    }
                </MudRadioGroup>
            }
            else
            {
                <MudAlert Severity="Severity.Info">No hay álbumes disponibles.</MudAlert>
            }

            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Add"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = true)">
                Crear nuevo álbum
            </MudButton>
        }
        else
        {
            <MudTextField @bind-Value="_newAlbumName"
                          Label="Nombre del álbum"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="_newAlbumDescription"
                          Label="Descripción (opcional)"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Lines="3" />
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = false)">
                Volver a selección
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseAddToAlbumDialog">Cancelar</MudButton>
        @if (_showCreateAlbum)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAlbumAndAddAsync">
                Crear y añadir
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddSelectionToAlbumAsync"
                       Disabled="@(!_selectedAlbumId.HasValue)">
                Añadir
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteAssetsDialogVisible" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar archivos</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>¿Quieres mover @_selectedAssetIds.Count archivos a la papelera?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteAssetsDialog">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteSelectedAsync">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .ph-search-people-bar {
        display: flex; align-items: center; flex-wrap: wrap;
        gap: 4px;
        padding: 8px 12px;
        background: var(--mud-palette-surface);
        border-bottom: 1px solid var(--mud-palette-divider);
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "search")] public string? SearchTerm { get; set; }
    [SupplyParameterFromQuery(Name = "personId")] public Guid[]? PersonIdsParam { get; set; }

    private List<PersonSummary> _personFilters = new();
    private List<TimelineItem> _results = new();
    private bool _loading;
    private bool _hasMore;
    private string _searchTerm = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string _folderFilter = string.Empty;
    private bool _filtersExpanded;

    // Selection
    private bool _selectionMode;
    private HashSet<Guid> _selectedAssetIds = new();
    private bool _downloadingZip;
    private DotNetObjectReference<Search>? _objRef;
    private System.Threading.Timer? _longPressTimer;
    private bool _longPressHandled;
    private double _touchStartX;
    private double _touchStartY;

    // Dialog state
    private bool _addToAlbumDialogVisible;
    private bool _deleteAssetsDialogVisible;
    private List<AlbumItem> _availableAlbums = new();
    private bool _loadingAlbums;
    private Guid? _selectedAlbumId;
    private bool _showCreateAlbum;
    private string _newAlbumName = string.Empty;
    private string? _newAlbumDescription = string.Empty;

    private int ActiveFilterCount =>
        (_fromDate.HasValue ? 1 : 0) +
        (_toDate.HasValue ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_folderFilter) ? 1 : 0);

    private string ResultCountLabel => _hasMore
        ? $"Mostrando los primeros {_results.Count} resultados"
        : $"{_results.Count} {(_results.Count == 1 ? "resultado" : "resultados")}";

    private bool HasAnyFilter =>
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        _fromDate.HasValue ||
        _toDate.HasValue ||
        !string.IsNullOrWhiteSpace(_folderFilter) ||
        _personFilters.Count > 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await DeviceLayout.InitializeAsync();
            DeviceLayout.OnChanged += OnDeviceLayoutChanged;
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var newTerm = (SearchTerm ?? string.Empty).Trim();
        var termChanged = !string.Equals(_searchTerm, newTerm, StringComparison.Ordinal);

        var paramIds = (PersonIdsParam ?? Array.Empty<Guid>()).Distinct().ToList();
        var currentIds = _personFilters.Select(p => p.Id).ToHashSet();
        var personFilterChanged = paramIds.Count != currentIds.Count || paramIds.Any(id => !currentIds.Contains(id));

        if (termChanged) _searchTerm = newTerm;

        if (personFilterChanged)
        {
            // Resolve names for the chips. Cheap because /api/people is paginated;
            // for large libraries this could fetch by id, but a 200-person cap is fine.
            if (paramIds.Count == 0)
            {
                _personFilters = new();
            }
            else
            {
                try
                {
                    var page = await PeopleService.GetPeopleAsync(limit: 500, includeHidden: true);
                    _personFilters = page.Items.Where(p => paramIds.Contains(p.Id)).ToList();
                }
                catch
                {
                    _personFilters = paramIds.Select(id => new PersonSummary(id, null, null, 0, false, DateTime.UtcNow, DateTime.UtcNow)).ToList();
                }
            }
        }

        if (termChanged || personFilterChanged) await SearchAsync();
    }

    private async Task HandleSearchTermChanged(string term)
    {
        _searchTerm = term;
        var trimmed = _searchTerm?.Trim() ?? string.Empty;
        var targetUri = string.IsNullOrWhiteSpace(trimmed)
            ? "/search"
            : $"/search?search={Uri.EscapeDataString(trimmed)}";
        Navigation.NavigateTo(targetUri, replace: true);
        await SearchAsync();
    }

    private async Task OnFromDateChanged(DateTime? date)
    {
        _fromDate = date;
        await SearchAsync();
    }

    private async Task OnToDateChanged(DateTime? date)
    {
        _toDate = date;
        await SearchAsync();
    }

    private async Task HandleFolderFilterChanged(string filter)
    {
        _folderFilter = filter;
        await SearchAsync();
    }

    private void ToggleFiltersExpanded()
    {
        _filtersExpanded = !_filtersExpanded;
    }

    private async Task SearchAsync()
    {
        if (!HasAnyFilter)
        {
            _results = new();
            _hasMore = false;
            return;
        }

        try
        {
            _loading = true;
            StateHasChanged();

            var (items, hasMore) = await AssetService.SearchAssetsAsync(
                q: string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                from: _fromDate,
                to: _toDate,
                folder: string.IsNullOrWhiteSpace(_folderFilter) ? null : _folderFilter,
                personIds: _personFilters.Count == 0 ? null : _personFilters.Select(p => p.Id).ToList());

            _results = items;
            _hasMore = hasMore;
            if (_selectionMode) ExitSelectionMode();
            AssetListNavigationState.SetList(_results, "search");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al buscar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnCardTouchStart((TouchEventArgs e, TimelineItem asset) args)
    {
        var (e, asset) = args;
        if (e.Touches.Length == 0) return;
        _touchStartX = e.Touches[0].ClientX;
        _touchStartY = e.Touches[0].ClientY;
        _longPressHandled = false;

        if (_selectionMode)
        {
            var selectMode = !_selectedAssetIds.Contains(asset.Id);
            _longPressHandled = true;
            ToggleAssetSelection((asset.Id, selectMode));
            await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
            if (_objRef != null)
                await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, selectMode);
            return;
        }

        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _longPressHandled = true;
                ToggleAssetSelection((asset.Id, true));
                await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
                if (_objRef != null)
                    await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, true);
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    [JSInvokable]
    public void OnDragSelectAsset(string assetIdStr, bool select)
    {
        if (!Guid.TryParse(assetIdStr, out var assetId)) return;
        if (select == _selectedAssetIds.Contains(assetId)) return;
        ToggleAssetSelection((assetId, select));
        StateHasChanged();
    }

    private void ToggleAssetSelection((Guid id, bool selected) args)
    {
        if (!_selectionMode) _selectionMode = true;

        if (args.selected)
            _selectedAssetIds.Add(args.id);
        else
        {
            _selectedAssetIds.Remove(args.id);
            if (_selectedAssetIds.Count == 0)
            {
                ExitSelectionMode();
                return;
            }
        }
        UpdateSelectionNavbar();
    }

    private void ExitSelectionMode()
    {
        _selectionMode = false;
        _selectedAssetIds.Clear();
        LayoutService.ResetNavbar();
    }

    private void ToggleSelectAll()
    {
        if (_selectedAssetIds.Count == _results.Count && _results.Any())
        {
            _selectedAssetIds.Clear();
            UpdateSelectionNavbar();
            return;
        }

        _selectedAssetIds = _results.Select(a => a.Id).ToHashSet();
        if (_selectedAssetIds.Any())
        {
            _selectionMode = true;
        }
        UpdateSelectionNavbar();
    }

    private void UpdateSelectionNavbar()
    {
        if (!_selectionMode)
        {
            LayoutService.ResetNavbar();
            return;
        }

        var selectedCount = _selectedAssetIds.Count;
        var allSelected = _results.Any() && selectedCount == _results.Count;
        var hasReadOnly = _selectedAssetIds.Any(id => _results.Any(r => r.Id == id && r.IsReadOnly));

        LayoutService.SetCustomNavbar(
            @<text>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Edge="Edge.Start" OnClick="ExitSelectionMode" />
                <MudText Typo="Typo.h6" Class="ml-2">@($"{selectedCount} seleccionadas")</MudText>
                <MudSpacer />
                <MudTooltip Text="@(allSelected ? "Deseleccionar todo" : "Seleccionar todo")">
                    <MudIconButton Icon="@Icons.Material.Filled.SelectAll" Color="Color.Inherit" Disabled="@(!_results.Any())" OnClick="ToggleSelectAll" />
                </MudTooltip>

                @* Desktop: botones individuales *@
                <span class="d-none d-md-flex">
                    <MudTooltip Text="Compartir selección">
                        <MudIconButton Icon="@Icons.Material.Outlined.Share" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenShareSelectionDialog" />
                    </MudTooltip>
                    <MudTooltip Text="Añadir a álbum">
                        <MudIconButton Icon="@Icons.Material.Outlined.AddToPhotos" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenAddToAlbumDialog" />
                    </MudTooltip>
                    <MudTooltip Text="Descargar">
                        <MudIconButton Icon="@Icons.Material.Outlined.Download" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any() || _downloadingZip)" OnClick="DownloadSelectedAsync" />
                    </MudTooltip>
                    @if (!hasReadOnly)
                    {
                        <MudTooltip Text="Archivar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Archive" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="ArchiveSelectedAsync" />
                        </MudTooltip>
                        <MudTooltip Text="Eliminar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Inherit" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenDeleteAssetsDialog" />
                        </MudTooltip>
                    }
                </span>

                @* Mobile: menú de desbordamiento *@
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Class="d-flex d-md-none">
                    <MudMenuItem Icon="@Icons.Material.Outlined.Share" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenShareSelectionDialog">
                        Compartir
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.AddToPhotos" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenAddToAlbumDialog">
                        Añadir a álbum
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Download" Disabled="@(!_selectedAssetIds.Any() || _downloadingZip)" OnClick="DownloadSelectedAsync">
                        Descargar
                    </MudMenuItem>
                    @if (!hasReadOnly)
                    {
                        <MudMenuItem Icon="@Icons.Material.Outlined.Archive" Disabled="@(!_selectedAssetIds.Any())" OnClick="ArchiveSelectedAsync">
                            Archivar
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Delete" IconColor="Color.Error" Disabled="@(!_selectedAssetIds.Any())" OnClick="OpenDeleteAssetsDialog">
                            <MudText Color="Color.Error">Eliminar</MudText>
                        </MudMenuItem>
                    }
                </MudMenu>
            </text>
        );
    }

    // ── Share ────────────────────────────────────────────────────────────
    private async Task OpenShareSelectionDialog()
    {
        if (!_selectedAssetIds.Any()) return;

        var parameters = new DialogParameters<ShareSelectionDialog>
        {
            { x => x.AssetIds, new HashSet<Guid>(_selectedAssetIds) }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        var dialogRef = await DialogService.ShowAsync<ShareSelectionDialog>("Compartir selección", parameters, options);
        var result = await dialogRef.Result;

        if (result is { Canceled: false, Data: AlbumItem album })
        {
            ExitSelectionMode();
            var shareParams = new DialogParameters<ShareDialog>
            {
                { x => x.AlbumId, album.Id },
                { x => x.AlbumName, album.Name }
            };
            var shareOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<ShareDialog>("Compartir álbum", shareParams, shareOptions);
        }
    }

    // ── Add to album ─────────────────────────────────────────────────────
    private void OpenAddToAlbumDialog()
    {
        if (!_selectedAssetIds.Any()) return;

        _addToAlbumDialogVisible = true;
        _loadingAlbums = true;
        _ = LoadAlbumsForSelectionAsync();
    }

    private async Task LoadAlbumsForSelectionAsync()
    {
        try
        {
            _availableAlbums = await AlbumService.GetAlbumsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar álbumes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingAlbums = false;
            StateHasChanged();
        }
    }

    private void CloseAddToAlbumDialog()
    {
        _addToAlbumDialogVisible = false;
        _showCreateAlbum = false;
        _selectedAlbumId = null;
    }

    private async Task AddSelectionToAlbumAsync()
    {
        if (!_selectedAlbumId.HasValue || !_selectedAssetIds.Any()) return;

        var failed = 0;
        var alreadyInAlbum = 0;
        var permissionDenied = false;
        foreach (var assetId in _selectedAssetIds.ToList())
        {
            try
            {
                var success = await AlbumService.AddAssetToAlbumAsync(_selectedAlbumId.Value, assetId);
                if (!success) failed++;
            }
            catch (InvalidOperationException)
            {
                alreadyInAlbum++;
                failed++;
            }
            catch (UnauthorizedAccessException)
            {
                permissionDenied = true;
                failed++;
                break;
            }
            catch
            {
                failed++;
            }
        }

        CloseAddToAlbumDialog();
        ExitSelectionMode();

        if (permissionDenied)
        {
            Snackbar.Add("No tienes permisos suficientes para añadir elementos a este álbum.", Severity.Error);
            return;
        }

        if (failed == 0)
        {
            Snackbar.Add("Elementos añadidos al álbum", Severity.Success);
        }
        else
        {
            if (alreadyInAlbum > 0)
            {
                var message = alreadyInAlbum == 1
                    ? "El elemento ya está en el álbum."
                    : $"{alreadyInAlbum} elementos ya estaban en el álbum.";
                Snackbar.Add(message, Severity.Warning);
            }

            if (failed > alreadyInAlbum)
            {
                Snackbar.Add("Algunos elementos no se pudieron añadir", Severity.Warning);
            }
        }
    }

    private async Task CreateAlbumAndAddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newAlbumName))
        {
            Snackbar.Add("El nombre del álbum es obligatorio", Severity.Warning);
            return;
        }

        var album = await AlbumService.CreateAlbumAsync(_newAlbumName, _newAlbumDescription);
        if (album == null)
        {
            Snackbar.Add("Error al crear el álbum", Severity.Error);
            return;
        }

        _selectedAlbumId = album.Id;
        await AddSelectionToAlbumAsync();
    }

    // ── Archive ──────────────────────────────────────────────────────────
    private async Task ArchiveSelectedAsync()
    {
        if (!_selectedAssetIds.Any()) return;
        try
        {
            await AssetService.ArchiveAssetsAsync(new ArchiveAssetsRequest
            {
                AssetIds = _selectedAssetIds.ToList()
            });
            var idSet = new HashSet<Guid>(_selectedAssetIds);
            _results.RemoveAll(r => idSet.Contains(r.Id));
            AssetListNavigationState.SetList(_results, "search");
            ExitSelectionMode();
            Snackbar.Add("Assets archivados correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al archivar: {ex.Message}", Severity.Error);
        }
    }

    // ── Delete ───────────────────────────────────────────────────────────
    private void OpenDeleteAssetsDialog()
    {
        _deleteAssetsDialogVisible = true;
    }

    private void CloseDeleteAssetsDialog()
    {
        _deleteAssetsDialogVisible = false;
    }

    private async Task DeleteSelectedAsync()
    {
        if (!_selectedAssetIds.Any()) return;

        try
        {
            var count = _selectedAssetIds.Count;
            await AssetService.DeleteAssetsAsync(new DeleteAssetsRequest
            {
                AssetIds = _selectedAssetIds.ToList()
            });
            var idSet = new HashSet<Guid>(_selectedAssetIds);
            _results.RemoveAll(r => idSet.Contains(r.Id));
            AssetListNavigationState.SetList(_results, "search");
            _deleteAssetsDialogVisible = false;
            ExitSelectionMode();
            Snackbar.Add($"{count} elementos movidos a la papelera", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al eliminar archivos: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadSelectedAsync()
    {
        if (!_selectedAssetIds.Any()) return;

        _downloadingZip = true;
        UpdateSelectionNavbar();
        try
        {
            var bytes = await AssetService.DownloadZipAsync(_selectedAssetIds.ToList());
            if (bytes != null)
                await JS.InvokeVoidAsync("downloadFileFromBytes", "photonne_selection.zip", "application/zip", bytes);
            else
                Snackbar.Add("Error al generar el ZIP", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al descargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloadingZip = false;
            UpdateSelectionNavbar();
        }
    }

    private async Task OpenAsset(TimelineItem asset)
    {
        if (_longPressHandled)
        {
            _longPressHandled = false;
            return;
        }

        if (_selectionMode)
        {
            ToggleAssetSelection((asset.Id, !_selectedAssetIds.Contains(asset.Id)));
            return;
        }

        await JS.InvokeVoidAsync("assetTransition.saveOriginByAssetId", asset.Id.ToString());
        if (asset.SyncStatus == AssetSyncStatus.Synced)
            Navigation.NavigateTo($"/asset/{asset.Id}?returnTo=search");
        else
        {
            var encodedPath = System.Net.WebUtility.UrlEncode(asset.FullPath);
            Navigation.NavigateTo($"/asset/{Guid.Empty}?path={encodedPath}&returnTo=search");
        }
    }

    private void OnDeviceLayoutChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _longPressTimer?.Dispose();
        _objRef?.Dispose();
        LayoutService.ResetNavbar();
        DeviceLayout.OnChanged -= OnDeviceLayoutChanged;
    }

    private void RemovePersonFilter(Guid personId)
    {
        var remaining = _personFilters.Where(p => p.Id != personId).Select(p => p.Id).ToList();
        var query = new List<string>();
        if (!string.IsNullOrWhiteSpace(_searchTerm))
            query.Add($"search={Uri.EscapeDataString(_searchTerm)}");
        foreach (var pid in remaining) query.Add($"personId={pid}");
        var url = query.Count == 0 ? "/search" : "/search?" + string.Join("&", query);
        Navigation.NavigateTo(url, replace: true);
    }
}
