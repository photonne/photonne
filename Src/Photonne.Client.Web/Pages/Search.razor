    private async Task HandleSearchTermChanged(string term)
    {
        _searchTerm = term;
        var trimmed = _searchTerm?.Trim() ?? string.Empty;
        var targetUri = string.IsNullOrWhiteSpace(trimmed)
            ? "/search"
            : $"/search?search={Uri.EscapeDataString(trimmed)}";
        Navigation.NavigateTo(targetUri, replace: true);
        // Kick off the suggestion refresh ourselves: OnParametersSetAsync
        // would see _searchTerm already in sync with the new SearchTerm
        // parameter (we just set it above) and short-circuit termChanged.
        _ = RefreshSuggestionsAsync(_searchTerm);
        await SearchAsync();
    }

