    // ── Share ────────────────────────────────────────────────────────────
    private async Task OpenShareSelectionDialog()
    {
        if (!_selectedAssetIds.Any()) return;

        var parameters = new DialogParameters<ShareSelectionDialog>
        {
            { x => x.AssetIds, new HashSet<Guid>(_selectedAssetIds) }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        var dialogRef = await DialogService.ShowAsync<ShareSelectionDialog>("Compartir selección", parameters, options);
        var result = await dialogRef.Result;

        if (result is { Canceled: false, Data: AlbumItem album })
        {
            ExitSelectionMode();
            var shareParams = new DialogParameters<ShareDialog>
            {
                { x => x.AlbumId, album.Id },
                { x => x.AlbumName, album.Name }
            };
            var shareOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<ShareDialog>("Compartir álbum", shareParams, shareOptions);
        }
    }

