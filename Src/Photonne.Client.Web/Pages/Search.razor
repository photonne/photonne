    private string BuildSearchUrl(IEnumerable<Guid> personIds) =>
        BuildSearchUrl(personIds, _objectLabels, _sceneLabels);

    private string BuildSearchUrl(IEnumerable<Guid> personIds, IEnumerable<string> objectLabels) =>
        BuildSearchUrl(personIds, objectLabels, _sceneLabels);

    private string BuildSearchUrl(IEnumerable<Guid> personIds, IEnumerable<string> objectLabels, IEnumerable<string> sceneLabels)
    {
        var query = new List<string>();
        if (!string.IsNullOrWhiteSpace(_searchTerm))
            query.Add($"search={Uri.EscapeDataString(_searchTerm)}");
        foreach (var pid in personIds) query.Add($"personId={pid}");
        foreach (var label in objectLabels)
        {
            if (string.IsNullOrWhiteSpace(label)) continue;
            query.Add($"objectLabel={Uri.EscapeDataString(label)}");
        }
        foreach (var label in sceneLabels)
        {
            if (string.IsNullOrWhiteSpace(label)) continue;
            query.Add($"sceneLabel={Uri.EscapeDataString(label)}");
        }
        return query.Count == 0 ? "/search" : "/search?" + string.Join("&", query);
    }

    // ─── Unified filter picker ────────────────────────────────────────────

    private void OpenFilterPicker()
    {
        // Refresh pools on every open so newly created persons / freshly
        // detected labels show up without a page reload.
        _peoplePool = null;
        _filterPickerVersion++;
        _filterPickerQuery = string.Empty;
        _filterPickerPeople = new();
        _filterPickerLabels = new();
        _filterPickerScenes = new();
        _filterPickerOpen = true;
        // Kick off the initial "empty query" load so the user sees the top
        // people + labels immediately, no typing required.
        _ = RefreshFilterPickerAsync();
    }

    private void CloseFilterPicker()
    {
        _filterPickerOpen = false;
        _filterPickerCts?.Cancel();
        _filterPickerCts?.Dispose();
        _filterPickerCts = null;
    }

    private void OnFilterPickerQueryChanged()
    {
        _ = RefreshFilterPickerAsync();
    }

    private async Task RefreshFilterPickerAsync()
    {
        _filterPickerCts?.Cancel();
        _filterPickerCts?.Dispose();
        _filterPickerCts = new CancellationTokenSource();
        var ct = _filterPickerCts.Token;

        var query = (_filterPickerQuery ?? string.Empty).Trim();

        try
        {
            _filterPickerLoading = true;
            StateHasChanged();

            // People are loaded once and filtered locally because the people
            // endpoint is paginated (no ILIKE) and 500 rows fit comfortably.
            // Labels use the server-side ILIKE so we don't pull the full
            // catalog when the user is typing.
            _peoplePool ??= (await PeopleService.GetPeopleAsync(limit: 500, includeHidden: false, ct: ct)).Items;
            var labelsTask = string.IsNullOrEmpty(query)
                ? ObjectsService.GetLabelsAsync(limit: 12, ct: ct)
                : ObjectsService.GetLabelsAsync(search: query, limit: 12, ct: ct);
            var scenesTask = string.IsNullOrEmpty(query)
                ? ScenesService.GetLabelsAsync(limit: 12, ct: ct)
                : ScenesService.GetLabelsAsync(search: query, limit: 12, ct: ct);

            var alreadyPickedPeople = _personFilters.Select(p => p.Id).ToHashSet();
            var people = _peoplePool
                .Where(p => !string.IsNullOrWhiteSpace(p.Name) && !alreadyPickedPeople.Contains(p.Id));
            if (!string.IsNullOrEmpty(query))
            {
                people = people.Where(p => p.Name!.Contains(query, StringComparison.OrdinalIgnoreCase));
            }
            var topPeople = people.OrderByDescending(p => p.FaceCount).Take(8).ToList();

            var labels = await labelsTask;
            var alreadyPickedLabels = _objectLabels.ToHashSet(StringComparer.OrdinalIgnoreCase);
            var topLabels = labels.Where(l => !alreadyPickedLabels.Contains(l.Label)).Take(12).ToList();

            var scenes = await scenesTask;
            var alreadyPickedScenes = _sceneLabels.ToHashSet(StringComparer.OrdinalIgnoreCase);
            var topScenes = scenes.Where(s => !alreadyPickedScenes.Contains(s.Label)).Take(12).ToList();

            if (ct.IsCancellationRequested) return;

            _filterPickerPeople = topPeople;
            _filterPickerLabels = topLabels;
            _filterPickerScenes = topScenes;
        }
        catch (OperationCanceledException) { /* superseded — ignore */ }
        catch
        {
            _filterPickerPeople = new();
            _filterPickerLabels = new();
            _filterPickerScenes = new();
        }
        finally
        {
            if (!ct.IsCancellationRequested)
            {
                _filterPickerLoading = false;
                StateHasChanged();
            }
        }
    }

    private void PickPerson(PersonSummary person)
    {
        var ids = _personFilters.Select(p => p.Id).Append(person.Id).Distinct().ToList();
        CloseFilterPicker();
        Navigation.NavigateTo(BuildSearchUrl(ids, _objectLabels, _sceneLabels), replace: true);
    }

    private void PickObject(string label)
    {
        var labels = _objectLabels.Append(label).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        CloseFilterPicker();
        Navigation.NavigateTo(BuildSearchUrl(_personFilters.Select(p => p.Id), labels, _sceneLabels), replace: true);
    }

    private void PickScene(string label)
    {
        var scenes = _sceneLabels.Append(label).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        CloseFilterPicker();
        Navigation.NavigateTo(BuildSearchUrl(_personFilters.Select(p => p.Id), _objectLabels, scenes), replace: true);
    }

    private static string Capitalize(string label)
    {
        if (string.IsNullOrEmpty(label)) return label;
        return char.ToUpperInvariant(label[0]) + label[1..];
    }
