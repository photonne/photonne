@page "/search"
@inject IAssetService AssetService
@inject IAlbumService AlbumService
@inject IPeopleService PeopleService
@inject IObjectsService ObjectsService
@inject IScenesService ScenesService
@inject LayoutService LayoutService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IAssetListNavigationState AssetListNavigationState
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject DeviceLayoutService DeviceLayout
@implements IDisposable

<PageTitle>Buscar - Photonne</PageTitle>

@* Single horizontal-scroll rail. Mobile-first: collapses sugerencias +
   personas + objetos into one row regardless of how many filters are
   active. Order: suggestion chips (when typing) → people chips → object
   chips → "+ Filtrar" entry point. *@
<div class="ph-search-rail">
    @if (HasTermSuggestions)
    {
        @foreach (var person in _suggestedPeople)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Primary"
                     Variant="Variant.Outlined"
                     Icon="@Icons.Material.Outlined.Person"
                     OnClick="@(() => ApplyPersonSuggestion(person.Id))">
                @(string.IsNullOrWhiteSpace(person.Name) ? "Sin nombre" : person.Name)
            </MudChip>
        }
        @foreach (var label in _suggestedLabels)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Secondary"
                     Variant="Variant.Outlined"
                     Icon="@Icons.Material.Outlined.Category"
                     OnClick="@(() => ApplyObjectSuggestion(label.Label))">
                @Capitalize(label.Label) <span class="ph-rail__count">@label.AssetCount</span>
            </MudChip>
        }
        @foreach (var scene in _suggestedScenes)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Tertiary"
                     Variant="Variant.Outlined"
                     Icon="@Icons.Material.Outlined.Landscape"
                     OnClick="@(() => ApplySceneSuggestion(scene.Label))">
                @Capitalize(scene.Label) <span class="ph-rail__count">@scene.AssetCount</span>
            </MudChip>
        }
        @if (_personFilters.Count > 0 || _objectLabels.Count > 0 || _sceneLabels.Count > 0)
        {
            <span class="ph-rail__divider" aria-hidden="true"></span>
        }
    }

    @foreach (var p in _personFilters)
    {
        <MudChip T="Guid"
                 Value="@p.Id"
                 Size="Size.Small"
                 Color="Color.Primary"
                 Icon="@Icons.Material.Filled.Person"
                 OnClose="@(() => RemovePersonFilter(p.Id))">
            @(string.IsNullOrWhiteSpace(p.Name) ? "Sin nombre" : p.Name)
        </MudChip>
    }
    @foreach (var label in _objectLabels)
    {
        <MudChip T="string"
                 Value="@label"
                 Size="Size.Small"
                 Color="Color.Secondary"
                 Icon="@Icons.Material.Filled.Category"
                 OnClose="@(() => RemoveObjectLabel(label))">
            @Capitalize(label)
        </MudChip>
    }
    @foreach (var label in _sceneLabels)
    {
        <MudChip T="string"
                 Value="@label"
                 Size="Size.Small"
                 Color="Color.Tertiary"
                 Icon="@Icons.Material.Filled.Landscape"
                 OnClose="@(() => RemoveSceneLabel(label))">
            @Capitalize(label)
        </MudChip>
    }

    <MudChip T="string"
             Size="Size.Small"
             Variant="Variant.Outlined"
             Icon="@Icons.Material.Filled.Add"
             OnClick="OpenFilterPicker">
        Filtrar
    </MudChip>

    @* Semantic-search toggle: when on, the free-text term is sent to
       /api/assets/search/semantic (CLIP) instead of the keyword endpoint.
       Useful for natural-language queries in any language ("día de playa
       con bañador rojo"). The other filter chips are ignored in that
       mode — semantic search is whole-image, not faceted. *@
    <MudChip T="string"
             Size="Size.Small"
             Variant="@(_semanticMode ? Variant.Filled : Variant.Outlined)"
             Color="@(_semanticMode ? Color.Info : Color.Default)"
             Icon="@Icons.Material.Filled.AutoAwesome"
             OnClick="ToggleSemanticMode">
        Búsqueda inteligente
    </MudChip>
</div>

@* Unified filter picker — one search field, two result sections (Personas
   and Objetos). Replaces the previous people-only and objects-only sheets. *@
@if (_filterPickerOpen)
{
    <div class="ph-people-picker__backdrop" @onclick="CloseFilterPicker"></div>
    <MudDrawer @key="_filterPickerVersion"
               Open="true"
               Anchor="Anchor.Bottom"
               Elevation="6"
               Variant="DrawerVariant.Temporary"
               Class="ph-bottom-sheet ph-people-picker ph-filter-picker">
        <div class="ph-sheet-handle"></div>
        <div class="d-flex justify-space-between align-center px-4 pt-2 pb-1">
            <MudText Typo="Typo.h6">Añadir filtro</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseFilterPicker" />
        </div>
        <MudDivider />
        <div class="px-4 pt-3 pb-2">
            <MudTextField @bind-Value="_filterPickerQuery"
                          @bind-Value:after="OnFilterPickerQueryChanged"
                          Placeholder="Persona, objeto o escena…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          DebounceInterval="200"
                          Clearable="true"
                          AutoFocus="true" />
        </div>

        <div class="ph-filter-picker__results">
            @if (_filterPickerLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
            }

            @if (_filterPickerPeople.Count > 0)
            {
                <MudText Typo="Typo.overline" Class="ph-filter-picker__section-title">Personas</MudText>
                @foreach (var p in _filterPickerPeople)
                {
                    <button type="button"
                            class="ph-filter-picker__row"
                            @onclick="@(() => PickPerson(p))">
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" Class="me-2" Color="Color.Primary" />
                        <span class="flex-grow-1">@(string.IsNullOrWhiteSpace(p.Name) ? "Sin nombre" : p.Name)</span>
                        <span class="ph-filter-picker__row-count">@p.FaceCount</span>
                    </button>
                }
            }

            @if (_filterPickerLabels.Count > 0)
            {
                <MudText Typo="Typo.overline" Class="ph-filter-picker__section-title">Objetos</MudText>
                @foreach (var l in _filterPickerLabels)
                {
                    <button type="button"
                            class="ph-filter-picker__row"
                            @onclick="@(() => PickObject(l.Label))">
                        <MudIcon Icon="@Icons.Material.Outlined.Category" Size="Size.Small" Class="me-2" Color="Color.Secondary" />
                        <span class="flex-grow-1">@Capitalize(l.Label)</span>
                        <span class="ph-filter-picker__row-count">@l.AssetCount</span>
                    </button>
                }
            }

            @if (_filterPickerScenes.Count > 0)
            {
                <MudText Typo="Typo.overline" Class="ph-filter-picker__section-title">Escenas</MudText>
                @foreach (var s in _filterPickerScenes)
                {
                    <button type="button"
                            class="ph-filter-picker__row"
                            @onclick="@(() => PickScene(s.Label))">
                        <MudIcon Icon="@Icons.Material.Outlined.Landscape" Size="Size.Small" Class="me-2" Color="Color.Tertiary" />
                        <span class="flex-grow-1">@Capitalize(s.Label)</span>
                        <span class="ph-filter-picker__row-count">@s.AssetCount</span>
                    </button>
                }
            }

            @if (!_filterPickerLoading && _filterPickerPeople.Count == 0 && _filterPickerLabels.Count == 0 && _filterPickerScenes.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="ph-filter-picker__empty">
                    @(string.IsNullOrWhiteSpace(_filterPickerQuery)
                        ? "Empieza a escribir un nombre, objeto o escena…"
                        : $"Sin resultados para «{_filterPickerQuery}».")
                </MudText>
            }
        </div>
    </MudDrawer>
}

@if (DeviceLayout.IsMobile)
{
    <SearchMobileView Loading="_loading"
                      Results="_results"
                      HasMore="_hasMore"
                      SearchTerm="@_searchTerm"
                      OnSearchTermChanged="HandleSearchTermChanged"
                      FromDate="_fromDate"
                      OnFromDateChanged="OnFromDateChanged"
                      ToDate="_toDate"
                      OnToDateChanged="OnToDateChanged"
                      FolderFilter="@_folderFilter"
                      OnFolderFilterChanged="HandleFolderFilterChanged"
                      FiltersExpanded="_filtersExpanded"
                      OnToggleFilters="ToggleFiltersExpanded"
                      ActiveFilterCount="ActiveFilterCount"
                      ResultCountLabel="@ResultCountLabel"
                      HasAnyFilter="HasAnyFilter"
                      SelectionMode="_selectionMode"
                      SelectedAssetIds="_selectedAssetIds"
                      OnToggleSelection="ToggleAssetSelection"
                      OnAssetTouchStart="OnCardTouchStart"
                      OnOpenAsset="OpenAsset" />
}
else
{
    <SearchDesktopView Loading="_loading"
                       Results="_results"
                       HasMore="_hasMore"
                       FromDate="_fromDate"
                       OnFromDateChanged="OnFromDateChanged"
                       ToDate="_toDate"
                       OnToDateChanged="OnToDateChanged"
                       FolderFilter="@_folderFilter"
                       OnFolderFilterChanged="HandleFolderFilterChanged"
                       ResultCountLabel="@ResultCountLabel"
                       HasAnyFilter="HasAnyFilter"
                       SelectionMode="_selectionMode"
                       SelectedAssetIds="_selectedAssetIds"
                       OnToggleSelection="ToggleAssetSelection"
                       OnAssetTouchStart="OnCardTouchStart"
                       OnOpenAsset="OpenAsset" />
}

<MudDialog @bind-Visible="_addToAlbumDialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Añadir a álbum</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">@($"{_selectedAssetIds.Count} elementos seleccionados")</MudText>
        @if (!_showCreateAlbum)
        {
            @if (_loadingAlbums)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_availableAlbums.Any())
            {
                <MudRadioGroup T="Guid?" @bind-Value="_selectedAlbumId">
                    @foreach (var album in _availableAlbums)
                    {
                        <MudRadio T="Guid?" Value="@album.Id">
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.subtitle2">@album.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@album.AssetCount fotos</MudText>
                            </div>
                        </MudRadio>
                    }
                </MudRadioGroup>
            }
            else
            {
                <MudAlert Severity="Severity.Info">No hay álbumes disponibles.</MudAlert>
            }

            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Add"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = true)">
                Crear nuevo álbum
            </MudButton>
        }
        else
        {
            <MudTextField @bind-Value="_newAlbumName"
                          Label="Nombre del álbum"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="_newAlbumDescription"
                          Label="Descripción (opcional)"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Lines="3" />
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.ArrowBack"
                       Class="mt-3"
                       OnClick="@(() => _showCreateAlbum = false)">
                Volver a selección
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseAddToAlbumDialog">Cancelar</MudButton>
        @if (_showCreateAlbum)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateAlbumAndAddAsync">
                Crear y añadir
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddSelectionToAlbumAsync"
                       Disabled="@(!_selectedAlbumId.HasValue)">
                Añadir
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteAssetsDialogVisible" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar archivos</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>¿Quieres mover @_selectedAssetIds.Count archivos a la papelera?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteAssetsDialog">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteSelectedAsync">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

<style>
    /* Single horizontal-scroll rail. flex-wrap:nowrap keeps it to one row even
       with many chips; users swipe to access the rest. Mobile-first: trades
       wrapping (which on a 360px screen makes 3 chips eat 3 rows) for a
       horizontal swipe that costs zero vertical space. */
    .ph-search-rail {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: var(--mud-palette-surface);
        border-bottom: 1px solid var(--mud-palette-divider);
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
    }
    .ph-search-rail > * {
        flex: 0 0 auto;
    }
    .ph-search-rail::-webkit-scrollbar {
        height: 4px;
    }
    .ph-search-rail::-webkit-scrollbar-thumb {
        background: var(--mud-palette-action-disabled);
        border-radius: 2px;
    }
    /* Vertical bar between the suggestion segment and the active-filter
       segment so the rail still reads as two semantic groups even without
       row labels. */
    .ph-rail__divider {
        width: 1px;
        align-self: stretch;
        margin: 4px 2px;
        background: var(--mud-palette-divider);
    }
    .ph-rail__count {
        opacity: 0.7;
        font-size: 0.85em;
        margin-left: 4px;
        font-variant-numeric: tabular-nums;
    }

    /* Same z-index strategy as the face-overlay / merge / cover sheets so the
       picker sits above the search results layer (and above the chip bar). */
    .ph-people-picker.mud-drawer,
    aside.ph-people-picker,
    .ph-people-picker {
        z-index: 1400 !important;
    }
    .ph-people-picker__backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        z-index: 1390;
        animation: ph-people-picker-fade-in 0.18s ease;
    }
    @@keyframes ph-people-picker-fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    /* Filter picker: scrollable result list under a sticky search field. Cap
       the height so it never eats the entire viewport on tall mobiles. */
    .ph-filter-picker__results {
        max-height: 50vh;
        overflow-y: auto;
        padding: 0 8px 16px 8px;
    }
    .ph-filter-picker__section-title {
        display: block;
        padding: 8px 8px 2px 8px;
        color: var(--mud-palette-text-secondary);
        letter-spacing: 0.04em;
    }
    .ph-filter-picker__row {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 10px 8px;
        background: transparent;
        border: 0;
        border-radius: 6px;
        cursor: pointer;
        text-align: left;
        font-size: 0.95rem;
        color: inherit;
    }
    .ph-filter-picker__row:hover,
    .ph-filter-picker__row:focus-visible {
        background: var(--mud-palette-action-default-hover);
        outline: none;
    }
    .ph-filter-picker__row-count {
        opacity: 0.65;
        font-size: 0.85em;
        font-variant-numeric: tabular-nums;
        margin-left: 8px;
    }
    .ph-filter-picker__empty {
        text-align: center;
        padding: 24px 16px;
        color: var(--mud-palette-text-secondary);
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "search")] public string? SearchTerm { get; set; }
    [SupplyParameterFromQuery(Name = "personId")] public Guid[]? PersonIdsParam { get; set; }
    [SupplyParameterFromQuery(Name = "objectLabel")] public string[]? ObjectLabelsParam { get; set; }
    [SupplyParameterFromQuery(Name = "sceneLabel")] public string[]? SceneLabelsParam { get; set; }

    private List<PersonSummary> _personFilters = new();
    private List<string> _objectLabels = new();
    private List<string> _sceneLabels = new();
    // Cached pool used by the inline suggestion fetcher. Populated lazily on
    // first match attempt; nulled out whenever a new chip is added so the
    // next typing pass sees fresh data.
    private List<PersonSummary>? _peoplePool;

    // Unified filter picker (personas + objetos in one bottom sheet).
    private bool _filterPickerOpen;
    private int _filterPickerVersion;
    private string _filterPickerQuery = string.Empty;
    private bool _filterPickerLoading;
    private List<PersonSummary> _filterPickerPeople = new();
    private List<ObjectLabelItem> _filterPickerLabels = new();
    private List<SceneLabelItem> _filterPickerScenes = new();
    private CancellationTokenSource? _filterPickerCts;

    // Inline term-to-filter suggestions: ranked matches of the current free-text
    // query against persons and object labels. Refreshed (debounced) every time
    // _searchTerm changes; cleared once the term is empty.
    private List<PersonSummary> _suggestedPeople = new();
    private List<ObjectLabelItem> _suggestedLabels = new();
    private List<SceneLabelItem> _suggestedScenes = new();
    private CancellationTokenSource? _suggestCts;
    private bool HasTermSuggestions =>
        !string.IsNullOrWhiteSpace(_searchTerm)
        && (_suggestedPeople.Count > 0 || _suggestedLabels.Count > 0 || _suggestedScenes.Count > 0);
    private List<TimelineItem> _results = new();
    private bool _loading;
    private bool _hasMore;
    // CLIP semantic search is the default path for free-text queries — it
    // handles natural-language and any language M-CLIP supports. The user can
    // toggle off via the "Búsqueda inteligente" chip to force the keyword
    // endpoint (filename / OCR / exact label match). With no free-text query
    // SearchAsync transparently falls back to keyword regardless of this flag,
    // so chip-only filtering (person/object/scene) keeps working.
    private bool _semanticMode = true;
    private string _searchTerm = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string _folderFilter = string.Empty;
    private bool _filtersExpanded;

    // Selection
    private bool _selectionMode;
    private HashSet<Guid> _selectedAssetIds = new();
    private bool _downloadingZip;
    private DotNetObjectReference<Search>? _objRef;
    private System.Threading.Timer? _longPressTimer;
    private bool _longPressHandled;
    private double _touchStartX;
    private double _touchStartY;

    // Dialog state
    private bool _addToAlbumDialogVisible;
    private bool _deleteAssetsDialogVisible;
    private List<AlbumItem> _availableAlbums = new();
    private bool _loadingAlbums;
    private Guid? _selectedAlbumId;
    private bool _showCreateAlbum;
    private string _newAlbumName = string.Empty;
    private string? _newAlbumDescription = string.Empty;

    private int ActiveFilterCount =>
        (_fromDate.HasValue ? 1 : 0) +
        (_toDate.HasValue ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_folderFilter) ? 1 : 0);

    private string ResultCountLabel => _hasMore
        ? $"Mostrando los primeros {_results.Count} resultados"
        : $"{_results.Count} {(_results.Count == 1 ? "resultado" : "resultados")}";

    private bool HasAnyFilter =>
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        _fromDate.HasValue ||
        _toDate.HasValue ||
        !string.IsNullOrWhiteSpace(_folderFilter) ||
        _personFilters.Count > 0 ||
        _objectLabels.Count > 0 ||
        _sceneLabels.Count > 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await DeviceLayout.InitializeAsync();
            DeviceLayout.OnChanged += OnDeviceLayoutChanged;
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var newTerm = (SearchTerm ?? string.Empty).Trim();
        var termChanged = !string.Equals(_searchTerm, newTerm, StringComparison.Ordinal);

        var paramIds = (PersonIdsParam ?? Array.Empty<Guid>()).Distinct().ToList();
        var currentIds = _personFilters.Select(p => p.Id).ToHashSet();
        var personFilterChanged = paramIds.Count != currentIds.Count || paramIds.Any(id => !currentIds.Contains(id));

        if (termChanged) _searchTerm = newTerm;

        if (personFilterChanged)
        {
            // Resolve names for the chips. Cheap because /api/people is paginated;
            // for large libraries this could fetch by id, but a 200-person cap is fine.
            if (paramIds.Count == 0)
            {
                _personFilters = new();
            }
            else
            {
                try
                {
                    var page = await PeopleService.GetPeopleAsync(limit: 500, includeHidden: true);
                    _personFilters = page.Items.Where(p => paramIds.Contains(p.Id)).ToList();
                }
                catch
                {
                    _personFilters = paramIds.Select(id => new PersonSummary(id, null, null, 0, false, DateTime.UtcNow, DateTime.UtcNow)).ToList();
                }
            }
        }

        var paramLabels = (ObjectLabelsParam ?? Array.Empty<string>())
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .Select(l => l.Trim().ToLowerInvariant())
            .Distinct()
            .ToList();
        var currentLabels = _objectLabels.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var objectFilterChanged = paramLabels.Count != currentLabels.Count
            || paramLabels.Any(l => !currentLabels.Contains(l));
        if (objectFilterChanged) _objectLabels = paramLabels;

        var paramScenes = (SceneLabelsParam ?? Array.Empty<string>())
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .Select(l => l.Trim().ToLowerInvariant())
            .Distinct()
            .ToList();
        var currentScenes = _sceneLabels.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var sceneFilterChanged = paramScenes.Count != currentScenes.Count
            || paramScenes.Any(l => !currentScenes.Contains(l));
        if (sceneFilterChanged) _sceneLabels = paramScenes;

        if (termChanged) _ = RefreshSuggestionsAsync(_searchTerm);

        if (termChanged || personFilterChanged || objectFilterChanged || sceneFilterChanged) await SearchAsync();
    }

    private async Task RefreshSuggestionsAsync(string? term)
    {
        // Cancel any in-flight call; the navbar debounces at 250 ms but the
        // user may also paste / clear text faster than that.
        _suggestCts?.Cancel();
        _suggestCts?.Dispose();
        _suggestCts = null;

        var trimmed = (term ?? string.Empty).Trim();
        if (trimmed.Length < 2)
        {
            // Single-letter or empty — too noisy to be useful.
            _suggestedPeople = new();
            _suggestedLabels = new();
            return;
        }

        _suggestCts = new CancellationTokenSource();
        var ct = _suggestCts.Token;

        try
        {
            // Three parallel fetches: people pool (loaded once, filtered
            // locally because we already cache it elsewhere) and the labels +
            // scenes endpoints which support a server-side ILIKE.
            _peoplePool ??= (await PeopleService.GetPeopleAsync(limit: 500, includeHidden: false, ct: ct)).Items;
            var labelsTask = ObjectsService.GetLabelsAsync(search: trimmed, limit: 5, ct);
            var scenesTask = ScenesService.GetLabelsAsync(search: trimmed, limit: 5, ct);

            var alreadyPickedPeople = _personFilters.Select(p => p.Id).ToHashSet();
            var people = _peoplePool
                .Where(p => !string.IsNullOrWhiteSpace(p.Name)
                            && !alreadyPickedPeople.Contains(p.Id)
                            && p.Name!.Contains(trimmed, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(p => p.FaceCount)
                .Take(3)
                .ToList();

            var labels = await labelsTask;
            var alreadyPickedLabels = _objectLabels.ToHashSet(StringComparer.OrdinalIgnoreCase);
            var filteredLabels = labels
                .Where(l => !alreadyPickedLabels.Contains(l.Label))
                .Take(3)
                .ToList();

            var scenes = await scenesTask;
            var alreadyPickedScenes = _sceneLabels.ToHashSet(StringComparer.OrdinalIgnoreCase);
            var filteredScenes = scenes
                .Where(s => !alreadyPickedScenes.Contains(s.Label))
                .Take(3)
                .ToList();

            if (ct.IsCancellationRequested) return;

            _suggestedPeople = people;
            _suggestedLabels = filteredLabels;
            _suggestedScenes = filteredScenes;
            StateHasChanged();
        }
        catch (OperationCanceledException) { /* superseded — ignore */ }
        catch
        {
            // Suggestions are a best-effort affordance; never let them break
            // the core search flow.
            _suggestedPeople = new();
            _suggestedLabels = new();
            _suggestedScenes = new();
        }
    }

    private void ApplyPersonSuggestion(Guid personId)
    {
        var ids = _personFilters.Select(p => p.Id).Append(personId).Distinct().ToList();
        // Drop the free-text term so the chip doesn't compete with q for the
        // same intent. The new URL has no `search=` segment.
        _searchTerm = string.Empty;
        Navigation.NavigateTo(BuildSearchUrl(ids, _objectLabels), replace: true);
