@page "/search"
@inject IAssetService AssetService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IAssetListNavigationState AssetListNavigationState
@inject IJSRuntime JS
@inject DeviceLayoutService DeviceLayout
@implements IDisposable

<PageTitle>Buscar - Photonne</PageTitle>

@if (DeviceLayout.IsMobile)
{
    <SearchMobileView Loading="_loading"
                      Results="_results"
                      HasMore="_hasMore"
                      SearchTerm="@_searchTerm"
                      OnSearchTermChanged="HandleSearchTermChanged"
                      FromDate="_fromDate"
                      OnFromDateChanged="OnFromDateChanged"
                      ToDate="_toDate"
                      OnToDateChanged="OnToDateChanged"
                      FolderFilter="@_folderFilter"
                      OnFolderFilterChanged="HandleFolderFilterChanged"
                      FiltersExpanded="_filtersExpanded"
                      OnToggleFilters="ToggleFiltersExpanded"
                      ActiveFilterCount="ActiveFilterCount"
                      ResultCountLabel="@ResultCountLabel"
                      HasAnyFilter="HasAnyFilter"
                      OnOpenAsset="OpenAsset" />
}
else
{
    <SearchDesktopView Loading="_loading"
                       Results="_results"
                       HasMore="_hasMore"
                       FromDate="_fromDate"
                       OnFromDateChanged="OnFromDateChanged"
                       ToDate="_toDate"
                       OnToDateChanged="OnToDateChanged"
                       FolderFilter="@_folderFilter"
                       OnFolderFilterChanged="HandleFolderFilterChanged"
                       ResultCountLabel="@ResultCountLabel"
                       HasAnyFilter="HasAnyFilter"
                       OnOpenAsset="OpenAsset" />
}

@code {
    [SupplyParameterFromQuery(Name = "search")] public string? SearchTerm { get; set; }

    private List<TimelineItem> _results = new();
    private bool _loading;
    private bool _hasMore;
    private string _searchTerm = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string _folderFilter = string.Empty;
    private bool _filtersExpanded;

    private int ActiveFilterCount =>
        (_fromDate.HasValue ? 1 : 0) +
        (_toDate.HasValue ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_folderFilter) ? 1 : 0);

    private string ResultCountLabel => _hasMore
        ? $"Mostrando los primeros {_results.Count} resultados"
        : $"{_results.Count} {(_results.Count == 1 ? "resultado" : "resultados")}";

    private bool HasAnyFilter =>
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        _fromDate.HasValue ||
        _toDate.HasValue ||
        !string.IsNullOrWhiteSpace(_folderFilter);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await DeviceLayout.InitializeAsync();
            DeviceLayout.OnChanged += OnDeviceLayoutChanged;
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var newTerm = (SearchTerm ?? string.Empty).Trim();
        if (!string.Equals(_searchTerm, newTerm, StringComparison.Ordinal))
        {
            _searchTerm = newTerm;
            await SearchAsync();
        }
    }

    private async Task HandleSearchTermChanged(string term)
    {
        _searchTerm = term;
        var trimmed = _searchTerm?.Trim() ?? string.Empty;
        var targetUri = string.IsNullOrWhiteSpace(trimmed)
            ? "/search"
            : $"/search?search={Uri.EscapeDataString(trimmed)}";
        Navigation.NavigateTo(targetUri, replace: true);
        await SearchAsync();
    }

    private async Task OnFromDateChanged(DateTime? date)
    {
        _fromDate = date;
        await SearchAsync();
    }

    private async Task OnToDateChanged(DateTime? date)
    {
        _toDate = date;
        await SearchAsync();
    }

    private async Task HandleFolderFilterChanged(string filter)
    {
        _folderFilter = filter;
        await SearchAsync();
    }

    private void ToggleFiltersExpanded()
    {
        _filtersExpanded = !_filtersExpanded;
    }

    private async Task SearchAsync()
    {
        if (!HasAnyFilter)
        {
            _results = new();
            _hasMore = false;
            return;
        }

        try
        {
            _loading = true;
            StateHasChanged();

            var (items, hasMore) = await AssetService.SearchAssetsAsync(
                q: string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                from: _fromDate,
                to: _toDate,
                folder: string.IsNullOrWhiteSpace(_folderFilter) ? null : _folderFilter);

            _results = items;
            _hasMore = hasMore;
            AssetListNavigationState.SetList(_results, "search");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al buscar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAsset(TimelineItem asset)
    {
        await JS.InvokeVoidAsync("assetTransition.saveOriginByAssetId", asset.Id.ToString());
        if (asset.SyncStatus == AssetSyncStatus.Synced)
            Navigation.NavigateTo($"/asset/{asset.Id}?returnTo=search");
        else
        {
            var encodedPath = System.Net.WebUtility.UrlEncode(asset.FullPath);
            Navigation.NavigateTo($"/asset/{Guid.Empty}?path={encodedPath}&returnTo=search");
        }
    }

    private void OnDeviceLayoutChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DeviceLayout.OnChanged -= OnDeviceLayoutChanged;
    }
}
