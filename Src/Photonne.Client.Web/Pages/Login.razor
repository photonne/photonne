@page "/login"
@layout LoginLayout
@using System.Linq
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject LayoutService LayoutService
@inject IDemoInfoService DemoInfoService

<PageTitle>Iniciar Sesión - Photonne</PageTitle>

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="3" Class="pa-8">
            <div class="d-flex justify-center mb-6">
                <img src="@(LayoutService.IsDarkMode ? "dark/logo.png" : "light/logo.png")" alt="Photonne" style="height: 48px; width: auto;" />
            </div>
            <form onsubmit="return false;">
                <MudTextField @bind-Value="_username"
                            Label="Usuario o Email"
                            Required="true"
                            RequiredError="El usuario o email es obligatorio"
                            Variant="Variant.Outlined"
                            FullWidth="true"
                            Class="mb-4"
                            UserAttributes="@_usernameAttributes"
                            OnKeyDown="HandleEnterKey" />

                <MudTextField @bind-Value="_password"
                            Label="Contraseña"
                            InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                            Required="true"
                            RequiredError="La contraseña es obligatoria"
                            Variant="Variant.Outlined"
                            FullWidth="true"
                            Class="mb-4"
                            UserAttributes="@_passwordAttributes"
                            Adornment="Adornment.End"
                            AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                            OnAdornmentClick="() => _showPassword = !_showPassword"
                            AdornmentAriaLabel="Mostrar contraseña"
                            OnKeyDown="HandleEnterKey" />

                <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        FullWidth="true"
                        OnClick="HandleLogin"
                        Disabled="@(_loggingIn)"
                        Class="mt-4">
                    @if (_loggingIn)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Iniciar Sesión
                </MudButton>
            </form>

            @if (_demoInfo.Enabled)
            {
                <MudDivider Class="my-6" />
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    <MudText Typo="Typo.body2">
                        Estás en la <strong>demo pública</strong>. Los datos se reinician periódicamente.
                    </MudText>
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Science"
                           OnClick="FillDemoCredentials">
                    Entrar como demo
                </MudButton>
            }
        </MudPaper>
    </MudContainer>
</div>

@code {
    private bool _loggingIn;

    private string _username = string.Empty;
    private string _password = string.Empty;
    private bool _showPassword;
    private string? _returnUrl;
    private DemoInfo _demoInfo = DemoInfo.Disabled;

    private static readonly Dictionary<string, object?> _usernameAttributes = new()
    {
        ["autocomplete"] = "username",
        ["name"] = "username",
        ["autocapitalize"] = "off",
        ["autocorrect"] = "off",
        ["spellcheck"] = "false",
        ["inputmode"] = "email"
    };

    private static readonly Dictionary<string, object?> _passwordAttributes = new()
    {
        ["autocomplete"] = "current-password",
        ["name"] = "password"
    };

    protected override async Task OnInitializedAsync()
    {
        _returnUrl = GetReturnUrl();
        _demoInfo = await DemoInfoService.GetAsync();

        if (await AuthService.IsAuthenticatedAsync())
        {
            NavigateToReturnUrlOrHome();
        }
    }

    private async Task FillDemoCredentials()
    {
        _username = _demoInfo.DemoUsername ?? "demo";
        _password = _demoInfo.DemoPassword ?? "demo";
        await SubmitLoginAsync();
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            return;
        }

        await SubmitLoginAsync();
    }

    private async Task HandleEnterKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_loggingIn)
        {
            await HandleLogin();
        }
    }

    private async Task SubmitLoginAsync()
    {
        try
        {
            _loggingIn = true;
            var result = await AuthService.LoginAsync(_username, _password);

            if (result.Success)
            {
                Snackbar.Add("Inicio de sesión exitoso", Severity.Success);
                NavigateToReturnUrlOrHome();
                return;
            }

            var (message, severity) = result.Error switch
            {
                LoginErrorKind.InvalidCredentials => ("Usuario o contraseña incorrectos", Severity.Error),
                LoginErrorKind.RateLimited => ("Demasiados intentos. Espera unos minutos e inténtalo de nuevo.", Severity.Warning),
                LoginErrorKind.NetworkError => ("No se pudo conectar con el servidor. Revisa tu conexión.", Severity.Warning),
                LoginErrorKind.ServerError => ("El servidor no está disponible. Inténtalo más tarde.", Severity.Error),
                LoginErrorKind.BadRequest => ("Solicitud inválida. Revisa los datos introducidos.", Severity.Error),
                _ => ("No se pudo iniciar sesión. Inténtalo de nuevo.", Severity.Error)
            };
            Snackbar.Add(message, severity);
        }
        finally
        {
            _loggingIn = false;
        }
    }

    private void NavigateToReturnUrlOrHome()
    {
        Navigation.NavigateTo(_returnUrl ?? "/");
    }

    private string? GetReturnUrl()
    {
        var uri = new Uri(Navigation.Uri);
        var query = ParseQuery(uri.Query);
        if (!query.TryGetValue("returnUrl", out var values))
        {
            return null;
        }

        var candidate = values.FirstOrDefault();
        return ReturnUrlValidator.IsSafe(candidate) ? candidate : null;
    }

    private static Dictionary<string, List<string>> ParseQuery(string query)
    {
        var result = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(query))
        {
            return result;
        }

        var trimmed = query.StartsWith("?", StringComparison.Ordinal)
            ? query[1..]
            : query;

        foreach (var pair in trimmed.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            var value = parts.Length > 1 ? Uri.UnescapeDataString(parts[1]) : string.Empty;

            if (!result.TryGetValue(key, out var list))
            {
                list = new List<string>();
                result[key] = list;
            }

            list.Add(value);
        }

        return result;
    }
}
