@page "/admin/system/tasks"
@page "/admin/system"
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Administración - Colas y tareas - Photonne</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
    {
        <div class="mt-8">
            <MudText Typo="Typo.h5">Acceso Denegado</MudText>
            <MudText Typo="Typo.body2">Solo los administradores pueden acceder a esta página.</MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Volver al inicio
            </MudButton>
        </div>
    }
    else
    {
        <div class="mt-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-1">Colas y tareas</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                Lanza y supervisa los procesos de indexación, miniaturas, metadatos e IA.
            </MudText>
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.Settings"
                       Href="/admin/settings/tasks">
                Ajustes de tareas (procesos simultáneos)
            </MudButton>
        </div>

        <MudGrid>

            @* ── 1. Indexar ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Indexar</MudText>
                            <MudText Typo="Typo.body2">Escanea y actualiza el índice de archivos.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/index"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 2. Extracción de metadatos ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Extracción de metadatos</MudText>
                            <MudText Typo="Typo.body2">Lee EXIF, GPS y otros metadatos de imágenes y vídeos.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/metadata"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── Restaurar fechas desde EXIF ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Restaurar fechas</MudText>
                            <MudText Typo="Typo.body2">Recalcula la fecha de captura de los assets a partir de su EXIF.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/restore-dates"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 3. Generar miniaturas ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Generar miniaturas</MudText>
                            <MudText Typo="Typo.body2">Crea las miniaturas faltantes o regenera todas.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/thumbnails"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 4. Detección de duplicados ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Detección de duplicados</MudText>
                            <MudText Typo="Typo.body2">Identifica y elimina archivos repetidos por hash SHA-256.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/duplicates"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 5. Reconocimiento facial ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Reconocimiento facial</MudText>
                            <MudText Typo="Typo.body2">Detecta caras y extrae embeddings para identificar personas.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/face-recognition"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 6. Reconocimiento de objetos ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Reconocimiento de objetos</MudText>
                            <MudText Typo="Typo.body2">Detecta objetos (YOLOv8) para etiquetar y buscar fotos.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/object-detection"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 7. Clasificación de escenas ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Clasificación de escenas</MudText>
                            <MudText Typo="Typo.body2">Reconoce escenas (Places365) para enriquecer la búsqueda.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/scene-classification"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 8. Reconocimiento de texto (OCR) ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Reconocimiento de texto (OCR)</MudText>
                            <MudText Typo="Typo.body2">Extrae texto de imágenes para búsqueda por contenido.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/text-recognition"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* ── 9. Búsqueda inteligente (CLIP) ── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Búsqueda inteligente (CLIP)</MudText>
                            <MudText Typo="Typo.body2">Genera embeddings multilingües para búsqueda libre por lenguaje natural en cualquier idioma.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/admin/system/tasks/image-embedding"))">
                            Abrir
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

        </MudGrid>
    }
</div>

@code {
    private bool _isAuthorized = false;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";
    }
}
