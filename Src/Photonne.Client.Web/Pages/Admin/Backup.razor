@page "/admin/system/backup"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IDatabaseBackupService BackupService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using System.Text.Json

<PageTitle>Administración - Copia de seguridad - Photonne</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
    {
        <div class="mt-8">
            <MudText Typo="Typo.h5">Acceso Denegado</MudText>
            <MudText Typo="Typo.body2">Solo los administradores pueden acceder a esta página.</MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Volver al inicio
            </MudButton>
        </div>
    }
    else
    {
        <div class="mt-0 mb-4">
            <MudText Typo="Typo.h5" Class="mb-1">Copia de seguridad</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Exporta o importa todos los registros de la base de datos.
                Las copias de seguridad no incluyen los archivos multimedia; solo los metadatos y la estructura de datos.
            </MudText>
        </div>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.CloudDownload" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Exportar copia de seguridad</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Descarga un archivo <strong>.json</strong> con los datos seleccionados.
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            Los archivos multimedia (fotos y vídeos) no se incluyen en la copia de seguridad.
                            Debes gestionarlos por separado.
                        </MudAlert>

                        <MudRadioGroup T="BackupLevel" Value="_level" ValueChanged="OnLevelChanged">
                            <MudRadio T="BackupLevel" Value="BackupLevel.Config" Color="Color.Primary" Dense="true">
                                <strong>Solo configuración</strong>
                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary" Style="margin-left: 0;">
                                    Ajustes del servidor, usuarios, carpetas (estructura), bibliotecas externas (definiciones)
                                    y permisos. Ideal para migrar la instalación a otra máquina sin la biblioteca actual.
                                </MudText>
                            </MudRadio>
                            <MudRadio T="BackupLevel" Value="BackupLevel.Essential" Color="Color.Primary" Dense="true" Class="mt-2">
                                <strong>Esencial</strong>
                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary" Style="margin-left: 0;">
                                    Lo anterior + álbumes, assets, EXIF, miniaturas, tags y enlaces compartidos.
                                    Sin datos de ML — se reprocesarán al restaurar.
                                </MudText>
                            </MudRadio>
                            <MudRadio T="BackupLevel" Value="BackupLevel.Full" Color="Color.Primary" Dense="true" Class="mt-2">
                                <strong>Completo (con ML)</strong>
                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary" Style="margin-left: 0;">
                                    Todo lo anterior + caras, personas, embeddings CLIP, OCR, objetos y escenas.
                                    Archivo notablemente mayor.
                                </MudText>
                            </MudRadio>
                        </MudRadioGroup>
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton
                            Variant="Variant.Filled"
                            Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.Download"
                            OnClick="HandleExportAsync"
                            Disabled="_exportLoading">
                            @if (_exportLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Generando...</span>
                            }
                            else
                            {
                                <span>Descargar @LevelLabel(_level).ToLower()</span>
                            }
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Warning" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Restaurar copia de seguridad</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Importa un archivo <strong>.json</strong> generado por esta aplicación.
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">
                            <strong>Atención:</strong> la restauración borra <strong>toda</strong> la base de datos
                            actual y la sustituye por la del archivo. Las tablas no incluidas en el backup
                            (p. ej. assets en una copia "solo configuración") quedarán <strong>vacías</strong>.
                        </MudAlert>

                        <div style="@(_selectedFile != null ? "display:none" : "")">
                            <MudFileUpload T="IBrowserFile"
                                           @ref="_fileUpload"
                                           FilesChanged="OnFileSelected"
                                           Accept=".json"
                                           MaximumFileCount="1">
                                <CustomContent>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.AttachFile"
                                               OnClick="@context.OpenFilePickerAsync">
                                        Seleccionar archivo
                                    </MudButton>
                                </CustomContent>
                                <SelectedTemplate Context="_">
                                </SelectedTemplate>
                            </MudFileUpload>
                        </div>

                        @if (_selectedFile != null)
                        {
                            @if (_previewLoading)
                            {
                                <div class="d-flex align-center mt-2 gap-2">
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Leyendo archivo...</MudText>
                                </div>
                            }
                            else if (_filePreview != null)
                            {
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @_filePreview.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        &nbsp;·&nbsp; v@_filePreview.Version
                                        &nbsp;·&nbsp;
                                        <MudChip T="string" Size="Size.Small" Color="@LevelChipColor(_filePreview.Level)" Variant="Variant.Outlined">@LevelLabel(_filePreview.Level)</MudChip>
                                    </MudText>
                                    <ul class="mt-1 mb-0" style="padding-left:1.2rem; font-size: 0.8rem">
                                        <li>Usuarios: <strong>@_filePreview.Users</strong></li>
                                        <li>Carpetas: <strong>@_filePreview.Folders</strong></li>
                                        <li>Bibliotecas externas: <strong>@_filePreview.ExternalLibraries</strong></li>
                                        @if (_filePreview.Level != BackupLevel.Config)
                                        {
                                            <li>Assets: <strong>@_filePreview.Assets</strong></li>
                                            <li>Álbumes: <strong>@_filePreview.Albums</strong></li>
                                        }
                                        @if (_filePreview.Level == BackupLevel.Full)
                                        {
                                            <li>Personas: <strong>@_filePreview.People</strong></li>
                                            <li>Caras: <strong>@_filePreview.Faces</strong></li>
                                            <li>Embeddings CLIP: <strong>@_filePreview.Embeddings</strong></li>
                                            <li>Líneas OCR: <strong>@_filePreview.OcrLines</strong></li>
                                        }
                                    </ul>
                                    @if (_filePreview.Level == BackupLevel.Config)
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                            Copia <strong>solo configuración</strong>: al restaurar, la biblioteca (assets, álbumes,
                                            datos de ML…) quedará <strong>vacía</strong>. Pensado para una instalación nueva.
                                        </MudAlert>
                                    }
                                    else if (_filePreview.Level == BackupLevel.Essential)
                                    {
                                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                            Copia <strong>esencial</strong>: el procesamiento de ML
                                            (caras, OCR, escenas, objetos, embeddings) se ejecutará de nuevo tras restaurar.
                                        </MudAlert>
                                    }
                                </MudPaper>
                            }
                            else if (_previewError)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">
                                    No se pudo leer el resumen del archivo.
                                </MudText>
                            }
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.Cancel"
                                       OnClick="ClearSelectedFile"
                                       Size="Size.Small"
                                       Class="mt-2">
                                Cancelar
                            </MudButton>
                        }
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton
                            Variant="Variant.Filled"
                            Color="Color.Warning"
                            StartIcon="@Icons.Material.Filled.RestorePage"
                            OnClick="OpenRestoreConfirmDialog"
                            Disabled="_restoreLoading || _selectedFile == null || _previewLoading">
                            @if (_restoreLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Restaurando...</span>
                            }
                            else
                            {
                                <span>Restaurar copia</span>
                            }
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @if (_restoreResult != null)
            {
                <MudItem xs="12">
                    <MudAlert Severity="@(_restoreResult.Success ? Severity.Success : Severity.Error)"
                              ShowCloseIcon="true"
                              CloseIconClicked="() => _restoreResult = null">
                        @_restoreResult.Message
                        @if (_restoreResult.Success && _restoreResult.Stats != null)
                        {
                            <ul class="mt-2 mb-0" style="padding-left:1.2rem">
                                <li>Usuarios: <strong>@_restoreResult.Stats.Users</strong></li>
                                <li>Carpetas: <strong>@_restoreResult.Stats.Folders</strong></li>
                                <li>Bibliotecas externas: <strong>@_restoreResult.Stats.ExternalLibraries</strong></li>
                                @if (_restoreResult.Stats.IncludesLibrary)
                                {
                                    <li>Assets: <strong>@_restoreResult.Stats.Assets</strong></li>
                                    <li>Álbumes: <strong>@_restoreResult.Stats.Albums</strong></li>
                                }
                                @if (_restoreResult.Stats.IncludesMlData)
                                {
                                    <li>Personas: <strong>@_restoreResult.Stats.People</strong></li>
                                    <li>Caras: <strong>@_restoreResult.Stats.Faces</strong></li>
                                    <li>Embeddings CLIP: <strong>@_restoreResult.Stats.Embeddings</strong></li>
                                    <li>Líneas OCR: <strong>@_restoreResult.Stats.OcrLines</strong></li>
                                }
                            </ul>
                            @if (!_restoreResult.Stats.IncludesLibrary)
                            {
                                <MudText Typo="Typo.caption" Class="d-block mt-2">
                                    Backup solo configuración: la biblioteca quedó vacía. Reescanea las carpetas
                                    desde la administración para indexar tus archivos.
                                </MudText>
                            }
                            else if (!_restoreResult.Stats.IncludesMlData)
                            {
                                <MudText Typo="Typo.caption" Class="d-block mt-2">
                                    Backup esencial: los procesos de ML se reejecutarán para regenerar caras,
                                    embeddings, OCR, escenas y objetos.
                                </MudText>
                            }
                        }
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    }
</div>

<MudDialog @bind-Visible="_confirmDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = false })">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Confirmar restauración</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>
            Estás a punto de reemplazar <strong>todos los datos</strong> de la base de datos con los del archivo:
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-2"><strong>@_selectedFile?.Name</strong></MudText>
        @if (_filePreview != null)
        {
            <ul class="mt-2 mb-0" style="padding-left:1.2rem; font-size: 0.875rem">
                <li>Usuarios: <strong>@_filePreview.Users</strong></li>
                <li>Carpetas: <strong>@_filePreview.Folders</strong></li>
                <li>Bibliotecas externas: <strong>@_filePreview.ExternalLibraries</strong></li>
                @if (_filePreview.Level != BackupLevel.Config)
                {
                    <li>Assets: <strong>@_filePreview.Assets</strong></li>
                    <li>Álbumes: <strong>@_filePreview.Albums</strong></li>
                }
                @if (_filePreview.Level == BackupLevel.Full)
                {
                    <li>Personas: <strong>@_filePreview.People</strong></li>
                    <li>Caras: <strong>@_filePreview.Faces</strong></li>
                    <li>Embeddings CLIP: <strong>@_filePreview.Embeddings</strong></li>
                    <li>Líneas OCR: <strong>@_filePreview.OcrLines</strong></li>
                }
            </ul>
            @if (_filePreview.Level == BackupLevel.Config)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                    Backup <strong>solo configuración</strong>: assets, álbumes y datos de ML actuales se
                    <strong>perderán</strong>. La biblioteca quedará vacía.
                </MudAlert>
            }
            else if (_filePreview.Level == BackupLevel.Essential)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                    Backup <strong>esencial</strong>: tras la restauración los datos de ML se borrarán y se reprocesarán.
                </MudAlert>
            }
        }
        <MudText Class="mt-3" Color="Color.Error">
            Esta acción no se puede deshacer. ¿Estás seguro de que deseas continuar?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmDialogOpen = false" Disabled="_restoreLoading">Cancelar</MudButton>
        <MudButton Color="Color.Warning"
                   Variant="Variant.Filled"
                   OnClick="HandleRestoreAsync"
                   Disabled="_restoreLoading">
            Sí, restaurar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private record BackupFilePreview(
        string Version,
        DateTime CreatedAt,
        BackupLevel Level,
        int Users,
        int Assets,
        int Albums,
        int Folders,
        int ExternalLibraries,
        int People,
        int Faces,
        int Embeddings,
        int OcrLines);

    private MudFileUpload<IBrowserFile>? _fileUpload;

    private bool _isAuthorized = false;

    private bool _exportLoading  = false;
    private bool _restoreLoading = false;
    private bool _previewLoading = false;
    private bool _previewError   = false;
    private bool _confirmDialogOpen = false;
    private BackupLevel _level     = BackupLevel.Essential;
    private IBrowserFile?      _selectedFile;
    private BackupFilePreview? _filePreview;
    private DatabaseRestoreResult? _restoreResult;

    private void OnLevelChanged(BackupLevel value) => _level = value;

    private static string LevelLabel(BackupLevel level) => level switch
    {
        BackupLevel.Config    => "Solo configuración",
        BackupLevel.Essential => "Esencial",
        BackupLevel.Full      => "Completo (con ML)",
        _                     => level.ToString(),
    };

    private static Color LevelChipColor(BackupLevel level) => level switch
    {
        BackupLevel.Config    => Color.Default,
        BackupLevel.Essential => Color.Info,
        BackupLevel.Full      => Color.Success,
        _                     => Color.Default,
    };

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        _selectedFile  = file;
        _restoreResult = null;
        _filePreview   = null;
        _previewError  = false;

        if (file == null) return;

        _previewLoading = true;
        StateHasChanged();

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            using var doc = await JsonDocument.ParseAsync(stream);
            var root = doc.RootElement;

            // v1.0 has no Includes* flags and always means "config + library, no ML".
            // v2.0 has IncludesMlData only (config + library always present).
            // v3.0+ has all three layer flags explicit.
            var version = root.TryGetProperty("version", out var v) ? v.GetString() ?? "?" : "?";

            var includesConfig = version == "1.0"
                || !root.TryGetProperty("includesConfig", out var ic)
                || ic.ValueKind != JsonValueKind.False;
            var includesLibrary = version == "1.0"
                || !root.TryGetProperty("includesLibrary", out var il)
                || il.ValueKind != JsonValueKind.False;
            var includesMl = version != "1.0"
                && includesLibrary
                && root.TryGetProperty("includesMlData", out var im)
                && im.ValueKind == JsonValueKind.True;

            var level = (includesLibrary, includesMl) switch
            {
                (false, _)     => BackupLevel.Config,
                (true, false)  => BackupLevel.Essential,
                (true, true)   => BackupLevel.Full,
            };

            _filePreview = new BackupFilePreview(
                Version:           version,
                CreatedAt:         root.TryGetProperty("createdAt",                out var ca)  ? ca.GetDateTime()    : DateTime.MinValue,
                Level:             level,
                Users:             root.TryGetProperty("users",                    out var u)   ? u.GetArrayLength()  : 0,
                Assets:            root.TryGetProperty("assets",                   out var a)   ? a.GetArrayLength()  : 0,
                Albums:            root.TryGetProperty("albums",                   out var al)  ? al.GetArrayLength() : 0,
                Folders:           root.TryGetProperty("folders",                  out var f)   ? f.GetArrayLength()  : 0,
                ExternalLibraries: root.TryGetProperty("externalLibraries",        out var el)  ? el.GetArrayLength() : 0,
                People:            root.TryGetProperty("people",                   out var pp)  ? pp.GetArrayLength() : 0,
                Faces:             root.TryGetProperty("faces",                    out var fc)  ? fc.GetArrayLength() : 0,
                Embeddings:        root.TryGetProperty("assetEmbeddings",          out var em)  ? em.GetArrayLength() : 0,
                OcrLines:          root.TryGetProperty("assetRecognizedTextLines", out var ocr) ? ocr.GetArrayLength(): 0
            );
        }
        catch
        {
            _previewError = true;
        }
        finally
        {
            _previewLoading = false;
        }
    }

    private async Task ClearSelectedFile()
    {
        _selectedFile  = null;
        _filePreview   = null;
        _previewError  = false;
        _restoreResult = null;
        if (_fileUpload != null)
            await _fileUpload.ResetAsync();
    }

    private void OpenRestoreConfirmDialog()
    {
        if (_selectedFile == null) return;
        _confirmDialogOpen = true;
    }

    private async Task HandleExportAsync()
    {
        _exportLoading = true;
        try
        {
            var backup = await BackupService.ExportAsync(_level);
            await JS.InvokeVoidAsync("downloadFileFromBytes", backup.FileName, "application/json", backup.Bytes);
            Snackbar.Add("Copia de seguridad descargada correctamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al generar la copia de seguridad: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exportLoading = false;
        }
    }

    private async Task HandleRestoreAsync()
    {
        if (_selectedFile == null) return;

        _confirmDialogOpen = false;
        _restoreLoading    = true;
        _restoreResult     = null;

        try
        {
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            _restoreResult = await BackupService.RestoreAsync(stream, _selectedFile.Name);

            if (_restoreResult.Success)
            {
                Snackbar.Add("Base de datos restaurada correctamente.", Severity.Success);
                _selectedFile = null;
                _filePreview  = null;
                if (_fileUpload != null)
                    await _fileUpload.ResetAsync();
            }
            else
            {
                Snackbar.Add($"Error en la restauración: {_restoreResult.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _restoreLoading = false;
        }
    }

}
