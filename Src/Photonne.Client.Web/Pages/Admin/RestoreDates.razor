@page "/admin/system/tasks/restore-dates"
@inject IDateRestoreService DateRestoreService
@inject IAuthService AuthService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject BackgroundTaskStateService BackgroundTaskState

<PageTitle>Restaurar fechas - Photonne</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
{
    <div class="mt-8">
        <MudText Typo="Typo.h5">Acceso Denegado</MudText>
        <MudText Typo="Typo.body1">Solo los administradores pueden acceder a esta página.</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
            Volver al inicio
        </MudButton>
    </div>
}
else
{
    <MudText Typo="Typo.h5" Class="mb-4">Restaurar fechas desde EXIF</MudText>

    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Opciones</MudText>
                        <MudText Typo="Typo.body2">
                            Recalcula la fecha de captura de cada asset (la que ordena la línea de tiempo)
                            a partir de su EXIF <em>DateTimeOriginal</em>.
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudRadioGroup T="bool" @bind-Value="_fromFile">
                        <MudRadio T="bool" Value="false" Color="Color.Primary">
                            <MudText Typo="Typo.body1"><strong>Desde metadatos guardados</strong></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                                Usa el EXIF ya almacenado en la base de datos. No accede al disco. Muy rápido.
                            </MudText>
                        </MudRadio>
                        <MudRadio T="bool" Value="true" Color="Color.Warning" Class="mt-2">
                            <MudText Typo="Typo.body1"><strong>Releyendo los archivos</strong></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                                Vuelve a leer el EXIF de cada archivo en disco antes de restaurar. Más lento,
                                útil para assets indexados antes de extraer metadatos.
                            </MudText>
                        </MudRadio>
                    </MudRadioGroup>

                    <MudDivider Class="my-4" />

                    <MudSwitch T="bool" @bind-Value="_inferFromPath" Color="Color.Primary">
                        <MudText Typo="Typo.body1"><strong>Inferir fechas del nombre o la carpeta</strong></MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                            Para assets sin fecha EXIF: la deduce del nombre del archivo
                            (<em>IMG_20100815_123456.jpg</em>, WhatsApp) o de carpetas con fecha
                            (<em>/2010/2010-08-15 Vacaciones/</em>). Nunca toca fechas EXIF reales ni manuales.
                        </MudText>
                    </MudSwitch>

                    @if (_inferFromPath)
                    {
                        <MudSwitch T="bool" @bind-Value="_writeToFile" Color="Color.Primary" Class="mt-2">
                            <MudText Typo="Typo.body1"><strong>Escribir la fecha en el archivo original</strong></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                                Hace la fecha inferida permanente: EXIF en imágenes y fecha de modificación
                                del archivo en todos los formatos, vídeos incluidos (las bibliotecas externas
                                solo se actualizan en la base de datos).
                            </MudText>
                        </MudSwitch>
                    }

                    <MudSwitch T="bool" @bind-Value="_dryRun" Color="Color.Secondary" Class="mt-2">
                        <MudText Typo="Typo.body1"><strong>Solo simular</strong></MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                            Cuenta cuántos assets se actualizarían sin cambiar nada. Revisa el resultado
                            y vuelve a lanzar sin este interruptor para aplicar.
                        </MudText>
                    </MudSwitch>

                    <div class="mt-4 d-flex gap-3 align-center">
                        @if (!_running)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="@(_fromFile ? Color.Warning : Color.Primary)"
                                       OnClick="Start"
                                       StartIcon="@Icons.Material.Filled.PlayArrow">
                                Iniciar
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Error"
                                       OnClick="Cancel"
                                       StartIcon="@Icons.Material.Filled.Stop">
                                Detener
                            </MudButton>
                        }
                        @if (_running && _runningInBackground)
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small"
                                     Icon="@Icons.Material.Filled.CloudSync">
                                Ejecutándose en segundo plano
                            </MudChip>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @if (_running || _lastUpdate != null)
    {
        <MudCard Class="mt-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Class="me-1">Progreso</MudText>
                        @if (_running && _startTime.HasValue)
                        {
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Timer">
                                @FormatDuration(DateTime.UtcNow - _startTime.Value)
                            </MudChip>
                            @if (_speed > 0)
                            {
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Speed">
                                    @($"{_speed:F1} assets/s")
                                </MudChip>
                            }
                            @if (_etaSeconds > 0)
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.AccessTime">
                                    ETA @FormatDuration(TimeSpan.FromSeconds(_etaSeconds))
                                </MudChip>
                            }
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Autorenew">En curso</MudChip>
                        }
                        else if (_duration.HasValue)
                        {
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.Schedule">
                                @FormatDuration(_duration.Value)
                            </MudChip>
                            @if (_lastUpdate?.IsCompleted == true)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Check">Completado</MudChip>
                            }
                        }
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-2">@_currentStatus</MudText>
                <MudProgressLinear Color="@(_stats?.Failed > 0 ? Color.Warning : Color.Primary)"
                                   Value="@_progress"
                                   Class="my-4"
                                   Rounded="true"
                                   Size="Size.Medium" />

                @if (_stats != null)
                {
                    <MudGrid Class="mt-2">
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="1" Class="text-center pa-4">
                                <MudText Typo="Typo.h4" Color="Color.Primary">@_stats.Processed</MudText>
                                <MudText Typo="Typo.caption">Procesados</MudText>
                                @if (_stats.TotalAssets > 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">de @_stats.TotalAssets</MudText>
                                }
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="1" Class="text-center pa-4">
                                <MudText Typo="Typo.h4" Color="Color.Success">@_stats.Extracted</MudText>
                                <MudText Typo="Typo.caption">Actualizados</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="1" Class="text-center pa-4">
                                <MudText Typo="Typo.h4" Color="Color.Info">@_stats.Skipped</MudText>
                                <MudText Typo="Typo.caption">Sin cambios</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudPaper Elevation="1" Class="text-center pa-4">
                                <MudText Typo="Typo.h4" Color="@(_stats.Failed > 0 ? Color.Error : Color.Default)">@_stats.Failed</MudText>
                                <MudText Typo="Typo.caption">Fallidos</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                }
            </MudCardContent>
        </MudCard>
    }
}
</div>

@code {
    private bool _isAuthorized;
    private bool _fromFile;
    private bool _inferFromPath;
    // Write-back defaults ON: an inferred date stored only in the DB is lost
    // on a rebuild, while EXIF inside the image survives anything.
    private bool _writeToFile = true;
    private bool _dryRun;
    private bool _running;
    private bool _runningInBackground;
    private double _progress;
    private string _currentStatus = "Esperando inicio...";
    private MetadataJobStatistics? _stats;
    private MetadataProgressUpdate? _lastUpdate;
    private DateTime? _startTime;
    private TimeSpan? _duration;
    private double _speed;
    private double _etaSeconds;
    private CancellationTokenSource? _cts;
    private Guid? _taskId;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }
        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";

        if (_isAuthorized)
            await TryReconnectAsync();
    }

    private async Task TryReconnectAsync()
    {
        var task = await BackgroundTaskState.GetRunningTaskAsync("DateRestore");
        if (task == null) return;

        _running = true;
        _runningInBackground = true;
        _progress = task.Percentage;
        _currentStatus = task.LastMessage;
        _startTime ??= task.StartedAt;
        StateHasChanged();

        _taskId = task.Id;
        _cts = new CancellationTokenSource();
        await ConsumeStreamAsync(DateRestoreService.ResumeAsync(task.Id, _cts.Token));
    }

    private async Task Start()
    {
        _cts = new CancellationTokenSource();
        _running = true;
        _runningInBackground = false;
        _startTime = DateTime.UtcNow;
        _duration = null;
        _progress = 0;
        _stats = null;
        _lastUpdate = null;
        _speed = 0;
        _etaSeconds = 0;
        _currentStatus = "Iniciando...";

        await ConsumeStreamAsync(DateRestoreService.RestoreDatesAsync(
            _fromFile, _inferFromPath, _inferFromPath && _writeToFile, _dryRun, _cts.Token));
    }

    private async Task ConsumeStreamAsync(IAsyncEnumerable<MetadataProgressUpdate> stream)
    {
        try
        {
            await foreach (var update in stream)
            {
                if (update.TaskId.HasValue)
                    _taskId = update.TaskId;

                _runningInBackground = false;
                _lastUpdate = update;
                _currentStatus = update.Message;
                _progress = update.Percentage;

                if (update.Statistics != null)
                {
                    _stats = update.Statistics;
                    UpdateSpeedAndEta();
                }

                StateHasChanged();
            }

            if (_startTime.HasValue)
                _duration = DateTime.UtcNow - _startTime.Value;

            if (_lastUpdate?.IsCompleted == true)
                Snackbar.Add("Restauración de fechas completada.", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            _currentStatus = "Proceso detenido.";
            if (_startTime.HasValue)
                _duration = DateTime.UtcNow - _startTime.Value;
        }
        catch (Exception ex)
        {
            _currentStatus = $"Error: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            if (_startTime.HasValue)
                _duration = DateTime.UtcNow - _startTime.Value;
        }
        finally
        {
            _running = false;
            _runningInBackground = false;
            _speed = 0;
            _etaSeconds = 0;
            StateHasChanged();
        }
    }

    private async Task Cancel()
    {
        if (_taskId.HasValue)
            await BackgroundTaskState.CancelTaskAsync(_taskId.Value);
        _cts?.Cancel();
    }

    private void UpdateSpeedAndEta()
    {
        if (_stats == null || !_startTime.HasValue || _stats.Processed == 0) return;

        var elapsed = (DateTime.UtcNow - _startTime.Value).TotalSeconds;
        if (elapsed <= 0) return;

        _speed = _stats.Processed / elapsed;

        var remaining = _stats.TotalAssets - _stats.Processed;
        _etaSeconds = _speed > 0 ? remaining / _speed : 0;
    }

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalHours >= 1)
            return $"{(int)d.TotalHours}h {d.Minutes}m {d.Seconds}s";
        if (d.TotalMinutes >= 1)
            return $"{d.Minutes}m {d.Seconds}s";
        return $"{d.Seconds}s";
    }
}
