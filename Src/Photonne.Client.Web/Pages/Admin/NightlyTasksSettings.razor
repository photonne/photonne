@page "/admin/settings/nightly"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISettingsService SettingsService
@inject ISnackbar Snackbar

<PageTitle>Tareas nocturnas - Photonne</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
    {
        <div class="mt-8">
            <MudText Typo="Typo.h5">Acceso Denegado</MudText>
            <MudText Typo="Typo.body1">Solo los administradores pueden acceder a esta página.</MudText>
        </div>
    }
    else if (_loading)
    {
        <div class="mt-8 d-flex justify-center">
            <MudProgressCircular Indeterminate="true" />
        </div>
    }
    else
    {
        <div class="mt-4">
            <MudText Typo="Typo.h5" Class="mb-2">Configuración de tareas nocturnas</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Ejecuta automáticamente las tareas de mantenimiento seleccionadas una vez al día a la hora configurada.
            </MudText>
        </div>

        <MudGrid Class="mt-4">

            <!-- Planificación -->
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Planificación</MudText>
                            <MudText Typo="Typo.body2">Activa las tareas nocturnas y define cuándo se ejecutan.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSwitch @bind-Value="_enabled"
                                   Color="Color.Primary"
                                   Label="@(_enabled ? "Activado" : "Desactivado")"
                                   Class="mb-4" />

                        <MudTextField @bind-Value="_scheduleTime"
                                      Label="Hora de ejecución (HH:mm)"
                                      Variant="Variant.Outlined"
                                      Placeholder="02:00"
                                      HelperText="Hora local en la zona horaria configurada"
                                      Disabled="!_enabled"
                                      Class="mb-4" />

                        <MudSelect @bind-Value="_timezone"
                                   Label="Zona horaria"
                                   Variant="Variant.Outlined"
                                   Disabled="!_enabled">
                            @foreach (var tz in _timezones)
                            {
                                <MudSelectItem Value="@tz.Id">@tz.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton OnClick="SaveScheduleAsync"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="_savingSchedule"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingSchedule ? "Guardando…" : "Guardar")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Última ejecución -->
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Última ejecución</MudText>
                            <MudText Typo="Typo.body2">Estado del último ciclo nocturno registrado.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (string.IsNullOrEmpty(_lastRunDate))
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-0">
                                Todavía no se ha ejecutado ningún ciclo nocturno.
                            </MudAlert>
                        }
                        else
                        {
                            <div class="d-flex align-center gap-3 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                <MudText Typo="Typo.body1">
                                    Última ejecución: <strong>@_lastRunDate</strong>
                                </MudText>
                            </div>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                El planificador comprueba cada minuto si es hora de ejecutar.
                                El ciclo se lanza una única vez por día.
                            </MudText>
                        }
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton OnClick="ResetLastRunAsync"
                                   Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   Disabled="string.IsNullOrEmpty(_lastRunDate) || _resettingLastRun"
                                   StartIcon="@Icons.Material.Filled.RestartAlt">
                            Forzar siguiente ejecución
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Generación de miniaturas -->
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Generación de miniaturas</MudText>
                            <MudText Typo="Typo.body2">Genera miniaturas de assets que no las tengan (o todas).</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSwitch @bind-Value="_thumbEnabled"
                                   Color="Color.Primary"
                                   Label="@(_thumbEnabled ? "Activado" : "Desactivado")"
                                   Disabled="!_enabled"
                                   Class="mb-4" />

                        <MudText Typo="Typo.subtitle2" Class="mb-2">Modo</MudText>
                        <MudRadioGroup @bind-Value="_thumbMode">
                            <MudRadio Value='"missing"' Color="Color.Primary" Disabled="!_enabled || !_thumbEnabled">
                                Solo las que faltan
                            </MudRadio>
                            <MudRadio Value='"all"' Color="Color.Warning" Disabled="!_enabled || !_thumbEnabled">
                                Regenerar todas
                            </MudRadio>
                        </MudRadioGroup>
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton OnClick="SaveThumbnailsAsync"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="_savingThumbnails"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingThumbnails ? "Guardando…" : "Guardar")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <!-- Extracción de metadatos -->
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Extracción de metadatos</MudText>
                            <MudText Typo="Typo.body2">Extrae EXIF/IPTC de assets sin metadatos (o de todos).</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSwitch @bind-Value="_metaEnabled"
                                   Color="Color.Primary"
                                   Label="@(_metaEnabled ? "Activado" : "Desactivado")"
                                   Disabled="!_enabled"
                                   Class="mb-4" />

                        <MudText Typo="Typo.subtitle2" Class="mb-2">Modo</MudText>
                        <MudRadioGroup @bind-Value="_metaMode">
                            <MudRadio Value='"missing"' Color="Color.Primary" Disabled="!_enabled || !_metaEnabled">
                                Solo los que faltan
                            </MudRadio>
                            <MudRadio Value='"all"' Color="Color.Warning" Disabled="!_enabled || !_metaEnabled">
                                Sobreescribir todos
                            </MudRadio>
                        </MudRadioGroup>
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton OnClick="SaveMetadataAsync"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="_savingMetadata"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @(_savingMetadata ? "Guardando…" : "Guardar")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

        </MudGrid>
    }
</div>

@code {
    private bool _isAuthorized;
    private bool _loading = true;

    // Schedule
    private bool   _enabled      = false;
    private string _scheduleTime = "02:00";
    private string _timezone     = "UTC";
    private string _lastRunDate  = "";
    private bool   _savingSchedule;
    private bool   _resettingLastRun;

    // Thumbnails
    private bool   _thumbEnabled  = false;
    private string _thumbMode     = "missing";
    private bool   _savingThumbnails;

    // Metadata
    private bool   _metaEnabled  = false;
    private string _metaMode     = "missing";
    private bool   _savingMetadata;

    private readonly record struct TzOption(string Id, string Label);
    private static readonly TzOption[] _timezones =
    [
        new("UTC",                          "UTC (Coordinated Universal Time)"),
        new("Europe/Madrid",                "Europe/Madrid (ES — España)"),
        new("Europe/London",                "Europe/London (GB — Reino Unido)"),
        new("Europe/Paris",                 "Europe/Paris (FR — Francia)"),
        new("Europe/Berlin",                "Europe/Berlin (DE — Alemania)"),
        new("Europe/Rome",                  "Europe/Rome (IT — Italia)"),
        new("Europe/Lisbon",                "Europe/Lisbon (PT — Portugal)"),
        new("Europe/Amsterdam",             "Europe/Amsterdam (NL — Países Bajos)"),
        new("Europe/Brussels",              "Europe/Brussels (BE — Bélgica)"),
        new("Europe/Zurich",                "Europe/Zurich (CH — Suiza)"),
        new("Europe/Warsaw",                "Europe/Warsaw (PL — Polonia)"),
        new("Europe/Helsinki",              "Europe/Helsinki (FI — Finlandia)"),
        new("Europe/Stockholm",             "Europe/Stockholm (SE — Suecia)"),
        new("Europe/Oslo",                  "Europe/Oslo (NO — Noruega)"),
        new("Europe/Copenhagen",            "Europe/Copenhagen (DK — Dinamarca)"),
        new("Europe/Athens",                "Europe/Athens (GR — Grecia)"),
        new("Europe/Bucharest",             "Europe/Bucharest (RO — Rumanía)"),
        new("Europe/Prague",                "Europe/Prague (CZ — República Checa)"),
        new("Europe/Vienna",                "Europe/Vienna (AT — Austria)"),
        new("Europe/Moscow",                "Europe/Moscow (RU — Moscú)"),
        new("America/New_York",             "America/New_York (US — Este)"),
        new("America/Chicago",              "America/Chicago (US — Centro)"),
        new("America/Denver",               "America/Denver (US — Montaña)"),
        new("America/Los_Angeles",          "America/Los_Angeles (US — Pacífico)"),
        new("America/Anchorage",            "America/Anchorage (US — Alaska)"),
        new("America/Sao_Paulo",            "America/Sao_Paulo (BR — Brasil)"),
        new("America/Argentina/Buenos_Aires","America/Argentina/Buenos_Aires (AR)"),
        new("America/Mexico_City",          "America/Mexico_City (MX — México)"),
        new("America/Bogota",               "America/Bogota (CO — Colombia)"),
        new("Asia/Tokyo",                   "Asia/Tokyo (JP — Japón)"),
        new("Asia/Shanghai",                "Asia/Shanghai (CN — China)"),
        new("Asia/Kolkata",                 "Asia/Kolkata (IN — India)"),
        new("Asia/Dubai",                   "Asia/Dubai (AE — Emiratos)"),
        new("Australia/Sydney",             "Australia/Sydney (AU — Este)"),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";

        if (_isAuthorized)
            await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _loading = true;
        try
        {
            _enabled      = (await SettingsService.GetSettingAsync("NightlyTaskSettings.Enabled"))      == "true";
            _scheduleTime =  await SettingsService.GetSettingAsync("NightlyTaskSettings.ScheduleTime") ?? "02:00";
            _timezone     =  await SettingsService.GetSettingAsync("NightlyTaskSettings.Timezone")     ?? "UTC";
            _lastRunDate  =  await SettingsService.GetSettingAsync("NightlyTaskSettings.LastRunDate")  ?? "";

            _thumbEnabled = (await SettingsService.GetSettingAsync("NightlyTaskSettings.Thumbnails.Enabled")) == "true";
            _thumbMode    =  await SettingsService.GetSettingAsync("NightlyTaskSettings.Thumbnails.Mode") ?? "missing";

            _metaEnabled  = (await SettingsService.GetSettingAsync("NightlyTaskSettings.Metadata.Enabled")) == "true";
            _metaMode     =  await SettingsService.GetSettingAsync("NightlyTaskSettings.Metadata.Mode") ?? "missing";

            if (!_timezones.Any(t => t.Id == _timezone))
                _timezone = "UTC";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveScheduleAsync()
    {
        if (!TimeOnly.TryParse(_scheduleTime, out _))
        {
            Snackbar.Add("Formato de hora no válido. Usa HH:mm (p.ej. 02:30).", Severity.Error);
            return;
        }

        _savingSchedule = true;
        try
        {
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.Enabled",      _enabled.ToString().ToLower());
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.ScheduleTime", _scheduleTime);
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.Timezone",     _timezone);
            Snackbar.Add("Planificación guardada.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingSchedule = false;
        }
    }

    private async Task ResetLastRunAsync()
    {
        _resettingLastRun = true;
        try
        {
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.LastRunDate", "");
            _lastRunDate = "";
            Snackbar.Add("La próxima vez que llegue la hora configurada se ejecutará el ciclo.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _resettingLastRun = false;
        }
    }

    private async Task SaveThumbnailsAsync()
    {
        _savingThumbnails = true;
        try
        {
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.Thumbnails.Enabled", _thumbEnabled.ToString().ToLower());
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.Thumbnails.Mode",    _thumbMode);
            Snackbar.Add("Configuración de miniaturas guardada.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingThumbnails = false;
        }
    }

    private async Task SaveMetadataAsync()
    {
        _savingMetadata = true;
        try
        {
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.Metadata.Enabled", _metaEnabled.ToString().ToLower());
            await SettingsService.SaveSettingAsync("NightlyTaskSettings.Metadata.Mode",    _metaMode);
            Snackbar.Add("Configuración de metadatos guardada.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingMetadata = false;
        }
    }
}
