@page "/admin/tasks/face-recognition"
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Reconocimiento facial - Photonne</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
    {
        <div class="mt-8">
            <MudText Typo="Typo.h5">Acceso Denegado</MudText>
            <MudText Typo="Typo.body1">Solo los administradores pueden acceder a esta página.</MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Volver al inicio
            </MudButton>
        </div>
    }
    else
    {
        <MudText Typo="Typo.h5" Class="mb-4">Reconocimiento facial</MudText>

        <MudGrid>
            <MudItem xs="12" md="8">
                <MlBackfillCard Title="Procesar fotos pendientes"
                                Description="Encola jobs de detección + embedding facial para fotos sin procesar. El procesador los irá completando en segundo plano."
                                EndpointKey="face-recognition" />
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private bool _isAuthorized;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }
        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";
    }
}
