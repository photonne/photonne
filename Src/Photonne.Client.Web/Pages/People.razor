@page "/people"
@using Photonne.Client.Web.Services
@inject IPeopleService PeopleService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Personas - Photonne</PageTitle>

<div class="px-3 pt-3 d-flex align-center justify-space-between">
    <MudText Typo="Typo.h5">Personas</MudText>
    <MudTooltip Text="@(_includeHidden ? "Ocultar las ocultas" : "Mostrar ocultas")">
        <MudIconButton Icon="@(_includeHidden ? Icons.Material.Filled.VisibilityOff : Icons.Material.Outlined.VisibilityOff)"
                       Color="@(_includeHidden ? Color.Primary : Color.Default)"
                       Size="Size.Small"
                       OnClick="ToggleIncludeHiddenAsync" />
    </MudTooltip>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}
else if (_people.Count == 0)
{
    <div class="d-flex flex-column align-center justify-center py-8 px-4">
        <MudIcon Icon="@Icons.Material.Outlined.GroupOff" Size="Size.Large" Class="mb-3" />
        <MudText Typo="Typo.h6">Sin personas todavía</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); text-align: center; max-width: 360px;">
            En cuanto subas más fotos, Photonne agrupará caras automáticamente.
            También puedes ejecutar el backfill desde Admin para procesar fotos antiguas.
        </MudText>
    </div>
}
else
{
    <div class="px-3 mt-2">
        <MudGrid Spacing="2">
            @foreach (var p in _people)
            {
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <MudCard Class="@($"ph-person-card{(p.IsHidden ? " ph-person-card--hidden" : "")}")"
                             @onclick="() => OpenPerson(p)">
                        <div class="ph-person-cover">
                            @if (p.CoverFaceId.HasValue)
                            {
                                <img src="@($"/api/faces/{p.CoverFaceId.Value}/thumbnail")" alt="@(p.Name ?? "Persona")" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Large" />
                            }
                            @if (p.IsHidden)
                            {
                                <span class="ph-person-cover__hidden-badge"
                                      title="Persona oculta"
                                      @onclick:stopPropagation="true"
                                      @onclick="() => UnhideAsync(p)">
                                    <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
                                </span>
                            }
                        </div>
                        <MudCardContent Class="py-2 px-3">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                @(string.IsNullOrWhiteSpace(p.Name) ? "Sin nombre" : p.Name)
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                @p.FaceCount fotos
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </div>
}

<style>
    .ph-person-card { cursor: pointer; }
    .ph-person-card--hidden { opacity: 0.55; }
    .ph-person-card--hidden:hover { opacity: 0.85; }
    .ph-person-cover {
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
        background: var(--mud-palette-background-grey);
        display: flex; align-items: center; justify-content: center;
    }
    .ph-person-cover img { width: 100%; height: 100%; object-fit: cover; }
    .ph-person-cover__hidden-badge {
        position: absolute;
        top: 6px; right: 6px;
        width: 28px; height: 28px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.65);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: background 0.15s ease;
    }
    .ph-person-cover__hidden-badge:hover { background: var(--mud-palette-primary); }
</style>

@code {
    private bool _loading = true;
    private bool _includeHidden;
    private List<PersonSummary> _people = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var page = await PeopleService.GetPeopleAsync(limit: 200, includeHidden: _includeHidden);
            _people = page.Items;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar personas: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleIncludeHiddenAsync()
    {
        _includeHidden = !_includeHidden;
        await LoadAsync();
    }

    private async Task UnhideAsync(PersonSummary p)
    {
        try
        {
            await PeopleService.UnhideAsync(p.Id);
            Snackbar.Add($"\"{p.Name ?? "Sin nombre"}\" vuelve a estar visible", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo mostrar: {ex.Message}", Severity.Error);
        }
    }

    private void OpenPerson(PersonSummary p)
    {
        Navigation.NavigateTo($"/people/{p.Id}");
    }
}
