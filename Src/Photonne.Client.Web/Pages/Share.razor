@page "/share/{Token}"
@layout PublicLayout
@inject IShareService ShareService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@_pageTitle - Photonne</PageTitle>

@if (_loading)
{
    <div class="share-center">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else if (_expired)
{
    <div class="share-center">
        <MudIcon Icon="@Icons.Material.Outlined.LinkOff" Style="font-size:64px; opacity:0.4;" />
        <MudText Typo="Typo.h6" Class="mt-4">Este enlace ha expirado</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">El propietario puede generar un nuevo enlace.</MudText>
    </div>
}
else if (_requiresPassword)
{
    <div class="share-center">
        <MudIcon Icon="@Icons.Material.Outlined.Lock" Style="font-size:64px; opacity:0.5;" />
        <MudText Typo="Typo.h6" Class="mt-4">Enlace protegido con contraseña</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1 mb-4">Introduce la contraseña para acceder al contenido.</MudText>
        @if (_wrongPassword)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" Style="max-width:320px;">Contraseña incorrecta</MudAlert>
        }
        <MudTextField @bind-Value="_password"
                      InputType="InputType.Password"
                      Label="Contraseña"
                      Variant="Variant.Outlined"
                      Style="max-width:320px; width:100%;"
                      OnKeyDown="OnPasswordKeyDown" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                   OnClick="SubmitPassword" Disabled="_loading">
            Acceder
        </MudButton>
    </div>
}
else if (_content == null)
{
    <div class="share-center">
        <MudIcon Icon="@Icons.Material.Outlined.BrokenImage" Style="font-size:64px; opacity:0.4;" />
        <MudText Typo="Typo.h6" Class="mt-4">Contenido no encontrado</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">Es posible que el enlace haya sido revocado.</MudText>
    </div>
}
else if (_content.Album != null)
{
    var album = _content.Album;
    var assets = _content.Assets ?? new();
    var coverUrl = album.CoverThumbnailUrl ?? assets.FirstOrDefault()?.ThumbnailUrl;

    <div class="share-album-view">

        @* ── Hero ─────────────────────────────────────────────────────────── *@
        <div class="share-album-hero">
            @if (!string.IsNullOrEmpty(coverUrl))
            {
                <div class="share-album-hero-bg" style="background-image: url('@coverUrl');"></div>
            }
            else
            {
                <div class="share-album-hero-bg share-album-hero-bg--empty"></div>
            }

            @if (_content.AllowDownload && assets.Any())
            {
                <div class="share-album-hero-actions">
                    <MudTooltip Text="Descargar todo">
                        <MudIconButton Icon="@Icons.Material.Outlined.Download"
                                       Color="Color.Inherit"
                                       OnClick="DownloadAll" />
                    </MudTooltip>
                </div>
            }

            <div class="share-album-hero-content">
                <MudText Typo="Typo.h3" Style="font-weight:700; color:white;">@album.Name</MudText>
                @if (!string.IsNullOrEmpty(album.Description))
                {
                    <MudText Typo="Typo.body1" Style="color:rgba(255,255,255,0.85); margin-top:4px;">@album.Description</MudText>
                }
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.65); margin-top:8px;">
                    <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" Style="vertical-align:middle; margin-right:4px;" />
                    @album.AssetCount @(album.AssetCount == 1 ? "foto" : "fotos")
                    @if (_content.ExpiresAt.HasValue)
                    {
                        <span style="margin-left:12px;">
                            <MudIcon Icon="@Icons.Material.Outlined.Schedule" Size="Size.Small" Style="vertical-align:middle; margin-right:4px;" />
                            Expira @_content.ExpiresAt.Value.ToString("d MMM yyyy")
                        </span>
                    }
                </MudText>
            </div>
        </div>

        @* ── Grid ─────────────────────────────────────────────────────────── *@
        @if (assets.Any())
        {
            <div class="share-album-grid-wrap">
                <div class="share-album-grid">
                    @foreach (var item in assets)
                    {
                        <div class="share-album-thumb @(_selectedAsset?.Id == item.Id ? "selected" : "")"
                             @onclick="() => SelectAsset(item)">
                            <img src="@item.ThumbnailUrl" alt="@item.FileName" loading="lazy" />
                            @if (item.Type == "VIDEO")
                            {
                                <div class="share-video-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* ── Lightbox ──────────────────────────────────────────────────────── *@
    @if (_selectedAsset != null)
    {
        <div class="share-lightbox" @onclick="() => _selectedAsset = null">
            <div class="share-lightbox-inner" @onclick:stopPropagation="true">
                @if (_selectedAsset.Type == "VIDEO")
                {
                    <video controls autoplay class="share-lightbox-media">
                        <source src="@_selectedAsset.ContentUrl" type="video/mp4" />
                    </video>
                }
                else
                {
                    <img src="@_selectedAsset.ContentUrl" alt="@_selectedAsset.FileName" class="share-lightbox-media" />
                }
                <div class="share-lightbox-bar">
                    <MudText Typo="Typo.caption" Style="color:white;">@_selectedAsset.FileName</MudText>
                    <div class="d-flex gap-1">
                        @if (_content!.AllowDownload)
                        {
                            <MudIconButton Icon="@Icons.Material.Outlined.Download"
                                           Color="Color.Inherit"
                                           Href="@($"{_selectedAsset.ContentUrl}?download=true")" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Color="Color.Inherit"
                                       OnClick="() => _selectedAsset = null" />
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    /* ── States ─────────────────────────────────────────── */
    .share-center {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 56px);
        color: rgba(255,255,255,0.6);
        padding: 24px;
        text-align: center;
    }

    /* ── Album hero ─────────────────────────────────────── */
    .share-album-view {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 56px);
    }

    .share-album-hero {
        position: relative;
        width: 100%;
        min-height: 360px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .share-album-hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        filter: blur(20px) brightness(0.7);
        transform: scale(1.1);
    }

    .share-album-hero-bg--empty {
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-dark) 100%);
        filter: brightness(0.7);
        transform: none;
    }

    .share-album-hero-actions {
        position: absolute;
        top: 8px;
        right: 8px;
        z-index: 2;
        color: white;
    }

    .share-album-hero-content {
        position: relative;
        z-index: 1;
        padding: 24px;
        background: linear-gradient(transparent, rgba(0,0,0,0.75));
    }

    /* ── Album grid ─────────────────────────────────────── */
    .share-album-grid-wrap {
        padding: 24px;
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
        box-sizing: border-box;
    }

    .share-album-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 4px;
    }

    .share-album-thumb {
        aspect-ratio: 1 / 1;
        overflow: hidden;
        cursor: pointer;
        position: relative;
        background: #2a2a2a;
        border-radius: 4px;
        border: 2px solid transparent;
        transition: opacity 0.15s;
    }
    .share-album-thumb:hover { opacity: 0.85; }
    .share-album-thumb.selected { border-color: var(--mud-palette-primary); }
    .share-album-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .share-video-badge {
        position: absolute;
        bottom: 6px;
        right: 6px;
        color: white;
        filter: drop-shadow(0 0 2px rgba(0,0,0,0.6));
    }

    /* ── Lightbox ───────────────────────────────────────── */
    .share-lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.92);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .share-lightbox-inner {
        display: flex;
        flex-direction: column;
        max-width: 95vw;
        max-height: 95vh;
    }
    .share-lightbox-media {
        max-width: 95vw;
        max-height: calc(95vh - 48px);
        object-fit: contain;
    }
    .share-lightbox-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 4px 4px 4px 12px;
        background: rgba(0,0,0,0.5);
    }
</style>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private SharedContentResponse? _content;
    private SharedAssetInfo? _selectedAsset;
    private bool _loading = true;
    private bool _expired = false;
    private bool _requiresPassword = false;
    private bool _wrongPassword = false;
    private string _password = string.Empty;

    private string _pageTitle => _content?.Album?.Name ?? "Álbum compartido";

    protected override async Task OnInitializedAsync()
    {
        await LoadContentAsync();
    }

    private async Task LoadContentAsync(string? password = null)
    {
        _loading = true;
        _requiresPassword = false;
        _wrongPassword = false;
        try
        {
            _content = await ShareService.GetSharedContentAsync(Token, password);
            if (_content?.RequiresPassword == true)
            {
                _requiresPassword = true;
                _wrongPassword = _content.WrongPassword;
                _content = null;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Gone)
        {
            _expired = true;
        }
        catch
        {
            _content = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitPassword()
    {
        if (string.IsNullOrEmpty(_password)) return;
        await LoadContentAsync(_password);
    }

    private async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitPassword();
    }

    private void SelectAsset(SharedAssetInfo asset)
    {
        _selectedAsset = asset;
    }

    private async Task DownloadAll()
    {
        if (_content?.Assets == null) return;
        foreach (var asset in _content.Assets)
        {
            await JS.InvokeVoidAsync("open", $"{asset.ContentUrl}?download=true", "_blank");
        }
    }
}
