@page "/map"
@inject IMapService MapService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

@inject LayoutService LayoutService
@inject IAssetListNavigationState AssetListNavigationState

<PageTitle>Mapa - Photonne</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0 map-fullscreen" Style="height: calc(100vh - 64px); position: relative;">
    @if (_loading)
    {
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }

    <div id="map-container" style="width: 100%; height: 100%; position: relative;">
        <div id="map" style="width: 100%; height: 100%;"></div>
    </div>
</MudContainer>

@* Bottom sheet — renderizado en el DOM del componente, sin portales externos *@
@if (_drawerOpen)
{
    <div style="position:fixed; inset:0; z-index:1999; background:rgba(0,0,0,0.5);"
         @onclick="CloseDrawer" />
    <div style="position:fixed; bottom:0; left:0; right:0; z-index:2000;
                background:var(--mud-palette-surface); border-radius:16px 16px 0 0;
                max-height:65vh; display:flex; flex-direction:column;
                box-shadow:0 -4px 24px rgba(0,0,0,0.35);">
        <div style="display:flex; align-items:center; padding:12px 16px 8px; flex-shrink:0;">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                @_drawerPoints.Count foto@(_drawerPoints.Count == 1 ? "" : "s")
            </MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="CloseDrawer" />
        </div>
        <div id="map-drawer-scroll" style="flex:1; min-height:0; overflow-y:auto;" @onclick:stopPropagation>
            <div class="map-drawer-grid">
                @{
                    var visible = Math.Min(_drawerVisibleCount, _drawerPoints.Count);
                }
                @for (var i = 0; i < visible; i++)
                {
                    var point = _drawerPoints[i];
                    <div class="map-drawer-cell"
                         @key="point.Id"
                         @onclick="@(() => OpenClusterAsset(point))">
                        @if (!string.IsNullOrEmpty(point.ThumbnailUrl))
                        {
                            <img src="@point.ThumbnailUrl"
                                 style="width:100%; height:100%; object-fit:cover; display:block;"
                                 loading="lazy"
                                 decoding="async" />
                        }
                    </div>
                }
            </div>
            @if (_drawerVisibleCount < _drawerPoints.Count)
            {
                <div id="map-drawer-sentinel" style="height:4px;"></div>
                <div style="display:flex; justify-content:center; padding:12px 0 16px;">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                </div>
            }
            else
            {
                <div style="height:16px;"></div>
            }
        </div>
    </div>
}

<style>
    #map {
        z-index: 0;
    }

    /* Bottom sheet grid: responsive, content-visibility for off-screen culling */
    .map-drawer-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 3px;
        padding: 0 8px 8px;
    }

    .map-drawer-cell {
        aspect-ratio: 1;
        cursor: pointer;
        border-radius: 4px;
        overflow: hidden;
        background: #333;
        /* Let the browser skip layout/paint when cell is off-screen */
        content-visibility: auto;
        contain-intrinsic-size: 110px 110px;
    }

    .map-cluster-icon {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
    }

    .map-cluster-icon img {
        border-radius: 50%;
    }

    /* Estilos simplificados para los controles de Leaflet */
    .leaflet-control {
        background: var(--mud-palette-surface) !important;
        color: var(--mud-palette-text-primary) !important;
        border-radius: 4px;
        box-shadow: 0 1px 5px rgba(0,0,0,0.4);
        border: 1px solid var(--mud-palette-divider) !important;
    }

    .leaflet-control-zoom a, .leaflet-control-locate a, .leaflet-control-fullscreen {
        background-color: var(--mud-palette-surface) !important;
        color: var(--mud-palette-text-primary) !important;
        border-bottom: 1px solid var(--mud-palette-divider) !important;
        width: 30px;
        height: 30px;
        line-height: 30px;
        text-align: center;
        text-decoration: none;
        display: block;
        font-size: 18px;
        font-weight: bold;
    }

    .leaflet-control-zoom a:hover, .leaflet-control-locate a:hover, .leaflet-control-fullscreen:hover {
        background-color: var(--mud-palette-background-grey) !important;
    }

    .leaflet-control-zoom-in {
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
    }

    .leaflet-control-zoom-out {
        border-bottom-left-radius: 4px;
        border-bottom-right-radius: 4px;
        border-bottom: none !important;
    }

    .leaflet-control-scale {
        background: var(--mud-palette-surface) !important;
        color: var(--mud-palette-text-primary) !important;
        border: 2px solid var(--mud-palette-divider) !important;
        border-top: none !important;
        line-height: 1.1;
        padding: 2px 5px 1px;
        font-size: 11px;
        white-space: nowrap;
        overflow: hidden;
        box-sizing: border-box;
    }
</style>

@code {
    private bool _loading = true;
    private DotNetObjectReference<Map>? _objRef;
    private string _mapStyle => LayoutService.IsDarkMode ? "dark" : "light";
    private List<MapPoint> _points = new();
    // Pre-built lookup so OnClusterClick is O(1) per asset id, even with 20k+ points
    private Dictionary<Guid, MapPoint>? _pointsById;

    private bool _drawerOpen = false;
    private List<MapPoint> _drawerPoints = new();
    // Paged rendering of the bottom sheet to avoid creating thousands of DOM nodes at once
    private const int DRAWER_INITIAL_BATCH = 120;
    private const int DRAWER_LOAD_MORE_BATCH = 120;
    private int _drawerVisibleCount = 0;
    private bool _drawerSentinelAttached = false;
    private bool _drawerLoadingMore = false;

    protected override async Task OnInitializedAsync()
    {
        _objRef = DotNetObjectReference.Create(this);
        LayoutService.OnMajorUpdate += OnLayoutUpdate;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _drawerSentinelAttached = false;
        _ = JS.InvokeVoidAsync("disconnectLoadMoreObserver", "map-drawer-sentinel");
    }

    private async void OnLayoutUpdate()
    {
        await JS.InvokeVoidAsync("mapHelpers.setStyle", _mapStyle);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await Task.Delay(100);
                await JS.InvokeVoidAsync("mapHelpers.initMap", "map", 40.4168, -3.7038, 6, _mapStyle);
                await Task.Delay(300);

                _loading = true;
                StateHasChanged();

                _points = await MapService.GetMapPointsAsync();

                Console.WriteLine($"[MAP] Loaded {_points.Count} GPS points");

                if (_points.Any())
                {
                    var jsPoints = _points.Select(p => new
                    {
                        id = p.Id.ToString(),
                        latitude = p.Latitude,
                        longitude = p.Longitude,
                        thumbnailUrl = p.ThumbnailUrl
                    }).ToList();

                    await JS.InvokeVoidAsync("mapHelpers.loadAllPoints", jsPoints, _objRef);

                    var stateRestored = await JS.InvokeAsync<bool>("mapHelpers.wasStateRestored");
                    if (!stateRestored)
                    {
                        var minLat = _points.Min(p => p.Latitude);
                        var minLng = _points.Min(p => p.Longitude);
                        var maxLat = _points.Max(p => p.Latitude);
                        var maxLng = _points.Max(p => p.Longitude);
                        var latPad = Math.Max((maxLat - minLat) * 0.1, 0.1);
                        var lngPad = Math.Max((maxLng - minLng) * 0.1, 0.1);

                        await JS.InvokeVoidAsync("mapHelpers.fitBounds",
                            minLat - latPad, minLng - lngPad,
                            maxLat + latPad, maxLng + lngPad);
                    }
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al inicializar el mapa: {ex.Message}", Severity.Error);
            }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
        }

        // (Re)attach the bottom-sheet load-more sentinel after each render where it's needed.
        // The flag prevents redundant JS interop calls between paged loads.
        if (_drawerOpen && !_drawerSentinelAttached && _drawerVisibleCount < _drawerPoints.Count && _objRef != null)
        {
            _drawerSentinelAttached = true;
            try
            {
                await JS.InvokeVoidAsync(
                    "setupLoadMoreObserver",
                    "map-drawer-sentinel",
                    _objRef,
                    nameof(LoadMoreDrawerItems),
                    "map-drawer-scroll",
                    "300px");
            }
            catch
            {
                _drawerSentinelAttached = false;
            }
        }
    }

    [JSInvokable]
    public async Task OnAssetClick(string assetId)
    {
        Console.WriteLine($"[MAP] OnAssetClick: {assetId}");
        if (Guid.TryParse(assetId, out var id))
        {
            await JS.InvokeVoidAsync("mapHelpers.destroyMap");
            // When clicking a single marker (no cluster), use all map points as nav list
            var navList = _points
                .OrderByDescending(p => p.Date)
                .Select(p => new TimelineItem { Id = p.Id, FileCreatedAt = p.Date, HasThumbnails = p.HasThumbnail })
                .ToList();
            AssetListNavigationState.SetList(navList, "map");
            Navigation.NavigateTo($"/asset/{id}?returnTo=map");
        }
    }

    [JSInvokable]
    public void OnClusterClick(string[] assetIds)
    {
        Console.WriteLine($"[MAP] OnClusterClick: {assetIds.Length} assets");

        // Lazy-build the dictionary the first time a cluster is clicked. Cached afterwards.
        if (_pointsById == null)
        {
            _pointsById = new Dictionary<Guid, MapPoint>(_points.Count);
            foreach (var p in _points)
                _pointsById[p.Id] = p;
        }

        // Filter using the dictionary: O(N) over assetIds with O(1) per lookup,
        // and avoids per-point ToString() allocations on the full _points list.
        var picked = new List<MapPoint>(assetIds.Length);
        foreach (var idStr in assetIds)
        {
            if (Guid.TryParse(idStr, out var id) && _pointsById.TryGetValue(id, out var point))
                picked.Add(point);
        }
        picked.Sort((a, b) => b.Date.CompareTo(a.Date));

        _drawerPoints = picked;
        _drawerVisibleCount = Math.Min(DRAWER_INITIAL_BATCH, _drawerPoints.Count);
        _drawerLoadingMore = false;
        _drawerSentinelAttached = false;
        _drawerOpen = true;
        StateHasChanged();
    }

    [JSInvokable]
    public Task LoadMoreDrawerItems()
    {
        if (_drawerLoadingMore) return Task.CompletedTask;
        if (_drawerVisibleCount >= _drawerPoints.Count) return Task.CompletedTask;

        _drawerLoadingMore = true;
        _drawerVisibleCount = Math.Min(_drawerVisibleCount + DRAWER_LOAD_MORE_BATCH, _drawerPoints.Count);
        // Force the sentinel to be re-attached after the next render so the
        // observer fires again if there's still more to load.
        _drawerSentinelAttached = false;
        StateHasChanged();
        _drawerLoadingMore = false;
        return Task.CompletedTask;
    }

    private async Task OpenClusterAsset(MapPoint point)
    {
        _drawerOpen = false;
        _drawerSentinelAttached = false;
        await JS.InvokeVoidAsync("disconnectLoadMoreObserver", "map-drawer-sentinel");
        await JS.InvokeVoidAsync("mapHelpers.destroyMap");
        // Only include assets from this cluster, not all map points
        var navList = _drawerPoints
            .Select(p => new TimelineItem { Id = p.Id, FileCreatedAt = p.Date, HasThumbnails = p.HasThumbnail })
            .ToList();
        AssetListNavigationState.SetList(navList, "map");
        Navigation.NavigateTo($"/asset/{point.Id}?returnTo=map");
    }

    public async ValueTask DisposeAsync()
    {
        LayoutService.OnMajorUpdate -= OnLayoutUpdate;
        _objRef?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("disconnectLoadMoreObserver", "map-drawer-sentinel");
        }
        catch
        {
            // ignore
        }
        try
        {
            // Safety net: si el usuario navegó de otra forma (p.ej. navMenu),
            // el mapa puede no haberse destruido aún — lo hacemos aquí.
            await JS.InvokeVoidAsync("mapHelpers.destroyMap");
        }
        catch
        {
            // El elemento ya puede estar fuera del DOM
        }
    }
}
