else
{
    <MudAlert Severity="Severity.Error" Class="mt-4">No se pudo cargar la información del archivo.</MudAlert>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Primary" OnClick="GoBack" Class="mt-2">@BackLabel</MudButton>
}

@code {
    [Parameter] public Guid AssetId { get; set; }
    [SupplyParameterFromQuery] public string? Path { get; set; }
    [SupplyParameterFromQuery] public Guid? AlbumId { get; set; }
    /// <summary>Ruta de retorno al volver (ej. folders/own, folders/shared, folders/{id}).</summary>
    [SupplyParameterFromQuery] public string? ReturnTo { get; set; }

    private string BackLabel => ReturnTo?.TrimStart('/') switch
    {
        null or "" => AlbumId.HasValue ? "Volver al álbum" : "Volver al Timeline",
        "favorites"               => "Volver a Favoritos",
        "archive"                 => "Volver al Archivo",
        "trash"                   => "Volver a la Papelera",
        "search"                  => "Volver a la Búsqueda",
        "map"                     => "Volver al Mapa",
        "my-shares"               => "Volver a Mis Compartidos",
        "utilities/duplicates"    => "Volver a Duplicados",
        "utilities/large-files"   => "Volver a Archivos grandes",
        var r when r.StartsWith("folders/") => "Volver a la Carpeta",
        _ => "Volver"
    };

    private Photonne.Client.Web.Models.AssetDetail? _asset;
    private string _displayContentUrl = string.Empty;
    private string _displayThumbnailUrl = string.Empty;
    private bool _loading = true;
    private bool _infoOpen = false;
    private bool _toolbarVisible = true;
    private bool _syncing = false;
    private bool _zoomed = false;
    private bool _imageLoadError = false;
    private bool _deleting = false;
    private bool _deleteConfirmOpen = false;
    private bool _isReadOnly => _asset?.IsReadOnly == true;
    private bool _tagBusy = false;
    private bool _favoriteBusy = false;
    private bool _archiveBusy = false;
    private bool _savingDescription = false;
    private string _descriptionEdit = string.Empty;
    private string _newTag = string.Empty;
    
    private TimelineItem? _prevAsset;
    private TimelineItem? _nextAsset;
    private List<TimelineItem> _allAssets = new();
    private bool _hasMoreBefore;
    private bool _hasMoreAfter;

    // Slideshow
    private bool _slideshowActive = false;
    private bool _slideshowPaused = false;
    private int _slideshowInterval = 5;
    private bool _slideshowControlsVisible = true;
    private int _slideshowProgressKey = 0;
    private System.Timers.Timer? _slideshowTimer;
    private System.Timers.Timer? _controlsHideTimer;

    private ElementReference _containerRef;
    private bool _enterAnimationPlayed = false;

    /// <summary>Evita cargar dos veces el mismo asset (OnInitializedAsync y OnParametersSetAsync se ejecutan ambos al navegar).</summary>
    private Guid _lastLoadedAssetId = Guid.Empty;
    private string _lastLoadedPath = string.Empty;
    private Guid _miniMapAssetId = Guid.Empty;

    /// <summary>Señal para evitar que LoadAsset() en vuelo llame UpdateNavbar() tras GoBack()/Dispose().</summary>
    private bool _navigatingAway;

    private bool CanEditTags => _asset != null && _asset.Id != Guid.Empty && _asset.SyncStatus == AssetSyncStatus.Synced;

    protected override void OnInitialized()
    {
        UpdateNavbar();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await DeviceLayout.InitializeAsync();
            DeviceLayout.OnChanged += OnDeviceLayoutChanged;
            StateHasChanged();
        }

        if (_containerRef.Context != null)
        {
            if (firstRender)
                await JSRuntime.InvokeVoidAsync("focusElement", _containerRef);

            if (!_enterAnimationPlayed)
            {
                _enterAnimationPlayed = true;
                await JSRuntime.InvokeVoidAsync("assetTransition.playEnterAnimation", _containerRef);
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Evitar doble carga: Blazor llama OnInitializedAsync y OnParametersSetAsync al montar; solo cargar cuando cambien los parámetros.
        if (AssetId == _lastLoadedAssetId && (Path ?? "") == _lastLoadedPath)
        {
            UpdateNavbar();
            return;
        }
        UpdateNavbar();
        await LoadAsset();
    }

    public void Dispose()
    {
        _navigatingAway = true;
        DeviceLayout.OnChanged -= OnDeviceLayoutChanged;
        LayoutService.ResetNavbar();
        DisposeSlideshowTimers();
        _ = JSRuntime.InvokeVoidAsync("miniMapHelpers.destroy", "asset-mini-map").AsTask();
    }

    private void UpdateNavbar()
    {
        var isDeviceAsset = _asset == null || _asset.Id == Guid.Empty;

        LayoutService.SetCustomNavbar(
            @<text>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" OnClick="GoBack" Edge="Edge.Start" />
                <MudSpacer />

                <div class="d-flex align-center gap-1">
                    @if (isDeviceAsset)
                    {
                        @* Dispositivo: Sync/Copied + Zoom + Info *@
                        @if (_asset != null && _asset.SyncStatus == AssetSyncStatus.Pending)
                        {
                            <MudTooltip Text="Sincronizar ahora">
                                <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                                               Color="Color.Inherit"
                                               OnClick="SyncAsset"
                                               Disabled="@_syncing" />
                            </MudTooltip>
                        }
                        else if (_asset != null && _asset.SyncStatus == AssetSyncStatus.Copied)
                        {
                            <MudTooltip Text="Pendiente de indexar">
                                <MudIconButton Icon="@Icons.Material.Outlined.Schedule"
                                               Color="Color.Inherit"
                                               OnClick="NavigateToIndex" />
                            </MudTooltip>
                        }

                        <MudTooltip Text="@(_zoomed ? "Ajustar" : "Zoom")">
                            <MudIconButton Icon="@(_zoomed ? Icons.Material.Outlined.ZoomOut : Icons.Material.Outlined.ZoomIn)"
                                           Color="Color.Inherit" OnClick="ToggleZoom" />
                        </MudTooltip>

                        <MudTooltip Text="Información">
                            <MudIconButton Icon="@(_infoOpen ? Icons.Material.Filled.Info : Icons.Material.Outlined.Info)"
                                           Color="Color.Inherit" OnClick="ToggleInfo" />
                        </MudTooltip>
                    }
                    else
                    {
                        @* Indexado: Favorito · Zoom · Info · Descargar · Añadir álbum · Slideshow · Archivar · Eliminar *@

                        @* Favorito — siempre visible *@
                        <MudTooltip Text="@(_asset != null && _asset.IsFavorite ? "Quitar de favoritos" : "Añadir a favoritos")">
                            <MudIconButton Icon="@(_asset != null && _asset.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                                           Color="@(_asset != null && _asset.IsFavorite ? Color.Error : Color.Inherit)"
                                           OnClick="ToggleFavoriteAsync"
                                           Disabled="@_favoriteBusy" />
                        </MudTooltip>

                        @* Info — siempre visible *@
                        <MudTooltip Text="Información">
                            <MudIconButton Icon="@(_infoOpen ? Icons.Material.Filled.Info : Icons.Material.Outlined.Info)"
                                           Color="Color.Inherit" OnClick="ToggleInfo" />
                        </MudTooltip>

                        @* Añadir a álbum — siempre visible *@
                        <MudTooltip Text="Añadir a álbum">
                            <MudIconButton Icon="@Icons.Material.Outlined.AddPhotoAlternate"
                                           Color="Color.Inherit" OnClick="OpenAddToAlbumDialog" />
                        </MudTooltip>

                        @* Botones secundarios — solo en md+ *@
                        <span class="d-none d-md-flex align-center">
                            <MudTooltip Text="@(_zoomed ? "Ajustar" : "Zoom")">
                                <MudIconButton Icon="@(_zoomed ? Icons.Material.Outlined.ZoomOut : Icons.Material.Outlined.ZoomIn)"
                                               Color="Color.Inherit" OnClick="ToggleZoom" />
                            </MudTooltip>
                            <MudTooltip Text="Descargar">
                                <MudIconButton Icon="@Icons.Material.Outlined.Download"
                                               Color="Color.Inherit" OnClick="DownloadAsset" />
                            </MudTooltip>
                            @if (_allAssets.Count > 1)
                            {
                                <MudTooltip Text="Presentación">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Slideshow"
                                                   Color="Color.Inherit" OnClick="StartSlideshow" />
                                </MudTooltip>
                            }
                            @if (!_isReadOnly)
                            {
                                <MudTooltip Text="@(_asset != null && _asset.IsArchived ? "Quitar del archivo" : "Archivar")">
                                    <MudIconButton Icon="@(_asset != null && _asset.IsArchived ? Icons.Material.Filled.Unarchive : Icons.Material.Outlined.Archive)"
                                                   Color="Color.Inherit"
                                                   OnClick="ToggleArchiveAsync"
                                                   Disabled="@_archiveBusy" />
                                </MudTooltip>
                                <MudTooltip Text="Eliminar">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                   Color="Color.Error"
                                                   OnClick="@(() => _deleteConfirmOpen = true)"
                                                   Disabled="@_deleting" />
                                </MudTooltip>
                            }
                        </span>

                        @* Menú de desbordamiento — solo en móvil *@
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit"
                                 AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                                 Class="d-flex d-md-none">
                            <MudMenuItem Icon="@(_zoomed ? Icons.Material.Outlined.ZoomOut : Icons.Material.Outlined.ZoomIn)"
                                         OnClick="ToggleZoom">
                                @(_zoomed ? "Ajustar" : "Zoom")
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Outlined.Download" OnClick="DownloadAsset">
                                Descargar
                            </MudMenuItem>
                            @if (_allAssets.Count > 1)
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.Slideshow" OnClick="StartSlideshow">
                                    Presentación
                                </MudMenuItem>
                            }
                            @if (!_isReadOnly)
                            {
                                <MudMenuItem Icon="@(_asset != null && _asset.IsArchived ? Icons.Material.Filled.Unarchive : Icons.Material.Outlined.Archive)"
                                             OnClick="ToggleArchiveAsync">
                                    @(_asset != null && _asset.IsArchived ? "Quitar del archivo" : "Archivar")
                                </MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Outlined.Delete"
                                             IconColor="Color.Error"
                                             OnClick="@(() => _deleteConfirmOpen = true)">
                                    <MudText Color="Color.Error">Eliminar</MudText>
                                </MudMenuItem>
                            }
                        </MudMenu>
                    }
                </div>
            </text>,
            overlay: true
        );
    }

    private async Task LoadAsset()
    {
        _navigatingAway = false;
        _imageLoadError = false;
        try
        {
            _loading = true;
            Console.WriteLine($"[AssetDetail] LoadAsset start. AssetId={AssetId}, Path={Path}");
            if (AssetId != Guid.Empty)
            {
                _asset = await AssetService.GetAssetDetailAsync(AssetId);
            }
            else if (!string.IsNullOrEmpty(Path))
            {
                _asset = await PendingAssetsProvider.GetPendingAssetDetailAsync(Path);
            }
            Console.WriteLine($"[AssetDetail] Asset loaded: {_asset != null}, IsFileMissing={_asset?.IsFileMissing}, Type={_asset?.Type}, HasThumbnails={_asset?.HasThumbnails}");

            // Actualizar el navbar una vez cargado el asset para habilitar botones
            // Asegurar que se actualice después de cargar el asset
            if (_asset != null && !_navigatingAway)
            {
                _descriptionEdit = _asset.Caption ?? string.Empty;
                await UpdateAssetDisplayUrlsAsync();
                Console.WriteLine($"[AssetDetail] URLs set: content='{_displayContentUrl}', thumb='{_displayThumbnailUrl}', imageLoadError={_imageLoadError}");
                if (!_navigatingAway)
                {
                    UpdateNavbar();
                    StateHasChanged();
                    Console.WriteLine("[AssetDetail] StateHasChanged called after URL setup");
                }
                else
                {
                    Console.WriteLine("[AssetDetail] SKIPPED StateHasChanged - _navigatingAway=true");
                }
            }
            else
            {
                Console.WriteLine($"[AssetDetail] SKIPPED URL setup - _asset={_asset != null}, _navigatingAway={_navigatingAway}");
            }
            
            if (_allAssets.Count == 0)
            {
                var navContextKey = GetNavigationContextKey();
                var listFromNavigation = AssetListNavigationState.TryGetList(navContextKey);
                if (listFromNavigation != null)
                {
                    _allAssets = listFromNavigation;
                }
                else if (AlbumId.HasValue && AlbumId.Value != Guid.Empty)
                {
                    _allAssets = await AlbumService.GetAlbumAssetsAsync(AlbumId.Value);
                }
                else if (AssetId != Guid.Empty && ReturnTo is not ("archive" or "trash" or "my-shares"
                    or "utilities/duplicates" or "utilities/large-files")
                    && !(ReturnTo?.StartsWith("folders/") == true)
                    && ReturnTo != "map")
                {
                    var neighbors = await AssetService.GetTimelineNeighborsAsync(AssetId);
                    _allAssets = neighbors.Items.Select(n => new TimelineItem
                    {
                        Id = n.Id,
                        FullPath = n.FullPath,
                        FileCreatedAt = n.FileCreatedAt,
                        SyncStatus = AssetSyncStatus.Synced
                    }).ToList();
                    _hasMoreBefore = neighbors.HasMoreBefore;
                    _hasMoreAfter = neighbors.HasMoreAfter;
                }
            }
            
            if (_navigatingAway) return;

            UpdateNavigation();
            UpdateNavbar(); // refresh after _allAssets is populated (slideshow button visibility)
            _lastLoadedAssetId = AssetId;
            _lastLoadedPath = Path ?? string.Empty;

            // Reinicializar el minimapa si el panel de info estaba abierto y el asset cambió
            if (_infoOpen && _asset != null)
            {
                var hasGps = _asset.Exif?.Latitude.HasValue == true && _asset.Exif?.Longitude.HasValue == true;
                if (hasGps && _miniMapAssetId != _asset.Id)
                {
                    _miniMapAssetId = _asset.Id;
                    _ = JSRuntime.InvokeVoidAsync("miniMapHelpers.initWhenVisible",
                        "asset-mini-map",
                        _asset.Exif!.Latitude!.Value,
                        _asset.Exif.Longitude!.Value,
                        LayoutService.IsDarkMode).AsTask();
                }
                else if (!hasGps && _miniMapAssetId != Guid.Empty)
                {
                    _miniMapAssetId = Guid.Empty;
                    _ = JSRuntime.InvokeVoidAsync("miniMapHelpers.destroy", "asset-mini-map").AsTask();
                }
            }

            if (_slideshowActive && !_slideshowPaused)
            {
                _slideshowProgressKey++;
                StartSlideshowTimer();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar archivo: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void UpdateNavigation()
    {
        int currentIndex = -1;
        if (AssetId != Guid.Empty)
        {
            currentIndex = _allAssets.FindIndex(a => a.Id == AssetId);
        }
        else if (!string.IsNullOrEmpty(Path))
        {
            currentIndex = _allAssets.FindIndex(a => a.FullPath == Path);
        }

        if (currentIndex != -1)
        {
            _prevAsset = currentIndex > 0 ? _allAssets[currentIndex - 1] : null;
            _nextAsset = currentIndex < _allAssets.Count - 1 ? _allAssets[currentIndex + 1] : null;

            // Prefetch more items when approaching window edges
            const int edgeThreshold = 10;
            if (_hasMoreBefore && currentIndex < edgeThreshold)
            {
                _ = ExpandWindowBeforeAsync();
            }
            else if (_hasMoreAfter && currentIndex > _allAssets.Count - 1 - edgeThreshold)
            {
                _ = ExpandWindowAfterAsync();
            }
        }
    }

    private async Task ExpandWindowBeforeAsync()
    {
        if (!_hasMoreBefore || _allAssets.Count == 0) return;
        var firstId = _allAssets[0].Id;
        if (firstId == Guid.Empty) return;

        var neighbors = await AssetService.GetTimelineNeighborsAsync(firstId, before: 50, after: 0);
        if (neighbors.Items.Count <= 1) { _hasMoreBefore = false; return; }

        // Items before the first asset (exclude the first asset itself which is at CurrentIndex)
        var newItems = neighbors.Items
            .Take(neighbors.CurrentIndex)
            .Select(n => new TimelineItem
            {
                Id = n.Id, FullPath = n.FullPath, FileCreatedAt = n.FileCreatedAt,
                SyncStatus = AssetSyncStatus.Synced
            })
            .ToList();

        if (newItems.Count > 0)
        {
            _allAssets.InsertRange(0, newItems);
        }
        _hasMoreBefore = neighbors.HasMoreBefore;
    }

    private async Task ExpandWindowAfterAsync()
    {
        if (!_hasMoreAfter || _allAssets.Count == 0) return;
        var lastId = _allAssets[^1].Id;
        if (lastId == Guid.Empty) return;

        var neighbors = await AssetService.GetTimelineNeighborsAsync(lastId, before: 0, after: 50);
        if (neighbors.Items.Count <= 1) { _hasMoreAfter = false; return; }

        // Items after the last asset (exclude the last asset itself which is at CurrentIndex)
        var newItems = neighbors.Items
            .Skip(neighbors.CurrentIndex + 1)
            .Select(n => new TimelineItem
            {
                Id = n.Id, FullPath = n.FullPath, FileCreatedAt = n.FileCreatedAt,
                SyncStatus = AssetSyncStatus.Synced
            })
            .ToList();

        if (newItems.Count > 0)
        {
            _allAssets.AddRange(newItems);
        }
        _hasMoreAfter = neighbors.HasMoreAfter;
    }

    private async Task UpdateAssetDisplayUrlsAsync()
    {
        if (_asset == null)
        {
            _displayContentUrl = string.Empty;
            _displayThumbnailUrl = string.Empty;
            return;
        }

        var contentUrl = _asset.ContentUrl;
        var thumbnailUrl = _asset.ThumbnailUrl;

        if (_asset.Id == Guid.Empty)
        {
            var token = await AuthService.GetTokenAsync();
            contentUrl = AppendAccessToken(contentUrl, token);
            thumbnailUrl = AppendAccessToken(thumbnailUrl, token);
        }

        _displayContentUrl = contentUrl;
        _displayThumbnailUrl = thumbnailUrl;
        _imageLoadError = false;
    }

    private static string AppendAccessToken(string url, string? token)
    {
        if (string.IsNullOrWhiteSpace(token) || url.Contains("access_token=", StringComparison.OrdinalIgnoreCase))
        {
            return url;
        }

        var separator = url.Contains('?') ? "&" : "?";
        return $"{url}{separator}access_token={Uri.EscapeDataString(token)}";
    }

    /// <summary>
    /// Deriva la clave de contexto de navegación a partir de los parámetros de la URL.
    /// Debe coincidir con lo que el origen (Folders, Map, Albums, etc.) pasó a SetList().
    /// </summary>
    private string? GetNavigationContextKey()
    {
        if (AlbumId.HasValue && AlbumId.Value != Guid.Empty)
            return $"album:{AlbumId.Value}";

        if (ReturnTo != null)
        {
            // "folders/{guid}" → "folder:{guid}"
            if (ReturnTo.StartsWith("folders/") && Guid.TryParse(ReturnTo.AsSpan(8), out var folderId))
                return $"folder:{folderId}";
            if (ReturnTo == "map")
                return "map";
            if (ReturnTo == "favorites")
                return "favorites";
            if (ReturnTo == "search")
                return "search";
        }

        return null; // timeline
    }

    private void NavigatePrev()
    {
        NavigateToAsset(_prevAsset);
    }

    private void NavigateNext()
    {
        NavigateToAsset(_nextAsset);
    }

    private void NavigateToAsset(TimelineItem? asset)
    {
        if (asset == null) return;

        var albumQuery = AlbumId.HasValue ? $"&albumId={AlbumId}" : "";
        var returnToQuery = !string.IsNullOrEmpty(ReturnTo) ? $"&returnTo={System.Net.WebUtility.UrlEncode(ReturnTo)}" : "";

        if (asset.SyncStatus == AssetSyncStatus.Synced)
        {
            var query = (albumQuery.TrimStart('&') + returnToQuery).TrimStart('&');
            Navigation.NavigateTo($"/asset/{asset.Id}{(string.IsNullOrEmpty(query) ? "" : "?")}{query}");
        }
        else
        {
            var encodedPath = System.Net.WebUtility.UrlEncode(asset.FullPath);
            Navigation.NavigateTo($"/asset/{Guid.Empty}?path={encodedPath}{albumQuery}{returnToQuery}");
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowLeft") NavigatePrev();
        else if (e.Key == "ArrowRight") NavigateNext();
        else if (e.Key == " ") { if (_slideshowActive) ToggleSlideshowPause(); }
        else if (e.Key == "Escape")
        {
            if (_slideshowActive) StopSlideshow();
            else if (_zoomed) { _zoomed = false; UpdateNavbar(); }
            else GoBack();
        }
    }

    private void GoBack()
    {
        _navigatingAway = true;
        // Restaurar navbar y menú lateral antes de navegar para que al llegar a la página destino se vea el drawer
        LayoutService.ResetNavbar();

        if (!string.IsNullOrEmpty(ReturnTo))
        {
            var path = ReturnTo.TrimStart('/');
            Navigation.NavigateTo("/" + path);
            return;
        }
        if (AlbumId.HasValue && AlbumId.Value != Guid.Empty)
        {
            Navigation.NavigateTo($"/albums/{AlbumId.Value}");
        }
        else if (!string.IsNullOrEmpty(Path))
        {
            // Abierto desde Mi Dispositivo (o similar con path local)
            Navigation.NavigateTo("/device");
        }
        else
        {
            Navigation.NavigateTo("/");
        }
    }

    private void NavigateToIndex()
    {
        Navigation.NavigateTo("/admin/tasks/index");
    }

    private void ToggleInfo()
    {
        _infoOpen = !_infoOpen;
        UpdateNavbar();
        StateHasChanged();

        if (_infoOpen && _asset?.Exif?.Latitude.HasValue == true && _asset.Exif.Longitude.HasValue
            && _miniMapAssetId != _asset.Id)
        {
            _miniMapAssetId = _asset.Id;
            _ = JSRuntime.InvokeVoidAsync("miniMapHelpers.initWhenVisible",
                "asset-mini-map",
                _asset.Exif.Latitude.Value,
                _asset.Exif.Longitude.Value,
                LayoutService.IsDarkMode).AsTask();
        }
    }

    private double _touchStartX;
    private bool _swipeHandled;

    private void HandleTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
            _touchStartX = e.Touches[0].ClientX;
        _swipeHandled = false;
    }

    private void HandleTouchEnd(TouchEventArgs e)
    {
        if (e.ChangedTouches.Length == 0) return;
        var deltaX = e.ChangedTouches[0].ClientX - _touchStartX;
        if (Math.Abs(deltaX) < 50) return;
        _swipeHandled = true;
        if (deltaX < 0) NavigateNext();
        else NavigatePrev();
    }

    private void ToggleToolbar()
    {
        if (_swipeHandled)
        {
            _swipeHandled = false;
            return;
        }
        if (_zoomed)
        {
            _zoomed = false;
            UpdateNavbar();
            return;
        }
        _toolbarVisible = !_toolbarVisible;
    }

    private void ToggleZoom()
    {
        _zoomed = !_zoomed;
        UpdateNavbar();
        StateHasChanged();
    }

    private async Task SaveDescriptionAsync()
    {
        if (_asset == null || _asset.Id == Guid.Empty || _savingDescription) return;
        try
        {
            _savingDescription = true;
            _asset.Caption = await AssetService.UpdateDescriptionAsync(_asset.Id, _descriptionEdit);
            _descriptionEdit = _asset.Caption ?? string.Empty;
            Snackbar.Add("Descripción guardada", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al guardar la descripción: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingDescription = false;
        }
    }

    private async Task ToggleFavoriteAsync()
    {
        if (_asset == null || _asset.Id == Guid.Empty || _favoriteBusy) return;
        try
        {
            _favoriteBusy = true;
            UpdateNavbar();
            _asset.IsFavorite = await AssetService.ToggleFavoriteAsync(_asset.Id);
            UpdateNavbar();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al actualizar favorito: {ex.Message}", Severity.Error);
        }
        finally
        {
            _favoriteBusy = false;
            StateHasChanged();
        }
    }

    private async Task ToggleArchiveAsync()
    {
        if (_asset == null || _asset.Id == Guid.Empty || _archiveBusy) return;
        try
        {
            _archiveBusy = true;
            UpdateNavbar();
            if (_asset.IsArchived)
            {
                await AssetService.UnarchiveAssetsAsync(new UnarchiveAssetsRequest { AssetIds = [_asset.Id] });
                _asset.IsArchived = false;
            }
            else
            {
                await AssetService.ArchiveAssetsAsync(new ArchiveAssetsRequest { AssetIds = [_asset.Id] });
                _asset.IsArchived = true;
            }
            UpdateNavbar();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al archivar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _archiveBusy = false;
            StateHasChanged();
        }
    }

    private async Task DownloadAsset()
    {
        if (_asset == null || _asset.Id == Guid.Empty) return;
        var url = $"/api/assets/{_asset.Id}/content?download=true";
        await JSRuntime.InvokeVoidAsync("downloadAsset", url, _asset.FileName);
    }

    private async Task DeleteAssetAsync()
    {
        if (_asset == null || _asset.Id == Guid.Empty) return;
        try
        {
            _deleting = true;
            _deleteConfirmOpen = false;
            UpdateNavbar();
            StateHasChanged();
            await AssetService.DeleteAssetsAsync(new DeleteAssetsRequest { AssetIds = [_asset.Id] });
            Snackbar.Add("Archivo enviado a la papelera", Severity.Success);
            GoBack();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleting = false;
            UpdateNavbar();
        }
    }

    private async Task AddTagAsync()
    {
        if (!CanEditTags || _asset == null || _tagBusy)
        {
            return;
        }

        var tag = _newTag.Trim();
        if (string.IsNullOrWhiteSpace(tag))
        {
            return;
        }

        try
        {
            _tagBusy = true;
            var tags = await AssetService.AddAssetTagsAsync(_asset.Id, new List<string> { tag });
            _asset.Tags = tags;
            _newTag = string.Empty;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo añadir la etiqueta: {ex.Message}", Severity.Error);
        }
        finally
        {
            _tagBusy = false;
        }
    }

    private async Task RemoveTagAsync(string tag)
    {
        if (!CanEditTags || _asset == null || _tagBusy)
        {
            return;
        }

        try
        {
            _tagBusy = true;
            var tags = await AssetService.RemoveAssetTagAsync(_asset.Id, tag);
            _asset.Tags = tags;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo eliminar la etiqueta: {ex.Message}", Severity.Error);
        }
        finally
        {
            _tagBusy = false;
        }
    }

    private async Task SyncAsset()
    {
        if (_asset == null || string.IsNullOrEmpty(_asset.FullPath) || _syncing) return;

        try
        {
            _syncing = true;
            UpdateNavbar();
            StateHasChanged();

            var result = await AssetService.SyncAssetAsync(_asset.FullPath);
            if (result != null && !string.IsNullOrEmpty(result.Message))
            {
                Snackbar.Add(result.Message, Severity.Success);
                
                // Si tiene AssetId, significa que ya estaba indexado, navegar a él
                if (result.AssetId.HasValue)
                {
                    Navigation.NavigateTo($"/asset/{result.AssetId.Value}");
                    return;
                }
                
                // Si no tiene AssetId, el archivo se copió pero aún no está indexado
                // Actualizar el estado del asset y recargar usando la nueva ruta
                if (!string.IsNullOrEmpty(result.TargetPath))
                {
                    // Recargar el asset con la nueva ruta para obtener el estado actualizado
                    // El endpoint AssetPendingEndpoint determinará automáticamente que está en Copied
                    Path = result.TargetPath;
                    AssetId = Guid.Empty; // Asegurar que se use el path en lugar del ID
                    await LoadAsset();
                    
                    // Asegurar que el navbar se actualice después de cargar completamente
                    // Esperar un momento para que el estado se actualice
                    await Task.Delay(100);
                    UpdateNavbar();
                    StateHasChanged();
                }
                else
                {
                    // Si no hay TargetPath, actualizar el estado manualmente
                    if (_asset != null)
                    {
                        _asset.SyncStatus = AssetSyncStatus.Copied;
                    }
                    UpdateNavbar();
                    StateHasChanged();
                }
            }
            else
            {
                Snackbar.Add("Error al sincronizar el asset", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
            UpdateNavbar();
            StateHasChanged();
        }
    }

    private string GetAssetIcon(string type)
    {
        return type == "Image" ? Icons.Material.Filled.Image : Icons.Material.Filled.VideoLibrary;
    }

    private string GetNavButtonClass(bool isPrev)
