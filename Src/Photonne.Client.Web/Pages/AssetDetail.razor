@page "/asset/{AssetId:guid}"
@implements IDisposable
@inject IAssetService AssetService
@inject IPendingAssetsProvider PendingAssetsProvider
@inject IAuthService AuthService
@inject IAlbumService AlbumService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject LayoutService LayoutService
@inject IAssetListNavigationState AssetListNavigationState
@inject IJSRuntime JSRuntime
@inject DeviceLayoutService DeviceLayout

<PageTitle>Detalle - Photonne</PageTitle>

@if (_loading && _asset == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}
else if (_asset != null && !string.IsNullOrEmpty(_displayContentUrl))
{
    @if (DeviceLayout.IsMobile)
    {
        <AssetDetailMobileView Asset="_asset"
                               Loading="_loading"
                               InfoOpen="_infoOpen"
                               Zoomed="_zoomed"
                               ToolbarVisible="_toolbarVisible"
                               PrevAsset="_prevAsset"
                               NextAsset="_nextAsset"
                               DisplayContentUrl="_displayContentUrl"
                               DisplayThumbnailUrl="_displayThumbnailUrl"
                               ImageLoadError="_imageLoadError"
                               AssetIcon="@GetAssetIcon(_asset.Type)"
                               NavButtonPrevClass="@GetNavButtonClass(true)"
                               NavButtonNextClass="@GetNavButtonClass(false)"
                               SlideshowActive="_slideshowActive"
                               SlideshowPaused="_slideshowPaused"
                               SlideshowControlsVisible="_slideshowControlsVisible"
                               SlideshowInterval="_slideshowInterval"
                               SlideshowProgressKey="_slideshowProgressKey"
                               AddToAlbumDialogVisible="_addToAlbumDialogVisible"
                               AvailableAlbums="_availableAlbums"
                               LoadingAlbums="_loadingAlbums"
                               SelectedAlbumId="_selectedAlbumId"
                               ShowCreateAlbum="_showCreateAlbum"
                               NewAlbumName="_newAlbumName"
                               NewAlbumDescription="_newAlbumDescription"
                               DescriptionEdit="_descriptionEdit"
                               SavingDescription="_savingDescription"
                               NewTag="_newTag"
                               TagBusy="_tagBusy"
                               CanEditTags="CanEditTags"
                               ContainerRefChanged="OnContainerRefChanged"
                               OnToggleToolbar="ToggleToolbar"
                               OnToggleInfo="ToggleInfo"
                               OnNavigatePrev="NavigatePrev"
                               OnNavigateNext="NavigateNext"
                               OnKeyDown="HandleKeyDown"
                               OnTouchStart="HandleTouchStart"
                               OnTouchEnd="HandleTouchEnd"
                               OnImageError="OnImageLoadError"
                               OnSlideshowMouseMove="OnSlideshowMouseMove"
                               OnToggleSlideshowPause="ToggleSlideshowPause"
                               OnSetSlideshowInterval="SetSlideshowInterval"
                               OnStopSlideshow="StopSlideshow"
                               OnCloseAddToAlbumDrawer="CloseAddToAlbumDrawer"
                               OnAddToAlbum="AddToAlbum"
                               OnCreateAlbumAndAdd="CreateAlbumAndAdd"
                               OnShowCreateAlbum="@(() => _showCreateAlbum = true)"
                               OnHideCreateAlbum="@(() => _showCreateAlbum = false)"
                               OnSelectedAlbumIdChanged="@(v => _selectedAlbumId = v)"
                               OnNewAlbumNameChanged="@(v => _newAlbumName = v)"
                               OnNewAlbumDescriptionChanged="@(v => _newAlbumDescription = v)"
                               OnDescriptionEditChanged="@(v => _descriptionEdit = v)"
                               OnSaveDescription="SaveDescriptionAsync"
                               OnNewTagChanged="@(v => _newTag = v)"
                               OnAddTag="AddTagAsync"
                               OnRemoveTag="RemoveTagAsync" />
    }
    else
    {
        <AssetDetailDesktopView Asset="_asset"
                                Loading="_loading"
                                InfoOpen="_infoOpen"
                                Zoomed="_zoomed"
                                ToolbarVisible="_toolbarVisible"
                                PrevAsset="_prevAsset"
                                NextAsset="_nextAsset"
                                DisplayContentUrl="_displayContentUrl"
                                DisplayThumbnailUrl="_displayThumbnailUrl"
                                ImageLoadError="_imageLoadError"
                                AssetIcon="@GetAssetIcon(_asset.Type)"
                                NavButtonPrevClass="@GetNavButtonClass(true)"
                                NavButtonNextClass="@GetNavButtonClass(false)"
                                SlideshowActive="_slideshowActive"
                                SlideshowPaused="_slideshowPaused"
                                SlideshowControlsVisible="_slideshowControlsVisible"
                                SlideshowInterval="_slideshowInterval"
                                SlideshowProgressKey="_slideshowProgressKey"
                                AddToAlbumDialogVisible="_addToAlbumDialogVisible"
                                AvailableAlbums="_availableAlbums"
                                LoadingAlbums="_loadingAlbums"
                                SelectedAlbumId="_selectedAlbumId"
                                ShowCreateAlbum="_showCreateAlbum"
                                NewAlbumName="_newAlbumName"
                                NewAlbumDescription="_newAlbumDescription"
                                DescriptionEdit="_descriptionEdit"
                                SavingDescription="_savingDescription"
                                NewTag="_newTag"
                                TagBusy="_tagBusy"
                                CanEditTags="CanEditTags"
                                ContainerRefChanged="OnContainerRefChanged"
                                OnToggleToolbar="ToggleToolbar"
