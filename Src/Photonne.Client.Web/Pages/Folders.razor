    private enum FolderSort
    {
        Name,
        AssetCount
    }

    private enum FolderViewMode
    {
        Grid,
        List
    }
    
    private int _activeTab;
    private FolderViewMode _folderViewMode = FolderViewMode.Grid;

    private async Task OnViewModeChanged(FolderViewMode mode)
    {
        _folderViewMode = mode;
        await JS.InvokeVoidAsync("localStorage.setItem", "photonne:folders:viewMode", mode.ToString());
    }

    private async Task OnFolderSortChanged(FolderSort sort)
    {
        _folderSort = sort;
        await JS.InvokeVoidAsync("localStorage.setItem", "photonne:folders:sort", sort.ToString());
    }

    private List<FolderItem> GetFilteredFolders(List<FolderItem> source)
    {
        var filtered = source;
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            filtered = source.Where(f => f.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        return _folderSort switch
        {
            FolderSort.Name => filtered.OrderBy(f => f.Name).ToList(),
            FolderSort.AssetCount => filtered.OrderByDescending(f => f.AssetCount).ToList(),
            _ => filtered
        };
    }

    // Cached filtered/sorted subfolders — avoids recomputing during a single render pass
    // (called up to 4 times per render). Invalidated when inputs change.
    private List<FolderItem>? _filteredSubFoldersCache;
    private string? _filteredSubFoldersSearchKey;
    private FolderSort _filteredSubFoldersSortKey;
    private int _filteredSubFoldersVersion;
    private int _subFoldersVersion;

    private List<FolderItem> GetFilteredSubFolders()
    {
        if (_filteredSubFoldersCache != null
            && _filteredSubFoldersSearchKey == _searchQuery
            && _filteredSubFoldersSortKey == _folderSort
            && _filteredSubFoldersVersion == _subFoldersVersion)
        {
            return _filteredSubFoldersCache;
        }

        var filtered = _subFoldersWithThumbnails;
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            filtered = _subFoldersWithThumbnails.Where(f => f.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        _filteredSubFoldersCache = _folderSort switch
        {
            FolderSort.Name => filtered.OrderBy(f => f.Name).ToList(),
            FolderSort.AssetCount => filtered.OrderByDescending(f => f.AssetCount).ToList(),
            _ => filtered
        };
        _filteredSubFoldersSearchKey = _searchQuery;
        _filteredSubFoldersSortKey = _folderSort;
        _filteredSubFoldersVersion = _subFoldersVersion;
        return _filteredSubFoldersCache;
    }

    private void OnTabChanged(int index)
    {
        _activeTab = index;
        string space = index switch { 1 => "shared", 2 => "libraries", _ => "own" };
        Navigation.NavigateTo($"/folders/{space}");
    }

    private void NavigateUp()
    {
        if (_selectedFolder != null)
        {
            var path = _selectedFolder.Path.Replace('\\', '/');
            bool isShared = _selectedFolder.IsShared || path.StartsWith("/assets/shared", StringComparison.OrdinalIgnoreCase);

            // Contexto de biblioteca externa
            if (_selectedFolder.ExternalLibraryId.HasValue)
            {
                if (IsLibraryRootFolder(_selectedFolder))
                {
                    // En la raíz de la biblioteca → volver a la lista de bibliotecas
                    _currentLibraryId = null;
                    Navigation.NavigateTo("/folders/libraries");
                    return;
                }

                // Subir al padre: si el padre también es de la misma biblioteca, navegar a él;
                // si el padre no pertenece a la biblioteca, volver a la raíz de la biblioteca
                if (_selectedFolder.ParentFolderId.HasValue)
                {
                    var parentFolder = _allFolders.FirstOrDefault(f => f.Id == _selectedFolder.ParentFolderId);
                    if (parentFolder?.ExternalLibraryId == _selectedFolder.ExternalLibraryId)
                    {
                        Navigation.NavigateTo($"/folders/{_selectedFolder.ParentFolderId}");
                        return;
                    }
                }
                // Padre fuera de la biblioteca → volver a la raíz de la biblioteca
                Navigation.NavigateTo($"/folders/library/{_selectedFolder.ExternalLibraryId}");
                return;
            }

            // Si ya estamos en una raíz (Personal o Compartida), ir a la selección de espacio (aquí ya debería estar en /folders/own o /folders/shared)
            if (IsUserRootPath(path) || path.TrimEnd('/').Equals("/assets/shared", StringComparison.OrdinalIgnoreCase))
            {
                // Ya estamos en la raíz, NavigateUp no debería ser llamado porque el botón está oculto,
                // pero por si acaso redirigimos a la URL limpia.
                string space = isShared ? "shared" : "own";
                Navigation.NavigateTo($"/folders/{space}");
                return;
            }

            if (_selectedFolder.ParentFolderId != null)
            {
                // Si al subir llegaríamos a la raíz del usuario o compartida, ir a la vista de "espacios"
                var parentFolder = _allFolders.FirstOrDefault(f => f.Id == _selectedFolder.ParentFolderId);
                if (parentFolder != null)
                {
                    var parentPath = parentFolder.Path.Replace('\\', '/');
                    
                    // Si el padre es una raíz, ir a la selección de espacio
                    if (IsUserRootPath(parentPath) || parentPath.TrimEnd('/').Equals("/assets/shared", StringComparison.OrdinalIgnoreCase))
                    {
                        string space = isShared ? "shared" : "own";
                        Navigation.NavigateTo($"/folders/{space}");
                        return;
                    }

                    // Bloqueo de seguridad: Si el padre es un ancestro de la raíz (assets, users, etc.)
                    // NO navegar a él, sino ir a la selección de espacio.
                    if (!isShared)
                    {
                        bool isAncestorOfPersonal = (!string.IsNullOrEmpty(_userRootPrefix) && _userRootPrefix.StartsWith(parentPath.EndsWith("/") ? parentPath : parentPath + "/", StringComparison.OrdinalIgnoreCase)) ||
                                                   (!string.IsNullOrEmpty(_userRootPhysicalPrefix) && _userRootPhysicalPrefix.StartsWith(parentPath.EndsWith("/") ? parentPath : parentPath + "/", StringComparison.OrdinalIgnoreCase));
                        
                        if (isAncestorOfPersonal)
                        {
                            Navigation.NavigateTo("/folders/own");
                            return;
                        }
                    }
                    else
                    {
                        bool isAncestorOfShared = "/assets/shared/".StartsWith(parentPath.EndsWith("/") ? parentPath : parentPath + "/", StringComparison.OrdinalIgnoreCase);
                        if (isAncestorOfShared)
                        {
                            Navigation.NavigateTo("/folders/shared");
                            return;
                        }
                    }
                    
                    Navigation.NavigateTo($"/folders/{_selectedFolder.ParentFolderId}");
                    return;
                }
            }

            // Si no hay ParentFolderId pero estamos en una subcarpeta (raro pero posible por inconsistencia de datos),
            // redirigir al espacio correspondiente por seguridad.
            string targetSpace = isShared ? "shared" : "own";
            Navigation.NavigateTo($"/folders/{targetSpace}");
        }
    }

    private RenderFragment RenderFolderGrid(List<FolderItem> folders) => __builder =>
    {
        if (folders.Any())
        {
            <div class="folder-card-grid">
                @foreach (var folderData in folders)
                {
                    @RenderFolderCard(folderData)
                }
            </div>
        }
        else
        {
            <EmptyState Icon="@Icons.Material.Filled.Folder"
                        Title="No hay carpetas"
                        Description="Empieza creando una nueva." />
        }
    };

    private RenderFragment RenderFolderList(List<FolderItem> folders) => __builder =>
    {
        if (folders.Any())
        {
            <div class="folder-list">
                @foreach (var folderData in folders)
                {
                    @RenderFolderListItem(folderData)
                }
            </div>
        }
        else
        {
            <EmptyState Icon="@Icons.Material.Filled.Folder"
                        Title="No hay carpetas"
                        Description="Empieza creando una nueva." />
        }
    };

    private RenderFragment RenderFolderCard(FolderItem folderData) => __builder =>
    {
