    /// <summary>
    /// Pre-fetches folder data, stores it in cache, then calls NavigateTo so the
    /// router updates parameters correctly (back button works). HandleFolderNavigation
    /// will find the cached data and render instantly — no flash, no scroll jump.
    /// </summary>
    private async Task NavigateToFolderInPlace(FolderItem folder)
    {
        _loadingAssets = true;
        _loadingSubFolders = true;
        StateHasChanged(); // show loading bar on CURRENT view

        try
        {
            // Pre-fetch folder + assets in parallel while the user still sees the current view
            var folderTask = FolderService.GetFolderByIdAsync(folder.Id);
            var assetsTask = FolderService.GetFolderAssetsAsync(folder.Id);
            await Task.WhenAll(folderTask, assetsTask);

            var freshFolder = await folderTask;
            if (freshFolder == null)
            {
                Snackbar.Add("Carpeta no encontrada", Severity.Warning);
                _loadingAssets = false;
                _loadingSubFolders = false;
                StateHasChanged();
                return;
            }

            // Store in the prefetch cache — HandleFolderNavigation / LoadFolderAssets
            // will consume these instantly after NavigateTo fires.
            _prefetchedFolderId = folder.Id;
            _prefetchedFolder = freshFolder;
            _prefetchedAssets = await assetsTask;
            _scrollToTopAfterRender = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar carpeta: {ex.Message}", Severity.Error);
            _prefetchedFolderId = null;
            _prefetchedFolder = null;
            _prefetchedAssets = null;
            _loadingAssets = false;
            _loadingSubFolders = false;
            StateHasChanged();
            return;
        }

        // Navigate via the router — data is cached so HandleFolderNavigation will
        // use it instantly (no API calls, no empty-state flash). The router updates
        // FolderId so the browser back button works correctly.
        var path = folder.Path.Replace('\\', '/');
        string url;
        if (IsUserRootPath(path))
            url = "/folders/own";
        else if (path.TrimEnd('/').Equals("/assets/shared", StringComparison.OrdinalIgnoreCase))
            url = "/folders/shared";
        else
            url = $"/folders/{folder.Id}";
        Navigation.NavigateTo(url);
    }

