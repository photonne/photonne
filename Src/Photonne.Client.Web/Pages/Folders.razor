            {
                Value = folder,
                Text = $"{GetDisplayFolderName(folder)} ({folder.AssetCount})",
                Icon = Icons.Material.Filled.Folder,
                Children = folder.SubFolders.Any() ? MapToTreeItemData(folder.SubFolders) : null
            })
            .ToList();
    }

