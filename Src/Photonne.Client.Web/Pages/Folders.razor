    private async Task OpenAsset(TimelineItem asset)
    {
        if (_longPressHandled)
        {
            _longPressHandled = false;
            return;
        }

        if (_selectionMode)
        {
            ToggleAssetSelection(asset.Id, !IsAssetSelected(asset.Id));
            return;
        }

        // Save the click origin so the asset detail page can play the
        // zoom-from-origin enter animation (preserves the AssetCard behaviour).
        await JS.InvokeVoidAsync("assetTransition.saveOriginByAssetId", asset.Id.ToString());

        var returnTo = _selectedFolder != null
            ? $"folders/{_selectedFolder.Id}"
            : (_activeTab == 1 ? "folders/shared" : "folders/own");
        var returnToEncoded = System.Net.WebUtility.UrlEncode(returnTo);

        // Set nav list so AssetDetail navigates within this folder's assets only
        if (_selectedFolder != null)
        {
            AssetListNavigationState.SetList(_assets, $"folder:{_selectedFolder.Id}");
        }

        Navigation.NavigateTo($"/asset/{asset.Id}?returnTo={returnToEncoded}");
    }

