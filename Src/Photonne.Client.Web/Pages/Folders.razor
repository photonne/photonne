             @key="folderData.Id"
             @onclick="@(() => OnFolderCardClick(folderData))"
             @ontouchstart="@(e => OnFolderItemTouchStart(e, folderData))"
             @ontouchmove="OnCardTouchMove"
             @ontouchend="OnCardTouchEnd">

            <div class="folder-thumbnail-wrapper">
                <div class="folder-select-checkbox" @onclick:stopPropagation="true">
                    <MudCheckBox T="bool"
                                 Value="@IsFolderSelected(folderData.Id)"
                                 ValueChanged="@(EventCallback.Factory.Create<bool>(this, value => ToggleFolderSelection(folderData.Id, value)))" />
                </div>

                @if (folderData.SharedWithCount > 0)
                {
                    <div class="folder-shared-badge" title="Compartida con @folderData.SharedWithCount usuarios">
                        <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" />
                        <span>@folderData.SharedWithCount</span>
