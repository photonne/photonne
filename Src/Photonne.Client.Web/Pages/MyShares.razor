@page "/my-shares"
@inject IShareService ShareService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Mis enlaces - Photonne</PageTitle>

<div class="page-pad">
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.h5">Álbumes</MudText>
    </div>
    <div class="ph-section-tabs">
        <a href="/albums/own"    class="ph-section-tab">Míos</a>
        <a href="/albums/shared" class="ph-section-tab">Compartidos</a>
        <a href="/my-shares"     class="ph-section-tab ph-section-tab--active">Links</a>
    </div>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
        Gestiona todos los enlaces públicos que has creado.
    </MudText>

@if (_loading)
{
    <div class="d-flex justify-center py-10">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else if (!_links.Any())
{
    <EmptyState Icon="@Icons.Material.Outlined.LinkOff"
                Title="No tienes enlaces activos"
                Description="Puedes crear enlaces desde el detalle de cualquier foto o álbum." />
}
else
{
    <div class="my-shares-list">
        @foreach (var link in _links)
        {
            <div class="my-shares-row">
                <div class="my-shares-thumb">
                    @if (link.ThumbnailUrl != null && !link.HasPassword)
                    {
                        <img src="@link.ThumbnailUrl" alt="@link.DisplayName" loading="lazy" />
                    }
                    else
                    {
                        <MudIcon Icon="@(link.HasPassword ? Icons.Material.Outlined.Lock : (link.AlbumId.HasValue ? Icons.Material.Outlined.Collections : Icons.Material.Outlined.Photo))"
                                 Style="font-size:28px; opacity:0.4;" />
                    }
                    <div class="my-shares-badge-type" title="@(link.AlbumId.HasValue ? "Álbum" : "Foto")">
                        <MudIcon Icon="@(link.AlbumId.HasValue ? Icons.Material.Outlined.Collections : Icons.Material.Outlined.Photo)"
                                 Style="font-size:11px;" />
                    </div>
                </div>

                <div class="my-shares-info">
                    <div class="my-shares-name-row">
                        <MudText Typo="Typo.subtitle2" Class="my-shares-name">@link.DisplayName</MudText>
                        <div class="my-shares-chips">
                            @if (link.HasPassword)
                            {
                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.Lock"
                                         Color="Color.Warning" Variant="Variant.Text" Class="my-shares-chip">
                                    Con contraseña
                                </MudChip>
                            }
                            @if (!link.AllowDownload)
                            {
                                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Outlined.DownloadForOffline"
                                         Color="Color.Inherit" Variant="Variant.Text" Class="my-shares-chip">
                                    Sin descarga
                                </MudChip>
                            }
                        </div>
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary my-shares-url">
                        @BuildShareUrl(link.Token)
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                        Creado @link.CreatedAt.ToString("dd/MM/yyyy")
                        @if (link.ExpiresAt.HasValue)
                        {
                            <span> · Expira @link.ExpiresAt.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <span> · Sin expiración</span>
                        }
                        @if (link.MaxViews.HasValue)
                        {
                            <span> · @link.ViewCount / @link.MaxViews vistas</span>
                        }
                        else if (link.ViewCount > 0)
                        {
                            <span> · @link.ViewCount @(link.ViewCount == 1 ? "vista" : "vistas")</span>
                        }
                    </MudText>
                </div>

                <div class="my-shares-actions">
                    <MudTooltip Text="Copiar enlace">
                        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                                       Size="Size.Small"
                                       OnClick="() => CopyLink(link.Token)" />
                    </MudTooltip>
                    <MudTooltip Text="Editar enlace">
                        <MudIconButton Icon="@Icons.Material.Outlined.EditNote"
                                       Size="Size.Small"
                                       OnClick="() => OpenEditDialog(link)" />
                    </MudTooltip>
                    @if (link.AssetId.HasValue)
                    {
                        <MudTooltip Text="Ver foto">
                            <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew"
                                           Size="Size.Small"
                                           OnClick="() => GoToAsset(link.AssetId!.Value)" />
                        </MudTooltip>
                    }
                    @if (link.AlbumId.HasValue)
                    {
                        <MudTooltip Text="Ver álbum">
                            <MudIconButton Icon="@Icons.Material.Outlined.Collections"
                                           Size="Size.Small"
                                           OnClick="() => GoToAlbum(link.AlbumId!.Value)" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Revocar enlace">
                        <MudIconButton Icon="@Icons.Material.Outlined.LinkOff"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="() => RevokeLink(link)" />
                    </MudTooltip>
                </div>
            </div>
        }
    </div>
}
</div>

@* ── Edit dialog ──────────────────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_editDialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Editar enlace</MudText>
        @if (_editingLink != null)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@_editingLink.DisplayName</MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4" Class="pt-2">

            <MudDatePicker Label="Fecha de expiración"
                           @bind-Date="_editExpiresAt"
                           Clearable="true"
                           MinDate="DateTime.Today.AddDays(1)"
                           Placeholder="Sin expiración"
                           DateFormat="dd/MM/yyyy" />

            <MudSwitch T="bool" @bind-Value="_editAllowDownload"
                       Label="Permitir descarga"
                       Color="Color.Primary" />

            <MudNumericField T="int?" @bind-Value="_editMaxViews"
                             Label="Límite de vistas"
                             Placeholder="Sin límite"
                             Min="1"
                             Clearable="true"
                             HelperText="Déjalo vacío para vistas ilimitadas" />

            <MudDivider />

            <div>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">Contraseña</MudText>
                @if (_editingLink?.HasPassword == true && !_editChangePassword)
                {
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Lock" Size="Size.Small" />
                        <MudText Typo="Typo.body2">Este enlace tiene contraseña</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick="() => { _editChangePassword = true; _editPassword = string.Empty; }">
                            Cambiar
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                   OnClick="() => { _editChangePassword = true; _editPassword = string.Empty; _editRemovePassword = true; }">
                            Quitar
                        </MudButton>
                    </div>
                }
                else if (_editRemovePassword)
                {
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.LockOpen" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.body2">Se eliminará la contraseña</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                   OnClick="() => { _editChangePassword = false; _editRemovePassword = false; _editPassword = null; }">
                            Cancelar
                        </MudButton>
                    </div>
                }
                else
                {
                    <MudTextField @bind-Value="_editPassword"
                                  Label="@(_editingLink?.HasPassword == true ? "Nueva contraseña" : "Contraseña (opcional)")"
                                  InputType="InputType.Password"
                                  Clearable="true"
                                  HelperText="@(_editingLink?.HasPassword == true ? "Déjalo vacío para no cambiarla" : "Déjalo vacío para no añadir contraseña")" />
                    @if (_editingLink?.HasPassword == true)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Text" Class="mt-1"
                                   OnClick="() => { _editChangePassword = false; _editPassword = null; }">
                            Cancelar cambio
                        </MudButton>
                    }
                }
            </div>

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditDialog" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton OnClick="SaveEdit" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="_editSaving">
            @if (_editSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .my-shares-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .my-shares-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 10px 12px;
        border-radius: 8px;
        transition: background 0.15s;
    }
    .my-shares-row:hover { background: rgba(255,255,255,0.05); }

    .my-shares-thumb {
        position: relative;
        width: 56px;
        height: 56px;
        border-radius: 6px;
        overflow: hidden;
        background: rgba(255,255,255,0.07);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .my-shares-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .my-shares-badge-type {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(2px);
    }

    .my-shares-info {
        flex: 1;
        min-width: 0;
    }

    .my-shares-name-row {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .my-shares-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
    }

    .my-shares-url {
        font-family: monospace;
        font-size: 0.72rem;
        opacity: 0.6;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        display: block;
        margin-top: 2px;
    }

    .my-shares-chip {
        height: 20px;
        font-size: 0.7rem;
    }

    .my-shares-actions {
        display: flex;
        gap: 2px;
        flex-shrink: 0;
    }
</style>

@code {
    private List<SentShareLinkDto> _links = new();
    private bool _loading = true;

    // ── Edit dialog state ──────────────────────────────────────────────────────
    private bool _editDialogOpen;
    private bool _editSaving;
    private SentShareLinkDto? _editingLink;
    private DateTime? _editExpiresAt;
    private bool _editAllowDownload;
    private int? _editMaxViews;
    private string? _editPassword;        // null = no change, "" = will be handled by _editRemovePassword
    private bool _editChangePassword;
    private bool _editRemovePassword;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private void GoToAsset(Guid assetId) => Navigation.NavigateTo($"/asset/{assetId}?returnTo=my-shares");
    private void GoToAlbum(Guid albumId) => Navigation.NavigateTo($"/albums/{albumId}");

    protected override async Task OnInitializedAsync()
    {
        try { _links = await ShareService.GetSentShareLinksAsync(); }
        catch { Snackbar.Add("Error al cargar los enlaces", Severity.Error); }
        finally { _loading = false; }
    }

    private string BuildShareUrl(string token)
    {
        var baseUri = new Uri(Navigation.BaseUri);
        return $"{baseUri.Scheme}://{baseUri.Authority}/share/{token}";
    }

    private async Task CopyLink(string token)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", BuildShareUrl(token));
        Snackbar.Add("Enlace copiado al portapapeles", Severity.Success);
    }

    // ── Edit ──────────────────────────────────────────────────────────────────

    private void OpenEditDialog(SentShareLinkDto link)
    {
        _editingLink = link;
        _editExpiresAt = link.ExpiresAt;
        _editAllowDownload = link.AllowDownload;
        _editMaxViews = link.MaxViews;
        _editPassword = null;
        _editChangePassword = false;
        _editRemovePassword = false;
        _editDialogOpen = true;
    }

    private void CloseEditDialog()
    {
        _editDialogOpen = false;
        _editingLink = null;
    }

    private async Task SaveEdit()
    {
        if (_editingLink == null) return;

        _editSaving = true;
        try
        {
            // Determine password field:
            // _editRemovePassword → send ""  (server will clear hash)
            // _editChangePassword && password entered → send new password
            // otherwise → send null (server keeps existing)
            string? passwordToSend = null;
            if (_editRemovePassword)
                passwordToSend = string.Empty;
            else if (_editChangePassword && !string.IsNullOrEmpty(_editPassword))
                passwordToSend = _editPassword;

            var request = new UpdateShareLinkRequest
            {
                ExpiresAt = _editExpiresAt,
                AllowDownload = _editAllowDownload,
                MaxViews = _editMaxViews,
                Password = passwordToSend
            };

            var updated = await ShareService.UpdateShareAsync(_editingLink.Token, request);
            if (updated != null)
            {
                _editingLink.ExpiresAt = updated.ExpiresAt;
                _editingLink.HasPassword = updated.HasPassword;
                _editingLink.AllowDownload = updated.AllowDownload;
                _editingLink.MaxViews = updated.MaxViews;
            }

            Snackbar.Add("Enlace actualizado", Severity.Success);
            CloseEditDialog();
        }
        catch
        {
            Snackbar.Add("Error al guardar los cambios", Severity.Error);
        }
        finally
        {
            _editSaving = false;
        }
    }

    // ── Revoke ────────────────────────────────────────────────────────────────

    private async Task RevokeLink(SentShareLinkDto link)
    {
        try
        {
            await ShareService.RevokeShareAsync(link.Token);
            _links.Remove(link);
            Snackbar.Add("Enlace revocado", Severity.Info);
        }
        catch
        {
            Snackbar.Add("Error al revocar el enlace", Severity.Error);
        }
    }
}
