    private string GetHeroStyle()
    {
        if (_selectedAlbum == null) return string.Empty;
        
        if (!string.IsNullOrEmpty(_selectedAlbum.CoverThumbnailUrl))
        {
            return $"background-image: url('{_selectedAlbum.CoverThumbnailUrl}');";
