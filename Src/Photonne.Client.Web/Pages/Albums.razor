            _loading = false;
        }
    }

    private async Task LoadAlbum(Guid albumId)
    {
        try
        {
            _loadingAssets = true;
            _assetSelectionMode = false;
            _selectedAlbumAssetIds.Clear();
            // Don't call ResetAlbumAssetPaging() here — keep old assets visible
            // while the new album loads so the page height doesn't collapse
            // Use prefetched data if available, otherwise fetch from API
            if (_prefetchedAlbum != null && _prefetchedAlbumId == albumId)
            {
                _selectedAlbum = _prefetchedAlbum;
                _prefetchedAlbum = null;
            }
            else
            {
                _selectedAlbum = await AlbumService.GetAlbumByIdAsync(albumId);
            }

            if (_selectedAlbum != null)
            {
                List<TimelineItem>? newAssets;
                if (_prefetchedAlbumAssets != null && _prefetchedAlbumId == albumId)
                {
                    newAssets = _prefetchedAlbumAssets;
                    _prefetchedAlbumAssets = null;
                    _prefetchedAlbumId = null;
                }
                else
                {
                    newAssets = await AlbumService.GetAlbumAssetsAsync(albumId);
                }
                // Atomic swap: new data + paging reset in one render cycle.
                _albumAssets = newAssets;
                _albumAssetVisibleCount = Math.Min(ALBUM_ASSETS_INITIAL_BATCH, _albumAssets.Count);
                _albumAssetsLoadingMore = false;
                if (_albumAssetsSentinelAttached)
                {
                    _albumAssetsSentinelAttached = false;
                    _ = JS.InvokeVoidAsync("disconnectLoadMoreObserver", "album-assets-load-more-sentinel");
                }
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Álbumes", href: "/albums"),
                    new BreadcrumbItem(_selectedAlbum.Name, href: null, disabled: true)
                };
            }
            else
            {
                Snackbar.Add("Álbum no encontrado", Severity.Warning);
                Navigation.NavigateTo("/albums");
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para acceder a este álbum.", Severity.Error);
            Navigation.NavigateTo("/albums");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar álbum: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingAssets = false;
        }
    }

    private List<AlbumYearGroup> GetAlbumGroups()
    {
        var albums = GetFilteredAlbums();

        if (!_groupByYear)
        {
            return new List<AlbumYearGroup> { new AlbumYearGroup(null, albums) };
        }

        return albums
            .GroupBy(album => album.CreatedAt.Year)
            .OrderByDescending(group => group.Key)
            .Select(group => new AlbumYearGroup(group.Key, group.ToList()))
            .ToList();
    }

    private List<AlbumItem> GetFilteredAlbums()
    {
        IEnumerable<AlbumItem> query = _albums;

        query = _albumFilter switch
        {
            AlbumFilter.Own => query.Where(album => album.IsOwner && !album.IsShared),
            AlbumFilter.Shared => query.Where(album => !album.IsOwner || album.IsShared),
            AlbumFilter.Public => query.Where(album => album.IsOwner && album.HasActiveShareLink),
            _ => query
        };

        if (!string.IsNullOrWhiteSpace(_albumSearch))
        {
            var term = _albumSearch.Trim();
            query = query.Where(album =>
                album.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (album.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        query = _albumSort switch
        {
            AlbumSort.Oldest => query.OrderBy(album => album.UpdatedAt),
            AlbumSort.Name => query.OrderBy(album => album.Name),
            _ => query.OrderByDescending(album => album.UpdatedAt)
        };

        return query.ToList();
    }

    private async Task OpenAlbum(Guid albumId)
    {
        await NavigateToAlbumInPlace(albumId);
    }

    /// <summary>
    /// Pre-fetches album data, stores it in cache, then calls NavigateTo so the
    /// router updates parameters correctly (back button works). LoadAlbum will
    /// find the cached data and render instantly — no flash, no scroll jump.
    /// </summary>
    private async Task NavigateToAlbumInPlace(Guid albumId)
    {
        _loadingAssets = true;
        StateHasChanged(); // show loading bar on CURRENT view

        try
        {
            var albumTask = AlbumService.GetAlbumByIdAsync(albumId);
            var assetsTask = AlbumService.GetAlbumAssetsAsync(albumId);
            await Task.WhenAll(albumTask, assetsTask);

            var album = await albumTask;
            if (album == null)
            {
                Snackbar.Add("Álbum no encontrado", Severity.Warning);
                _loadingAssets = false;
                StateHasChanged();
                Navigation.NavigateTo("/albums");
                return;
            }

            // Store in cache — LoadAlbum will consume these instantly after NavigateTo
            _prefetchedAlbumId = albumId;
            _prefetchedAlbum = album;
            _prefetchedAlbumAssets = await assetsTask;
            _scrollToTopAfterRender = true;
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para acceder a este álbum.", Severity.Error);
            _loadingAssets = false;
            StateHasChanged();
            Navigation.NavigateTo("/albums");
            return;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar álbum: {ex.Message}", Severity.Error);
            _prefetchedAlbumId = null;
            _prefetchedAlbum = null;
            _prefetchedAlbumAssets = null;
            _loadingAssets = false;
            StateHasChanged();
            return;
        }

        // Navigate via the router — data is cached so LoadAlbum uses it instantly.
        // Router updates AlbumId so the browser back button works correctly.
        Navigation.NavigateTo($"/albums/{albumId}");
    }

    private async Task OnAlbumAssetClick(TimelineItem asset)
    {
        if (_longPressHandled)
        {
            _longPressHandled = false;
            return;
        }

        if (_assetSelectionMode)
        {
            ToggleAlbumAssetSelection(asset.Id, !IsAlbumAssetSelected(asset.Id));
            return;
        }
        // Save the click origin so the asset detail page can play the
        // zoom-from-origin enter animation (preserves the AssetCard behaviour).
        await JS.InvokeVoidAsync("assetTransition.saveOriginByAssetId", asset.Id.ToString());
        OpenAsset(asset);
    }

    private void OpenAsset(TimelineItem asset)
    {
        var effectiveAlbumId = _selectedAlbum?.Id ?? AlbumId;
        AssetListNavigationState.SetList(_albumAssets, effectiveAlbumId);
        Navigation.NavigateTo($"/asset/{asset.Id}?albumId={effectiveAlbumId}");
    }

    private void OpenCreateDialog()
