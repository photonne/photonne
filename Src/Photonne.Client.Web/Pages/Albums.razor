    private async Task LoadAlbums(bool forceRefresh = false)
    {
        try
        {
            _loading = true;
            if (!forceRefresh && AlbumsCache.IsValid)
            {
                _albums = AlbumsCache.Albums!;
                return;
            }
            _albums = await AlbumService.GetAlbumsAsync();
            AlbumsCache.Set(_albums);
