    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await DeviceLayout.InitializeAsync();
            DeviceLayout.OnChanged += OnDeviceLayoutChanged;
            StateHasChanged();
        }

        // Scroll to top after in-place album navigation completes
        if (_scrollToTopAfterRender)
        {
            _scrollToTopAfterRender = false;
            await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
        }

        // (Re)attach the asset-grid load-more sentinel whenever the visible count
        // is below the total. The flag avoids redundant JS interop calls between paged loads.
        if (_selectedAlbum != null && _albumAssetVisibleCount < _albumAssets.Count && !_albumAssetsSentinelAttached && _objRef != null)
        {
            _albumAssetsSentinelAttached = true;
            try
            {
                await JS.InvokeVoidAsync(
                    "setupLoadMoreObserver",
                    "album-assets-load-more-sentinel",
                    _objRef,
                    nameof(LoadMoreAlbumAssetsFromJs),
                    null,
                    "300px");
            }
            catch
            {
                _albumAssetsSentinelAttached = false;
            }
        }
        else if (_albumAssetVisibleCount >= _albumAssets.Count && _albumAssetsSentinelAttached)
        {
            _albumAssetsSentinelAttached = false;
            try { await JS.InvokeVoidAsync("disconnectLoadMoreObserver", "album-assets-load-more-sentinel"); }
            catch { }
        }
    }

    [JSInvokable]
    public Task LoadMoreAlbumAssetsFromJs()
    {
        if (_albumAssetsLoadingMore) return Task.CompletedTask;
        if (_albumAssetVisibleCount >= _albumAssets.Count) return Task.CompletedTask;

        _albumAssetsLoadingMore = true;
        _albumAssetVisibleCount = Math.Min(_albumAssetVisibleCount + ALBUM_ASSETS_LOAD_MORE_BATCH, _albumAssets.Count);
        // Force the sentinel to be re-attached after the next render so the
        // observer keeps firing while there's still more to show.
        _albumAssetsSentinelAttached = false;
        StateHasChanged();
        _albumAssetsLoadingMore = false;
        return Task.CompletedTask;
    }

    private void ResetAlbumAssetPaging()
    {
        _albumAssetVisibleCount = 0;
        _albumAssetsLoadingMore = false;
        if (_albumAssetsSentinelAttached)
        {
            _albumAssetsSentinelAttached = false;
            _ = JS.InvokeVoidAsync("disconnectLoadMoreObserver", "album-assets-load-more-sentinel");
        }
    }

    private async Task OnCardTouchStart(TouchEventArgs e, TimelineItem asset)
    {
        if (e.Touches.Length == 0) return;
        _touchStartX = e.Touches[0].ClientX;
        _touchStartY = e.Touches[0].ClientY;
        _longPressHandled = false;

        if (_assetSelectionMode)
        {
            var selectMode = !IsAlbumAssetSelected(asset.Id);
            _longPressHandled = true;
            ToggleAlbumAssetSelection(asset.Id, selectMode);
            await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
            if (_objRef != null)
                await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, selectMode);
            return;
        }

        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _longPressHandled = true;
                ToggleAlbumAssetSelection(asset.Id, true);
                await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
                if (_objRef != null)
                    await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, true);
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private void OnCardTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length == 0 || _longPressTimer == null) return;
        var dx = e.Touches[0].ClientX - _touchStartX;
        var dy = e.Touches[0].ClientY - _touchStartY;
        if (Math.Sqrt(dx * dx + dy * dy) > 10)
        {
            _longPressTimer.Dispose();
            _longPressTimer = null;
        }
    }

    private void OnCardTouchEnd(TouchEventArgs e)
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
    }

    // Album-specific long-press: same UX as the asset cells. Triggers selection
    // mode after 500 ms held on an album card / list item.
    private async Task OnAlbumItemTouchStart(TouchEventArgs e, AlbumItem album)
    {
        if (e.Touches.Length == 0) return;
        _touchStartX = e.Touches[0].ClientX;
        _touchStartY = e.Touches[0].ClientY;
        _longPressHandled = false;

        if (_albumSelectionMode)
        {
            var selectMode = !IsAlbumSelected(album.Id);
            _longPressHandled = true;
            ToggleAlbumSelection(album.Id, selectMode);
            await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
            return;
        }

        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _longPressHandled = true;
                ToggleAlbumSelection(album.Id, true);
                await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

