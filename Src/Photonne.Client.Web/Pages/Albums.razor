    private async Task OpenShareDialogForAlbum(Guid albumId, string albumName)
    {
        _shareSheetAlbumId = albumId;
        _shareSheetAlbumName = albumName;
        _sharePublicLinks = new();
        ResetShareForm();
        _shareSheetEverOpened = true;
        _shareSheetOpen = true;
        _shareLoadingLinks = true;
        StateHasChanged();
        try { _sharePublicLinks = await ShareService.GetShareLinksAsync(null, albumId); }
        catch { /* non-critical */ }
        finally { _shareLoadingLinks = false; StateHasChanged(); }
