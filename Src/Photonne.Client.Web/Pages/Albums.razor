@page "/albums"
@page "/albums/{Filter}"
@page "/albums/{AlbumId:guid}"
@inject IAlbumService AlbumService
@inject AlbumsCache AlbumsCache
@inject IAssetService AssetService
@inject IShareService ShareService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject LayoutService LayoutService
@inject IAssetListNavigationState AssetListNavigationState
@inject IJSRuntime JS
@inject ISettingsService SettingsService
@inject DeviceLayoutService DeviceLayout
@implements IDisposable

<PageTitle>Álbumes - Photonne</PageTitle>

@{
    var albumGroups = GetAlbumGroups();
}

@if (DeviceLayout.IsMobile)
{
    <AlbumsMobileView Loading="_loading"
                      Filter="@Filter"
                      AlbumSearch="@_albumSearch"
                      OnAlbumSearchChanged="OnAlbumSearchChanged"
                      AlbumViewMode="_albumViewMode"
                      AlbumSelectionMode="_albumSelectionMode"
                      SelectedAlbumIds="_selectedAlbumIds"
                      AlbumGroups="albumGroups"
                      OnAlbumCardClick="OnAlbumCardClick"
                      OnAlbumItemTouchStart="OnAlbumItemTouchStartFromView"
                      OnCardTouchMove="OnCardTouchMove"
                      OnCardTouchEnd="OnCardTouchEnd"
                      OnToggleAlbumSelection="OnToggleAlbumSelectionFromView"
                      OnOpenCreateDialog="OpenCreateDialog"
                      OnOpenFilterSheet="@(() => { _albumFilterSheetEverOpened = true; _albumFilterSheetOpen = true; })"
                      OnOpenShareDialog="OnOpenShareDialogFromView"
                      SelectedAlbum="_selectedAlbum"
                      AlbumAssets="_albumAssets"
                      LoadingAssets="_loadingAssets"
                      AlbumAssetVisibleCount="_albumAssetVisibleCount"
                      AssetSelectionMode="_assetSelectionMode"
                      SelectedAlbumAssetIds="_selectedAlbumAssetIds"
                      DownloadingZip="_downloadingZip"
                      Breadcrumbs="_breadcrumbs"
                      OnAlbumAssetClick="OnAlbumAssetClick"
                      OnAssetTouchStart="OnAssetTouchStartFromView"
                      OnToggleAlbumAssetSelection="OnToggleAlbumAssetSelectionFromView"
                      OnToggleAlbumAssetFavorite="ToggleAlbumAssetFavoriteAsync"
                      OnNavigateBack="@(() => Navigation.NavigateTo($"/albums/{(_selectedAlbum?.IsOwner == true ? "own" : "shared")}"))"
                      OnOpenAlbumShareDialog="OpenAlbumShareDialog"
                      OnDownloadAlbum="DownloadAlbumAsync"
                      OnNavigateToAddPhotos="@(() => Navigation.NavigateTo("/"))"
                      OnOpenEditDialog="OpenEditDialog"
                      OnNavigateToPermissions="@(() => Navigation.NavigateTo($"/albums/{(_selectedAlbum?.Id ?? AlbumId)}/permissions"))"
                      OnLeaveAlbum="LeaveAlbum"
                      OnOpenDeleteDialog="OpenDeleteDialog" />
}
else
{
    <AlbumsDesktopView Loading="_loading"
                       Filter="@Filter"
                       AlbumSearch="@_albumSearch"
                       OnAlbumSearchChanged="OnAlbumSearchChanged"
                       AlbumViewMode="_albumViewMode"
                       AlbumSelectionMode="_albumSelectionMode"
                       SelectedAlbumIds="_selectedAlbumIds"
                       AlbumGroups="albumGroups"
                       OnAlbumCardClick="OnAlbumCardClick"
                       OnAlbumItemTouchStart="OnAlbumItemTouchStartFromView"
                       OnCardTouchMove="OnCardTouchMove"
                       OnCardTouchEnd="OnCardTouchEnd"
                       OnToggleAlbumSelection="OnToggleAlbumSelectionFromView"
                       OnOpenCreateDialog="OpenCreateDialog"
                       OnOpenFilterSheet="@(() => { _albumFilterSheetEverOpened = true; _albumFilterSheetOpen = true; })"
                       OnOpenShareDialog="OnOpenShareDialogFromView"
                       SelectedAlbum="_selectedAlbum"
                       AlbumAssets="_albumAssets"
                       LoadingAssets="_loadingAssets"
                       AlbumAssetVisibleCount="_albumAssetVisibleCount"
                       AssetSelectionMode="_assetSelectionMode"
                       SelectedAlbumAssetIds="_selectedAlbumAssetIds"
                       DownloadingZip="_downloadingZip"
                       Breadcrumbs="_breadcrumbs"
                       OnAlbumAssetClick="OnAlbumAssetClick"
                       OnAssetTouchStart="OnAssetTouchStartFromView"
                       OnToggleAlbumAssetSelection="OnToggleAlbumAssetSelectionFromView"
                       OnToggleAlbumAssetFavorite="ToggleAlbumAssetFavoriteAsync"
                       OnNavigateBack="@(() => Navigation.NavigateTo($"/albums/{(_selectedAlbum?.IsOwner == true ? "own" : "shared")}"))"
                       OnOpenAlbumShareDialog="OpenAlbumShareDialog"
                       OnDownloadAlbum="DownloadAlbumAsync"
                       OnNavigateToAddPhotos="@(() => Navigation.NavigateTo("/"))"
                       OnOpenEditDialog="OpenEditDialog"
                       OnNavigateToPermissions="@(() => Navigation.NavigateTo($"/albums/{(_selectedAlbum?.Id ?? AlbumId)}/permissions"))"
                       OnLeaveAlbum="LeaveAlbum"
                       OnOpenDeleteDialog="OpenDeleteDialog" />
}

<style>
    .album-card-container {
        position: relative;
        cursor: pointer;
        width: 100%;
    }

    .album-select-checkbox {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 5;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s;
        background: rgba(0,0,0,0.45);
        border-radius: 999px;
        padding: 2px;
        color: white;
    }

    .album-select-checkbox .mud-icon-root {
        color: white !important;
    }

    .album-card-container:hover .album-select-checkbox,
    .album-card-container.selected .album-select-checkbox {
        opacity: 1;
        pointer-events: auto;
    }

    @@media (max-width: 959.98px) {
        /* Touch devices: hide checkbox unless the album is actually selected */
        .album-card-container:not(.selected):hover .album-select-checkbox {
            opacity: 0;
            pointer-events: none;
        }
    }

    .albums-search {
        max-width: 300px;
    }

    .album-card-container {
        position: relative;
        cursor: pointer;
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        background: var(--mud-palette-surface);
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid var(--mud-palette-divider);
        /* Skip layout/paint when off-screen — major perf win for large album lists */
        content-visibility: auto;
        contain-intrinsic-size: 220px 260px;
    }

    .album-card-container:hover {
        transform: translateY(-4px);
        box-shadow: var(--mud-elevation-4);
    }

    .album-overlay-name {
        color: white;
        font-weight: 600;
        font-size: 0.875rem;
        line-height: 1.4;
        text-overflow: ellipsis;
        overflow: hidden;
        white-space: nowrap;
    }

    .album-overlay-count {
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.75rem;
        line-height: 1.4;
    }

    /* ── Collage de previsualización ── */
    .album-thumb-collage {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background: var(--mud-palette-surface);
    }

    .collage-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        width: 100%;
        height: 100%;
        gap: 2px;
        transition: gap 0.35s ease;
    }

    .album-card-container:hover .collage-grid {
        gap: 3px;
    }

    .collage-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
        display: block;
    }

    .album-card-container:hover .collage-img {
        transform: scale(1.06);
    }

    .collage-single {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.35s ease;
        display: block;
    }

    .album-card-container:hover .collage-single {
        transform: scale(1.06);
    }

    .collage-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-dark, #4f46e5) 100%);
        color: white;
    }

    .collage-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 12px;
        background: linear-gradient(transparent, rgba(0,0,0,0.82));
        pointer-events: none;
    }

    .albums-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: nowrap;
        overflow-x: auto;
    }


    .album-year-header {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin: 16px 0 8px;
    }

    .album-year-count {
        color: var(--mud-palette-text-secondary);
    }

    .album-grid-badges {
        position: absolute;
        top: 8px;
        right: 8px;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 4px;
        z-index: 5;
    }

    .album-shared-badge {
        background: rgba(0,0,0,0.5);
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .album-grid-share-btn {
        background: rgba(0,0,0,0.5);
        color: white;
        padding: 3px 5px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        z-index: 5;
        cursor: pointer;
        transition: background 0.15s;
    }

    .album-grid-share-btn.active {
        color: var(--mud-palette-primary-lighten);
    }

    .album-grid-share-btn:hover {
        background: var(--mud-palette-primary);
        color: white;
    }


    .album-list-share-btn {
        flex-shrink: 0;
    }

    .album-list-shared-badge {
        display: flex;
        align-items: center;
        gap: 4px;
        color: var(--mud-palette-text-secondary);
        font-size: 0.875rem;
    }

    .album-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* Lightweight responsive grid for album cards — replaces MudGrid + MudItem
       to eliminate the per-item Blazor component overhead. */
    .album-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 12px;
    }

    @@media (max-width: 599.98px) {
        .album-card-grid {
            grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
            gap: 6px;
        }
    }

    .album-list-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px;
        border-radius: 12px;
        background: var(--mud-palette-surface);
        transition: background 0.2s ease;
        cursor: pointer;
        position: relative;
        /* Skip layout/paint when off-screen — major perf win for long album lists */
        content-visibility: auto;
        contain-intrinsic-size: 100% 120px;
    }

    .album-list-item:hover {
        background: var(--mud-palette-action-hover);
    }

    .album-list-thumb {
        width: 70px;
        height: 70px;
        position: relative;
        flex: 0 0 80px;
        border-radius: 8px;
        overflow: hidden;
    }

    .album-list-info {
        flex: 1;
        min-width: 0;
    }

    .album-list-title {
        font-weight: 600;
    }

    .album-list-meta {
        color: var(--mud-palette-text-secondary);
        font-size: 0.85rem;
    }


    /* Estilos para el Hero del álbum */
    .album-hero {
        position: relative;
        width: calc(100% + 48px);
        margin-left: -24px;
        margin-right: -24px;
        margin-top: -24px;
        min-height: 360px;
        border-radius: 0;
        overflow: hidden;
        margin-bottom: 24px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .album-hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        background-size: cover;
        background-position: center;
        filter: blur(20px) brightness(0.7);
        transform: scale(1.1);
    }

    .album-hero-content {
        position: relative;
        z-index: 1;
        padding: 24px;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        color: white;
    }

    .album-hero-actions {
        position: absolute;
        top: 8px;
        right: 8px;
        z-index: 2;
        display: flex;
        gap: 8px;
        color: white;
    }

    .album-hero-back {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 2;
        color: white;
    }

    .album-description-text {
        max-height: 100px;
        overflow-y: auto;
        opacity: 0.9;
    }

    /* Album detail — fixed-height scroll container so AppBar/BottomNav stay fixed */
    .album-detail-scroll {
        height: calc(100vh - var(--mud-appbar-height, 64px));
        overflow-y: auto;
        overflow-x: hidden;
    }

    @@media (max-width: 959.98px) {
        .album-detail-scroll {
            height: calc(100vh - var(--mud-appbar-height, 64px) - 64px - env(safe-area-inset-bottom));
        }

        .album-hero {
            min-height: 260px;
        }
    }

    /* View toggle in filter sheet */
    .album-view-toggle {
        gap: 8px;
        border: none !important;
        box-shadow: none !important;
    }

    .album-view-toggle .mud-toggle-item {
        border-radius: 20px !important;
        background: var(--mud-palette-action-default-hover);
        flex: 1;
    }

    .album-view-toggle .mud-toggle-item-selected {
        background: var(--mud-palette-primary) !important;
        color: var(--mud-palette-primary-text) !important;
    }

    /* Section tabs moved to `wwwroot/css/app.css` */

    .share-link-row {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .share-link-row:last-child { border-bottom: none; }
    .share-link-info {
        flex: 1;
        min-width: 0;
    }
    .share-link-url {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-family: monospace;
        font-size: 0.78rem;
        opacity: 0.75;
    }
</style>


@* ── Crear álbum — bottom sheet ── *@
@if (_createAlbumSheetEverOpened)
{
<MudDrawer @bind-Open="_createDialogVisible"
           Anchor="Anchor.Bottom"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Class="ph-bottom-sheet">
    <div class="ph-sheet-handle"></div>
    <div class="d-flex justify-space-between align-center px-4 pt-1 pb-2">
        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Nuevo álbum</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       OnClick="CloseCreateDialog" />
    </div>
    <MudDivider />
    <div class="px-4 pt-3 pb-6">
        <MudTextField @bind-Value="_newAlbumName"
                      Label="Nombre"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Autofocus="true"
                      Class="mb-3" />
        <MudTextField @bind-Value="_newAlbumDescription"
                      Label="Descripción (opcional)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Lines="2"
                      Class="mb-3" />
        @if (_albumFilter == AlbumFilter.Shared)
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">
                Al crear podrás añadir colaboradores de inmediato.
            </MudAlert>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   FullWidth="true" Size="Size.Medium"
                   OnClick="CreateAlbum">
            Crear
        </MudButton>
    </div>
</MudDrawer>
}

@* ── Opciones de vista — bottom sheet ── *@
@if (_albumFilterSheetEverOpened)
{
<MudDrawer @bind-Open="_albumFilterSheetOpen"
           Anchor="Anchor.Bottom"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Class="ph-bottom-sheet">
    <div class="ph-sheet-handle"></div>
    <div class="d-flex justify-space-between align-center px-4 pt-1 pb-2">
        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Opciones de vista</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       OnClick="@(() => _albumFilterSheetOpen = false)" />
    </div>
    <MudDivider />
    <div class="px-4 pt-3 pb-6">
        <MudText Typo="Typo.caption" Style="font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--mud-palette-text-secondary);" Class="mb-2 d-block">Ordenar por</MudText>
        <MudSelect T="AlbumSort"
                   Value="_albumSort"
                   ValueChanged="OnAlbumSortChanged"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   FullWidth="true"
                   Class="mb-4">
            <MudSelectItem Value="AlbumSort.Recent">Foto más reciente</MudSelectItem>
            <MudSelectItem Value="AlbumSort.Oldest">Foto más antigua</MudSelectItem>
            <MudSelectItem Value="AlbumSort.Name">Nombre</MudSelectItem>
        </MudSelect>
        <MudDivider Class="mb-3" />
        <MudSwitch T="bool" Value="_groupByYear" ValueChanged="ToggleGroupByYear"
                   Color="Color.Primary" Label="Agrupar por año" Class="mb-3" />
        <MudDivider Class="mb-3" />
        <MudText Typo="Typo.caption" Style="font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--mud-palette-text-secondary);" Class="mb-2 d-block">Vista</MudText>
        <MudToggleGroup T="AlbumViewMode" Value="_albumViewMode" ValueChanged="OnViewModeChanged"
                        Color="Color.Primary" Outline="false" Delimiters="false" Size="Size.Small"
                        Class="w-100 album-view-toggle">
            <MudToggleItem Value="AlbumViewMode.Grid" Icon="@Icons.Material.Filled.ViewModule" Text="Cuadrícula" />
            <MudToggleItem Value="AlbumViewMode.List" Icon="@Icons.Material.Filled.ViewList" Text="Lista" />
        </MudToggleGroup>
    </div>
</MudDrawer>
}

@* ── Compartir álbum — bottom sheet ── *@
@if (_shareSheetEverOpened)
{
<MudDrawer @bind-Open="_shareSheetOpen"
           Anchor="Anchor.Bottom"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Class="ph-bottom-sheet">
    <div class="ph-sheet-handle"></div>
    <div class="d-flex justify-space-between align-center px-4 pt-1 pb-2">
        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Compartir @(_shareSheetAlbumName ?? "")</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       OnClick="@(() => _shareSheetOpen = false)" />
    </div>
    <MudDivider />
    <div class="px-4 pt-3 pb-6">
        @if (_shareLoadingLinks)
        {
            <div class="d-flex justify-center py-4">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            </div>
        }
        else if (_sharePublicLinks.Any())
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2 mud-text-secondary">Links activos</MudText>
            @foreach (var link in _sharePublicLinks)
            {
                <div class="share-link-row">
                    <div class="share-link-info">
                        <MudText Typo="Typo.body2" Class="share-link-url">
                            @BuildShareUrl(link.Token)
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @if (link.HasPassword) { <span>🔒 Con contraseña · </span> }
                            @if (!link.AllowDownload) { <span>⬇️ Sin descarga · </span> }
                            @if (link.MaxViews.HasValue) { <span>👁 @link.ViewCount/@link.MaxViews vistas · </span> }
                            @if (link.ExpiresAt.HasValue)
                            { <span>Expira @link.ExpiresAt.Value.ToString("dd/MM/yyyy")</span> }
                            else
                            { <span>Sin expiración</span> }
                        </MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small"
                                   Title="Copiar enlace" OnClick="() => ShareCopyLink(link.Token)" />
                    <MudIconButton Icon="@Icons.Material.Outlined.LinkOff" Size="Size.Small"
                                   Color="Color.Error" Title="Revocar"
                                   OnClick="() => ShareRevokeLink(link.Token)" />
                </div>
            }
            <MudDivider Class="my-4" />
        }

        <MudText Typo="Typo.subtitle2" Class="mb-3 mud-text-secondary">Crear nuevo enlace</MudText>
        <div class="d-flex flex-column gap-3">
            <MudSwitch @bind-Value="_shareNewPasswordEnabled" Label="Proteger con contraseña" Color="Color.Primary" />
            @if (_shareNewPasswordEnabled)
            {
                <MudTextField @bind-Value="_shareNewPassword"
                              Label="Contraseña"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Lock" />
            }
            <MudSwitch @bind-Value="_shareNewExpiryEnabled" Label="Fecha de expiración" Color="Color.Primary" />
            @if (_shareNewExpiryEnabled)
            {
                <MudDatePicker @bind-Date="_shareNewExpiry"
                               Label="Expira el"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               MinDate="DateTime.Today.AddDays(1)"
                               DateFormat="dd/MM/yyyy" />
            }
            <MudSwitch @bind-Value="_shareNewMaxViewsEnabled" Label="Límite de vistas" Color="Color.Primary" />
            @if (_shareNewMaxViewsEnabled)
            {
                <MudNumericField @bind-Value="_shareNewMaxViews"
                                 Label="Máximo de vistas"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="1" Max="10000" />
            }
            <MudSwitch @bind-Value="_shareNewAllowDownload" Label="Permitir descarga" Color="Color.Primary" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.AddLink"
                       Disabled="_shareCreatingLink"
                       Class="mb-2"
                       OnClick="ShareCreateLink">
                @if (_shareCreatingLink)
                { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Crear enlace
            </MudButton>
        </div>
    </div>
</MudDrawer>
}

@* ── Editar álbum — bottom sheet ── *@
@if (_editAlbumSheetEverOpened)
{
<MudDrawer @bind-Open="_editDialogVisible"
           Anchor="Anchor.Bottom"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Class="ph-bottom-sheet">
    <div class="ph-sheet-handle"></div>
    <div class="d-flex justify-space-between align-center px-4 pt-1 pb-2">
        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Editar álbum</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       OnClick="CloseEditDialog" />
    </div>
    <MudDivider />
    <div class="px-4 pt-3 pb-6">
        <MudTextField @bind-Value="_editAlbumName"
                      Label="Nombre del álbum"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Class="mb-3" />
        <MudTextField @bind-Value="_editAlbumDescription"
                      Label="Descripción (opcional)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Lines="3"
                      Class="mb-4" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   FullWidth="true" Size="Size.Medium"
                   OnClick="UpdateAlbum">
            Guardar
        </MudButton>
    </div>
</MudDrawer>
}

<MudDialog @bind-Visible="_deleteDialogVisible" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar Álbum</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>¿Estás seguro de que quieres eliminar el álbum "@_deleteTargetAlbumName"? Esta acción no se puede deshacer.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="DeleteAlbum">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_deleteSelectedDialogVisible" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar álbumes</MudText>
    </TitleContent>
    <DialogContent>
