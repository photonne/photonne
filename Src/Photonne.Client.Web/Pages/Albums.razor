        {
            var sort = await JS.InvokeAsync<string?>("localStorage.getItem", "photonne:albums:sort");
            if (Enum.TryParse<AlbumSort>(sort, out var sortValue)) _albumSort = sortValue;

            var viewMode = await JS.InvokeAsync<string?>("localStorage.getItem", "photonne:albums:viewMode");
            if (Enum.TryParse<AlbumViewMode>(viewMode, out var viewModeValue)) _albumViewMode = viewModeValue;

