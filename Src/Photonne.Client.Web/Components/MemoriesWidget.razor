@if (_yearGroups.Any())
{
    <div class="memories-widget">
        <div class="memories-header">
            <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Small" Class="memories-icon" />
            <div class="memories-header-text">
                <span class="memories-title">Recuerdos</span>
                <span class="memories-date">@_dateLabel</span>
            </div>
        </div>

        <div class="memories-cards">
            @foreach (var group in _yearGroups)
            {
                var yearsAgo = DateTime.Today.Year - group.Key;
                var heroAsset = group.Value.First();
                var stripAssets = group.Value.Skip(1).Take(4).ToList();

                <div class="memories-card">
                    <!-- Hero -->
                    <div class="memories-card-hero"
                         @onclick="() => OnThumbClick.InvokeAsync(new MemoryClickArgs { Asset = heroAsset, GroupAssets = group.Value })">
                        <img src="@heroAsset.ThumbnailUrl" alt="memory" loading="lazy" />

                        @if (heroAsset.Type == "Video")
                        {
                            <div class="memories-video-badge">
                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                            </div>
                        }

                        <div class="memories-card-overlay">
                            <span class="memories-card-time">Hace @yearsAgo @(yearsAgo == 1 ? "año" : "años")</span>
                            <span class="memories-card-year">@group.Key</span>
                        </div>

                        <div class="memories-card-pill">
                            @group.Value.Count @(group.Value.Count == 1 ? "foto" : "fotos")
                        </div>
                    </div>

                    <!-- Strip: máximo 4 fotos, sin scroll -->
                    @if (stripAssets.Any())
                    {
                        <div class="memories-strip">
                            @foreach (var asset in stripAssets)
                            {
                                <div class="memories-strip-thumb"
                                     @onclick="() => OnThumbClick.InvokeAsync(new MemoryClickArgs { Asset = asset, GroupAssets = group.Value })">
                                    <img src="@asset.ThumbnailUrl" alt="memory" loading="lazy" />
                                    @if (asset.Type == "Video")
                                    {
                                        <div class="memories-video-sm">
                                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    /* ── Widget ── */
    .memories-widget {
        box-sizing: border-box;
        width: 100%;
        margin-bottom: 24px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    /* ── Header ── */
    .memories-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
        padding: 0 2px;
    }

    .memories-icon { color: var(--mud-palette-primary); flex-shrink: 0; }

    .memories-header-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .memories-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        letter-spacing: 0.01em;
    }

    .memories-date {
        font-size: 0.72rem;
        color: var(--mud-palette-text-secondary);
        text-transform: capitalize;
    }

    /* ── Cards list ── */
    .memories-cards {
        display: flex;
        flex-direction: column;
        gap: 12px;
        /* Contiene el ancho — nunca desborda el padre */
        min-width: 0;
        width: 100%;
        box-sizing: border-box;
    }

    /* ── Card (full-width con márgenes laterales) ── */
    .memories-card {
        box-sizing: border-box;
        width: 100%;
        overflow: hidden;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        box-shadow: 0 2px 14px rgba(0,0,0,0.35);
        /* Evita que el contenido interno empuje el ancho */
        min-width: 0;
    }

    /* ── Hero ── */
    .memories-card-hero {
        position: relative;
        width: 100%;
        /* Ratio 16:9 para paisaje — más natural en fotos */
        aspect-ratio: 16 / 9;
        cursor: pointer;
        overflow: hidden;
        background: #1a1a1a;
        -webkit-tap-highlight-color: transparent;
    }

    .memories-card-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .memories-card-hero:hover img,
    .memories-card-hero:active img {
        transform: scale(1.03);
    }

    /* Gradient overlay */
    .memories-card-overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 40px 14px 12px;
        background: linear-gradient(to top, rgba(0,0,0,0.80) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
    }

    .memories-card-time {
        font-size: 0.88rem;
        font-weight: 700;
        color: #fff;
        text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }

    .memories-card-year {
        font-size: 0.78rem;
        font-weight: 400;
        color: rgba(255,255,255,0.72);
        text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }

    /* Pill top-right */
    .memories-card-pill {
        position: absolute;
        top: 10px; right: 10px;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.9);
        font-size: 0.7rem;
        font-weight: 500;
        padding: 3px 9px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.12);
        z-index: 1;
    }

    /* Video badge hero */
    .memories-video-badge {
        position: absolute;
        bottom: 48px; right: 12px;
        color: #fff;
        filter: drop-shadow(0 0 3px rgba(0,0,0,0.7));
        z-index: 1;
    }

    /* ── Strip: grid de 4 columnas, sin scroll ── */
    .memories-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2px;
        background: rgba(0,0,0,0.25);
        width: 100%;
        box-sizing: border-box;
    }

    .memories-strip-thumb {
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
        cursor: pointer;
        background: #2a2a2a;
        -webkit-tap-highlight-color: transparent;
    }

    .memories-strip-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity 0.15s;
    }

    .memories-strip-thumb:hover img,
    .memories-strip-thumb:active img {
        opacity: 0.75;
    }

    /* Video badge strip */
    .memories-video-sm {
        position: absolute;
        bottom: 4px; right: 4px;
        color: #fff;
        filter: drop-shadow(0 0 2px rgba(0,0,0,0.8));
        z-index: 1;
    }
</style>

@code {
    [Parameter] public EventCallback<MemoryClickArgs> OnThumbClick { get; set; }
    [Parameter] public bool Test { get; set; }
    [Inject] private IAssetService AssetService { get; set; } = null!;

    private Dictionary<int, List<TimelineItem>> _yearGroups = new();
    private string _dateLabel = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        _dateLabel = today.ToString("d 'de' MMMM", new System.Globalization.CultureInfo("es-ES"));

        var items = await AssetService.GetMemoriesAsync(Test);
        _yearGroups = items
            .GroupBy(a => a.FileCreatedAt.Year)
            .OrderByDescending(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }
}
