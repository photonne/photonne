@inject IPeopleService PeopleService
@inject ISnackbar Snackbar
@using Photonne.Client.Web.Services

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <img src="@($"/api/faces/{Face.Id}/thumbnail")"
                 alt="Cara"
                 class="ph-face-dialog__thumb" />
            <div>
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Asignar cara</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                    Actualmente: @CurrentPersonName
                </MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAutocomplete T="PersonSummary"
                         Label="Buscar persona"
                         SearchFunc="SearchPeople"
                         Value="_selectedPerson"
                         ValueChanged="OnPersonSelected"
                         ToStringFunc="@(p => string.IsNullOrWhiteSpace(p?.Name) ? "Sin nombre" : p!.Name)"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Clearable="true"
                         CoerceText="false"
                         Class="mt-2"
                         Placeholder="Empieza a escribir un nombre…" />

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);" Class="mb-1 d-block">
            …o crea una persona nueva
        </MudText>
        <div class="d-flex gap-2 align-center">
            <MudTextField @bind-Value="_newName"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="Nombre"
                          OnKeyDown="OnNewNameKey" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_busy || string.IsNullOrWhiteSpace(_newName))"
                       OnClick="CreateAndAssignAsync">
                Crear
            </MudButton>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Default"
                   StartIcon="@Icons.Material.Outlined.Block"
                   Disabled="@_busy"
                   OnClick="RejectAsync">
            No es una cara
        </MudButton>
        <MudButton Color="Color.Warning"
                   StartIcon="@Icons.Material.Outlined.LinkOff"
                   Disabled="@(_busy || !Face.PersonId.HasValue)"
                   OnClick="UnassignAsync">
            Desvincular
        </MudButton>
        <MudButton OnClick="Cancel" Disabled="@_busy">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .ph-face-dialog__thumb {
        width: 48px; height: 48px; border-radius: 50%;
        object-fit: cover; flex: 0 0 auto;
        background: var(--mud-palette-background-grey);
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public FaceItem Face { get; set; } = null!;
    [Parameter] public string CurrentPersonName { get; set; } = string.Empty;

    private List<PersonSummary>? _peopleCache;
    private PersonSummary? _selectedPerson;
    private string _newName = string.Empty;
    private bool _busy;

    private async Task<IEnumerable<PersonSummary>> SearchPeople(string? value, CancellationToken ct)
    {
        _peopleCache ??= (await PeopleService.GetPeopleAsync(limit: 500, includeHidden: false, ct: ct)).Items;

        var pool = _peopleCache.Where(p => !string.IsNullOrWhiteSpace(p.Name));
        if (string.IsNullOrWhiteSpace(value))
            return pool.OrderBy(p => p.Name).Take(20);

        return pool
            .Where(p => p.Name!.Contains(value, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.Name)
            .Take(20);
    }

    private async Task OnPersonSelected(PersonSummary? person)
    {
        _selectedPerson = person;
        if (person == null || _busy) return;
        await AssignToAsync(person.Id, null);
    }

    private async Task CreateAndAssignAsync()
    {
        var name = _newName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        await AssignToAsync(null, name);
    }

    private async Task OnNewNameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newName))
            await CreateAndAssignAsync();
    }

    private async Task AssignToAsync(Guid? personId, string? newName)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await PeopleService.AssignFaceAsync(Face.Id, personId, newName);
            Snackbar.Add("Cara asignada", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            _busy = false;
        }
    }

    private async Task UnassignAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await PeopleService.UnassignFaceAsync(Face.Id);
            Snackbar.Add("Cara desvinculada", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            _busy = false;
        }
    }

    private async Task RejectAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await PeopleService.RejectFaceAsync(Face.Id);
            Snackbar.Add("Cara descartada", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            _busy = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
