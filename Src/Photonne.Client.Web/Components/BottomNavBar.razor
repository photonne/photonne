@inject NavigationManager Navigation
@inject LayoutService LayoutService
@implements IDisposable

@* ── SECTION CONTEXT BAR (mobile only, settings & admin) ── *@
@if ((IsSettingsSection || IsAdminSection) && !LayoutService.HideBottomNav)
{
    <div class="ph-section-header">
        <button class="ph-section-header__back" @onclick="@(() => OnBackToMore.InvokeAsync())">
            <MudIcon Icon="@Icons.Material.Outlined.ArrowBack" Class="ph-section-header__back-icon" />
            <span>Volver</span>
        </button>
        <span class="ph-section-header__title">
            @(IsSettingsSection ? "Configuración" : "Administración")
        </span>
    </div>
}

@if (!LayoutService.HideBottomNav)
{
    @if (IsSettingsSection)
    {
        @* ── SETTINGS NAV ── *@
        <nav class="ph-bottom-nav" role="navigation" aria-label="Configuración">
            <a href="/settings/profile"    class="ph-bottom-nav__tab @(IsActive("/settings/profile")    ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/settings/profile")    ? Icons.Material.Filled.Person       : Icons.Material.Outlined.Person)"       Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Perfil</span>
            </a>
            <a href="/settings/security"   class="ph-bottom-nav__tab @(IsActive("/settings/security")   ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/settings/security")   ? Icons.Material.Filled.Lock         : Icons.Material.Outlined.Lock)"         Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Seguridad</span>
            </a>
            <a href="/settings/appearance" class="ph-bottom-nav__tab @(IsActive("/settings/appearance") ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/settings/appearance") ? Icons.Material.Filled.Palette      : Icons.Material.Outlined.Palette)"      Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Apariencia</span>
            </a>
            <a href="/settings/device"     class="ph-bottom-nav__tab @(IsActive("/settings/device")     ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/settings/device")     ? Icons.Material.Filled.PhoneAndroid : Icons.Material.Outlined.PhoneAndroid)" Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Dispositivo</span>
            </a>
        </nav>
    }
    else if (IsAdminSection)
    {
        @* ── ADMIN NAV ── *@
        <nav class="ph-bottom-nav" role="navigation" aria-label="Administración">
            <a href="/admin/users"     class="ph-bottom-nav__tab @(IsActive("/admin/users")     ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/admin/users")     ? Icons.Material.Filled.People         : Icons.Material.Outlined.People)"         Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Usuarios</span>
            </a>
            <a href="/admin/libraries" class="ph-bottom-nav__tab @(IsActive("/admin/libraries") ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/admin/libraries") ? Icons.Material.Filled.FolderSpecial   : Icons.Material.Outlined.FolderSpecial)"   Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Bibliotecas</span>
            </a>
            <a href="/admin/stats"     class="ph-bottom-nav__tab @(IsActive("/admin/stats")     ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/admin/stats")     ? Icons.Material.Filled.QueryStats     : Icons.Material.Outlined.QueryStats)"     Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Estadísticas</span>
            </a>
            <a href="/admin/settings"  class="ph-bottom-nav__tab @(IsActive("/admin/settings")  ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsActive("/admin/settings")  ? Icons.Material.Filled.Settings       : Icons.Material.Outlined.Settings)"       Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Ajustes</span>
            </a>
            <a href="/admin/system"    class="ph-bottom-nav__tab @(IsAdminSystemTab             ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsAdminSystemTab             ? Icons.Material.Filled.Storage        : Icons.Material.Outlined.Storage)"        Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Sistema</span>
            </a>
        </nav>
    }
    else
    {
        @* ── MAIN NAV ── *@
        <nav class="ph-bottom-nav" role="navigation" aria-label="Navegación principal">
            <a href="/" class="ph-bottom-nav__tab @(IsTabActive("/", exact: true) ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsTabActive("/", exact: true) ? Icons.Material.Filled.PhotoLibrary : Icons.Material.Outlined.PhotoLibrary)" Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Fotos</span>
            </a>
            <a href="/search" class="ph-bottom-nav__tab @(IsTabActive("/search") ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsTabActive("/search") ? Icons.Material.Filled.Search : Icons.Material.Outlined.Search)" Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Buscar</span>
            </a>
            <a href="/albums/own" class="ph-bottom-nav__tab @(IsTabActive("/albums") || IsTabActive("/my-shares") ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsTabActive("/albums") || IsTabActive("/my-shares") ? Icons.Material.Filled.Collections : Icons.Material.Outlined.Collections)" Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Álbumes</span>
            </a>
            <a href="/folders/own" class="ph-bottom-nav__tab @(IsTabActive("/folders") ? "ph-bottom-nav__tab--active" : "")">
                <MudIcon Icon="@(IsTabActive("/folders") ? Icons.Material.Filled.Folder : Icons.Material.Outlined.FolderOpen)" Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Carpetas</span>
            </a>
            <button class="ph-bottom-nav__tab ph-bottom-nav__tab--btn @(IsMoreSection || IsMoreSheetOpen ? "ph-bottom-nav__tab--active" : "")"
                    @onclick="@(() => OnOpenMoreSheet.InvokeAsync())">
                <MudIcon Icon="@(IsMoreSection ? Icons.Material.Filled.GridView : Icons.Material.Outlined.GridView)" Class="ph-bottom-nav__icon" />
                <span class="ph-bottom-nav__label">Más</span>
            </button>
        </nav>


    }
}

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        LayoutService.OnMajorUpdate += HandleMajorUpdate;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private void HandleMajorUpdate()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        LayoutService.OnMajorUpdate -= HandleMajorUpdate;
    }

    [Parameter] public EventCallback OnOpenMoreSheet { get; set; }
    [Parameter] public EventCallback OnBackToMore { get; set; }
    [Parameter] public bool IsMoreSheetOpen { get; set; }

    private bool IsActive(string path, bool exact = false)
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        return exact
            ? currentPath.Equals(path, StringComparison.OrdinalIgnoreCase)
            : currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsTabActive(string path, bool exact = false)
        => !IsMoreSheetOpen && IsActive(path, exact);

    private bool IsSettingsSection  => IsActive("/settings");
    private bool IsAdminSection     => IsActive("/admin");
    private bool IsAdminSystemTab   => IsActive("/admin/system") || IsActive("/admin/tasks") || IsActive("/admin/backup");

    private bool IsMoreSection =>
        IsActive("/favorites") || IsActive("/map")     ||
        IsActive("/device")    || IsActive("/archive") || IsActive("/trash") ||
        IsActive("/utilities");
}
