@using Photonne.Client.Web.Services

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4" Variant="Variant.Outlined">
            Cambiar el nombre de usuario lanzará un proceso que renombrará la carpeta física
            del usuario en el servidor y actualizará todas las referencias en la base de datos.
            La operación es atómica: o se completa por entero o se revierte.
        </MudAlert>

        <MudText Typo="Typo.body1" Class="mb-2">
            <strong>De:</strong> <code>@Preview.CurrentUsername</code>
            &nbsp;→&nbsp;
            <strong>A:</strong> <code>@Preview.NewUsername</code>
        </MudText>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Cambios que se aplicarán</MudText>
        <MudList T="string" Dense="true" ReadOnly="true">
            <MudListItem Icon="@Icons.Material.Filled.Folder" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    Carpeta física: <code>@Preview.CurrentVirtualPath</code> → <code>@Preview.NewVirtualPath</code>
                    @if (!Preview.FolderExistsOnDisk)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-2">aún no existe en disco</MudChip>
                    }
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.Image" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    Assets a actualizar: <strong>@Preview.AssetsToUpdate</strong>
                </MudText>
            </MudListItem>
            <MudListItem Icon="@Icons.Material.Filled.FolderOpen" IconColor="Color.Primary">
                <MudText Typo="Typo.body2">
                    Carpetas a actualizar: <strong>@Preview.FoldersToUpdate</strong>
                </MudText>
            </MudListItem>
            @if (Preview.SettingsToUpdate > 0)
            {
                <MudListItem Icon="@Icons.Material.Filled.Settings" IconColor="Color.Primary">
                    <MudText Typo="Typo.body2">
                        Ajustes con rutas personalizadas a actualizar: <strong>@Preview.SettingsToUpdate</strong>
                    </MudText>
                </MudListItem>
            }
        </MudList>

        @if (Preview.AssetsToUpdate > 1000 || Preview.FoldersToUpdate > 100)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Variant="Variant.Outlined">
                Hay muchos registros afectados; la operación puede tardar varios segundos.
                Durante el proceso no se podrán realizar cambios sobre estos datos.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="Confirm">
            Sí, renombrar y migrar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public RenamePreviewDto Preview { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
}
