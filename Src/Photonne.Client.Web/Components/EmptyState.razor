<div class="d-flex flex-column align-center justify-center py-12 text-center @(string.IsNullOrWhiteSpace(Class) ? "" : Class)">
    <MudIcon Icon="@Icon"
             Style="font-size: 5.5rem; opacity: .45;" Color="Color.Primary" />
    <MudText Typo="Typo.h6" Class="mt-4">@Title</MudText>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1 text-center"
                 Style="max-width: 240px;">@Description</MudText>
    }
    @if (Actions is not null)
    {
        <div class="mt-4">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Icon { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
