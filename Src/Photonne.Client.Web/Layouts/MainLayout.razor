@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject LayoutService LayoutService
@inject ThemeService ThemeService
@inject IAuthService AuthService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ApiErrorNotifier ApiErrorNotifier
@inject INotificationService NotificationService
@inject PwaUpdateService PwaUpdateService
@inject IDemoInfoService DemoInfoService
@inject IJSRuntime JS
@inject DeviceLayoutService DeviceLayout
@inject BackNavigationService BackNavigation

<MudThemeProvider IsDarkMode="LayoutService.IsDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Surface" Class="px-4 border-b">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" Class="mr-2" />

        <div class="d-flex align-center" style="cursor: pointer;" @onclick="@(() => Navigation.NavigateTo("/"))">
            <img src="@(LayoutService.IsDarkMode ? "dark/logo.png" : "light/logo.png")" alt="Photonne" style="height: 32px; width: auto;" />
            <MudText Typo="Typo.subtitle2" Class="ml-2 d-none d-sm-flex mud-text-secondary">Admin</MudText>
        </div>

        <MudSpacer />

        <div class="d-flex align-center">
            @* Dark mode toggle *@
            <ResponsiveTooltip Text="Alternar modo claro/oscuro">
                <MudIconButton Icon="@(LayoutService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               OnClick="@LayoutService.ToggleDarkModeAsync" />
            </ResponsiveTooltip>

            @* Notifications dropdown *@
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)" Class="notification-badge">
                        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                                       OnClick="@(async () => { await LoadRecentNotificationsAsync(); await context.ToggleAsync(); })" />
                    </MudBadge>
                </ActivatorContent>
                <ChildContent>
                    @NotificationsMenuContent()
                </ChildContent>
            </MudMenu>

            @* Avatar menu *@
            <AuthorizeView>
                <Authorized>
                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <div @onclick="@context.ToggleAsync" style="cursor: pointer;">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="ml-2" Style="width: 32px; height: 32px;">
                                    @UserInitial
                                </MudAvatar>
                            </div>
                        </ActivatorContent>
                        <ChildContent>
                            @AvatarMenuContent()
                        </ChildContent>
                    </MudMenu>
                </Authorized>
                <NotAuthorized>
                    <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small">
                        Iniciar Sesión
                    </MudButton>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </MudAppBar>

    @if (_isNavigating)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"
                           Style="position: fixed; top: var(--mud-appbar-height, 64px); left: 0; right: 0; z-index: 1299; margin: 0; height: 3px;" />
    }

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
               Variant="@DrawerVariant.Responsive" Class="border-r">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="flex-grow: 1; display: flex; flex-direction: column;">
        @if (_demoInfo.Enabled)
        {
            <div class="demo-banner">
                <MudIcon Icon="@Icons.Material.Filled.Science" Size="Size.Small" Class="flex-shrink-0" />
                <MudText Typo="Typo.body2" Class="flex-grow-1">
                    Demo pública de Photonne · Los datos se reinician
                    @if (_demoInfo.NextResetAt.HasValue)
                    {
                        <span> @FormatNextReset(_demoInfo.NextResetAt.Value)</span>
                    }
                    else if (_demoInfo.ResetIntervalHours.HasValue)
                    {
                        <span> cada @_demoInfo.ResetIntervalHours h</span>
                    }
                </MudText>
                <MudLink Href="https://github.com/photonne/photonne" Target="_blank"
                         Typo="Typo.body2" Underline="Underline.Always">
                    Ver en GitHub
                </MudLink>
            </div>
        }
        @if (PwaUpdateService.UpdateAvailable)
        {
            <div class="pwa-update-banner">
                <MudIcon Icon="@Icons.Material.Filled.SystemUpdate" Size="Size.Small" Color="Color.Primary" Class="flex-shrink-0" />
                <MudText Typo="Typo.body2" Class="flex-grow-1">
                    Nueva versión disponible
                    @if (!string.IsNullOrEmpty(PwaUpdateService.CurrentVersion) && !string.IsNullOrEmpty(PwaUpdateService.NewVersion))
                    {
                        <MudText Typo="Typo.caption" Inline="true" Class="ml-1" Style="opacity: 0.7;">
                            (v@(PwaUpdateService.CurrentVersion) → v@(PwaUpdateService.NewVersion))
                        </MudText>
                    }
                    else if (!string.IsNullOrEmpty(PwaUpdateService.NewVersion))
                    {
                        <MudText Typo="Typo.caption" Inline="true" Class="ml-1" Style="opacity: 0.7;">
                            (v@(PwaUpdateService.NewVersion))
                        </MudText>
                    }
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                               Variant="Variant.Filled" Color="Color.Primary"
                               Title="Actualizar ahora"
                               OnClick="@PwaUpdateService.ApplyUpdateAsync" />
            </div>
        }
        <div class="page-content" style="flex-grow: 1;">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isNavigating = false;
    private int _unreadCount;
    private List<NotificationDto> _recentNotifications = [];
    private CancellationTokenSource? _pollingCts;
    private string _appVersion = string.Empty;
    private DemoInfo _demoInfo = DemoInfo.Disabled;
    private UserDto? _currentUser;
    private bool _checkingForUpdate;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        LayoutService.OnMajorUpdate += StateHasChanged;
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        ApiErrorNotifier.OnError += HandleApiError;
        PwaUpdateService.OnUpdateAvailable += HandlePwaUpdateAvailable;
    }

    protected override async Task OnInitializedAsync()
    {
        await LayoutService.InitializeAsync();
        await DeviceLayout.InitializeAsync();
        DeviceLayout.OnChanged += HandleDeviceLayoutChanged;
        await LoadCurrentUserAsync();
        await LoadUnreadCountAsync();
        _demoInfo = await DemoInfoService.GetAsync();
        StartNotificationPolling();
    }

    private void HandleDeviceLayoutChanged() => InvokeAsync(StateHasChanged);

    private static string FormatNextReset(DateTimeOffset next)
    {
        var delta = next - DateTimeOffset.UtcNow;
        if (delta.TotalMinutes < 1) return "en menos de un minuto";
        if (delta.TotalHours < 1)   return $"en {(int)delta.TotalMinutes} min";
        if (delta.TotalDays < 1)    return $"en {(int)delta.TotalHours} h";
        return $"el {next.ToLocalTime():dd/MM HH:mm}";
    }

    private async void HandleAuthStateChanged()
    {
        await LoadCurrentUserAsync();

        if (!await AuthService.IsAuthenticatedAsync())
        {
            var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            if (!path.StartsWith("login"))
            {
                var loginUrl = BuildLoginUrl(new Uri(Navigation.Uri).PathAndQuery);
                Navigation.NavigateTo(loginUrl);
            }
        }

        StateHasChanged();
    }

    private async Task LoadCurrentUserAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        LayoutService.OnMajorUpdate -= StateHasChanged;
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
        ApiErrorNotifier.OnError -= HandleApiError;
        PwaUpdateService.OnUpdateAvailable -= HandlePwaUpdateAvailable;
        DeviceLayout.OnChanged -= HandleDeviceLayoutChanged;
    }

    private string UserInitial
        => !string.IsNullOrWhiteSpace(_currentUser?.FirstName)
            ? _currentUser!.FirstName.Trim()[0].ToString().ToUpperInvariant()
            : !string.IsNullOrWhiteSpace(_currentUser?.Username)
                ? _currentUser!.Username.Trim()[0].ToString().ToUpperInvariant()
                : "?";

    private string UserFullName => GetUserFullName();

    private string UserEmail => _currentUser?.Email ?? string.Empty;

    private string GetUserFullName()
    {
        var parts = new[] { _currentUser?.FirstName, _currentUser?.LastName }
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToArray();

        return parts.Length > 0
            ? string.Join(" ", parts)
            : _currentUser?.Username ?? "Usuario";
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _isNavigating = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BackNavigation.EnsureInitializedAsync();
            await PwaUpdateService.InitAsync(JS);
            _appVersion = await JS.InvokeAsync<string>("pwaUpdate.getAppVersion");
        }

        if (_isNavigating)
        {
            _isNavigating = false;
            StateHasChanged();
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private void HandlePwaUpdateAvailable()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task CheckForUpdatesAsync()
    {
        if (_checkingForUpdate) return;
        _checkingForUpdate = true;
        try
        {
            var hasUpdate = await PwaUpdateService.CheckForUpdateAsync();
            if (hasUpdate)
            {
                await PwaUpdateService.ApplyUpdateAsync();
                return;
            }
            Snackbar.Add("Ya tienes la última versión.", Severity.Success);
        }
        finally
        {
            _checkingForUpdate = false;
            StateHasChanged();
        }
    }

    private void HandleApiError(ApiErrorInfo info)
    {
        _ = InvokeAsync(async () =>
        {
            if (ShouldForceLogin(info))
            {
                await AuthService.LogoutAsync();
                var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
                if (!path.StartsWith("login"))
                {
                    var loginUrl = BuildLoginUrl(new Uri(Navigation.Uri).PathAndQuery);
                    Navigation.NavigateTo(loginUrl);
                }
                return;
            }

            var parameters = new DialogParameters
            {
                ["Error"] = info
            };

            var options = new DialogOptions
            {
                Position = DialogPosition.Center,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true,
                BackdropClick = false
            };

            DialogService.ShowAsync<ApiErrorDialog>(info.Title, parameters, options);
        });
    }

    private static bool ShouldForceLogin(ApiErrorInfo info)
    {
        if (info.StatusCode is null) return false;
        return info.StatusCode >= 500 || info.StatusCode == 401 || info.StatusCode == 403;
    }

    private static string BuildLoginUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl)) return "/login";
        return $"/login?returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private void StartNotificationPolling()
    {
        _pollingCts = new CancellationTokenSource();
        var token = _pollingCts.Token;
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(60));
            while (!token.IsCancellationRequested && await timer.WaitForNextTickAsync(token).ConfigureAwait(false))
            {
                await InvokeAsync(async () =>
                {
                    await LoadUnreadCountAsync();
                    StateHasChanged();
                });
            }
        }, token);
    }

    private async Task LoadUnreadCountAsync()
    {
        try { _unreadCount = await NotificationService.GetUnreadCountAsync(); }
        catch { /* no interrumpir el layout por fallo de notificaciones */ }
    }

    private async Task LoadRecentNotificationsAsync()
    {
        try
        {
            var result = await NotificationService.GetNotificationsAsync(page: 1, pageSize: 5);
            _recentNotifications = result.Items;
            _unreadCount = result.UnreadCount;
        }
        catch { /* ignorar errores en el dropdown */ }
    }

    private async Task MarkAllNotificationsReadAsync()
    {
        try
        {
            await NotificationService.MarkAllAsReadAsync();
            foreach (var n in _recentNotifications) n.IsRead = true;
            _unreadCount = 0;
        }
        catch { }
    }

    private static string GetNotificationIcon(NotificationTypeDto type) => type switch
    {
        NotificationTypeDto.JobCompleted => Icons.Material.Filled.CheckCircle,
        NotificationTypeDto.JobFailed   => Icons.Material.Filled.Error,
        NotificationTypeDto.ShareViewed => Icons.Material.Filled.Visibility,
        NotificationTypeDto.SharedAssetsDeleted => Icons.Material.Filled.DeleteSweep,
        _                               => Icons.Material.Filled.Notifications
    };

    private static Color GetNotificationColor(NotificationTypeDto type) => type switch
    {
        NotificationTypeDto.JobCompleted => Color.Success,
        NotificationTypeDto.JobFailed   => Color.Error,
        NotificationTypeDto.ShareViewed => Color.Info,
        NotificationTypeDto.SharedAssetsDeleted => Color.Warning,
        _                               => Color.Default
    };

    private static string FormatNotificationDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "Ahora mismo";
        if (diff.TotalHours < 1)   return $"Hace {(int)diff.TotalMinutes} min";
        if (diff.TotalDays < 1)    return $"Hace {(int)diff.TotalHours}h";
        if (diff.TotalDays < 7)    return $"Hace {(int)diff.TotalDays}d";
        return dt.ToLocalTime().ToString("dd/MM/yyyy");
    }

    private RenderFragment NotificationsMenuContent() => @<text>
        <div class="d-flex justify-space-between align-center px-4 pt-3" style="min-width: 320px;">
            <MudText Typo="Typo.subtitle1">Notificaciones</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                       OnClick="MarkAllNotificationsReadAsync"
                       Disabled="@(_unreadCount == 0)">
                Marcar leídas
            </MudButton>
        </div>
        <MudDivider Class="my-2" />
        <MudList T="NotificationDto" Class="px-2 pb-1">
            @if (_recentNotifications.Any())
            {
                @foreach (var notification in _recentNotifications)
                {
                    <MudListItem Class="@(notification.IsRead ? "" : "mud-background-gray")">
                        <div class="d-flex align-start gap-2">
                            <MudIcon Icon="@GetNotificationIcon(notification.Type)"
                                     Color="@GetNotificationColor(notification.Type)"
                                     Size="Size.Small" Class="mt-1 flex-shrink-0" />
                            <div>
                                <MudText Typo="Typo.body2" Class="@(notification.IsRead ? "mud-text-secondary" : "font-weight-medium")">
                                    @notification.Title
                                </MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@notification.Message</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@FormatNotificationDate(notification.CreatedAt)</MudText>
                            </div>
                        </div>
                    </MudListItem>
                }
            }
            else
            {
                <MudListItem>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No hay notificaciones.</MudText>
                </MudListItem>
            }
        </MudList>
        <MudDivider />
        <div class="px-4 py-2">
            <MudButton Variant="Variant.Text" FullWidth="true" Color="Color.Primary"
                       OnClick="@(() => Navigation.NavigateTo("/notifications"))">
                Ver todas las notificaciones
            </MudButton>
        </div>
    </text>;

    private RenderFragment AvatarMenuContent() => @<text>
        <div class="d-flex flex-column align-center pa-4" style="min-width: 240px;">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="width: 56px; height: 56px;">
                @UserInitial
            </MudAvatar>
            <MudText Typo="Typo.subtitle1" Class="mt-2">@UserFullName</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@UserEmail</MudText>
        </div>
        <MudDivider />
        <MudButton Variant="Variant.Text" FullWidth="true" OnClick="@LayoutService.ToggleDarkModeAsync">
            @(LayoutService.IsDarkMode ? "Modo claro" : "Modo oscuro")
        </MudButton>
        <MudButton Variant="Variant.Text" FullWidth="true" OnClick="@(() => Navigation.NavigateTo("/settings"))">
            Configuración cuenta
        </MudButton>
        <MudButton Variant="Variant.Text" FullWidth="true"
                   StartIcon="@Icons.Material.Outlined.SystemUpdate"
                   Disabled="@_checkingForUpdate"
                   OnClick="@(async () => await CheckForUpdatesAsync())">
            @(_checkingForUpdate ? "Buscando actualizaciones…" : "Buscar actualizaciones")
        </MudButton>
        <MudDivider />
        <MudButton Variant="Variant.Text" FullWidth="true" OnClick="Logout">
            Cerrar sesión
        </MudButton>
    </text>;
}
