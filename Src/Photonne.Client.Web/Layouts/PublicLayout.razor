@inherits LayoutComponentBase
@implements IDisposable
@inject LayoutService LayoutService
@inject ThemeService ThemeService
@inject DeviceLayoutService DeviceLayout

<MudThemeProvider IsDarkMode="LayoutService.IsDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="public-layout">
    <header class="public-header">
        <MudText Typo="Typo.h6" Class="public-brand">Photonne</MudText>
        <MudButton Href="/login" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
            Iniciar sesión
        </MudButton>
    </header>
    <main class="public-content">
        @Body
    </main>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await DeviceLayout.InitializeAsync();
        DeviceLayout.OnChanged += HandleDeviceLayoutChanged;
    }

    private void HandleDeviceLayoutChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        DeviceLayout.OnChanged -= HandleDeviceLayoutChanged;
    }
}
