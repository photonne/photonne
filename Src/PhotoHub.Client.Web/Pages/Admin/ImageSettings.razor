@page "/admin/settings/imagenes"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISettingsService SettingsService
@inject ISnackbar Snackbar

<PageTitle>Administración - Ajustes de imagen - PhotoHub</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
    {
        <div class="mt-8">
            <MudText Typo="Typo.h5">Acceso Denegado</MudText>
            <MudText Typo="Typo.body1">Solo los administradores pueden acceder a esta página.</MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Volver al inicio
            </MudButton>
        </div>
    }
    else
    {
        <div class="mt-4">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/admin/settings"))" Class="mb-2">
                Volver
            </MudButton>
            <MudText Typo="Typo.h5" Class="mb-2">Ajustes de imagen</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Parámetros de calidad y formato para las miniaturas generadas.
            </MudText>
        </div>

        <MudGrid Class="mt-4">
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">Formato de miniaturas</MudText>
                        <MudRadioGroup T="string" @bind-Value="_format">
                            <MudRadio T="string" Value="@("JPEG")" Color="Color.Primary">JPEG</MudRadio>
                            <MudRadio T="string" Value="@("WebP")" Color="Color.Primary">
                                WebP
                                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">(~30% menos espacio)</MudText>
                            </MudRadio>
                        </MudRadioGroup>

                        <MudDivider Class="my-4" />

                        <MudText Typo="Typo.subtitle1" Class="mb-4">Calidad de miniaturas</MudText>

                        <MudText Typo="Typo.body2" Class="mb-1">Pequeña (220px) — @_qualitySmall%</MudText>
                        <MudSlider T="int" @bind-Value="_qualitySmall" Min="1" Max="100" Step="1" Color="Color.Primary" Class="mb-4" />

                        <MudText Typo="Typo.body2" Class="mb-1">Media (640px) — @_qualityMedium%</MudText>
                        <MudSlider T="int" @bind-Value="_qualityMedium" Min="1" Max="100" Step="1" Color="Color.Primary" Class="mb-4" />

                        <MudText Typo="Typo.body2" Class="mb-1">Grande (1280px) — @_qualityLarge%</MudText>
                        <MudSlider T="int" @bind-Value="_qualityLarge" Min="1" Max="100" Step="1" Color="Color.Primary" Class="mb-2" />

                        <MudAlert Severity="Severity.Info" Class="mt-4">
                            Cambiar estos ajustes no modifica las miniaturas existentes. Ve a
                            <strong>Colas de trabajo → Generar miniaturas</strong> y usa
                            <strong>Regenerar todas</strong> para aplicarlos.
                        </MudAlert>
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="SaveSettings"
                                   Disabled="_saving"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @if (_saving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
                            }
                            Guardar
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private const string KeyFormat = "TaskSettings.ThumbnailFormat";
    private const string KeyQualitySmall = "TaskSettings.ThumbnailQuality.Small";
    private const string KeyQualityMedium = "TaskSettings.ThumbnailQuality.Medium";
    private const string KeyQualityLarge = "TaskSettings.ThumbnailQuality.Large";

    private bool _isAuthorized = false;
    private bool _saving = false;
    private string _format = "JPEG";
    private int _qualitySmall = 75;
    private int _qualityMedium = 80;
    private int _qualityLarge = 85;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";

        if (_isAuthorized)
        {
            _format = await SettingsService.GetSettingAsync(KeyFormat, "JPEG");
            _qualitySmall = ParseInt(await SettingsService.GetSettingAsync(KeyQualitySmall, "75"), 1, 100, 75);
            _qualityMedium = ParseInt(await SettingsService.GetSettingAsync(KeyQualityMedium, "80"), 1, 100, 80);
            _qualityLarge = ParseInt(await SettingsService.GetSettingAsync(KeyQualityLarge, "85"), 1, 100, 85);
        }
    }

    private static int ParseInt(string value, int min, int max, int defaultValue)
    {
        if (!int.TryParse(value, out var n)) return defaultValue;
        return Math.Clamp(n, min, max);
    }

    private async Task SaveSettings()
    {
        _saving = true;
        try
        {
            var ok = await SettingsService.SaveSettingAsync(KeyFormat, _format)
                && await SettingsService.SaveSettingAsync(KeyQualitySmall, _qualitySmall.ToString())
                && await SettingsService.SaveSettingAsync(KeyQualityMedium, _qualityMedium.ToString())
                && await SettingsService.SaveSettingAsync(KeyQualityLarge, _qualityLarge.ToString());

            if (ok)
                Snackbar.Add("Ajustes de imagen guardados correctamente", Severity.Success);
            else
                Snackbar.Add("Error al guardar los ajustes", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
