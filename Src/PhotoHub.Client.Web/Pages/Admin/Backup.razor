@page "/admin/backup"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IDatabaseBackupService BackupService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Administración - Copia de seguridad - PhotoHub</PageTitle>

<div class="page-pad">
    @if (!_isAuthorized)
    {
        <div class="mt-8">
            <MudText Typo="Typo.h5">Acceso Denegado</MudText>
            <MudText Typo="Typo.body2">Solo los administradores pueden acceder a esta página.</MudText>
            <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Volver al inicio
            </MudButton>
        </div>
    }
    else
    {
        <div class="mt-4">
            <MudText Typo="Typo.h5" Class="mb-2">Copia de seguridad</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
                Exporta o importa todos los registros de la base de datos.
                Las copias de seguridad no incluyen los archivos multimedia; solo los metadatos y la estructura de datos.
            </MudText>

            <MudDivider Class="mb-6" />

            <MudGrid>
                <!-- Export -->
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                    <MudIcon Icon="@Icons.Material.Filled.CloudDownload" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Exportar copia de seguridad</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    Descarga un archivo <strong>.json</strong> con todos los datos de la base de datos.
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                                Los archivos multimedia (fotos y vídeos) no se incluyen en la copia de seguridad.
                                Debes gestionarlos por separado.
                            </MudAlert>
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-4">
                            <MudButton
                                Variant="Variant.Filled"
                                Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.Download"
                                OnClick="HandleExportAsync"
                                Disabled="_exportLoading">
                                @if (_exportLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Generando...</span>
                                }
                                else
                                {
                                    <span>Descargar copia</span>
                                }
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Restore -->
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Warning" Variant="Variant.Filled">
                                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Restaurar copia de seguridad</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    Importa un archivo <strong>.json</strong> generado por esta aplicación.
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">
                                <strong>Atención:</strong> esta operación eliminará permanentemente todos los datos actuales
                                de la base de datos y los reemplazará con los del archivo seleccionado.
                            </MudAlert>

                            <MudFileUpload T="IBrowserFile"
                                           FilesChanged="OnFileSelected"
                                           Accept=".json"
                                           MaximumFileCount="1">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Default"
                                               StartIcon="@Icons.Material.Filled.AttachFile">
                                        Seleccionar archivo
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>

                            @if (_selectedFile != null)
                            {
                                <div class="d-flex align-center mt-3 gap-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.InsertDriveFile" Size="Size.Small" Class="mud-text-secondary" />
                                    <MudText Typo="Typo.body2">@_selectedFile.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">(@FormatBytes(_selectedFile.Size))</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   OnClick="ClearSelectedFile" />
                                </div>
                            }
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-4">
                            <MudButton
                                Variant="Variant.Filled"
                                Color="Color.Warning"
                                StartIcon="@Icons.Material.Filled.RestorePage"
                                OnClick="OpenRestoreConfirmDialog"
                                Disabled="_restoreLoading || _selectedFile == null">
                                @if (_restoreLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Restaurando...</span>
                                }
                                else
                                {
                                    <span>Restaurar copia</span>
                                }
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Restore result -->
                @if (_restoreResult != null)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="@(_restoreResult.Success ? Severity.Success : Severity.Error)"
                                  ShowCloseIcon="true"
                                  CloseIconClicked="() => _restoreResult = null">
                            @_restoreResult.Message
                            @if (_restoreResult.Success && _restoreResult.Stats != null)
                            {
                                <ul class="mt-2 mb-0" style="padding-left:1.2rem">
                                    <li>Usuarios: <strong>@_restoreResult.Stats.Users</strong></li>
                                    <li>Assets: <strong>@_restoreResult.Stats.Assets</strong></li>
                                    <li>Álbumes: <strong>@_restoreResult.Stats.Albums</strong></li>
                                    <li>Carpetas: <strong>@_restoreResult.Stats.Folders</strong></li>
                                    <li>Bibliotecas externas: <strong>@_restoreResult.Stats.ExternalLibraries</strong></li>
                                </ul>
                            }
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>
        </div>
    }
</div>

<!-- Restore confirmation dialog -->
<MudDialog @bind-Visible="_confirmDialogOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Confirmar restauración</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>
            Estás a punto de reemplazar <strong>todos los datos</strong> de la base de datos con los del archivo:
        </MudText>
        <MudText Class="mt-2 font-bold">@_selectedFile?.Name</MudText>
        <MudText Class="mt-3" Color="Color.Error">
            Esta acción no se puede deshacer. ¿Estás seguro de que deseas continuar?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmDialogOpen = false" Disabled="_restoreLoading">Cancelar</MudButton>
        <MudButton Color="Color.Warning"
                   Variant="Variant.Filled"
                   OnClick="HandleRestoreAsync"
                   Disabled="_restoreLoading">
            Sí, restaurar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _isAuthorized = false;
    private bool _exportLoading = false;
    private bool _restoreLoading = false;
    private bool _confirmDialogOpen = false;
    private IBrowserFile? _selectedFile;
    private DatabaseRestoreResult? _restoreResult;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            var returnUrl = Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        var currentUser = await AuthService.GetCurrentUserAsync();
        _isAuthorized = currentUser?.Role == "Admin";
    }

    private void OnFileSelected(IBrowserFile? file)
    {
        _selectedFile  = file;
        _restoreResult = null;
    }

    private void ClearSelectedFile()
    {
        _selectedFile  = null;
        _restoreResult = null;
    }

    private void OpenRestoreConfirmDialog()
    {
        if (_selectedFile == null) return;
        _confirmDialogOpen = true;
    }

    private async Task HandleExportAsync()
    {
        _exportLoading = true;
        try
        {
            var backup = await BackupService.ExportAsync();
            await JS.InvokeVoidAsync("downloadFileFromBytes", backup.FileName, "application/json", backup.Bytes);
            Snackbar.Add("Copia de seguridad descargada correctamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al generar la copia de seguridad: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exportLoading = false;
        }
    }

    private async Task HandleRestoreAsync()
    {
        if (_selectedFile == null) return;

        _confirmDialogOpen = false;
        _restoreLoading    = true;
        _restoreResult     = null;

        try
        {
            // 100 MB max
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            _restoreResult = await BackupService.RestoreAsync(stream, _selectedFile.Name);

            if (_restoreResult.Success)
            {
                Snackbar.Add("Base de datos restaurada correctamente.", Severity.Success);
                _selectedFile = null;
            }
            else
            {
                Snackbar.Add($"Error en la restauración: {_restoreResult.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _restoreLoading = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}
