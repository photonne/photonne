@page "/device"
@inject IAssetService AssetService
@inject IPendingAssetsProvider PendingAssetsProvider
@inject ISettingsService SettingsService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Mi Dispositivo - PhotoHub</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}

<div class="page-pad">
    <MudText Typo="Typo.h5" Class="mb-4">Mi Dispositivo</MudText>

    @* ── Ruta configurada ────────────────────────────────────────── *@
    @if (!_loading)
    {
        @if (string.IsNullOrWhiteSpace(_devicePath))
        {
            <EmptyState Icon="@Icons.Material.Filled.FolderOff"
                        Title="No hay ninguna ruta configurada"
                        Description="Ve a Configuración → Dispositivo para establecer la carpeta donde están tus fotos.">
                <Actions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="@(() => Navigation.NavigateTo("/settings/device"))">
                        Configurar ruta
                    </MudButton>
                </Actions>
            </EmptyState>
        }
        else
        {
            <MudPaper Class="d-flex align-center gap-3 px-4 py-3 mb-4" Elevation="0"
                      Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" />
                <div class="flex-grow-1 min-width-0">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Ruta analizada</MudText>
                    <MudText Typo="Typo.body2" Style="word-break: break-all;">@_devicePath</MudText>
                </div>
                <MudTooltip Text="Re-escanear">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   Disabled="@_loading"
                                   OnClick="@(async () => await LoadDeviceAssets())" />
                </MudTooltip>
            </MudPaper>

            @* ── Alerta de pendientes ────────────────────────────────── *@
            @if (_pendingAssetsCount > 0 && !_syncingAll)
            {
                <MudPaper Class="mb-4 pa-4" Elevation="0"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <div class="d-flex align-center gap-3 mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" Size="Size.Small" />
                        <div>
                            <MudText Typo="Typo.body2" Class="font-weight-medium">
                                @_pendingAssetsCount @(_pendingAssetsCount == 1 ? "foto pendiente" : "fotos pendientes") de sincronizar
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Se copiarán al directorio interno para su indexación
                            </MudText>
                        </div>
                    </div>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               FullWidth="true"
                               OnClick="SyncAllPendingAssets">
                        Sincronizar todas
                    </MudButton>
                </MudPaper>
            }

            @* ── Progreso de sincronización ──────────────────────────── *@
            @if (_syncingAll)
            {
                <MudPaper Class="mb-4 pa-4" Elevation="0"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <div class="d-flex align-center gap-3 mb-2">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="flex-shrink-0" />
                        <MudText Typo="Typo.body2" Class="font-weight-medium flex-grow-1">@_syncProgressMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelSyncAll" Size="Size.Small">
                            Cancelar
                        </MudButton>
                    </div>
                    <MudProgressLinear Color="Color.Primary" Value="@_syncProgress" Rounded="true" Class="mb-2" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @_syncCurrent de @_syncTotal sincronizadas
                        @if (_syncSuccessful > 0 || _syncFailed > 0)
                        {
                            <span> · @_syncSuccessful exitosas@(_syncFailed > 0 ? $", {_syncFailed} fallidas" : "")</span>
                        }
                    </MudText>
                </MudPaper>
            }

            @* ── Grid de assets ──────────────────────────────────────── *@
            @if (_groupedAssets.Any())
            {
                @foreach (var group in _groupedAssets)
                {
                    <div class="mb-6">
                        <MudText Typo="Typo.body2" Class="device-date-header">@group.Key</MudText>
                        <MudGrid Spacing="1">
                            @foreach (var asset in group.Value)
                            {
                                <MudItem xs="4" sm="3" md="2" lg="2" xl="1">
                                    <AssetCard Asset="@asset" OnAssetClick="OpenAsset" />
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                }
            }
            else if (!_loading)
            {
                <EmptyState Icon="@Icons.Material.Filled.CheckCircle"
                            Title="Todo sincronizado"
                            Description="@($"No hay archivos nuevos en {_devicePath}")" />
            }
        }
    }
</div>

<style>
    .device-date-header {
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        text-transform: capitalize;
        padding: 0 4px 6px 4px;
    }

    @@media (max-width: 599.98px) {
        .device-date-header {
            font-size: 0.78rem !important;
        }
    }
</style>

@code {
    private List<TimelineItem> _assets = new();
    private Dictionary<string, List<TimelineItem>> _groupedAssets = new();
    private bool _loading = true;
    private string _devicePath = "";

    // Sincronización múltiple
    private int _pendingAssetsCount = 0;
    private bool _syncingAll = false;
    private string _syncProgressMessage = "";
    private double _syncProgress = 0;
    private int _syncCurrent = 0;
    private int _syncTotal = 0;
    private int _syncSuccessful = 0;
    private int _syncFailed = 0;
    private CancellationTokenSource? _syncCancellationTokenSource;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            _devicePath = await SettingsService.GetAssetsPathAsync();
            if (!string.IsNullOrWhiteSpace(_devicePath))
            {
                await LoadDeviceAssets();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDeviceAssets()
    {
        try
        {
            _loading = true;
            StateHasChanged();
            _assets = await PendingAssetsProvider.GetPendingAssetsAsync();
            GroupAssets();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al analizar la ruta: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void GroupAssets()
    {
        _groupedAssets = _assets
            .OrderByDescending(a => a.ModifiedDate)
            .GroupBy(a => a.ModifiedDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES")))
            .ToDictionary(g => char.ToUpper(g.Key[0]) + g.Key.Substring(1), g => g.ToList());

        _pendingAssetsCount = _assets.Count;
    }

    private void OpenAsset(TimelineItem asset)
    {
        var encodedPath = System.Net.WebUtility.UrlEncode(asset.FullPath);
        Navigation.NavigateTo($"/asset/{Guid.Empty}?path={encodedPath}");
    }

    private async Task SyncAllPendingAssets()
    {
        var pendingAssets = _assets.ToList();
        if (!pendingAssets.Any())
        {
            Snackbar.Add("No hay fotos pendientes de sincronizar", Severity.Info);
            return;
        }

        _syncingAll = true;
        _syncTotal = pendingAssets.Count;
        _syncCurrent = 0;
        _syncSuccessful = 0;
        _syncFailed = 0;
        _syncProgress = 0;
        _syncProgressMessage = "Iniciando sincronización...";
        _syncCancellationTokenSource = new CancellationTokenSource();

        StateHasChanged();

        try
        {
            var paths = pendingAssets.Select(a => a.FullPath).ToList();

            await foreach (var update in AssetService.SyncMultipleAssetsAsync(paths, _syncCancellationTokenSource.Token))
            {
                _syncCurrent = update.Current;
                _syncTotal = update.Total;
                _syncSuccessful = update.Successful;
                _syncFailed = update.Failed;
                _syncProgress = update.Percentage;
                _syncProgressMessage = update.Message;

                var asset = _assets.FirstOrDefault(a => a.FullPath == update.CurrentPath);
                if (asset != null)
                {
                    asset.SyncStatus = update.Message.Contains("Error")
                        ? AssetSyncStatus.Pending
                        : AssetSyncStatus.Copied;
                }

                StateHasChanged();

                if (update.IsCompleted) break;
            }

            await LoadDeviceAssets();

            Snackbar.Add($"Sincronización completada: {_syncSuccessful} exitosas, {_syncFailed} fallidas",
                _syncFailed > 0 ? Severity.Warning : Severity.Success);
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Sincronización cancelada", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error durante la sincronización: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncingAll = false;
            _syncCancellationTokenSource?.Dispose();
            _syncCancellationTokenSource = null;
            StateHasChanged();
        }
    }

    private void CancelSyncAll()
    {
        _syncCancellationTokenSource?.Cancel();
    }

    public void Dispose()
    {
        _syncCancellationTokenSource?.Cancel();
        _syncCancellationTokenSource?.Dispose();
    }
}
