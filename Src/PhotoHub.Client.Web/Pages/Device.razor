@page "/device"
@inject IAssetService AssetService
@inject ILocalFolderService LocalFolderService
@inject IPendingAssetsProvider PendingAssetsProvider
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Mi Dispositivo - PhotoHub</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
}

@* ── Lightbox local ──────────────────────────────────────────────────── *@
@if (_lightboxAsset != null)
{
    <div class="local-lightbox" @onclick="CloseLightbox">
        <div class="local-lightbox-toolbar" @onclick:stopPropagation="true">
            <MudText Typo="Typo.body2" Class="white-text flex-grow-1"
                     Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                @_lightboxAsset.FileName
            </MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary mr-3">
                @_lightboxAsset.FileSizeFormatted
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Color="Color.Inherit"
                           Size="Size.Small"
                           OnClick="CloseLightbox" />
        </div>

        <div class="local-lightbox-content" @onclick:stopPropagation="true">
            @if (_lightboxLoading)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            }
            else if (_lightboxBlobUrl != null)
            {
                @if (_lightboxAsset.Type == "VIDEO")
                {
                    <video src="@_lightboxBlobUrl" controls autoplay playsinline
                           class="local-lightbox-media" />
                }
                else
                {
                    <img src="@_lightboxBlobUrl" alt="@_lightboxAsset.FileName"
                         class="local-lightbox-media" />
                }
            }
            else
            {
                <MudAlert Severity="Severity.Error">No se pudo abrir el archivo.</MudAlert>
            }
        </div>
    </div>
}

<div class="page-pad">
    <MudText Typo="Typo.h5" Class="mb-4">Mi Dispositivo</MudText>

    @if (!_loading)
    {
        @if (string.IsNullOrWhiteSpace(_folderName))
        {
            <EmptyState Icon="@Icons.Material.Filled.FolderOff"
                        Title="No hay ninguna carpeta seleccionada"
                        Description="Ve a Configuración → Dispositivo para seleccionar la carpeta donde están tus fotos.">
                <Actions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Settings"
                               OnClick="@(() => Navigation.NavigateTo("/settings/device"))">
                        Configurar carpeta
                    </MudButton>
                </Actions>
            </EmptyState>
        }
        else
        {
            @* ── Header: carpeta + re-escanear ──────────────────────────── *@
            <MudPaper Class="d-flex align-center gap-3 px-4 py-3 mb-4" Elevation="0"
                      Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" />
                <div class="flex-grow-1 min-width-0">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Carpeta analizada</MudText>
                    <MudText Typo="Typo.body2" Style="word-break: break-all;">@_folderName</MudText>
                </div>
                <MudTooltip Text="Re-escanear">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   Disabled="@(_loading || _checkingExisting)"
                                   OnClick="@(async () => await LoadDeviceAssetsAsync())" />
                </MudTooltip>
            </MudPaper>

            @* ── Permiso denegado ─────────────────────────────────────── *@
            @if (_permissionDenied)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-4">
                    Permiso de lectura denegado. Pulsa el botón para volver a solicitarlo.
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="RetryPermissionAsync" Class="ml-2">
                        Solicitar permiso
                    </MudButton>
                </MudAlert>
            }

            @* ── Comprobando duplicados (Opción A) ────────────────────── *@
            @if (_checkingExisting)
            {
                <MudPaper Class="d-flex align-center gap-3 px-4 py-3 mb-4" Elevation="0"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="flex-shrink-0" />
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Comprobando cuáles ya están en el servidor…</MudText>
                </MudPaper>
            }

            @* ── Resumen de estado ────────────────────────────────────── *@
            @if (!_checkingExisting && _assets.Count > 0 && !_uploadingAll)
            {
                var pendingCount = _assets.Count(a => a.SyncStatus == AssetSyncStatus.Pending);
                var syncedCount  = _assets.Count(a => a.SyncStatus == AssetSyncStatus.Synced);

                @if (pendingCount > 0)
                {
                    <MudPaper Class="mb-4 pa-4" Elevation="0"
                              Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                        <div class="d-flex align-center gap-3 mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" Size="Size.Small" />
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    @pendingCount @(pendingCount == 1 ? "foto nueva" : "fotos nuevas") para subir
                                    @if (syncedCount > 0)
                                    {
                                        <span Class="mud-text-secondary font-weight-regular"> · @syncedCount ya en servidor</span>
                                    }
                                </MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Se subirán al servidor para su indexación
                                </MudText>
                            </div>
                        </div>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   FullWidth="true"
                                   OnClick="UploadAllAsync">
                            Subir @pendingCount @(pendingCount == 1 ? "foto" : "fotos")
                        </MudButton>
                    </MudPaper>
                }
                else if (syncedCount > 0)
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4">
                        Todo sincronizado — @syncedCount @(syncedCount == 1 ? "foto" : "fotos") ya en el servidor.
                    </MudAlert>
                }
            }

            @* ── Progreso de subida ──────────────────────────────────── *@
            @if (_uploadingAll)
            {
                <MudPaper Class="mb-4 pa-4" Elevation="0"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <div class="d-flex align-center gap-3 mb-2">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="flex-shrink-0" />
                        <MudText Typo="Typo.body2" Class="font-weight-medium flex-grow-1">@_uploadMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelUpload" Size="Size.Small">
                            Cancelar
                        </MudButton>
                    </div>
                    <MudProgressLinear Color="Color.Primary" Value="@_uploadProgress" Rounded="true" Class="mb-2" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @_uploadCurrent de @_uploadTotal procesadas
                        @if (_uploadSuccessful > 0 || _uploadSkipped > 0 || _uploadFailed > 0)
                        {
                            <span>
                                · @_uploadSuccessful subidas
                                @if (_uploadSkipped > 0) { <span>, @_uploadSkipped ya existían</span> }
                                @if (_uploadFailed > 0) { <span>, @_uploadFailed fallidas</span> }
                            </span>
                        }
                    </MudText>
                </MudPaper>
            }

            @* ── Grid de assets ──────────────────────────────────────── *@
            @if (_groupedAssets.Count > 0)
            {
                @foreach (var group in _groupedAssets)
                {
                    <div class="mb-6">
                        <MudText Typo="Typo.body2" Class="device-date-header">@group.Key</MudText>
                        <MudGrid Spacing="1">
                            @foreach (var asset in group.Value)
                            {
                                <MudItem xs="4" sm="3" md="2" lg="2" xl="1">
                                    <AssetCard Asset="@asset" OnAssetClick="OpenAsset" />
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                }
            }
            else if (!_loading && !_permissionDenied && !_checkingExisting)
            {
                <EmptyState Icon="@Icons.Material.Filled.CheckCircle"
                            Title="Todo sincronizado"
                            Description="@($"No hay archivos nuevos en «{_folderName}»")" />
            }
        }
    }
</div>

<style>
    .device-date-header {
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        text-transform: capitalize;
        padding: 0 4px 6px 4px;
    }

    @@media (max-width: 599.98px) {
        .device-date-header {
            font-size: 0.78rem !important;
        }
    }

    .local-lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.96);
        z-index: 9999;
        display: flex;
        flex-direction: column;
    }

    .local-lightbox-toolbar {
        display: flex;
        align-items: center;
        padding: 8px 8px 8px 16px;
        gap: 4px;
        background: rgba(0, 0, 0, 0.6);
        flex-shrink: 0;
    }

    .local-lightbox-content {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 8px;
    }

    .local-lightbox-media {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 4px;
    }
</style>

@code {
    private List<TimelineItem> _assets = new();
    private Dictionary<string, List<TimelineItem>> _groupedAssets = new();
    private bool _loading = true;
    private bool _checkingExisting;
    private bool _permissionDenied;
    private string _folderName = "";

    private bool _uploadingAll;
    private string _uploadMessage = "";
    private double _uploadProgress;
    private int _uploadCurrent;
    private int _uploadTotal;
    private int _uploadSuccessful;
    private int _uploadSkipped;
    private int _uploadFailed;
    private CancellationTokenSource? _cts;

    // Lightbox
    private TimelineItem? _lightboxAsset;
    private string? _lightboxBlobUrl;
    private bool _lightboxLoading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            _folderName = await LocalFolderService.GetStoredFolderNameAsync() ?? "";
            if (!string.IsNullOrWhiteSpace(_folderName))
                await LoadDeviceAssetsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDeviceAssetsAsync()
    {
        try
        {
            _loading = true;
            _permissionDenied = false;
            StateHasChanged();

            _assets = await PendingAssetsProvider.GetPendingAssetsAsync();

            if (_assets.Count == 0)
            {
                var hasPermission = await LocalFolderService.RequestPermissionAsync();
                if (!hasPermission)
                {
                    _permissionDenied = true;
                    return;
                }
                _assets = await PendingAssetsProvider.GetPendingAssetsAsync();
            }

            GroupAssets();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al analizar la carpeta: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }

        // Opción A: comprobar cuáles ya existen en el servidor por nombre+tamaño
        await CheckExistingOnServerAsync();
    }

    // ── Opción A: check por nombre + tamaño ─────────────────────────────────
    private async Task CheckExistingOnServerAsync()
    {
        if (_assets.Count == 0) return;

        _checkingExisting = true;
        StateHasChanged();

        try
        {
            var filesToCheck = _assets.Select(a => (a.FileName, a.FileSize));
            var existingKeys = await AssetService.CheckExistingAsync(filesToCheck);

            foreach (var asset in _assets)
            {
                var key = $"{asset.FileName}|{asset.FileSize}";
                if (existingKeys.Contains(key))
                    asset.SyncStatus = AssetSyncStatus.Synced;
            }

            GroupAssets();
        }
        catch
        {
            // Si falla el check, dejamos todos como Pending (conservador)
        }
        finally
        {
            _checkingExisting = false;
            StateHasChanged();
        }
    }

    private async Task RetryPermissionAsync()
    {
        var granted = await LocalFolderService.RequestPermissionAsync();
        if (granted)
            await LoadDeviceAssetsAsync();
        else
            Snackbar.Add("Permiso denegado por el usuario", Severity.Warning);
    }

    private void GroupAssets()
    {
        _groupedAssets = _assets
            .OrderByDescending(a => a.ModifiedDate)
            .GroupBy(a => a.ModifiedDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES")))
            .ToDictionary(
                g => char.ToUpper(g.Key[0]) + g.Key[1..],
                g => g.ToList());
    }

    private async Task OpenAsset(TimelineItem asset)
    {
        _lightboxAsset = asset;
        _lightboxBlobUrl = null;
        _lightboxLoading = true;
        StateHasChanged();

        var url = await LocalFolderService.GetBlobUrlAsync(asset.FullPath);
        _lightboxBlobUrl = url;
        _lightboxLoading = false;
        StateHasChanged();
    }

    private async Task CloseLightbox()
    {
        if (_lightboxBlobUrl != null)
            await LocalFolderService.RevokeBlobUrlAsync(_lightboxBlobUrl);
        _lightboxAsset = null;
        _lightboxBlobUrl = null;
    }

    // ── Upload: opción B (checksum) antes de subir cada fichero ─────────────
    private async Task UploadAllAsync()
    {
        var pending = _assets.Where(a => a.SyncStatus == AssetSyncStatus.Pending).ToList();
        if (pending.Count == 0) return;

        _uploadingAll = true;
        _uploadTotal = pending.Count;
        _uploadCurrent = 0;
        _uploadSuccessful = 0;
        _uploadSkipped = 0;
        _uploadFailed = 0;
        _uploadProgress = 0;
        _uploadMessage = "Iniciando subida…";
        _cts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            foreach (var asset in pending)
            {
                _cts.Token.ThrowIfCancellationRequested();
                _uploadMessage = $"Procesando {asset.FileName}…";
                StateHasChanged();

                try
                {
                    // Opción B: calcular SHA-256 y comprobar antes de subir
                    var checksum = await LocalFolderService.ComputeChecksumAsync(asset.FullPath);
                    if (checksum != null)
                    {
                        var existingId = await AssetService.ExistsByChecksumAsync(checksum, _cts.Token);
                        if (existingId.HasValue)
                        {
                            // Ya existe en el servidor — marcar y saltar
                            asset.SyncStatus = AssetSyncStatus.Synced;
                            _uploadSkipped++;
                            _uploadCurrent++;
                            _uploadProgress = (double)_uploadCurrent / _uploadTotal * 100;
                            StateHasChanged();
                            continue;
                        }
                    }

                    // No existe: leer y subir
                    _uploadMessage = $"Subiendo {asset.FileName}…";
                    StateHasChanged();

                    var bytes = await LocalFolderService.ReadFileBytesAsync(asset.FullPath);
                    if (bytes == null || bytes.Length == 0)
                    {
                        _uploadFailed++;
                    }
                    else
                    {
                        using var stream = new MemoryStream(bytes);
                        var result = await AssetService.UploadAssetAsync(asset.FileName, stream, _cts.Token);
                        if (result != null)
                        {
                            asset.SyncStatus = AssetSyncStatus.Synced;
                            _uploadSuccessful++;
                        }
                        else
                        {
                            _uploadFailed++;
                        }
                    }
                }
                catch (OperationCanceledException)
                {
                    throw;
                }
                catch
                {
                    _uploadFailed++;
                }

                _uploadCurrent++;
                _uploadProgress = (double)_uploadCurrent / _uploadTotal * 100;
                StateHasChanged();
            }

            GroupAssets();

            var summary = $"{_uploadSuccessful} subidas";
            if (_uploadSkipped > 0) summary += $", {_uploadSkipped} ya existían";
            if (_uploadFailed > 0) summary += $", {_uploadFailed} fallidas";
            Snackbar.Add($"Completado: {summary}", _uploadFailed > 0 ? Severity.Warning : Severity.Success);
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Subida cancelada", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error durante la subida: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploadingAll = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private void CancelUpload() => _cts?.Cancel();

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        if (_lightboxBlobUrl != null)
            _ = LocalFolderService.RevokeBlobUrlAsync(_lightboxBlobUrl);
    }
}
