@page "/albums"
@page "/albums/{Filter}"
@page "/albums/{AlbumId:guid}"
@inject IAlbumService AlbumService
@inject AlbumsCache AlbumsCache
@inject IAssetService AssetService
@inject IShareService ShareService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject LayoutService LayoutService
@inject IAssetListNavigationState AssetListNavigationState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Álbumes - PhotoHub</PageTitle>

<style>
    .album-card-container {
        position: relative;
        cursor: pointer;
        width: 100%;
    }

    .album-select-checkbox {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 5;
        opacity: 0;
        transition: opacity 0.2s;
        background: rgba(0,0,0,0.45);
        border-radius: 999px;
        padding: 2px;
        color: white;
    }

    .album-select-checkbox .mud-icon-root {
        color: white !important;
    }

    .album-card-container:hover .album-select-checkbox {
        opacity: 1;
    }

    .album-card-container.selection-mode .album-select-checkbox,
    .album-card-container.selected .album-select-checkbox {
        opacity: 1;
    }

    .asset-select-container {
        position: relative;
        height: 100%;
    }

    .asset-select-checkbox {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 5;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s;
        background: rgba(0,0,0,0.4);
        border-radius: 999px;
        padding: 2px;
        color: white;
    }

    .asset-select-checkbox .mud-icon-root {
        color: white !important;
    }

    .asset-select-container:hover .asset-select-checkbox {
        opacity: 1;
        pointer-events: auto;
    }

    .asset-select-container.selection-mode .asset-select-checkbox,
    .asset-select-container.selected .asset-select-checkbox {
        opacity: 1;
        pointer-events: auto;
    }

    @@media (max-width: 959.98px) {
        .asset-select-container:not(.selection-mode):not(.selected):hover .asset-select-checkbox {
            opacity: 0;
            pointer-events: none;
        }
    }

    .albums-search {
        max-width: 300px;
    }

    .album-card-container {
        position: relative;
        cursor: pointer;
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        background: var(--mud-palette-surface);
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid var(--mud-palette-divider);
    }

    .album-card-container:hover {
        transform: translateY(-4px);
        box-shadow: var(--mud-elevation-4);
    }

    .album-card {
        background: transparent !important;
        box-shadow: none !important;
    }

    /* ── Collage de previsualización ── */
    .album-thumb-collage {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background: var(--mud-palette-surface);
    }

    .collage-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        width: 100%;
        height: 100%;
        gap: 2px;
        transition: gap 0.35s ease;
    }

    .album-card-container:hover .collage-grid {
        gap: 3px;
    }

    .collage-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
        display: block;
    }

    .album-card-container:hover .collage-img {
        transform: scale(1.06);
    }

    .collage-single {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.35s ease;
        display: block;
    }

    .album-card-container:hover .collage-single {
        transform: scale(1.06);
    }

    .collage-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-dark, #4f46e5) 100%);
        color: white;
    }

    .collage-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 12px;
        background: linear-gradient(transparent, rgba(0,0,0,0.82));
        pointer-events: none;
    }

    .albums-toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: nowrap;
        overflow-x: auto;
    }


    .album-year-header {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin: 16px 0 8px;
    }

    .album-year-count {
        color: var(--mud-palette-text-secondary);
    }

    .album-grid-badges {
        position: absolute;
        top: 8px;
        right: 8px;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 4px;
        z-index: 5;
    }

    .album-shared-badge {
        background: rgba(0,0,0,0.5);
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .album-grid-share-btn {
        background: rgba(0,0,0,0.5);
        color: white;
        padding: 3px 5px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        z-index: 5;
        cursor: pointer;
        transition: background 0.15s;
    }

    .album-grid-share-btn.active {
        color: var(--mud-palette-primary-lighten);
    }

    .album-grid-share-btn:hover {
        background: var(--mud-palette-primary);
        color: white;
    }


    .album-list-share-btn {
        flex-shrink: 0;
    }

    .album-list-shared-badge {
        display: flex;
        align-items: center;
        gap: 4px;
        color: var(--mud-palette-text-secondary);
        font-size: 0.875rem;
    }

    .album-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .album-list-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px;
        border-radius: 12px;
        background: var(--mud-palette-surface);
        transition: background 0.2s ease;
        cursor: pointer;
        position: relative;
    }

    .album-list-item:hover {
        background: var(--mud-palette-action-hover);
    }

    .album-list-thumb {
        width: 96px;
        height: 96px;
        position: relative;
        flex: 0 0 96px;
        border-radius: 8px;
        overflow: hidden;
    }

    .album-list-info {
        flex: 1;
        min-width: 0;
    }

    .album-list-title {
        font-weight: 600;
    }

    .album-list-meta {
        color: var(--mud-palette-text-secondary);
        font-size: 0.85rem;
    }


    /* Estilos para el Hero del álbum */
    .album-hero {
        position: relative;
        width: calc(100% + 48px);
        margin-left: -24px;
        margin-right: -24px;
        margin-top: -24px;
        min-height: 360px;
        border-radius: 0;
        overflow: hidden;
        margin-bottom: 24px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .album-hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        background-size: cover;
        background-position: center;
        filter: blur(20px) brightness(0.7);
        transform: scale(1.1);
    }

    .album-hero-content {
        position: relative;
        z-index: 1;
        padding: 24px;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        color: white;
    }

    .album-hero-actions {
        position: absolute;
        top: 8px;
        right: 8px;
        z-index: 2;
        display: flex;
        gap: 8px;
        color: white;
    }

    .album-hero-back {
        position: absolute;
        top: 8px;
        left: 8px;
        z-index: 2;
        color: white;
    }

    .album-description-text {
        max-height: 100px;
        overflow-y: auto;
        opacity: 0.9;
    }

    /* Album detail — fixed-height scroll container so AppBar/BottomNav stay fixed */
    .album-detail-scroll {
        height: calc(100vh - var(--mud-appbar-height, 64px));
        overflow-y: auto;
        overflow-x: hidden;
    }

    @@media (max-width: 959.98px) {
        .album-detail-scroll {
            height: calc(100vh - var(--mud-appbar-height, 64px) - 64px - env(safe-area-inset-bottom));
        }

        .album-hero {
            min-height: 260px;
        }
    }

    /* View toggle in filter sheet */
    .album-view-toggle {
        gap: 8px;
        border: none !important;
        box-shadow: none !important;
    }

    .album-view-toggle .mud-toggle-item {
        border-radius: 20px !important;
        background: var(--mud-palette-action-default-hover);
        flex: 1;
    }

    .album-view-toggle .mud-toggle-item-selected {
        background: var(--mud-palette-primary) !important;
        color: var(--mud-palette-primary-text) !important;
    }

    /* Section tabs moved to `wwwroot/css/app.css` */

    .share-link-row {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .share-link-row:last-child { border-bottom: none; }
    .share-link-info {
        flex: 1;
        min-width: 0;
    }
    .share-link-url {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-family: monospace;
        font-size: 0.78rem;
        opacity: 0.75;
    }
</style>

@if (_selectedAlbum == null)
{
    <div class="page-pad">
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.h5">Álbumes</MudText>

        <div class="d-flex align-center gap-1">
            <MudTextField @bind-Value="_albumSearch"
                          Placeholder="Buscar"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="albums-search d-none d-sm-flex" />
            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Title="Nuevo álbum"
                           OnClick="OpenCreateDialog" />
            <MudIconButton Icon="@Icons.Material.Filled.Tune"
                           Size="Size.Small"
                           Title="Opciones de vista"
                           OnClick="@(() => { _albumFilterSheetEverOpened = true; _albumFilterSheetOpen = true; })" />
        </div>
    </div>

    @* ── Section tabs ── *@
    <div class="ph-section-tabs">
        <a href="/albums/own"    class="ph-section-tab @(Filter?.ToLower() == "own"    || Filter == null ? "ph-section-tab--active" : "")">Míos</a>
        <a href="/albums/shared" class="ph-section-tab @(Filter?.ToLower() == "shared" ? "ph-section-tab--active" : "")">Compartidos</a>
        <a href="/my-shares"     class="ph-section-tab">Links</a>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
    }
    else
    {
        var albumGroups = GetAlbumGroups();
        var hasAlbums = albumGroups.Any(group => group.Albums.Any());

        if (hasAlbums)
        {
            @foreach (var group in albumGroups)
            {
                if (group.Year.HasValue)
                {
                    <div class="album-year-header">
                        <MudText Typo="Typo.h5">@group.Year</MudText>
                        <MudText Typo="Typo.body2" Class="album-year-count">@($"{group.Albums.Count} álbumes")</MudText>
                    </div>
                }

                if (_albumViewMode == AlbumViewMode.Grid)
                {
                    <MudGrid>
                        @foreach (var album in group.Albums)
                        {
                            <MudItem xs="6" sm="4" md="3" lg="2">
                                <div class="album-card-container @(_albumSelectionMode ? "selection-mode" : "") @(IsAlbumSelected(album.Id) ? "selected" : "")"
                                     @onclick="@(() => OnAlbumCardClick(album.Id))">
                                    <div class="album-select-checkbox" @onclick:stopPropagation="true">
                                        <MudCheckBox T="bool"
                                                     Value="@IsAlbumSelected(album.Id)"
                                                     ValueChanged="@(EventCallback.Factory.Create<bool>(this, value => ToggleAlbumSelection(album.Id, value)))" />
                                    </div>
                                    <div class="album-grid-badges">
                                        @if (album.SharedWithCount > 0)
                                        {
                                            <div class="album-shared-badge" title="Compartido con @album.SharedWithCount usuarios">
                                                <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Color="Color.Inherit" />
                                                <span>@album.SharedWithCount</span>
                                            </div>
                                        }
                                        @if (album.IsOwner)
                                        {
                                            <div class="album-grid-share-btn @(album.HasActiveShareLink ? "active" : "")"
                                                 title="@(album.HasActiveShareLink ? "Gestionar enlace" : "Compartir álbum")"
                                                 @onclick:stopPropagation="true"
                                                 @onclick="() => OpenShareDialogForAlbum(album.Id, album.Name)">
                                                <MudIcon Icon="@Icons.Material.Outlined.Share" Size="Size.Small" Color="Color.Inherit" />
                                            </div>
                                        }
                                    </div>
                                    <MudCard Class="album-card" Style="cursor: pointer;">
                                        <MudCardContent Style="padding: 0;">
                                            <div class="album-thumb-collage">
                                                @if (album.PreviewThumbnailUrls.Count >= 4)
                                                {
                                                    <div class="collage-grid">
                                                        @foreach (var url in album.PreviewThumbnailUrls.Take(4))
                                                        {
                                                            <img src="@url" class="collage-img" loading="lazy" alt="" />
                                                        }
                                                    </div>
                                                }
                                                else if (!string.IsNullOrEmpty(album.CoverThumbnailUrl))
                                                {
                                                    <img src="@album.CoverThumbnailUrl" class="collage-single" loading="lazy" alt="@album.Name" />
                                                }
                                                else
                                                {
                                                    <div class="collage-empty">
                                                        <MudIcon Icon="@Icons.Material.Filled.Collections" Size="Size.Large" Color="Color.Inherit" />
                                                    </div>
                                                }
                                                <div class="collage-overlay">
                                                    <MudText Typo="Typo.body2" Style="color: white; font-weight: 600; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">@album.Name</MudText>
                                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.9);">
                                                        @album.AssetCount @(album.AssetCount == 1 ? "foto" : "fotos")
                                                    </MudText>
                                                </div>
                                            </div>
                                        </MudCardContent>
                                    </MudCard>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                }
                else
                {
                    <div class="album-list">
                        @foreach (var album in group.Albums)
                        {
                            <div class="album-list-item album-card-container @(_albumSelectionMode ? "selection-mode" : "") @(IsAlbumSelected(album.Id) ? "selected" : "")"
                                 @onclick="@(() => OnAlbumCardClick(album.Id))">
                                <div class="album-list-thumb">
                                    <div class="album-select-checkbox" @onclick:stopPropagation="true">
                                        <MudCheckBox T="bool"
                                                     Value="@IsAlbumSelected(album.Id)"
                                                     ValueChanged="@(EventCallback.Factory.Create<bool>(this, value => ToggleAlbumSelection(album.Id, value)))" />
                                    </div>
                                    @if (!string.IsNullOrEmpty(album.CoverThumbnailUrl))
                                    {
                                        <img src="@album.CoverThumbnailUrl"
                                             style="width: 100%; height: 100%; object-fit: cover;"
                                             alt="@album.Name" />
                                    }
                                    else
                                    {
                                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-dark) 100%);">
                                            <MudIcon Icon="@Icons.Material.Filled.Collections"
                                                     Size="Size.Medium"
                                                     Color="Color.Inherit" />
                                        </div>
                                    }
                                </div>
                                <div class="album-list-info">
                                    <MudText Typo="Typo.subtitle1" Class="album-list-title">
                                        @album.Name
                                        @if (album.SharedWithCount > 0)
                                        {
                                            <div class="album-list-shared-badge" title="Compartido con @album.SharedWithCount usuarios">
                                                <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" />
                                                <span>@album.SharedWithCount</span>
                                            </div>
                                        }
                                        @if (album.HasActiveShareLink)
                                        {
                                            <div class="album-list-shared-badge" title="Tiene enlace público activo">
                                                <MudIcon Icon="@Icons.Material.Outlined.Share" Size="Size.Small" />
                                            </div>
                                        }
                                    </MudText>
                                    <MudText Typo="Typo.body2" Class="album-list-meta">
                                        @album.AssetCount @(album.AssetCount == 1 ? "foto" : "fotos")
                                    </MudText>
                                </div>
                                @if (album.IsOwner)
                                {
                                    <div @onclick:stopPropagation="true">
                                        <MudTooltip Text="@(album.HasActiveShareLink ? "Gestionar enlace" : "Compartir álbum")">
                                            <MudIconButton Icon="@Icons.Material.Outlined.Share"
                                                           Size="Size.Small"
                                                           Color="@(album.HasActiveShareLink ? Color.Primary : Color.Inherit)"
                                                           Class="album-list-share-btn"
                                                           OnClick="() => OpenShareDialogForAlbum(album.Id, album.Name)" />
                                        </MudTooltip>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        }
        else
        {
            <EmptyState Icon="@Icons.Material.Filled.Collections"
                        Title="No hay álbumes"
                        Description="Empieza creando uno nuevo." />
        }
    }
    </div>
}
else
{
    <div class="album-detail-scroll">
    <div class="page-pad">
    @* ── Section tabs (también en detalle, solo desktop) ── *@
    <div class="ph-section-tabs d-none d-md-flex">
        <a href="/albums/own"    class="ph-section-tab @(_selectedAlbum?.IsOwner == true ? "ph-section-tab--active" : "")">Míos</a>
        <a href="/albums/shared" class="ph-section-tab @(_selectedAlbum?.IsOwner == true ? "" : "ph-section-tab--active")">Compartidos</a>
        <a href="/my-shares"     class="ph-section-tab">Links</a>
    </div>

    <div class="album-hero">
        <div class="album-hero-bg" style="background-image: url('@(_selectedAlbum?.CoverThumbnailUrl ?? "")'); background-color: var(--mud-palette-primary);"></div>

        <div class="album-hero-back">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" OnClick="@(() => Navigation.NavigateTo($"/albums/{(_selectedAlbum?.IsOwner == true ? "own" : "shared")}"))" Title="Volver a álbumes" />
        </div>

        <div class="album-hero-actions">
            @if (_selectedAlbum?.IsOwner == true)
            {
                <MudTooltip Text="Compartir">
                    <MudIconButton Icon="@Icons.Material.Outlined.Share"
                                   Color="Color.Inherit"
                                   OnClick="OpenAlbumShareDialog" />
                </MudTooltip>
            }

            @if (_albumAssets.Any())
            {
                <MudTooltip Text="Descargar álbum">
                    <MudIconButton Icon="@Icons.Material.Outlined.Download"
                                   Color="Color.Inherit"
                                   Disabled="@_downloadingZip"
                                   OnClick="DownloadAlbumAsync" />
                </MudTooltip>
            }

            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" >
                @if (_selectedAlbum?.CanEdit == true || _selectedAlbum?.IsOwner == true)
                {
                    <MudMenuItem Icon="@Icons.Material.Outlined.AddPhotoAlternate" OnClick="@(() => Navigation.NavigateTo("/"))">Añadir fotos</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Edit" OnClick="OpenEditDialog">Editar nombre/descripción</MudMenuItem>
                }
                @if (_selectedAlbum?.CanManagePermissions == true || _selectedAlbum?.IsOwner == true)
                {
                    <MudMenuItem Icon="@Icons.Material.Outlined.Group"
                                 OnClick="@(() => Navigation.NavigateTo($"/albums/{AlbumId}/permissions"))">
                        Colaboradores
                    </MudMenuItem>
                }
                @if (_selectedAlbum?.IsOwner != true)
                {
                    <MudMenuItem Icon="@Icons.Material.Outlined.ExitToApp" OnClick="LeaveAlbum">Salir del álbum</MudMenuItem>
                }
                @if (_selectedAlbum?.CanDelete == true || _selectedAlbum?.IsOwner == true)
                {
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Outlined.Delete" OnClick="OpenDeleteDialog" Class="red-text">Eliminar álbum</MudMenuItem>
                }
            </MudMenu>
        </div>

        <div class="album-hero-content">
            <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0 mb-2" Style="color: rgba(255,255,255,0.7);" />
            
            <div class="d-flex align-center gap-2 mb-1">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_selectedAlbum.Name</MudText>
                @if (_selectedAlbum.IsShared)
                {
                    <MudTooltip Text="Álbum compartido">
                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Medium" Style="color: rgba(255,255,255,0.8);" />
                    </MudTooltip>
                }
            </div>

            <div class="d-flex align-center gap-4 mb-3">
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                    <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                    @_selectedAlbum.AssetCount @(_selectedAlbum.AssetCount == 1 ? "foto" : "fotos")
                </MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                    @_selectedAlbum.CreatedAt.ToString("MMMM yyyy")
                </MudText>
            </div>

            @if (!string.IsNullOrEmpty(_selectedAlbum.Description))
            {
                <div class="album-description-text">
                    <MudText Typo="Typo.body1">@_selectedAlbum.Description</MudText>
                </div>
            }
        </div>
    </div>

    @if (_loadingAssets)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="page-loading-bar" />
    }
    else if (_albumAssets.Any())
    {
        <div class="pb-4">
            <div class="mb-3">
                <MudText Typo="Typo.h6">Archivos</MudText>
            </div>
            <MudGrid Spacing="2">
                @foreach (var asset in _albumAssets)
                {
                    <MudItem xs="4" sm="3" md="2" lg="2" xl="1">
                        <div class="asset-select-container @(_assetSelectionMode ? "selection-mode" : "") @(IsAlbumAssetSelected(asset.Id) ? "selected" : "")"
                             data-asset-id="@asset.Id"
                             @ontouchstart="@(e => OnCardTouchStart(e, asset))"
                             @ontouchmove="OnCardTouchMove"
                             @ontouchend="OnCardTouchEnd">
                            <AssetCard Asset="@asset" OnAssetClick="OnAlbumAssetClick" />
                            <div class="asset-select-checkbox" @onclick:stopPropagation="true">
                                <MudCheckBox T="bool"
                                             Value="@IsAlbumAssetSelected(asset.Id)"
                                             ValueChanged="@(EventCallback.Factory.Create<bool>(this, value => ToggleAlbumAssetSelection(asset.Id, value)))" />
                            </div>
                        </div>
                    </MudItem>
                }
            </MudGrid>
