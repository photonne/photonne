@code {
    [Parameter] public Guid AlbumId { get; set; }
    [Parameter] public string? Filter { get; set; }

    private string PageHeader => Filter?.ToLower() switch
    {
        "own" => "Mis Álbumes",
        "shared" => "Compartidos",
        "public" => "Públicos",
        _ => "Álbumes"
    };

    private enum AlbumFilter
    {
        All = 0,
        Own = 1,
        Shared = 2,
        Public = 3
    }

    private enum AlbumViewMode
    {
        Grid,
        List
    }

    private enum AlbumSort
    {
        Recent,
        Oldest,
        Name
    }

    private List<AlbumItem> _albums = new();
    private AlbumItem? _selectedAlbum;
    private List<TimelineItem> _albumAssets = new();
    private bool _loading = true;
    private bool _loadingAssets = false;
    private bool _albumSelectionMode = false;
    private bool _assetSelectionMode = false;
    private HashSet<Guid> _selectedAlbumIds = new();
    private HashSet<Guid> _selectedAlbumAssetIds = new();
    private string _albumSearch = string.Empty;
    private AlbumFilter _albumFilter = AlbumFilter.All;
    private AlbumViewMode _albumViewMode = AlbumViewMode.Grid;
    private AlbumSort _albumSort = AlbumSort.Recent;
    private bool _groupByYear = true;

    private bool _downloadingZip = false;

    // Touch / long-press / drag-select
    private DotNetObjectReference<Albums>? _objRef;
    private System.Threading.Timer? _longPressTimer;
    private bool _longPressHandled;
    private double _touchStartX;
    private double _touchStartY;

    // Dialogs
    private bool _createDialogVisible = false;
    private bool _createAlbumSheetEverOpened = false;
    private bool _albumFilterSheetOpen = false;
    private bool _albumFilterSheetEverOpened = false;
    private bool _editDialogVisible = false;
    private bool _editAlbumSheetEverOpened = false;
    private bool _deleteDialogVisible = false;
    private bool _deleteSelectedDialogVisible = false;

    // Share bottom sheet
    private bool _shareSheetOpen = false;
    private bool _shareSheetEverOpened = false;
    private Guid? _shareSheetAlbumId;
    private string? _shareSheetAlbumName;
    private bool _shareLoadingLinks = false;
    private List<CreateShareLinkResponse> _sharePublicLinks = new();
    private bool _shareNewPasswordEnabled = false;
    private string _shareNewPassword = string.Empty;
    private bool _shareNewExpiryEnabled = false;
    private DateTime? _shareNewExpiry = null;
    private bool _shareNewMaxViewsEnabled = false;
    private int _shareNewMaxViews = 10;
    private bool _shareNewAllowDownload = true;
    private bool _shareCreatingLink = false;
    private string _newAlbumName = "";
    private string? _newAlbumDescription = "";
    private string _editAlbumName = "";
    private string? _editAlbumDescription = "";
    private Guid? _editTargetAlbumId;
    private Guid? _deleteTargetAlbumId;
    private string _deleteTargetAlbumName = "";

    private List<BreadcrumbItem> _breadcrumbs = new();

    private string GetHeroStyle()
    {
        if (_selectedAlbum == null) return string.Empty;
        
        if (!string.IsNullOrEmpty(_selectedAlbum.CoverThumbnailUrl))
        {
            return $"background-image: url('{_selectedAlbum.CoverThumbnailUrl}');";
        }
        
        return "background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-dark) 100%);";
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) _objRef = DotNetObjectReference.Create(this);
    }

    private async Task OnCardTouchStart(TouchEventArgs e, TimelineItem asset)
    {
        if (e.Touches.Length == 0) return;
        _touchStartX = e.Touches[0].ClientX;
        _touchStartY = e.Touches[0].ClientY;
        _longPressHandled = false;

        if (_assetSelectionMode)
        {
            var selectMode = !IsAlbumAssetSelected(asset.Id);
            _longPressHandled = true;
            ToggleAlbumAssetSelection(asset.Id, selectMode);
            await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
            if (_objRef != null)
                await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, selectMode);
            return;
        }

        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _longPressHandled = true;
                ToggleAlbumAssetSelection(asset.Id, true);
                await JS.InvokeVoidAsync("assetGridHelpers.suppressNextClick");
                if (_objRef != null)
                    await JS.InvokeVoidAsync("assetGridHelpers.startDragSelect", _objRef, true);
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private void OnCardTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length == 0 || _longPressTimer == null) return;
        var dx = e.Touches[0].ClientX - _touchStartX;
        var dy = e.Touches[0].ClientY - _touchStartY;
        if (Math.Sqrt(dx * dx + dy * dy) > 10)
        {
            _longPressTimer.Dispose();
            _longPressTimer = null;
        }
    }

    private void OnCardTouchEnd(TouchEventArgs e)
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
    }

    [JSInvokable]
    public void OnDragSelectAsset(string assetIdStr, bool select)
    {
        if (!Guid.TryParse(assetIdStr, out var assetId)) return;
        if (select == IsAlbumAssetSelected(assetId)) return;
        ToggleAlbumAssetSelection(assetId, select);
        StateHasChanged();
    }

    private async Task OnViewModeChanged(AlbumViewMode mode)
    {
        _albumViewMode = mode;
        await JS.InvokeVoidAsync("localStorage.setItem", "photohub:albums:viewMode", mode.ToString());
    }

    private void OpenPermissionsDialog(Guid albumId)
    {
        _selectedAlbumIds.Clear();
        _selectedAlbumIds.Add(albumId);
        OpenPermissionsForSelectedAlbum();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPreferences();
        // Solo cargar la lista de álbumes cuando estamos en la vista de listado (sin AlbumId).
        // Si entramos en /albums/{id} (p. ej. volver del detalle de un asset), no pedir /api/albums.
        if (AlbumId == Guid.Empty)
            await LoadAlbums();
    }

    private async Task LoadPreferences()
    {
        try
        {
            var sort = await JS.InvokeAsync<string?>("localStorage.getItem", "photohub:albums:sort");
            if (Enum.TryParse<AlbumSort>(sort, out var sortValue)) _albumSort = sortValue;

            var viewMode = await JS.InvokeAsync<string?>("localStorage.getItem", "photohub:albums:viewMode");
            if (Enum.TryParse<AlbumViewMode>(viewMode, out var viewModeValue)) _albumViewMode = viewModeValue;

            var groupByYear = await JS.InvokeAsync<string?>("localStorage.getItem", "photohub:albums:groupByYear");
            if (groupByYear != null) _groupByYear = groupByYear == "true";
        }
        catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Filter != null)
        {
            _albumFilter = Filter.ToLower() switch
            {
                "own" => AlbumFilter.Own,
                "shared" => AlbumFilter.Shared,
                "public" => AlbumFilter.Public,
                _ => AlbumFilter.All
            };
        }
        else if (AlbumId == Guid.Empty)
        {
            _albumFilter = AlbumFilter.All;
        }

        if (AlbumId != Guid.Empty)
        {
            _albumSelectionMode = false;
            _selectedAlbumIds.Clear();
            await LoadAlbum(AlbumId);
        }
        else
        {
            // Volver a la vista de listado (Mis Álbumes / Compartidos): cargar la lista si veníamos de un álbum
            if (_selectedAlbum != null)
                await LoadAlbums();
            _selectedAlbum = null;
            _albumAssets = new();
            _assetSelectionMode = false;
            _selectedAlbumAssetIds.Clear();
        }
        UpdateSelectionNavbar();
    }

    private async Task LoadAlbums(bool forceRefresh = false)
    {
        try
        {
            _loading = true;
            if (!forceRefresh && AlbumsCache.IsValid)
            {
                _albums = AlbumsCache.Albums!;
                return;
            }
            _albums = await AlbumService.GetAlbumsAsync();
            AlbumsCache.Set(_albums);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar álbumes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadAlbum(Guid albumId)
    {
        try
        {
            _loadingAssets = true;
            _assetSelectionMode = false;
            _selectedAlbumAssetIds.Clear();
            _selectedAlbum = await AlbumService.GetAlbumByIdAsync(albumId);
            
            if (_selectedAlbum != null)
            {
                _albumAssets = await AlbumService.GetAlbumAssetsAsync(albumId);
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Álbumes", href: "/albums"),
                    new BreadcrumbItem(_selectedAlbum.Name, href: null, disabled: true)
                };
            }
            else
            {
                Snackbar.Add("Álbum no encontrado", Severity.Warning);
                Navigation.NavigateTo("/albums");
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para acceder a este álbum.", Severity.Error);
            Navigation.NavigateTo("/albums");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar álbum: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingAssets = false;
        }
    }

    private List<AlbumYearGroup> GetAlbumGroups()
    {
        var albums = GetFilteredAlbums();

        if (!_groupByYear)
        {
            return new List<AlbumYearGroup> { new AlbumYearGroup(null, albums) };
        }

        return albums
            .GroupBy(album => album.CreatedAt.Year)
            .OrderByDescending(group => group.Key)
            .Select(group => new AlbumYearGroup(group.Key, group.ToList()))
            .ToList();
    }

    private List<AlbumItem> GetFilteredAlbums()
    {
        IEnumerable<AlbumItem> query = _albums;

        query = _albumFilter switch
        {
            AlbumFilter.Own => query.Where(album => album.IsOwner && !album.IsShared),
            AlbumFilter.Shared => query.Where(album => !album.IsOwner || album.IsShared),
            AlbumFilter.Public => query.Where(album => album.IsOwner && album.HasActiveShareLink),
            _ => query
        };

        if (!string.IsNullOrWhiteSpace(_albumSearch))
        {
            var term = _albumSearch.Trim();
            query = query.Where(album =>
                album.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (album.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        query = _albumSort switch
        {
            AlbumSort.Oldest => query.OrderBy(album => album.UpdatedAt),
            AlbumSort.Name => query.OrderBy(album => album.Name),
            _ => query.OrderByDescending(album => album.UpdatedAt)
        };

        return query.ToList();
    }

    private void OpenAlbum(Guid albumId)
    {
        Navigation.NavigateTo($"/albums/{albumId}");
    }

    private void OnAlbumAssetClick(TimelineItem asset)
    {
        if (_longPressHandled)
        {
            _longPressHandled = false;
            return;
        }

        if (_assetSelectionMode)
        {
            ToggleAlbumAssetSelection(asset.Id, !IsAlbumAssetSelected(asset.Id));
            return;
        }
        OpenAsset(asset);
    }

    private void OpenAsset(TimelineItem asset)
    {
        AssetListNavigationState.SetList(_albumAssets, AlbumId);
        Navigation.NavigateTo($"/asset/{asset.Id}?albumId={AlbumId}");
    }

    private void OpenCreateDialog()
    {
        _newAlbumName = "";
        _newAlbumDescription = "";
        _createAlbumSheetEverOpened = true;
        _createDialogVisible = true;
    }

    private void CloseCreateDialog()
    {
        _createDialogVisible = false;
    }

    private async Task CreateAlbum()
    {
        if (string.IsNullOrWhiteSpace(_newAlbumName))
        {
            Snackbar.Add("El nombre del álbum es obligatorio", Severity.Warning);
            return;
        }

        var album = await AlbumService.CreateAlbumAsync(_newAlbumName, _newAlbumDescription);
        if (album != null)
        {
            Snackbar.Add("Álbum creado correctamente", Severity.Success);
            _createDialogVisible = false;
            if (_albumFilter == AlbumFilter.Shared)
                Navigation.NavigateTo($"/albums/{album.Id}/permissions");
            else
                await LoadAlbums(forceRefresh: true);
        }
        else
        {
            Snackbar.Add("Error al crear el álbum", Severity.Error);
        }
    }

    private async Task OpenAlbumShareDialog()
    {
        if (_selectedAlbum == null) return;
        await OpenShareDialogForAlbum(_selectedAlbum.Id, _selectedAlbum.Name);
    }

    private async Task OpenShareDialogForAlbum(Guid albumId, string albumName)
    {
        _shareSheetAlbumId = albumId;
        _shareSheetAlbumName = albumName;
        _sharePublicLinks = new();
        ResetShareForm();
        _shareSheetEverOpened = true;
        _shareSheetOpen = true;
        _shareLoadingLinks = true;
        StateHasChanged();
        try { _sharePublicLinks = await ShareService.GetShareLinksAsync(null, albumId); }
        catch { /* non-critical */ }
        finally { _shareLoadingLinks = false; StateHasChanged(); }
    }

    private string BuildShareUrl(string token)
    {
        var baseUri = new Uri(Navigation.BaseUri);
        return $"{baseUri.Scheme}://{baseUri.Authority}/share/{token}";
    }

    private async Task ShareCopyLink(string token)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", BuildShareUrl(token));
        Snackbar.Add("Enlace copiado al portapapeles", Severity.Success);
    }

    private async Task ShareRevokeLink(string token)
    {
        try
        {
            await ShareService.RevokeShareAsync(token);
            _sharePublicLinks.RemoveAll(l => l.Token == token);
            await LoadAlbums(forceRefresh: true);
            Snackbar.Add("Enlace revocado", Severity.Info);
        }
        catch
        {
            Snackbar.Add("Error al revocar el enlace", Severity.Error);
        }
    }

    private async Task ShareCreateLink()
    {
        if (_shareCreatingLink || _shareSheetAlbumId == null) return;
        try
        {
            _shareCreatingLink = true;
            var request = new CreateShareLinkRequest
            {
                AlbumId = _shareSheetAlbumId,
                Password = _shareNewPasswordEnabled ? _shareNewPassword : null,
                AllowDownload = _shareNewAllowDownload,
                MaxViews = _shareNewMaxViewsEnabled ? _shareNewMaxViews : null,
                ExpiresAt = _shareNewExpiryEnabled ? _shareNewExpiry?.ToUniversalTime() : null
            };
            var link = await ShareService.CreatePublicShareAsync(request);
            if (link != null)
            {
                _sharePublicLinks.Insert(0, link);
                await ShareCopyLink(link.Token);
                ResetShareForm();
                await LoadAlbums(forceRefresh: true);
            }
        }
        catch
        {
            Snackbar.Add("Error al crear el enlace", Severity.Error);
        }
        finally
        {
            _shareCreatingLink = false;
        }
    }

    private void ResetShareForm()
    {
        _shareNewPasswordEnabled = false;
        _shareNewPassword = string.Empty;
        _shareNewExpiryEnabled = false;
        _shareNewExpiry = null;
        _shareNewMaxViewsEnabled = false;
        _shareNewMaxViews = 10;
        _shareNewAllowDownload = true;
    }

    private void OpenEditDialog()
    {
        if (_selectedAlbum == null)
            return;

        OpenEditDialog(_selectedAlbum);
    }

    private void OpenEditDialog(AlbumItem album)
    {
        _editTargetAlbumId = album.Id;
        _editAlbumName = album.Name;
        _editAlbumDescription = album.Description;
        _editAlbumSheetEverOpened = true;
        _editDialogVisible = true;
    }

    private void CloseEditDialog()
    {
        _editDialogVisible = false;
    }

    private async Task UpdateAlbum()
    {
        if (!_editTargetAlbumId.HasValue || string.IsNullOrWhiteSpace(_editAlbumName))
        {
            Snackbar.Add("El nombre del álbum es obligatorio", Severity.Warning);
            return;
        }

        try
        {
            var success = await AlbumService.UpdateAlbumAsync(_editTargetAlbumId.Value, _editAlbumName, _editAlbumDescription);
            if (success)
            {
                Snackbar.Add("Álbum actualizado correctamente", Severity.Success);
                _editDialogVisible = false;
                if (_selectedAlbum?.Id == _editTargetAlbumId)
                {
                    await LoadAlbum(_editTargetAlbumId.Value);
                }
                await LoadAlbums(forceRefresh: true);
            }
            else
            {
                Snackbar.Add("Error al actualizar el álbum", Severity.Error);
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para editar este álbum.", Severity.Error);
        }
    }

    private void OpenDeleteDialog()
    {
        if (_selectedAlbum == null)
            return;

        OpenDeleteDialog(_selectedAlbum);
    }

    private void OpenDeleteDialog(AlbumItem album)
    {
        _deleteTargetAlbumId = album.Id;
        _deleteTargetAlbumName = album.Name;
        _deleteDialogVisible = true;
    }

    private void CloseDeleteDialog()
    {
        _deleteDialogVisible = false;
    }

    private async Task DeleteAlbum()
    {
        if (!_deleteTargetAlbumId.HasValue)
            return;

        try
        {
            var success = await AlbumService.DeleteAlbumAsync(_deleteTargetAlbumId.Value);
            if (success)
            {
                Snackbar.Add("Álbum eliminado correctamente", Severity.Success);
                _deleteDialogVisible = false;
                if (_selectedAlbum?.Id == _deleteTargetAlbumId)
                {
                    Navigation.NavigateTo("/albums");
                }
                else
                {
                    await LoadAlbums(forceRefresh: true);
                }
            }
            else
            {
                Snackbar.Add("Error al eliminar el álbum", Severity.Error);
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para eliminar este álbum.", Severity.Error);
        }
    }

    private async Task LeaveAlbum()
    {
        if (_selectedAlbum == null)
            return;

        await LeaveAlbum(_selectedAlbum);
    }

    private async Task LeaveAlbum(AlbumItem album)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Salir del álbum",
            $"¿Quieres dejar de tener acceso al álbum \"{album.Name}\"?",
            yesText: "Salir",
            cancelText: "Cancelar");

        if (confirm != true)
            return;

        try
        {
            var success = await AlbumService.LeaveAlbumAsync(album.Id);
            if (success)
            {
                Snackbar.Add("Has dejado de tener acceso al álbum.", Severity.Success);
                if (_selectedAlbum?.Id == album.Id)
                {
                    Navigation.NavigateTo("/albums");
                }
                await LoadAlbums(forceRefresh: true);
            }
            else
            {
                Snackbar.Add("Error al salir del álbum", Severity.Error);
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para salir de este álbum.", Severity.Error);
        }
    }

    private void OnAlbumCardClick(Guid albumId)
    {
        if (_albumSelectionMode)
        {
            ToggleAlbumSelection(albumId, !IsAlbumSelected(albumId));
            return;
        }

        OpenAlbum(albumId);
    }

    private void EnterAlbumSelectionMode()
    {
        _albumSelectionMode = true;
        _assetSelectionMode = false;
        _selectedAlbumAssetIds.Clear();
        UpdateSelectionNavbar();
    }

    private void ExitAlbumSelectionMode()
    {
        _albumSelectionMode = false;
        _selectedAlbumIds.Clear();
        UpdateSelectionNavbar();
    }

    private void ToggleAlbumSelection(Guid albumId, bool selected)
    {
        if (!_albumSelectionMode)
        {
            _albumSelectionMode = true;
            _assetSelectionMode = false;
            _selectedAlbumAssetIds.Clear();
        }

        if (selected)
        {
            _selectedAlbumIds.Add(albumId);
        }
        else
        {
            _selectedAlbumIds.Remove(albumId);
            if (_selectedAlbumIds.Count == 0)
            {
                ExitAlbumSelectionMode();
                return;
            }
        }

        UpdateSelectionNavbar();
    }

    private bool IsAlbumSelected(Guid albumId) => _selectedAlbumIds.Contains(albumId);

    private AlbumItem? GetSingleSelectedAlbum()
    {
        if (_selectedAlbumIds.Count != 1)
        {
            return null;
        }

        var selectedId = _selectedAlbumIds.First();
        return _albums.FirstOrDefault(album => album.Id == selectedId);
    }

    private bool CanEditSelectedAlbum()
    {
        var album = GetSingleSelectedAlbum();
        return album != null && (album.CanEdit || album.IsOwner);
    }

    private bool CanManagePermissionsSelectedAlbum()
    {
        var album = GetSingleSelectedAlbum();
        return album != null && (album.CanManagePermissions || album.IsOwner);
    }

    private bool CanLeaveSelectedAlbum()
    {
        var album = GetSingleSelectedAlbum();
        return album != null && !album.IsOwner;
    }

    private bool CanDeleteSelectedAlbums()
    {
        if (!_selectedAlbumIds.Any())
        {
            return false;
        }

        return _selectedAlbumIds.All(id =>
        {
            var album = _albums.FirstOrDefault(item => item.Id == id);
            return album != null && (album.CanDelete || album.IsOwner);
        });
    }

    private void OpenEditSelectedAlbum()
    {
        var album = GetSingleSelectedAlbum();
        if (album == null)
        {
            return;
        }

        OpenEditDialog(album);
    }

    private void OpenPermissionsForSelectedAlbum()
    {
        var album = GetSingleSelectedAlbum();
        if (album == null)
        {
            return;
        }

        Navigation.NavigateTo($"/albums/{album.Id}/permissions");
    }

    private void OpenDeleteSelectedDialog()
    {
        if (!_selectedAlbumIds.Any())
        {
            return;
        }

        _deleteSelectedDialogVisible = true;
    }

    private void CloseDeleteSelectedDialog()
    {
        _deleteSelectedDialogVisible = false;
    }

    private async Task DeleteSelectedAlbumsAsync()
    {
        if (!_selectedAlbumIds.Any())
        {
            return;
        }

        var failed = 0;
        foreach (var albumId in _selectedAlbumIds.ToList())
        {
            try
            {
                var success = await AlbumService.DeleteAlbumAsync(albumId);
                if (!success)
                {
                    failed++;
                }
            }
            catch
            {
                failed++;
            }
        }

        _deleteSelectedDialogVisible = false;
        ExitAlbumSelectionMode();
        await LoadAlbums(forceRefresh: true);

        if (failed == 0)
        {
            Snackbar.Add("Álbumes eliminados correctamente", Severity.Success);
        }
        else
        {
            Snackbar.Add("Algunos álbumes no se pudieron eliminar", Severity.Warning);
        }
    }

    private async Task LeaveSelectedAlbumAsync()
    {
        var album = GetSingleSelectedAlbum();
        if (album == null)
        {
            return;
        }

        await LeaveAlbum(album);
        ExitAlbumSelectionMode();
    }

    private void ExitAssetSelectionMode()
    {
        _assetSelectionMode = false;
        _selectedAlbumAssetIds.Clear();
        UpdateSelectionNavbar();
    }

    private void ToggleAlbumAssetSelection(Guid assetId, bool selected)
    {
        if (!_assetSelectionMode)
        {
            _assetSelectionMode = true;
            _albumSelectionMode = false;
            _selectedAlbumIds.Clear();
        }

        if (selected)
        {
            _selectedAlbumAssetIds.Add(assetId);
        }
        else
        {
            _selectedAlbumAssetIds.Remove(assetId);
            if (_selectedAlbumAssetIds.Count == 0)
            {
                ExitAssetSelectionMode();
                return;
            }
        }

        UpdateSelectionNavbar();
    }

    private bool IsAlbumAssetSelected(Guid assetId) => _selectedAlbumAssetIds.Contains(assetId);

    private bool CanEditAlbumAssets()
    {
        return _selectedAlbum != null && (_selectedAlbum.CanEdit || _selectedAlbum.IsOwner);
    }

    private async Task RemoveSelectedAssetsAsync()
    {
        if (_selectedAlbum == null || !_selectedAlbumAssetIds.Any())
        {
            return;
        }

        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Quitar del álbum",
            $"¿Quieres quitar {_selectedAlbumAssetIds.Count} elemento(s) del álbum?",
            yesText: "Quitar",
            cancelText: "Cancelar");

        if (confirm != true)
        {
            return;
        }

        var failed = 0;
        foreach (var assetId in _selectedAlbumAssetIds.ToList())
        {
            try
            {
                var success = await AlbumService.RemoveAssetFromAlbumAsync(_selectedAlbum.Id, assetId);
                if (!success)
                {
                    failed++;
                }
            }
            catch
            {
                failed++;
            }
        }

        await LoadAlbum(_selectedAlbum.Id);
        await LoadAlbums(forceRefresh: true);
        ExitAssetSelectionMode();

        if (failed == 0)
        {
            Snackbar.Add("Elementos quitados del álbum", Severity.Success);
        }
        else
        {
            Snackbar.Add("Algunos elementos no se pudieron quitar", Severity.Warning);
        }
    }

    private async Task SetCoverFromSelectionAsync()
    {
        if (_selectedAlbum == null || _selectedAlbumAssetIds.Count != 1)
        {
            return;
        }

        var assetId = _selectedAlbumAssetIds.First();
        try
        {
            var success = await AlbumService.SetAlbumCoverAsync(_selectedAlbum.Id, assetId);
            if (success)
            {
                Snackbar.Add("Portada actualizada", Severity.Success);
                await LoadAlbum(_selectedAlbum.Id);
                await LoadAlbums(forceRefresh: true);
                ExitAssetSelectionMode();
            }
            else
            {
                Snackbar.Add("Error al actualizar la portada", Severity.Error);
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add("No tienes permisos suficientes para actualizar la portada.", Severity.Error);
        }
    }

    private void ExitSelectionFromNavbar()
    {
        if (_albumSelectionMode)
        {
            ExitAlbumSelectionMode();
            return;
        }

        if (_assetSelectionMode)
        {
            ExitAssetSelectionMode();
        }
    }

    private void UpdateSelectionNavbar()
    {
        if (!_albumSelectionMode && !_assetSelectionMode)
        {
            LayoutService.ResetNavbar();
            return;
        }

        if (_albumSelectionMode)
        {
            var selectedCount = _selectedAlbumIds.Count;

            LayoutService.SetCustomNavbar(
                @<text>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Edge="Edge.Start" OnClick="ExitSelectionFromNavbar" />
                    <MudText Typo="Typo.h6" Class="ml-2">@($"{selectedCount} seleccionadas")</MudText>
                    <MudSpacer />

                    @* Botones individuales — solo desktop *@
                    <span class="d-none d-md-flex">
                        <MudTooltip Text="Colaboradores">
                            <MudIconButton Icon="@Icons.Material.Outlined.Group" Color="Color.Inherit" Disabled="@(!CanManagePermissionsSelectedAlbum())" OnClick="OpenPermissionsForSelectedAlbum" />
                        </MudTooltip>
                        <MudTooltip Text="Editar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Color="Color.Inherit" Disabled="@(!CanEditSelectedAlbum())" OnClick="OpenEditSelectedAlbum" />
                        </MudTooltip>
                        <MudTooltip Text="Eliminar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Color="Color.Inherit" Disabled="@(!CanDeleteSelectedAlbums())" OnClick="OpenDeleteSelectedDialog" />
                        </MudTooltip>
                        <MudTooltip Text="Salir del álbum">
                            <MudIconButton Icon="@Icons.Material.Outlined.ExitToApp" Color="Color.Inherit" Disabled="@(!CanLeaveSelectedAlbum())" OnClick="LeaveSelectedAlbumAsync" />
                        </MudTooltip>
                    </span>

                    @* Menú de desbordamiento — solo móvil *@
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                             Class="d-flex d-md-none">
                        <MudMenuItem Icon="@Icons.Material.Outlined.Group" Disabled="@(!CanManagePermissionsSelectedAlbum())" OnClick="OpenPermissionsForSelectedAlbum">
                            Colaboradores
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Edit" Disabled="@(!CanEditSelectedAlbum())" OnClick="OpenEditSelectedAlbum">
                            Editar
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Delete" IconColor="Color.Error" Disabled="@(!CanDeleteSelectedAlbums())" OnClick="OpenDeleteSelectedDialog">
                            <MudText Color="Color.Error">Eliminar</MudText>
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.ExitToApp" Disabled="@(!CanLeaveSelectedAlbum())" OnClick="LeaveSelectedAlbumAsync">
                            Salir
                        </MudMenuItem>
                    </MudMenu>
                </text>
            , keepDrawerVisible: true);
            return;
        }

        if (_assetSelectionMode)
        {
            var selectedCount = _selectedAlbumAssetIds.Count;
            var canEdit = CanEditAlbumAssets();

            LayoutService.SetCustomNavbar(
                @<text>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Edge="Edge.Start" OnClick="ExitSelectionFromNavbar" />
                    <MudText Typo="Typo.h6" Class="ml-2">@($"{selectedCount} seleccionadas")</MudText>
                    <MudSpacer />

                    @* Botones individuales — solo desktop *@
                    <span class="d-none d-md-flex">
                        <MudTooltip Text="Quitar del álbum">
                            <MudIconButton Icon="@Icons.Material.Outlined.RemoveCircleOutline" Color="Color.Inherit" Disabled="@(!canEdit || !_selectedAlbumAssetIds.Any())" OnClick="RemoveSelectedAssetsAsync" />
                        </MudTooltip>
                        <MudTooltip Text="Establecer portada">
                            <MudIconButton Icon="@Icons.Material.Outlined.Wallpaper" Color="Color.Inherit" Disabled="@(!canEdit || _selectedAlbumAssetIds.Count != 1)" OnClick="SetCoverFromSelectionAsync" />
                        </MudTooltip>
                        <MudTooltip Text="Descargar">
                            <MudIconButton Icon="@Icons.Material.Outlined.Download" Color="Color.Inherit" Disabled="@(!_selectedAlbumAssetIds.Any() || _downloadingZip)" OnClick="DownloadSelectedAssetsAsync" />
                        </MudTooltip>
                    </span>

                    @* Menú de desbordamiento — solo móvil *@
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                             Class="d-flex d-md-none">
                        <MudMenuItem Icon="@Icons.Material.Outlined.RemoveCircleOutline" Disabled="@(!canEdit || !_selectedAlbumAssetIds.Any())" OnClick="RemoveSelectedAssetsAsync">
                            Quitar del álbum
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Wallpaper" Disabled="@(!canEdit || _selectedAlbumAssetIds.Count != 1)" OnClick="SetCoverFromSelectionAsync">
                            Establecer portada
                        </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Download" Disabled="@(!_selectedAlbumAssetIds.Any() || _downloadingZip)" OnClick="DownloadSelectedAssetsAsync">
                            Descargar
                        </MudMenuItem>
                    </MudMenu>
                </text>
            , keepDrawerVisible: true);
        }
    }

    private async Task DownloadAlbumAsync()
    {
        if (_selectedAlbum == null || !_albumAssets.Any()) return;

        _downloadingZip = true;
        StateHasChanged();
        try
        {
            var assetIds = _albumAssets.Select(a => a.Id).ToList();
            var bytes = await AssetService.DownloadZipAsync(assetIds, _selectedAlbum.Name);
            if (bytes != null)
                await JS.InvokeVoidAsync("downloadFileFromBytes", $"{_selectedAlbum.Name}.zip", "application/zip", bytes);
            else
                Snackbar.Add("Error al generar el ZIP", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al descargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloadingZip = false;
            StateHasChanged();
        }
    }

    private async Task DownloadSelectedAssetsAsync()
    {
        if (!_selectedAlbumAssetIds.Any()) return;

        _downloadingZip = true;
        UpdateSelectionNavbar();
        try
        {
            var bytes = await AssetService.DownloadZipAsync(_selectedAlbumAssetIds.ToList());
            if (bytes != null)
                await JS.InvokeVoidAsync("downloadFileFromBytes", "photohub_selection.zip", "application/zip", bytes);
            else
                Snackbar.Add("Error al generar el ZIP", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al descargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloadingZip = false;
            UpdateSelectionNavbar();
        }
    }

    public void Dispose()
    {
        _longPressTimer?.Dispose();
        _objRef?.Dispose();
        LayoutService.ResetNavbar();
    }

    private async Task ToggleAlbumViewMode()
    {
        _albumViewMode = _albumViewMode == AlbumViewMode.Grid ? AlbumViewMode.List : AlbumViewMode.Grid;
        await JS.InvokeVoidAsync("localStorage.setItem", "photohub:albums:viewMode", _albumViewMode.ToString());
    }

    private async Task OnAlbumSortChanged(AlbumSort sort)
    {
        _albumSort = sort;
        await JS.InvokeVoidAsync("localStorage.setItem", "photohub:albums:sort", sort.ToString());
    }

    private async Task ToggleGroupByYear()
    {
        _groupByYear = !_groupByYear;
        await JS.InvokeVoidAsync("localStorage.setItem", "photohub:albums:groupByYear", _groupByYear ? "true" : "false");
    }

    private sealed record AlbumYearGroup(int? Year, List<AlbumItem> Albums);
}
