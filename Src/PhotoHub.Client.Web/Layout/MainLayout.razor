@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject LayoutService LayoutService
@inject ThemeService ThemeService
@inject IAuthService AuthService
@inject IDialogService DialogService
@inject ApiErrorNotifier ApiErrorNotifier
@inject INotificationService NotificationService
@inject PwaUpdateService PwaUpdateService
@inject IJSRuntime JS

<MudThemeProvider IsDarkMode="LayoutService.IsDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Surface" Class="@GetAppBarClass()" Style="@GetAppBarStyle()">
        @if (!LayoutService.IsNavbarCustom)
        {
            @* Hamburger — desktop only (replaced by bottom nav on mobile) *@
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                           OnClick="@ToggleDrawer" Class="mr-2 d-none d-md-flex" />

            <div class="d-flex align-center" style="cursor: pointer;" @onclick="@(() => Navigation.NavigateTo("/"))">
                <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Color="Color.Primary" Size="Size.Large" Class="mr-2" />
                <MudText Typo="Typo.h6" Class="font-weight-bold">PhotoHub</MudText>
            </div>

            <MudSpacer />

            @* Search bar — desktop only *@
            <div class="search-container d-none d-md-flex">
                <MudPaper Class="search-box d-flex align-center px-3" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Size="Size.Small" Class="mr-2 flex-shrink-0" />
                    <MudTextField @bind-Value="_searchQuery"
                                  @bind-Value:after="@(() => OnSearchQueryChanged(_searchQuery))"
                                  Immediate="true"
                                  DebounceInterval="250"
                                  Placeholder="Buscar fotos, vídeos..."
                                  Variant="Variant.Text"
                                  Margin="Margin.Dense"
                                  DisableUnderLine="true"
                                  Class="search-input flex-grow-1" />
                </MudPaper>
            </div>

            <MudSpacer />

            <div class="d-flex align-center">
                @if (!IsAdminSection)
                {
                    @* Upload — desktop: labeled button; mobile: icon button *@
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               Size="Size.Medium"
                               Class="mr-1 d-none d-md-flex"
                               OnClick="@(() => Navigation.NavigateTo("/upload"))">
                        Subir
                    </MudButton>
                    <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                                   Color="Color.Inherit"
                                   Class="d-flex d-md-none"
                                   OnClick="@(() => Navigation.NavigateTo("/upload"))" />
                }

                @* Dark mode toggle — desktop only; avatar sheet handles it on mobile *@
                <div class="d-none d-md-flex">
                    <MudTooltip Text="Alternar modo claro/oscuro">
                        <MudIconButton Icon="@(LayoutService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                                       Color="Color.Inherit"
                                       OnClick="@LayoutService.ToggleDarkModeAsync" />
                    </MudTooltip>
                </div>

                @* NOTIFICATIONS — desktop: dropdown menu *@
                <div class="d-none d-md-flex">
                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)" Class="notification-badge">
                                <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                                               OnClick="@(async () => { await LoadRecentNotificationsAsync(); await context.ToggleAsync(); })" />
                            </MudBadge>
                        </ActivatorContent>
                        <ChildContent>
                            @NotificationsMenuContent(onClose: null)
                        </ChildContent>
                    </MudMenu>
                </div>

                @* NOTIFICATIONS — mobile: opens bottom sheet *@
                <div class="d-flex d-md-none">
                    <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)" Class="notification-badge">
                        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                                       OnClick="@(async () => { await LoadRecentNotificationsAsync(); _notifSheetEverOpened = true; _notifSheetOpen = true; })" />
                    </MudBadge>
                </div>

                @* AVATAR — desktop: dropdown menu *@
                <AuthorizeView>
                    <Authorized>
                        <div class="d-none d-md-flex">
                            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <ActivatorContent>
                                    <div @onclick="@context.ToggleAsync" style="cursor: pointer;">
                                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="ml-2" Style="width: 32px; height: 32px;">
                                            @UserInitial
                                        </MudAvatar>
                                    </div>
                                </ActivatorContent>
                                <ChildContent>
                                    @AvatarMenuContent(onClose: null)
                                </ChildContent>
                            </MudMenu>
                        </div>


                    </Authorized>
                    <NotAuthorized>
                        <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small">
                            Iniciar Sesión
                        </MudButton>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        }
        else
        {
            @LayoutService.NavbarContent
        }
    </MudAppBar>

    <style>
        .border-b {
            border-bottom: 1px solid var(--mud-palette-divider);
        }
        .custom-navbar {
            border-bottom: 1px solid var(--mud-palette-divider);
        }
        .search-container {
            width: 100%;
            max-width: 560px;
        }
        .search-box {
            width: 100%;
            height: 40px;
            border-radius: 24px;
            border: 1.5px solid rgba(128, 128, 128, 0.35);
            background: rgba(128, 128, 128, 0.06);
            transition: border-color 0.2s;
        }
        .search-box:hover {
            border-color: rgba(128, 128, 128, 0.65);
        }
        .search-box:focus-within {
            border-color: var(--mud-palette-primary);
        }
        .mud-dark .search-box {
            border-color: rgba(255, 255, 255, 0.22);
            background: rgba(255, 255, 255, 0.06);
        }
        .mud-dark .search-box:hover {
            border-color: rgba(255, 255, 255, 0.5);
        }
        .search-input .mud-input-control {
            margin-top: 0;
        }
        .search-input .mud-input::before,
        .search-input .mud-input::after {
            display: none !important;
        }
        .notification-badge .mud-badge {
            top: -4px !important;
        }
        /* Mobile: extra bottom padding so content isn't hidden behind bottom nav */
        @@media (max-width: 959.98px) {
            .page-content {
                padding-bottom: 64px !important;
            }
        }
        .pwa-update-banner {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 16px;
            background: var(--mud-palette-surface);
            border-bottom: 1px solid var(--mud-palette-divider);
            position: sticky;
            z-index: 1200;
        }
    </style>

    @if (_isNavigating)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"
                           Style="position: fixed; top: var(--mud-appbar-height, 64px); left: 0; right: 0; z-index: 1299; margin: 0; height: 3px;" />
    }

    @* Sidebar drawer — hidden on mobile (bottom nav replaces it) *@
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
               Variant="@DrawerVariant.Responsive" Class="@GetDrawerClass()">
        <NavMenu />
    </MudDrawer>

    <style>
        .border-r {
            border-right: 1px solid var(--mud-palette-divider);
        }
        .page-content {
            /* Padding managed by each page; bottom padding injected via media query above */
        }
    </style>

    <MudMainContent Style="flex-grow: 1; display: flex; flex-direction: column;">
        @if (PwaUpdateService.UpdateAvailable)
        {
            <div class="pwa-update-banner">
                <MudIcon Icon="@Icons.Material.Filled.SystemUpdate" Size="Size.Small" Color="Color.Primary" Class="flex-shrink-0" />
                <MudText Typo="Typo.body2" Class="flex-grow-1">
                    Nueva versión disponible
                    @if (!string.IsNullOrEmpty(PwaUpdateService.CurrentVersion) && !string.IsNullOrEmpty(PwaUpdateService.NewVersion))
                    {
                        <MudText Typo="Typo.caption" Inline="true" Class="ml-1" Style="opacity: 0.7;">
                            (v@(PwaUpdateService.CurrentVersion) → v@(PwaUpdateService.NewVersion))
                        </MudText>
                    }
                    else if (!string.IsNullOrEmpty(PwaUpdateService.NewVersion))
                    {
                        <MudText Typo="Typo.caption" Inline="true" Class="ml-1" Style="opacity: 0.7;">
                            (v@(PwaUpdateService.NewVersion))
                        </MudText>
                    }
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                               Variant="Variant.Filled" Color="Color.Primary"
                               Title="Actualizar ahora"
                               OnClick="@PwaUpdateService.ApplyUpdateAsync" />
            </div>
        }
        <div class="page-content" style="flex-grow: 1;">
            @Body
        </div>
    </MudMainContent>

    @* Mobile bottom navigation + FAB *@
    <BottomNavBar OnOpenMoreSheet="@OpenMoreSheet" IsMoreSheetOpen="@_moreSheetOpen" />

    @* ── MOBILE BOTTOM SHEETS ───────────────────────────────────────────────── *@

    @* Notifications sheet — only mounted after first open to avoid render flash *@
    @if (_notifSheetEverOpened)
    {
    <MudDrawer @bind-Open="_notifSheetOpen"
               Anchor="Anchor.Bottom"
               Elevation="4"
               Variant="DrawerVariant.Temporary"
               Class="ph-bottom-sheet">
        <div class="ph-sheet-handle"></div>
        <div class="d-flex justify-space-between align-center px-4 pt-1 pb-2">
            <MudText Typo="Typo.h6">Notificaciones</MudText>
            <div class="d-flex align-center gap-1">
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           OnClick="MarkAllNotificationsReadAsync"
                           Disabled="@(_unreadCount == 0)">
                    Marcar leídas
                </MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _notifSheetOpen = false)" />
            </div>
        </div>
        <MudDivider />
        <MudList T="NotificationDto" Class="px-2 pb-1" Style="overflow-y: auto; max-height: 55svh;">
            @if (_recentNotifications.Any())
            {
                @foreach (var notification in _recentNotifications)
                {
                    <MudListItem Class="@(notification.IsRead ? "" : "mud-background-gray")">
                        <div class="d-flex align-start gap-2">
                            <MudIcon Icon="@GetNotificationIcon(notification.Type)"
                                     Color="@GetNotificationColor(notification.Type)"
                                     Size="Size.Small" Class="mt-1 flex-shrink-0" />
                            <div>
                                <MudText Typo="Typo.body2" Class="@(notification.IsRead ? "mud-text-secondary" : "font-weight-medium")">
                                    @notification.Title
                                </MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@notification.Message</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@FormatNotificationDate(notification.CreatedAt)</MudText>
                            </div>
                        </div>
                    </MudListItem>
                }
            }
            else
            {
                <MudListItem>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No hay notificaciones.</MudText>
                </MudListItem>
            }
        </MudList>
        <MudDivider />
        <div class="px-4 py-2">
            <MudButton Variant="Variant.Text" FullWidth="true" Color="Color.Primary"
                       OnClick="@(() => { _notifSheetOpen = false; Navigation.NavigateTo("/notifications"); })">
                Ver todas las notificaciones
            </MudButton>
        </div>
    </MudDrawer>
    }

    @* Combined "Más + Profile" overlay — full screen above bottom nav *@
    @if (_moreSheetOpen)
    {
        <div class="ph-more-overlay">
            @* Close button — top right *@
            <div class="d-flex justify-end px-2 pt-2">
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _moreSheetOpen = false)" />
            </div>

            @* Profile header — centered and prominent *@
            <div class="ph-more-profile">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled"
                           Style="width: 72px; height: 72px; font-size: 2rem;">
                    @UserInitial
                </MudAvatar>
                <MudText Typo="Typo.h6" Class="font-weight-medium mt-3">@UserFullName</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@UserEmail</MudText>
            </div>
            <StorageWidget />
            <MudDivider />

            @* Navigation grid *@
            <div class="ph-more-grid">
                <button class="ph-more-tile @(IsNavActive("/favorites") ? "ph-more-tile--active" : "")"
                        @onclick="@(() => NavigateFromSheet("/favorites"))">
                    <MudIcon Icon="@(IsNavActive("/favorites") ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)" Class="ph-more-tile__icon" />
                    <span class="ph-more-tile__label">Favoritos</span>
                </button>
                <button class="ph-more-tile @(IsNavActive("/map") ? "ph-more-tile--active" : "")"
                        @onclick="@(() => NavigateFromSheet("/map"))">
                    <MudIcon Icon="@(IsNavActive("/map") ? Icons.Material.Filled.Map : Icons.Material.Outlined.Map)" Class="ph-more-tile__icon" />
                    <span class="ph-more-tile__label">Mapa</span>
                </button>
                <button class="ph-more-tile @(IsNavActive("/device") ? "ph-more-tile--active" : "")"
                        @onclick="@(() => NavigateFromSheet("/device"))">
                    <MudIcon Icon="@(IsNavActive("/device") ? Icons.Material.Filled.SyncAlt : Icons.Material.Outlined.SyncAlt)" Class="ph-more-tile__icon" />
                    <span class="ph-more-tile__label">Sincronizar Dispositivo</span>
                </button>
                <button class="ph-more-tile @(IsNavActive("/archive") ? "ph-more-tile--active" : "")"
                        @onclick="@(() => NavigateFromSheet("/archive"))">
                    <MudIcon Icon="@(IsNavActive("/archive") ? Icons.Material.Filled.Archive : Icons.Material.Outlined.Archive)" Class="ph-more-tile__icon" />
                    <span class="ph-more-tile__label">Archivo</span>
                </button>
                <button class="ph-more-tile @(IsNavActive("/trash") ? "ph-more-tile--active" : "")"
                        @onclick="@(() => NavigateFromSheet("/trash"))">
                    <MudIcon Icon="@(IsNavActive("/trash") ? Icons.Material.Filled.Delete : Icons.Material.Outlined.Delete)" Class="ph-more-tile__icon" />
                    <span class="ph-more-tile__label">Papelera</span>
                </button>
                <button class="ph-more-tile @(IsNavActive("/utilities") ? "ph-more-tile--active" : "")"
                        @onclick="@(() => NavigateFromSheet("/utilities"))">
                    <MudIcon Icon="@(IsNavActive("/utilities") ? Icons.Material.Filled.Build : Icons.Material.Outlined.Build)" Class="ph-more-tile__icon" />
                    <span class="ph-more-tile__label">Utilidades</span>
                </button>
            </div>
            <MudDivider />

            @* Account actions *@
            <MudList T="string" Class="py-1">
                <MudListItem OnClick="@(async () => await LayoutService.ToggleDarkModeAsync())">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@(LayoutService.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                                 Color="Color.Default" />
                        <MudText Typo="Typo.body1">@(LayoutService.IsDarkMode ? "Modo claro" : "Modo oscuro")</MudText>
                    </div>
                </MudListItem>
                <MudListItem OnClick="@(() => { _moreSheetOpen = false; Navigation.NavigateTo("/settings"); })">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Settings" Color="Color.Default" />
                        <MudText Typo="Typo.body1">Configuración cuenta</MudText>
                    </div>
                </MudListItem>
                @if (IsAdmin)
                {
                    <MudListItem OnClick="@(() => { _moreSheetOpen = false; Navigation.NavigateTo("/admin/users"); })">
                        <div class="d-flex align-center gap-3">
                            <MudIcon Icon="@Icons.Material.Outlined.AdminPanelSettings" Color="Color.Default" />
                            <MudText Typo="Typo.body1">Administración</MudText>
                        </div>
                    </MudListItem>
                }
            </MudList>
            <MudDivider />
            <MudList T="string" Class="py-1">
                <MudListItem OnClick="@(async () => { _moreSheetOpen = false; await Logout(); })">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Logout" Color="Color.Error" />
                        <MudText Typo="Typo.body1" Color="Color.Error">Cerrar sesión</MudText>
                    </div>
                </MudListItem>
            </MudList>
            @if (!string.IsNullOrEmpty(_appVersion))
            {
                <div class="ph-more-version">PhotoHub v@_appVersion</div>
            }
            <div style="height: env(safe-area-inset-bottom);"></div>
        </div>
    }

    <style>
        /* Bottom sheet shared styles */
        .ph-bottom-sheet {
            border-radius: 16px 16px 0 0 !important;
            overflow: hidden;
        }
        .ph-bottom-sheet .mud-drawer-content {
            border-radius: 16px 16px 0 0;
            overflow: hidden;
        }
        /* Drag handle pill */
        .ph-sheet-handle {
            width: 36px;
            height: 4px;
            background: var(--mud-palette-divider);
            border-radius: 2px;
            margin: 10px auto 6px;
            flex-shrink: 0;
        }
        /* Combined "Más" overlay — full screen above bottom nav */
        .ph-more-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: calc(64px + env(safe-area-inset-bottom));
            background-color: var(--mud-palette-surface);
            z-index: 1300;
            overflow-y: auto;
        }
        /* Profile section — centered and prominent */
        .ph-more-profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 24px 24px 32px;
        }
        /* Nav icon tiles grid */
        .ph-more-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px;
        }
        .ph-more-tile {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 18px 8px;
            background: var(--mud-palette-background-grey);
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-family: inherit;
            color: var(--mud-palette-text-primary);
            -webkit-tap-highlight-color: transparent;
            transition: opacity 0.15s ease;
        }
        .ph-more-tile:active {
            opacity: 0.6;
        }
        .ph-more-tile--active {
            color: var(--mud-palette-primary);
            background: color-mix(in srgb, var(--mud-palette-primary) 12%, transparent);
        }
        .ph-more-tile__icon {
            font-size: 26px !important;
            width: 26px !important;
            height: 26px !important;
        }
        .ph-more-tile__label {
            font-size: 12px;
            font-weight: 500;
            line-height: 1;
            text-align: center;
        }
        .ph-more-version {
            text-align: center;
            font-size: 11px;
            color: var(--mud-palette-text-disabled);
            padding: 10px 0 6px;
        }
    </style>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _searchQuery = "";
    private bool _isNavigating = false;
    private int _unreadCount;
    private List<NotificationDto> _recentNotifications = [];
    private CancellationTokenSource? _pollingCts;

    private bool _notifSheetOpen;
    private bool _notifSheetEverOpened;
    private bool _moreSheetOpen;
    private string _appVersion = string.Empty;

    private string GetAppBarClass()
    {
        if (LayoutService.IsOverlayNavbar) return "px-4";
        return LayoutService.IsNavbarCustom ? "px-4 custom-navbar" : "px-4 border-b";
    }

    private string GetAppBarStyle()
    {
        if (!LayoutService.IsOverlayNavbar) return string.Empty;
        return "background: rgba(0,0,0,0.75) !important; backdrop-filter: blur(8px); color: white !important;";
    }

    private string GetDrawerClass()
    {
        if (LayoutService.IsNavbarCustom && !LayoutService.KeepDrawerVisible)
            return "d-none";
        // Sidebar only on desktop — bottom nav replaces it on mobile
        return "border-r d-none d-md-flex";
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        LayoutService.OnMajorUpdate += StateHasChanged;
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        ApiErrorNotifier.OnError += HandleApiError;
        PwaUpdateService.OnUpdateAvailable += HandlePwaUpdateAvailable;
        UpdateSearchQueryFromUri();
    }

    protected override void OnParametersSet()
    {
        EnsureNavbarMatchesLocation();
    }

    protected override async Task OnInitializedAsync()
    {
        await LayoutService.InitializeAsync();
        await LoadCurrentUserAsync();
        await LoadUnreadCountAsync();
        StartNotificationPolling();
    }

    private void EnsureNavbarMatchesLocation()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
        if (!path.StartsWith("asset/", StringComparison.OrdinalIgnoreCase) && LayoutService.IsNavbarCustom)
        {
            LayoutService.ResetNavbar();
        }
    }

    private async void HandleAuthStateChanged()
    {
        await LoadCurrentUserAsync();

        if (!await AuthService.IsAuthenticatedAsync())
        {
            var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
            if (!path.StartsWith("login"))
            {
                var loginUrl = BuildLoginUrl(new Uri(Navigation.Uri).PathAndQuery);
                Navigation.NavigateTo(loginUrl);
            }
        }

        StateHasChanged();
    }

    private async Task LoadCurrentUserAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        LayoutService.OnMajorUpdate -= StateHasChanged;
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
        ApiErrorNotifier.OnError -= HandleApiError;
        PwaUpdateService.OnUpdateAvailable -= HandlePwaUpdateAvailable;
    }

    private UserDto? _currentUser;

    private string UserInitial
        => !string.IsNullOrWhiteSpace(_currentUser?.FirstName)
            ? _currentUser!.FirstName.Trim()[0].ToString().ToUpperInvariant()
            : !string.IsNullOrWhiteSpace(_currentUser?.Username)
                ? _currentUser!.Username.Trim()[0].ToString().ToUpperInvariant()
                : "?";

    private string UserFullName => GetUserFullName();

    private string UserEmail => _currentUser?.Email ?? string.Empty;

    private bool IsAdmin => _currentUser?.Role == "Admin";

    private string GetUserFullName()
    {
        var parts = new[] { _currentUser?.FirstName, _currentUser?.LastName }
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToArray();

        return parts.Length > 0
            ? string.Join(" ", parts)
            : _currentUser?.Username ?? "Usuario";
    }

    private void OpenMoreSheet() => _moreSheetOpen = true;

    private bool IsNavActive(string path)
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        return currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateFromSheet(string path)
    {
        _moreSheetOpen = false;
        Navigation.NavigateTo(path);
    }

    private bool IsAdminSection
        => new Uri(Navigation.Uri).AbsolutePath.Trim('/').StartsWith("admin", StringComparison.OrdinalIgnoreCase);

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _moreSheetOpen = false;
        EnsureNavbarMatchesLocation();
        UpdateSearchQueryFromUri();
        _isNavigating = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await PwaUpdateService.InitAsync(JS);
            _appVersion = await JS.InvokeAsync<string>("pwaUpdate.getAppVersion");
        }

        if (_isNavigating)
        {
            _isNavigating = false;
            StateHasChanged();
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private void HandlePwaUpdateAvailable()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleApiError(ApiErrorInfo info)
    {
        _ = InvokeAsync(async () =>
        {
            if (ShouldForceLogin(info))
            {
                await AuthService.LogoutAsync();
                var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
                if (!path.StartsWith("login"))
                {
                    var loginUrl = BuildLoginUrl(new Uri(Navigation.Uri).PathAndQuery);
                    Navigation.NavigateTo(loginUrl);
                }
                return;
            }

            var parameters = new DialogParameters
            {
                ["Error"] = info
            };

            var options = new DialogOptions
            {
                Position = DialogPosition.Center,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true,
                BackdropClick = false
            };

            DialogService.ShowAsync<ApiErrorDialog>(info.Title, parameters, options);
        });
    }

    private static bool ShouldForceLogin(ApiErrorInfo info)
    {
        if (info.StatusCode is null) return false;
        return info.StatusCode >= 500 || info.StatusCode == 401 || info.StatusCode == 403;
    }

    private static string BuildLoginUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl)) return "/login";
        return $"/login?returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private void StartNotificationPolling()
    {
        _pollingCts = new CancellationTokenSource();
        var token = _pollingCts.Token;
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(60));
            while (!token.IsCancellationRequested && await timer.WaitForNextTickAsync(token).ConfigureAwait(false))
            {
                await InvokeAsync(async () =>
                {
                    await LoadUnreadCountAsync();
                    StateHasChanged();
                });
            }
        }, token);
    }

    private async Task LoadUnreadCountAsync()
    {
        try { _unreadCount = await NotificationService.GetUnreadCountAsync(); }
        catch { /* no interrumpir el layout por fallo de notificaciones */ }
    }

    private async Task LoadRecentNotificationsAsync()
    {
        try
        {
            var result = await NotificationService.GetNotificationsAsync(page: 1, pageSize: 5);
            _recentNotifications = result.Items;
            _unreadCount = result.UnreadCount;
        }
        catch { /* ignorar errores en el dropdown */ }
    }

    private async Task MarkAllNotificationsReadAsync()
    {
        try
        {
            await NotificationService.MarkAllAsReadAsync();
            foreach (var n in _recentNotifications) n.IsRead = true;
            _unreadCount = 0;
        }
        catch { }
    }

    private static string GetNotificationIcon(NotificationTypeDto type) => type switch
    {
        NotificationTypeDto.JobCompleted => Icons.Material.Filled.CheckCircle,
        NotificationTypeDto.JobFailed   => Icons.Material.Filled.Error,
        NotificationTypeDto.ShareViewed => Icons.Material.Filled.Visibility,
        _                               => Icons.Material.Filled.Notifications
    };

    private static Color GetNotificationColor(NotificationTypeDto type) => type switch
    {
        NotificationTypeDto.JobCompleted => Color.Success,
        NotificationTypeDto.JobFailed   => Color.Error,
        NotificationTypeDto.ShareViewed => Color.Info,
        _                               => Color.Default
    };

    private static string FormatNotificationDate(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "Ahora mismo";
        if (diff.TotalHours < 1)   return $"Hace {(int)diff.TotalMinutes} min";
        if (diff.TotalDays < 1)    return $"Hace {(int)diff.TotalHours}h";
        if (diff.TotalDays < 7)    return $"Hace {(int)diff.TotalDays}d";
        return dt.ToLocalTime().ToString("dd/MM/yyyy");
    }

