@page "/login"
@layout LoginLayout
@using System.Linq
@using MudBlazor
@using PhotoHub.Client.Native.Services
@using PhotoHub.Client.Shared
@using PhotoHub.Client.Shared.Layout
@using PhotoHub.Client.Shared.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ServerUrlService ServerUrlService

<PageTitle>Iniciar Sesión - PhotoHub</PageTitle>

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="3" Class="pa-8">
            <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-1">
                PhotoHub
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-6">
                Conecta con tu servidor
            </MudText>

            <MudForm @ref="_form" @bind-IsValid="_isValid">

                <MudTextField @bind-Value="_serverUrl"
                              Label="Dirección del servidor"
                              Placeholder="http://192.168.1.100:5030"
                              Required="true"
                              RequiredError="La dirección del servidor es obligatoria"
                              Validation="@(new Func<string, string?>(ValidateServerUrl))"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Class="mb-4"
                              InputType="InputType.Url"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Dns" />

                <MudTextField @bind-Value="_username"
                              Label="Usuario o Email"
                              Required="true"
                              RequiredError="El usuario o email es obligatorio"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Class="mb-4"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person" />

                <MudTextField @bind-Value="_password"
                              Label="Contraseña"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="La contraseña es obligatoria"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Class="mb-6"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Lock" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="HandleLogin"
                           Disabled="@_loggingIn">
                    @if (_loggingIn)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Iniciar Sesión
                </MudButton>

            </MudForm>
        </MudPaper>
    </MudContainer>
</div>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _loggingIn;

    private string _serverUrl = string.Empty;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        _serverUrl = ServerUrlService.Url ?? string.Empty;
        _returnUrl = GetReturnUrl();

        if (await AuthService.IsAuthenticatedAsync())
            NavigateToReturnUrlOrHome();
    }

    private static string? ValidateServerUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "La dirección del servidor es obligatoria";

        if (!Uri.TryCreate(value, UriKind.Absolute, out var uri) ||
            (uri.Scheme != "http" && uri.Scheme != "https"))
            return "Introduce una URL válida (ej: http://192.168.1.100:5030)";

        return null;
    }

    private async Task HandleLogin()
    {
        await _form!.Validate();
        if (!_isValid) return;

        _loggingIn = true;
        try
        {
            // Guardar la URL antes del login para que el HttpClient y los modelos la usen
            ServerUrlService.Url = _serverUrl.TrimEnd('/');
            ApiConfig.BaseUrl = ServerUrlService.Url ?? string.Empty;

            var success = await AuthService.LoginAsync(_username, _password);
            if (success)
            {
                Snackbar.Add("Inicio de sesión exitoso", Severity.Success);
                NavigateToReturnUrlOrHome();
            }
            else
            {
                Snackbar.Add("Usuario o contraseña incorrectos", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            var detail = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error de conexión: {detail}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loggingIn = false;
        }
    }

    private void NavigateToReturnUrlOrHome() => Navigation.NavigateTo(_returnUrl ?? "/");

    private string? GetReturnUrl()
    {
        var uri = new Uri(Navigation.Uri);
        var query = ParseQuery(uri.Query);
        if (!query.TryGetValue("returnUrl", out var values))
            return null;

        var candidate = values.FirstOrDefault();
        return IsSafeReturnUrl(candidate) ? candidate : null;
    }

    private static bool IsSafeReturnUrl(string? url) =>
        !string.IsNullOrWhiteSpace(url) &&
        Uri.TryCreate(url, UriKind.Relative, out _) &&
        url.StartsWith("/", StringComparison.Ordinal);

    private static Dictionary<string, List<string>> ParseQuery(string query)
    {
        var result = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(query)) return result;

        var trimmed = query.StartsWith('?') ? query[1..] : query;
        foreach (var pair in trimmed.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            var value = parts.Length > 1 ? Uri.UnescapeDataString(parts[1]) : string.Empty;
            if (!result.TryGetValue(key, out var list)) { list = []; result[key] = list; }
            list.Add(value);
        }
        return result;
    }
}
