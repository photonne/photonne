<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ runtime permission; only used to surface background
         backup failures. If the user never grants it, the failure still
         shows up in the Backup status card on next app open. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Media read + ACCESS_MEDIA_LOCATION are required to read the ORIGINAL
         (un-redacted) bytes of gallery photos/videos. Since Android 10 the
         platform strips GPS EXIF from media handed to apps without these,
         regardless of whether the file is read via MediaStore or SAF — the
         only documented way to keep location is MediaStore.setRequireOriginal,
         which needs ACCESS_MEDIA_LOCATION + a media read grant. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <application
        android:name=".PhotonneApplication"
        android:label="Photonne"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Photonne">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.Photonne">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
        FileProvider that vends downloaded photos / videos / zips to
        other apps via the share sheet. The cache path matches the
        directory we write into in AssetSharing.android.kt.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/photonne_file_paths" />
        </provider>
    </application>
</manifest>
